<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Error <%= code %> — BotCommand</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --purple: #7C3AED; --purple-light: #9D5CF5; --purple-dark: #5B21B6;
      --green: #10B981; --bg: #0D0D14; --surface: rgba(255,255,255,0.04);
      --border: rgba(255,255,255,0.08); --text: #F1F0FF; --muted: #8B8FAE;
    }
    html, body { height: 100%; font-family: 'Inter', sans-serif; background: var(--bg); color: var(--text); }

    .bg-scene { position: fixed; inset: 0; z-index: 0; pointer-events: none; overflow: hidden; }
    .blob { position: absolute; border-radius: 50%; filter: blur(130px); opacity: 0.18; }
    .blob-1 { width: 600px; height: 600px; background: var(--purple); top: -200px; left: -200px; }
    .blob-2 { width: 400px; height: 400px; background: #EF4444; bottom: -100px; right: -100px; }

    .center {
      position: relative; z-index: 1;
      min-height: 100vh;
      display: flex; align-items: center; justify-content: center;
      padding: 24px;
    }

    .card {
      background: rgba(255,255,255,0.04);
      backdrop-filter: blur(32px);
      border: 1px solid var(--border);
      border-radius: 24px;
      padding: 52px 48px;
      width: 100%; max-width: 480px;
      text-align: center;
      box-shadow: 0 32px 80px rgba(0,0,0,0.5);
    }

    .error-code {
      font-size: 80px; font-weight: 800; letter-spacing: -0.05em; line-height: 1;
      background: linear-gradient(135deg, var(--purple-light), #F87171);
      -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
      margin-bottom: 20px;
    }

    h1 { font-size: 22px; font-weight: 700; letter-spacing: -0.02em; margin-bottom: 10px; }

    .detail {
      font-size: 14px; color: var(--muted); line-height: 1.6; margin-bottom: 36px;
      max-width: 320px; margin-left: auto; margin-right: auto;
    }

    .actions { display: flex; gap: 10px; justify-content: center; flex-wrap: wrap; }

    .btn-home {
      padding: 12px 28px; border-radius: 10px; border: none;
      background: linear-gradient(135deg, var(--purple), var(--purple-dark));
      color: #fff; font-family: 'Inter', sans-serif; font-size: 14px; font-weight: 700;
      cursor: pointer; text-decoration: none;
      box-shadow: 0 4px 20px rgba(124,58,237,0.4);
      transition: all 0.15s;
    }
    .btn-home:hover { transform: translateY(-2px); box-shadow: 0 6px 28px rgba(124,58,237,0.55); }

    .btn-back {
      padding: 12px 24px; border-radius: 10px;
      border: 1px solid var(--border); background: transparent;
      color: var(--muted); font-family: 'Inter', sans-serif; font-size: 14px; font-weight: 500;
      cursor: pointer; text-decoration: none; transition: all 0.15s;
    }
    .btn-back:hover { color: var(--text); border-color: rgba(255,255,255,0.2); }

    @media (max-width: 480px) {
      .card { padding: 36px 20px; }
      .error-code { font-size: 60px; }
    }
  </style>
</head>
<body>
  <div class="bg-scene">
    <div class="blob blob-1"></div>
    <div class="blob blob-2"></div>
  </div>
  <div class="center">
    <div class="card">
      <div class="error-code"><%= code %></div>
      <h1><%= message %></h1>
      <p class="detail"><%= detail %></p>
      <div class="actions">
        <a href="javascript:history.back()" class="btn-back">Go back</a>
        <a href="/" class="btn-home">Dashboard home</a>
      </div>
    </div>
  </div>
</body>
</html>
