    <script>
        // ─── MODULE NAVIGATION ───
        function showModule(module) {
            // Update sidebar active state
            document.querySelectorAll('.sidebar .nav-item').forEach(el => {
                el.classList.remove('active');
            });
            document.querySelectorAll('.sidebar .nav-item').forEach(el => {
                if (el.textContent.trim().toLowerCase().includes(module)) {
                    el.classList.add('active');
                }
            });

            // Update top tabs
            document.querySelectorAll('.top-tabs .tab').forEach(el => {
                el.classList.remove('active');
            });
            document.querySelectorAll('.top-tabs .tab').forEach(el => {
                if (el.textContent.trim().toLowerCase().includes(module)) {
                    el.classList.add('active');
                }
            });

            // Hide all panels
            document.querySelectorAll('.module-panel').forEach(el => {
                el.classList.remove('active');
            });

            // Show selected panel
            const target = document.getElementById('module-' + module);
            if (target) {
                target.classList.add('active');
                target.scrollIntoView({ behavior: 'smooth', block: 'start' });
            }
        }

        // ─── SEARCH FEATURES ───
        function searchFeatures() {
            const query = document.getElementById('featureSearch').value.toLowerCase().trim();
            const cards = document.querySelectorAll('.module-card');

            cards.forEach(card => {
                const title = card.querySelector('.card-title')?.textContent?.toLowerCase() || '';
                const desc = card.querySelector('.card-desc')?.textContent?.toLowerCase() || '';
                const match = title.includes(query) || desc.includes(query);

                // Show/hide card
                card.style.display = match ? '' : 'none';

                // Show parent panel if any card is visible
                const panel = card.closest('.module-panel');
                if (panel) {
                    const visibleCards = panel.querySelectorAll('.module-card[style*="display: none"]');
                    const totalCards = panel.querySelectorAll('.module-card').length;
                    // If query is empty, show all panels
                    if (query === '') {
                        panel.style.display = '';
                    } else {
                        const hasVisible = Array.from(panel.querySelectorAll('.module-card')).some(c => c.style.display !== 'none');
                        panel.style.display = hasVisible ? '' : 'none';
                    }
                }
            });

            // If query is empty, show all panels
            if (query === '') {
                document.querySelectorAll('.module-panel').forEach(el => el.style.display = '');
            }
        }
    </script>

