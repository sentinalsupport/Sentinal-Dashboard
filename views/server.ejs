<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title || 'Modules — Sentinal' %></title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@400;500;600;700;800&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --ink: #060A10;
            --panel: #0D1520;
            --panel-raised: #111D2C;
            --panel-hover: #162033;
            --line: rgba(255,255,255,0.07);
            --line-bright: rgba(255,255,255,0.13);
            --text: #E6EDF6;
            --muted: #6C7A90;
            --muted-dim: #3E4A5C;
            --signal: #3DFFB8;
            --signal-tab: rgba(61,255,184,0.08);
            --signal-glow: rgba(61,255,184,0.15);
            --gold: #F5C842;
            --gold-tab: rgba(245,200,66,0.12);
            --violet: #8B7EFF;
            --violet-tab: rgba(139,126,255,0.12);
            --red: #F87171;
            --red-bg: rgba(248,113,113,0.08);
            --red-border: rgba(248,113,113,0.22);
            --discord: #5865F2;
            --discord-hover: #4752C4;
        }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Inter', -apple-system, sans-serif;
            background: var(--ink);
            color: var(--text);
            min-height: 100vh;
            overflow-x: hidden;
        }

        .navbar {
            background: rgba(6,10,16,0.9);
            backdrop-filter: blur(28px) saturate(160%);
            border-bottom: 1px solid var(--line);
            padding: 0 48px;
            height: 72px;
            display: flex; align-items: center; justify-content: space-between;
            position: sticky; top: 0; z-index: 200;
        }
        .brand { display: flex; align-items: center; gap: 12px; text-decoration: none; }
        .brand-logo {
            width: 40px; height: 40px; border-radius: 12px;
            background: var(--panel-raised); border: 1px solid var(--line-bright);
            display: flex; align-items: center; justify-content: center;
        }
        .brand-logo svg { width: 22px; height: 22px; }
        .brand-name {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 20px; font-weight: 700; color: #fff; letter-spacing: -0.3px;
        }
        .nav-center { display: flex; align-items: center; gap: 8px; }
        .nav-center a {
            color: var(--muted); text-decoration: none; font-size: 15px; font-weight: 500;
            padding: 8px 18px; border-radius: 10px; transition: all 0.18s ease;
        }
        .nav-center a:hover { color: var(--text); background: rgba(255,255,255,0.05); }
        .nav-center a.active { color: #fff; }
        .nav-right { display: flex; align-items: center; gap: 16px; }
        .user-pill {
            display: flex; align-items: center; gap: 12px;
            background: var(--panel); border: 1px solid var(--line);
            border-radius: 100px; padding: 6px 18px 6px 8px;
        }
        .user-avatar {
            width: 32px; height: 32px; border-radius: 50%;
            background: var(--panel-raised); overflow: hidden;
            display: flex; align-items: center; justify-content: center;
            font-size: 14px; font-weight: 700;
        }
        .user-avatar img { width: 100%; height: 100%; object-fit: cover; }
        .user-name { font-size: 14px; font-weight: 500; color: var(--text); }
        .user-plan {
            font-size: 11px; font-weight: 600; color: var(--signal);
            background: var(--signal-tab); border: 1px solid rgba(61,255,184,0.22);
            border-radius: 100px; padding: 3px 10px; letter-spacing: 0.3px;
        }
        .logout-btn {
            background: transparent; border: 1px solid var(--line); border-radius: 10px;
            padding: 8px 14px; color: var(--muted); cursor: pointer; font-size: 14px;
            transition: all 0.18s ease; text-decoration: none;
            display: flex; align-items: center; gap: 8px;
        }
        .logout-btn:hover { background: var(--red-bg); border-color: var(--red-border); color: var(--red); }

        /* ============ PAGE WRAPPER - SIDEBAR FLUSH LEFT ============ */
        .page-wrapper {
            max-width: 100%;
            margin: 0;
            padding: 32px 48px 60px 5px;
            display: flex;
            gap: 32px;
            align-items: flex-start;
            min-height: calc(100vh - 72px);
        }

        /* ============ SIDEBAR - FLUSH LEFT ============ */
        .sidebar {
            width: 280px;  /* CHANGED: from 240px to 280px - MAKES SIDEBAR BIGGER */
            flex-shrink: 0;
            background: var(--panel);
            border: 1px solid var(--line);
            border-radius: 0 14px 14px 0;
            padding: 16px 14px;
            position: sticky;
            top: 88px;
            height: calc(100vh - 108px);
            overflow-y: auto;
            overflow-x: hidden;
            margin-left: -5px;
            border-left: none;
        }
        .sidebar::-webkit-scrollbar { width: 3px; }
        .sidebar::-webkit-scrollbar-track { background: transparent; }
        .sidebar::-webkit-scrollbar-thumb { background: var(--muted-dim); border-radius: 10px; }

        .sidebar .server-info {
            padding-bottom: 14px;
            border-bottom: 1px solid var(--line);
            margin-bottom: 12px;
        }
        .sidebar .server-info .icon {
            width: 40px; height: 40px; border-radius: 10px;
            background: var(--panel-raised); border: 1px solid var(--line);
            display: flex; align-items: center; justify-content: center;
            font-size: 16px; font-weight: 700;
            overflow: hidden;
            color: var(--signal);
            margin-bottom: 6px;
        }
        .sidebar .server-info .icon img { width: 100%; height: 100%; object-fit: cover; }
        .sidebar .server-info .name {
            font-weight: 600; font-size: 13px;
            color: #fff;
        }
        .sidebar .server-info .plan {
            font-size: 10px;
            color: var(--signal);
            font-weight: 500;
            background: var(--signal-tab);
            padding: 2px 10px;
            border-radius: 100px;
            display: inline-block;
            border: 1px solid rgba(61,255,184,0.2);
        }
        .sidebar .server-info .upgrade {
            display: block;
            margin-top: 6px;
            padding: 4px 10px;
            border-radius: 6px;
            background: var(--gold-tab);
            color: var(--gold);
            font-size: 10px;
            font-weight: 600;
            text-decoration: none;
            text-align: center;
            border: 1px solid rgba(245,200,66,0.2);
        }
        .sidebar .server-info .upgrade:hover { background: rgba(245,200,66,0.18); }

        .sidebar .nav-section { padding: 0; }
        .sidebar .section-title {
            font-size: 9px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.8px;
            color: var(--muted-dim);
            padding: 8px 8px 4px;
        }
        .sidebar .nav-item {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 6px 10px;
            border-radius: 6px;
            color: var(--muted);
            text-decoration: none;
            font-size: 12px;
            font-weight: 500;
            transition: all 0.18s ease;
            cursor: pointer;
            border: none;
            background: none;
            width: 100%;
            text-align: left;
        }
        .sidebar .nav-item:hover { background: rgba(255,255,255,0.04); color: var(--text); }
        .sidebar .nav-item.active { background: var(--signal-tab); color: var(--signal); }
        .sidebar .nav-item i { width: 16px; font-size: 13px; color: var(--muted-dim); }
        .sidebar .nav-item.active i { color: var(--signal); }
        .sidebar .nav-item .badge {
            margin-left: auto;
            font-size: 7px;
            font-weight: 700;
            padding: 1px 6px;
            border-radius: 100px;
            text-transform: uppercase;
        }
        .sidebar .nav-item .badge.live { background: var(--signal-tab); color: var(--signal); }
        .sidebar .nav-item .badge.new { background: var(--violet-tab); color: var(--violet); }

        .sidebar .divider { height: 1px; background: var(--line); margin: 8px 0; }

        .content {
            flex: 1;
            min-width: 0;
        }

        .server-header {
            display: flex; align-items: center; gap: 20px;
            padding: 24px 0 20px;
            border-bottom: 1px solid var(--line);
            margin-bottom: 28px;
        }
        .server-header .icon {
            width: 64px; height: 64px; border-radius: 16px;
            background: var(--panel-raised); border: 1px solid var(--line);
            display: flex; align-items: center; justify-content: center;
            font-size: 28px; font-weight: 700; overflow: hidden;
            flex-shrink: 0; color: var(--signal);
        }
        .server-header .icon img { width: 100%; height: 100%; object-fit: cover; }
        .server-header .info h1 {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 28px; font-weight: 700; color: #fff;
        }
        .server-header .info p {
            font-size: 15px; color: var(--muted);
        }
        .server-header .info p i { color: var(--signal); margin-right: 6px; }

        .top-tabs {
            display: flex; gap: 8px;
            border-bottom: 1px solid var(--line);
            margin-bottom: 32px;
            flex-wrap: wrap;
            padding-bottom: 2px;
        }
        .top-tabs .tab {
            padding: 12px 28px;
            border-radius: 12px 12px 0 0;
            color: var(--muted);
            font-size: 16px; font-weight: 600;
            cursor: pointer;
            text-decoration: none;
            transition: all 0.18s ease;
            border-bottom: 3px solid transparent;
            background: none;
            border-top: none;
            border-left: none;
            border-right: none;
            font-family: 'Inter', sans-serif;
        }
        .top-tabs .tab:hover { color: var(--text); background: rgba(255,255,255,0.04); }
        .top-tabs .tab.active {
            color: var(--signal);
            border-bottom-color: var(--signal);
            background: var(--signal-tab);
        }

        .search-box {
            margin-bottom: 28px;
        }
        .search-box input {
            width: 100%;
            max-width: 400px;
            padding: 12px 20px;
            border-radius: 12px;
            border: 1px solid var(--line);
            background: var(--panel);
            color: var(--text);
            font-size: 14px;
            font-family: 'Inter', sans-serif;
            outline: none;
            transition: all 0.18s ease;
        }
        .search-box input:focus {
            border-color: var(--signal);
            box-shadow: 0 0 0 4px var(--signal-glow);
        }
        .search-box input::placeholder {
            color: var(--muted-dim);
        }

        .module-panel {
            display: none;
            animation: fadeIn 0.25s ease;
        }
        .module-panel.active {
            display: block;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(8px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .section-header {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 24px;
            font-weight: 700;
            color: #fff;
            margin: 32px 0 16px;
            padding-bottom: 4px;
            border-bottom: 2px solid var(--line);
        }
        .section-header:first-of-type {
            margin-top: 0;
        }

        .module-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
            gap: 20px;
            margin-bottom: 8px;
        }

        .module-card {
            background: var(--panel);
            border: 1px solid var(--line);
            border-radius: 14px;
            padding: 22px 24px;
            transition: all 0.2s ease;
            display: flex;
            flex-direction: column;
        }
        .module-card:hover {
            border-color: var(--line-bright);
        }
        .module-card .card-header {
            display: flex; justify-content: space-between; align-items: center;
            margin-bottom: 6px;
        }
        .module-card .card-header .card-title {
            font-weight: 600;
            font-size: 16px;
            color: #fff;
        }
        .module-card .card-header .card-badge {
            font-size: 10px; font-weight: 700;
            padding: 2px 12px; border-radius: 100px;
            text-transform: uppercase;
        }
        .module-card .card-header .card-badge.new {
            background: var(--violet-tab); color: var(--violet);
        }
        .module-card .card-header .card-badge.live {
            background: var(--signal-tab); color: var(--signal);
        }
        .module-card .card-desc {
            font-size: 14px;
            color: var(--muted);
            margin-bottom: 16px;
            line-height: 1.6;
            flex: 1;
        }
        .module-card .card-actions {
            display: flex; gap: 10px; flex-wrap: wrap;
            margin-top: auto;
        }
        .module-card .card-actions .btn-config {
            padding: 8px 20px;
            border-radius: 8px;
            font-size: 13px;
            font-weight: 600;
            cursor: pointer; border: none;
            background: var(--signal-tab); color: var(--signal);
            border: 1px solid rgba(61,255,184,0.2);
            transition: all 0.18s ease;
            text-decoration: none;
            display: inline-flex; align-items: center; gap: 8px;
            height: 36px;
            font-family: 'Inter', sans-serif;
        }
        .module-card .card-actions .btn-config:hover {
            background: rgba(61,255,184,0.18);
        }

        .toast-container {
            position: fixed;
            bottom: 24px;
            right: 24px;
            z-index: 9999;
            display: flex;
            flex-direction: column;
            gap: 10px;
            max-width: 380px;
            width: 100%;
        }
        .toast {
            background: var(--panel);
            border: 1px solid var(--line);
            border-radius: 12px;
            padding: 14px 20px;
            display: flex;
            align-items: center;
            gap: 12px;
            box-shadow: 0 8px 32px rgba(0,0,0,0.4);
            animation: slideIn 0.3s ease;
            backdrop-filter: blur(10px);
            border-left: 4px solid var(--signal);
        }
        .toast .toast-icon { color: var(--signal); font-size: 18px; flex-shrink: 0; }
        .toast .toast-content { flex: 1; font-size: 13px; color: var(--text); line-height: 1.4; }
        .toast .toast-close {
            background: none; border: none;
            color: var(--muted-dim); cursor: pointer;
            font-size: 14px; padding: 4px;
        }
        .toast .toast-close:hover { color: var(--text); }
        .toast.error { border-left-color: var(--red); }
        .toast.error .toast-icon { color: var(--red); }
        .toast.success { border-left-color: var(--signal); }
        .toast.success .toast-icon { color: var(--signal); }
        @keyframes slideIn {
            from { opacity: 0; transform: translateX(40px); }
            to { opacity: 1; transform: translateX(0); }
        }
        @keyframes slideOut {
            from { opacity: 1; transform: translateX(0); }
            to { opacity: 0; transform: translateX(40px); }
        }
        .toast.hiding { animation: slideOut 0.3s ease forwards; }

        .footer {
            border-top: 1px solid var(--line);
            margin-top: 60px;
            padding: 28px 48px;
            text-align: center;
            color: var(--muted-dim);
            font-size: 13px;
            font-family: 'IBM Plex Mono', monospace;
            letter-spacing: 0.5px;
        }

        @media (max-width: 1200px) {
            .module-grid { grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); }
        }
        @media (max-width: 1024px) {
            .page-wrapper { padding: 24px 32px 60px 5px; gap: 24px; }
            .sidebar { width: 220px; }
        }
        @media (max-width: 768px) {
            .navbar { padding: 0 16px; height: 64px; flex-wrap: wrap; }
            .nav-center { display: none; }
            .page-wrapper { padding: 16px; flex-direction: column; }
            .sidebar {
                width: 100%; position: relative; top: 0;
                display: flex; flex-wrap: wrap; gap: 4px; padding: 12px;
                border-radius: 12px; max-height: none; height: auto;
                margin-left: 0;
                border: 1px solid var(--line);
                border-radius: 12px;
            }
            .sidebar .server-info { display: none; }
            .sidebar .nav-section { display: flex; flex-wrap: wrap; gap: 4px; }
            .sidebar .section-title { display: none; }
            .sidebar .nav-item { padding: 6px 14px; font-size: 13px; width: auto; }
            .sidebar .divider { display: none; }
            .server-header { flex-wrap: wrap; }
            .server-header .info h1 { font-size: 22px; }
            .server-header .icon { width: 48px; height: 48px; font-size: 20px; }
            .top-tabs { flex-wrap: wrap; }
            .top-tabs .tab { font-size: 14px; padding: 10px 18px; }
            .module-grid { grid-template-columns: 1fr; }
            .module-card { padding: 18px 20px; }
            .module-card .card-title { font-size: 15px; }
            .search-box input { font-size: 14px; padding: 12px 16px; max-width: 100%; }
            .footer { padding: 20px 16px; }
            .section-header { font-size: 20px; }
            .toast-container { bottom: 16px; right: 16px; max-width: calc(100% - 32px); }
        }
    </style>
</head>
<body>

    <nav class="navbar">
        <a href="/dashboard" class="brand">
            <div class="brand-logo">
                <svg viewBox="0 0 245 240" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M104.4 103.9c-5.7 0-10.2 5-10.2 11.1s4.6 11.1 10.2 11.1c5.7 0 10.2-5 10.2-11.1.1-6.1-4.5-11.1-10.2-11.1zM140.9 103.9c-5.7 0-10.2 5-10.2 11.1s4.6 11.1 10.2 11.1c5.7 0 10.2-5 10.2-11.1s-4.5-11.1-10.2-11.1z" fill="#3DFFB8"/>
                    <path d="M189.5 20H55.5C44.7 20 36 28.7 36 39.5v140.9c0 10.8 8.7 19.5 19.5 19.5h113.5l-5.3-18.5 12.8 11.9 12.1 11.2L209 220V39.5C209 28.7 200.3 20 189.5 20zM155.7 152.1s-3.6-4.3-6.6-8.1c13.1-3.7 18.1-11.9 18.1-11.9-4.1 2.7-8 4.6-11.5 5.9-5 2.1-9.8 3.5-14.5 4.3-9.6 1.8-18.4 1.3-25.9-.1-5.7-1.1-10.6-2.6-14.7-4.3-2.3-.9-4.8-2-7.3-3.4-.3-.2-.6-.3-.9-.5-.2-.1-.3-.2-.4-.3-2-1.1-3.1-1.9-3.1-1.9 4.7 4.3 9.3 6.5 21.7 10.2-2.9 3.8-6.6 8.1-6.6 8.1-22 0-32.1-15.2-32.1-15.2 0-32.2 14.4-58.4 14.4-58.4 14.4-10.8 28.1-10.5 28.1-10.5l1 1.2C99.2 87.7 87.9 97.4 87.9 97.4s2.9-1.6 7.8-3.8c14.1-6.2 25.3-7.9 29.9-8.3.8-.1 1.5-.2 2.3-.2 8.2-1 17.5-1.3 27.2.2 12.9 2 26.7 7.5 40.8 17.3 0 0-10.8-10.2-28.5-13.7l1.4-1.6s13.7-.3 28.1 10.5c0 0 14.4 26.2 14.4 58.4 0 0-10.2 15.2-32.1 15.2z" fill="#3DFFB8"/>
                </svg>
            </div>
            <span class="brand-name">Sentinal</span>
        </a>
        <div class="nav-center">
            <a href="/dashboard">Home</a>
            <a href="/servers" class="active">Servers</a>
            <a href="#" onclick="window.open('https://discord.gg/UmqmewYWRd','_blank'); return false;">Support</a>
            <a href="#">Premium</a>
        </div>
        <div class="nav-right">
            <div class="user-pill">
                <div class="user-avatar">
                    <% if (locals.user && user.avatar) { %>
                        <img src="https://cdn.discordapp.com/avatars/<%= user.id %>/<%= user.avatar %>.png" alt="Avatar">
                    <% } else { %>
                        <%= locals.user ? (user.username ? user.username.charAt(0).toUpperCase() : 'U') : 'U' %>
                    <% } %>
                </div>
                <span class="user-name"><%= locals.user ? (user.global_name || user.username) : 'User' %></span>
                <span class="user-plan">Free</span>
            </div>
            <a href="/logout" class="logout-btn"><i class="fas fa-sign-out-alt"></i></a>
        </div>
    </nav>

    <div class="toast-container" id="toastContainer"></div>

    <div class="page-wrapper">

        <!-- ─── LEFT SIDEBAR ─── -->
        <aside class="sidebar">
            <div class="server-info">
                <div class="icon">
                    <% if (locals.guild && guild.icon) { %>
                        <img src="https://cdn.discordapp.com/icons/<%= guild.id %>/<%= guild.icon %>.png" alt="<%= guild.name %>">
                    <% } else { %>
                        <%= locals.guild ? (guild.name ? guild.name.charAt(0).toUpperCase() : '?') : '?' %>
                    <% } %>
                </div>
                <div class="name"><%= locals.guild ? guild.name : 'Server' %></div>
                <div class="plan">Free</div>
                <a href="#" class="upgrade" onclick="showToast('Upgrade to Premium!', 'info')">Upgrade to Premium</a>
            </div>

            <div class="nav-section">
                <div class="section-title">Modules</div>
                <a href="/servers/<%= locals.guild ? guild.id : '' %>" class="nav-item active">
                    <i class="fas fa-th-large"></i> Overview
                </a>
                <a href="/servers/<%= locals.guild ? guild.id : '' %>/automation" class="nav-item">
                    <i class="fas fa-robot"></i> Automation
                    <span class="badge new">New</span>
                </a>
                <a href="/servers/<%= locals.guild ? guild.id : '' %>/security" class="nav-item">
                    <i class="fas fa-shield-halved"></i> Security
                    <span class="badge live">Live</span>
                </a>
                <a href="/servers/<%= locals.guild ? guild.id : '' %>/community" class="nav-item">
                    <i class="fas fa-users"></i> Community
                    <span class="badge new">New</span>
                </a>
                <!-- ✅ ADDED TICKETS LINK -->
                <a href="/servers/<%= locals.guild ? guild.id : '' %>/tickets" class="nav-item">
                    <i class="fas fa-ticket-alt"></i> Tickets
                    <span class="badge live">Live</span>
                </a>
                <a href="/servers/<%= locals.guild ? guild.id : '' %>/audit" class="nav-item">
                    <i class="fas fa-clipboard-list"></i> Audit & Logs
                </a>
            </div>

            <div class="divider"></div>

            <div class="nav-section">
                <div class="section-title">Support</div>
                <button class="nav-item" onclick="showToast('Support server coming soon!', 'info')">
                    <i class="fas fa-headset"></i> Support Server
                </button>
            </div>
        </aside>

        <!-- ─── RIGHT CONTENT ─── -->
        <div class="content">

            <div class="server-header">
                <div class="icon">
                    <% if (locals.guild && guild.icon) { %>
                        <img src="https://cdn.discordapp.com/icons/<%= guild.id %>/<%= guild.icon %>.png" alt="<%= guild.name %>">
                    <% } else { %>
                        <%= locals.guild ? (guild.name ? guild.name.charAt(0).toUpperCase() : '?') : '?' %>
                    <% } %>
                </div>
                <div class="info">
                    <h1><%= locals.guild ? guild.name : 'Server' %></h1>
                    <p><i class="fas fa-users"></i> <%= locals.guild ? (guild.approximate_member_count || 'N/A') : 'N/A' %> members</p>
                </div>
            </div>

            <!-- ─── TOP TABS ─── -->
            <div class="top-tabs">
                <button class="tab active" onclick="showModule('overview')">Overview</button>
                <button class="tab" onclick="showModule('automation')">Automation</button>
                <button class="tab" onclick="showModule('security')">Security</button>
                <button class="tab" onclick="showModule('community')">Community</button>
                <!-- ✅ ADDED TICKETS TAB -->
                <button class="tab" onclick="showModule('tickets')">Tickets</button>
                <button class="tab" onclick="showModule('audit')">Audit & Logs</button>
            </div>

            <div class="search-box">
                <input type="text" placeholder="Search for a feature..." id="featureSearch" onkeyup="searchFeatures()">
            </div>

            <!-- ─── MODULE PANELS ─── -->

            <!-- OVERVIEW -->
            <div class="module-panel active" id="module-overview">
                <div class="section-header">Overview</div>
                <div class="module-grid">
                    <div class="module-card">
                        <div class="card-header">
                            <span class="card-title">General Settings</span>
                            <span class="card-badge live">Live</span>
                        </div>
                        <div class="card-desc">Configure basic server settings for Sentinal</div>
                        <div class="card-actions">
                            <button class="btn-config" onclick="showToast('General settings coming soon!', 'info')">
                                <i class="fas fa-cog"></i> Configure
                            </button>
                        </div>
                    </div>
                    <div class="module-card">
                        <div class="card-header">
                            <span class="card-title">Bot Status</span>
                            <span class="card-badge live">Live</span>
                        </div>
                        <div class="card-desc">
                            <% if (locals.botInServer) { %>
                                ✅ Bot is currently in this server
                            <% } else { %>
                                ❌ Bot is not in this server
                            <% } %>
                        </div>
                        <div class="card-actions">
                            <% if (!locals.botInServer) { %>
                                <a href="<%= locals.inviteLink %>" target="_blank" class="btn-config">
                                    <i class="fas fa-plus"></i> Invite Bot
                                </a>
                            <% } %>
                            <button class="btn-config" onclick="showToast('Bot status refreshed!', 'success')">
                                <i class="fas fa-sync"></i> Refresh Status
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- AUTOMATION -->
            <div class="module-panel" id="module-automation">
                <div class="section-header">Automation</div>
                <div class="module-grid">
                    <div class="module-card">
                        <div class="card-header">
                            <span class="card-title">Auto Roles</span>
                            <span class="card-badge new">New</span>
                        </div>
                        <div class="card-desc">Automatically assign roles to users when they join your server</div>
                        <div class="card-actions">
                            <a href="/servers/<%= locals.guild ? guild.id : '' %>/automation" class="btn-config">
                                <i class="fas fa-cog"></i> Configure
                            </a>
                        </div>
                    </div>
                    <div class="module-card">
                        <div class="card-header">
                            <span class="card-title">Welcome Messages</span>
                            <span class="card-badge new">New</span>
                        </div>
                        <div class="card-desc">Automatically greet new users with a personalized message</div>
                        <div class="card-actions">
                            <button class="btn-config" onclick="showToast('Welcome messages coming soon!', 'info')">
                                <i class="fas fa-cog"></i> Configure
                            </button>
                        </div>
                    </div>
                    <div class="module-card">
                        <div class="card-header">
                            <span class="card-title">Leave Messages</span>
                            <span class="card-badge new">New</span>
                        </div>
                        <div class="card-desc">Automatically say goodbye to users who leave your server</div>
                        <div class="card-actions">
                            <button class="btn-config" onclick="showToast('Leave messages coming soon!', 'info')">
                                <i class="fas fa-cog"></i> Configure
                            </button>
                        </div>
                    </div>
                    <div class="module-card">
                        <div class="card-header">
                            <span class="card-title">Leveling</span>
                            <span class="card-badge new">New</span>
                        </div>
                        <div class="card-desc">Track user activity and reward them with XP and levels</div>
                        <div class="card-actions">
                            <button class="btn-config" onclick="showToast('Leveling system coming soon!', 'info')">
                                <i class="fas fa-cog"></i> Configure
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- SECURITY -->
            <div class="module-panel" id="module-security">
                <div class="section-header">Security</div>
                <div class="module-grid">
                    <div class="module-card">
                        <div class="card-header">
                            <span class="card-title">Verification</span>
                            <span class="card-badge live">Live</span>
                        </div>
                        <div class="card-desc">Ensure only humans are allowed into your server</div>
                        <div class="card-actions">
                            <button class="btn-config" onclick="showToast('Verification settings coming soon!', 'info')">
                                <i class="fas fa-cog"></i> Configure
                            </button>
                        </div>
                    </div>
                    <div class="module-card">
                        <div class="card-header">
                            <span class="card-title">Anti-Raid</span>
                            <span class="card-badge new">New</span>
                        </div>
                        <div class="card-desc">Protect your server from raid attacks</div>
                        <div class="card-actions">
                            <button class="btn-config" onclick="showToast('Anti-raid settings coming soon!', 'info')">
                                <i class="fas fa-cog"></i> Configure
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- COMMUNITY -->
            <div class="module-panel" id="module-community">
                <div class="section-header">Community</div>
                <div class="module-grid">
                    <div class="module-card">
                        <div class="card-header">
                            <span class="card-title">Polls</span>
                            <span class="card-badge new">New</span>
                        </div>
                        <div class="card-desc">Create and manage polls for your server members to vote on.</div>
                        <div class="card-actions">
                            <button class="btn-config" onclick="showToast('Polls coming soon!', 'info')">
                                <i class="fas fa-cog"></i> Configure
                            </button>
                        </div>
                    </div>
                    <div class="module-card">
                        <div class="card-header">
                            <span class="card-title">Giveaways</span>
                            <span class="card-badge new">New</span>
                        </div>
                        <div class="card-desc">Create and manage giveaways for your server members to enter.</div>
                        <div class="card-actions">
                            <button class="btn-config" onclick="showToast('Giveaways coming soon!', 'info')">
                                <i class="fas fa-cog"></i> Configure
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ✅ ADDED TICKETS PANEL -->
            <!-- TICKETS -->
            <div class="module-panel" id="module-tickets">
                <div class="section-header">Tickets</div>
                <div class="module-grid">
                    <div class="module-card">
                        <div class="card-header">
                            <span class="card-title">Templates</span>
                            <span class="card-badge live">Live</span>
                        </div>
                        <div class="card-desc">Create tickets for users to open in your server</div>
                        <div class="card-actions">
                            <button class="btn-config" onclick="showToast('Templates coming soon!', 'info')">
                                <i class="fas fa-cog"></i> Configure
                            </button>
                        </div>
                    </div>
                    <div class="module-card">
                        <div class="card-header">
                            <span class="card-title">Panels</span>
                            <span class="card-badge live">Live</span>
                        </div>
                        <div class="card-desc">Organize your tickets into panels</div>
                        <div class="card-actions">
                            <button class="btn-config" onclick="showToast('Panels coming soon!', 'info')">
                                <i class="fas fa-cog"></i> Configure
                            </button>
                        </div>
                    </div>
                    <div class="module-card">
                        <div class="card-header">
                            <span class="card-title">Quick Responses</span>
                            <span class="card-badge live">Live</span>
                        </div>
                        <div class="card-desc">Create quick responses to answer common questions</div>
                        <div class="card-actions">
                            <button class="btn-config" onclick="showToast('Quick responses coming soon!', 'info')">
                                <i class="fas fa-cog"></i> Configure
                            </button>
                        </div>
                    </div>
                    <div class="module-card">
                        <div class="card-header">
                            <span class="card-title">Transcripts</span>
                            <span class="card-badge live">Live</span>
                        </div>
                        <div class="card-desc">Get a comprehensive view of all open and closed tickets</div>
                        <div class="card-actions">
                            <button class="btn-config" onclick="showToast('Transcripts coming soon!', 'info')">
                                <i class="fas fa-cog"></i> Configure
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- AUDIT & LOGS -->
            <div class="module-panel" id="module-audit">
                <div class="section-header">Audit & Logs</div>
                <div class="module-grid">
                    <div class="module-card">
                        <div class="card-header">
                            <span class="card-title">Dashboard Logs</span>
                            <span class="card-badge live">Live</span>
                        </div>
                        <div class="card-desc">Monitor and review all dashboard activities and config changes</div>
                        <div class="card-actions">
                            <button class="btn-config" onclick="showToast('Dashboard logs coming soon!', 'info')">
                                <i class="fas fa-cog"></i> Configure
                            </button>
                        </div>
                    </div>
                    <div class="module-card">
                        <div class="card-header">
                            <span class="card-title">Moderation Logs</span>
                            <span class="card-badge live">Live</span>
                        </div>
                        <div class="card-desc">View all moderation actions taken in your server</div>
                        <div class="card-actions">
                            <button class="btn-config" onclick="showToast('Moderation logs coming soon!', 'info')">
                                <i class="fas fa-cog"></i> Configure
                            </button>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>

    <footer class="footer">
        © 2026 SENTINAL — STATUS: OPERATIONAL
    </footer>

    <script>
        function showToast(message, type = 'info') {
            const container = document.getElementById('toastContainer');
            const toast = document.createElement('div');
            toast.className = 'toast ' + type;
            toast.innerHTML = `
                <span class="toast-icon"><i class="fas fa-${type === 'success' ? 'check-circle' : 'exclamation-circle'}"></i></span>
                <span class="toast-content">${message}</span>
                <button class="toast-close" onclick="this.closest('.toast').classList.add('hiding'); setTimeout(() => this.closest('.toast').remove(), 300);">
                    <i class="fas fa-times"></i>
                </button>
            `;
            container.appendChild(toast);
            setTimeout(() => {
                if (toast.parentNode) {
                    toast.classList.add('hiding');
                    setTimeout(() => { if (toast.parentNode) toast.remove(); }, 300);
                }
            }, 4000);
        }

        function showModule(module) {
            // Update sidebar
            document.querySelectorAll('.sidebar .nav-item').forEach(el => el.classList.remove('active'));
            document.querySelectorAll('.sidebar .nav-item').forEach(el => {
                if (el.textContent.trim().toLowerCase().includes(module)) {
                    el.classList.add('active');
                }
            });

            // Update top tabs
            document.querySelectorAll('.top-tabs .tab').forEach(el => el.classList.remove('active'));
            document.querySelectorAll('.top-tabs .tab').forEach(el => {
                if (el.textContent.trim().toLowerCase().includes(module)) {
                    el.classList.add('active');
                }
            });

            // Hide all panels
            document.querySelectorAll('.module-panel').forEach(el => el.classList.remove('active'));

            // Show selected panel
            const target = document.getElementById('module-' + module);
            if (target) {
                target.classList.add('active');
            }
        }

        function searchFeatures() {
            const query = document.getElementById('featureSearch').value.toLowerCase().trim();
            const cards = document.querySelectorAll('.module-card');

            cards.forEach(card => {
                const title = card.querySelector('.card-title')?.textContent?.toLowerCase() || '';
                const desc = card.querySelector('.card-desc')?.textContent?.toLowerCase() || '';
                const match = title.includes(query) || desc.includes(query);
                card.style.display = match ? '' : 'none';
            });

            if (query === '') {
                cards.forEach(card => card.style.display = '');
                document.querySelectorAll('.module-panel').forEach(el => el.style.display = '');
            }
        }

        // Make functions globally accessible
        window.showToast = showToast;
        window.showModule = showModule;
        window.searchFeatures = searchFeatures;
    </script>

</body>
</html>
