<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sentinal — Server Selection</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css" />
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        :root {
            --pu: #7C3AED; --pu-l: #A855F7; --pu-xl: #D8B4FE;
            --pi: #D4537E; --pi-l: #F472B6;
            --gold: #F59E0B; --gold-l: #FBBF24;
            --bg0: #0A0812; --bg1: #100C1C; --bg2: #160F26;
            --card: rgba(120,50,200,0.07);
            --bord: rgba(168,85,247,0.15); --bord2: rgba(236,72,153,0.2);
            --t1: #F1F5F9; --t2: #C4B5D8; --t3: #7B6C96;
        }
        body { font-family: 'Inter', -apple-system, sans-serif; background: var(--bg0); color: var(--t1); min-height: 100vh; display: flex; overflow-x: hidden; }
        body::before { content: ''; position: fixed; inset: 0; z-index: 0; background: radial-gradient(ellipse 50% 60% at 15% 50%, rgba(124,58,237,.12) 0%, transparent 70%), radial-gradient(ellipse 40% 50% at 85% 20%, rgba(212,83,126,.1) 0%, transparent 70%), radial-gradient(ellipse 60% 40% at 60% 80%, rgba(168,85,247,.07) 0%, transparent 70%); pointer-events: none; }
        .sb { width: 220px; min-height: 100vh; background: var(--bg1); border-right: 1px solid var(--bord); padding: 20px 12px; display: flex; flex-direction: column; gap: 6px; position: sticky; top: 0; height: 100vh; z-index: 10; flex-shrink: 0; }
        .sb-logo { display: flex; align-items: center; gap: 10px; padding: 8px 10px; margin-bottom: 12px; }
        .sb-logo .ic { width: 36px; height: 36px; border-radius: 10px; background: linear-gradient(135deg, var(--pu), var(--pi)); display: flex; align-items: center; justify-content: center; font-weight: 800; font-size: 17px; color: #fff; flex-shrink: 0; }
        .sb-logo .nm { font-size: 17px; font-weight: 700; color: #fff; letter-spacing: -.3px; }
        .sb-logo .bk { font-size: 10px; font-weight: 600; background: rgba(244,114,182,.15); color: var(--pi-l); padding: 2px 8px; border-radius: 12px; border: 1px solid rgba(244,114,182,.2); }
        .sb-nav { display: flex; flex-direction: column; gap: 2px; flex: 1; }
        .sb-nav a { display: flex; align-items: center; gap: 10px; padding: 9px 12px; border-radius: 10px; color: var(--t2); text-decoration: none; font-size: 13.5px; font-weight: 500; transition: all .25s; position: relative; overflow: hidden; cursor: pointer; }
        .sb-nav a::before { content: ''; position: absolute; inset: 0; background: linear-gradient(90deg, rgba(124,58,237,.12), rgba(212,83,126,.08)); opacity: 0; transition: opacity .25s; border-radius: 10px; }
        .sb-nav a:hover::before, .sb-nav a.active::before { opacity: 1; }
        .sb-nav a:hover { color: #fff; }
        .sb-nav a.active { color: var(--pu-xl); border: 1px solid rgba(168,85,247,.2); }
        .sb-nav a i { font-size: 17px; flex-shrink: 0; }
        .sb-user { border-top: 1px solid var(--bord); padding-top: 14px; margin-top: auto; position: relative; }
        .sb-user .ui { display: flex; align-items: center; gap: 10px; padding: 8px 10px; border-radius: 10px; cursor: pointer; transition: all .2s; }
        .sb-user .ui:hover { background: var(--card); }
        .sb-user .av { width: 34px; height: 34px; border-radius: 50%; background: linear-gradient(135deg, var(--pu), var(--pi-l)); display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 13px; color: #fff; flex-shrink: 0; }
        .sb-user .un { font-size: 13px; font-weight: 600; color: #fff; }
        .sb-user .up { font-size: 11px; color: var(--t3); }
        .sb-user .chevron { margin-left: auto; color: var(--t3); font-size: 16px; transition: transform .3s; }
        .user-dropdown { position: absolute; bottom: 70px; left: 0; right: 0; background: var(--bg2); border: 1px solid var(--bord); border-radius: 14px; padding: 8px 0; opacity: 0; visibility: hidden; transform: translateY(10px); transition: all .3s cubic-bezier(.25,.46,.45,.94); box-shadow: 0 20px 60px rgba(0,0,0,.6); z-index: 20; }
        .user-dropdown.open { opacity: 1; visibility: visible; transform: translateY(0); }
        .user-dropdown .di { display: flex; align-items: center; gap: 10px; padding: 10px 16px; color: var(--t2); text-decoration: none; font-size: 13px; font-weight: 500; transition: all .2s; cursor: pointer; }
        .user-dropdown .di:hover { background: var(--card); color: #fff; }
        .user-dropdown .di i { font-size: 16px; width: 20px; }
        .dd-div { height: 1px; background: var(--bord); margin: 4px 12px; }
        .prem-badge { background: linear-gradient(135deg, var(--gold), var(--gold-l)); color: #78350F !important; }
        .prem-badge i { color: #78350F !important; }
        .main { flex: 1; padding: 28px 36px; position: relative; z-index: 1; overflow-y: auto; }
        .ph { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 28px; }
        .ph h1 { font-size: 26px; font-weight: 800; letter-spacing: -.5px; }
        .ph h1 span { background: linear-gradient(135deg, var(--pu-l), var(--pi-l), #EC4899); -webkit-background-clip: text; background-clip: text; color: transparent; }
        .ph p { color: var(--t2); font-size: 14px; margin-top: 3px; }
        .pa { display: flex; gap: 10px; align-items: center; }
        .srch { display: flex; align-items: center; gap: 8px; background: var(--bg2); border: 1px solid var(--bord); border-radius: 12px; padding: 8px 14px; width: 240px; transition: all .3s; }
        .srch:focus-within { border-color: var(--pu-l); box-shadow: 0 0 0 3px rgba(168,85,247,.12); }
        .srch input { background: none; border: none; color: var(--t1); font-size: 13.5px; width: 100%; outline: none; font-family: inherit; }
        .srch input::placeholder { color: var(--t3); }
        .srch i { color: var(--t3); font-size: 16px; }
        .btn-rf { background: var(--bg2); border: 1px solid var(--bord); color: var(--t2); padding: 8px 14px; border-radius: 10px; cursor: pointer; font-size: 13px; transition: all .2s; font-family: inherit; display: flex; align-items: center; gap: 6px; }
        .btn-rf:hover { border-color: var(--bord2); color: #fff; background: rgba(212,83,126,.08); }
        .btn-rf i { font-size: 16px; }
        .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(270px, 1fr)); gap: 16px; }
        .sc { background: var(--bg1); border: 1px solid var(--bord); border-radius: 18px; padding: 20px 22px; transition: all .35s cubic-bezier(.25,.46,.45,.94); cursor: pointer; position: relative; overflow: hidden; animation: fadeUp .4s ease both; }
        .sc::before { content: ''; position: absolute; inset: 0; background: linear-gradient(135deg, rgba(124,58,237,.06), rgba(212,83,126,.04)); opacity: 0; transition: opacity .35s; border-radius: 18px; }
        .sc:hover::before { opacity: 1; }
        .sc:hover { transform: translateY(-5px); border-color: rgba(168,85,247,.35); box-shadow: 0 12px 40px rgba(124,58,237,.18); }
        .sc-head { display: flex; align-items: center; gap: 12px; margin-bottom: 10px; }
        .sc-ico { width: 44px; height: 44px; border-radius: 12px; background: linear-gradient(135deg, var(--pu), var(--pi)); display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 18px; color: #fff; flex-shrink: 0; }
        .sc-info .nm { font-size: 15px; font-weight: 600; color: #fff; }
        .sc-info .ow { font-size: 11px; color: var(--t3); margin-top: 1px; }
        .sc-role { display: inline-block; font-size: 10px; font-weight: 600; padding: 2px 8px; border-radius: 10px; margin-top: 2px; }
        .role-owner { background: rgba(245,158,11,.15); color: var(--gold-l); border: 1px solid rgba(245,158,11,.2); }
        .role-admin { background: rgba(168,85,247,.15); color: var(--pu-l); border: 1px solid rgba(168,85,247,.2); }
        .role-none { background: rgba(107,114,128,.15); color: #9CA3AF; border: 1px solid rgba(107,114,128,.2); }
        .badge { display: inline-flex; align-items: center; gap: 5px; font-size: 11.5px; font-weight: 500; padding: 3px 10px; border-radius: 20px; }
        .badge-off { background: rgba(239,68,68,.1); color: #FCA5A5; border: 1px solid rgba(239,68,68,.2); }
        .badge-on { background: rgba(16,185,129,.12); color: #34D399; border: 1px solid rgba(16,185,129,.25); }
        .badge-dot { width: 6px; height: 6px; border-radius: 50%; flex-shrink: 0; background: #FCA5A5; }
        .badge-on .badge-dot { background: #34D399; animation: pulse 2s infinite; }
        .sc-acts { display: flex; gap: 8px; margin-top: 12px; }
        .btn-inv { flex: 1; background: linear-gradient(135deg, var(--pu), var(--pi)); color: #fff; border: none; padding: 8px 14px; border-radius: 9px; font-size: 12.5px; font-weight: 600; cursor: pointer; transition: all .25s; font-family: inherit; display: flex; align-items: center; justify-content: center; gap: 6px; }
        .btn-inv:hover { box-shadow: 0 4px 20px rgba(212,83,126,.35); filter: brightness(1.1); }
        .btn-cfg { flex: 1; background: rgba(255,255,255,.04); color: var(--t2); border: 1px solid var(--bord); padding: 8px 14px; border-radius: 9px; font-size: 12.5px; font-weight: 500; cursor: pointer; transition: all .25s; font-family: inherit; display: flex; align-items: center; justify-content: center; gap: 6px; }
        .btn-cfg:hover { border-color: rgba(168,85,247,.35); color: var(--pu-xl); background: rgba(124,58,237,.08); }
        .btn-cfg.disabled { opacity: .4; cursor: not-allowed; pointer-events: none; }
        .hint { margin-top: 20px; font-size: 12.5px; color: var(--t3); display: flex; align-items: center; gap: 6px; }
        .hint i { font-size: 14px; }
        .empty-state { text-align: center; padding: 60px 20px; color: var(--t2); }
        .empty-state i { font-size: 48px; color: var(--t3); margin-bottom: 16px; display: block; }
        .empty-state h3 { color: #fff; margin-bottom: 8px; }
        @keyframes fadeUp { from { opacity: 0; transform: translateY(16px); } to { opacity: 1; transform: translateY(0); } }
        @keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: .5; } }
        @media (max-width: 1024px) {
            .sb { width: 72px; padding: 16px 8px; }
            .sb-logo .nm, .sb-logo .bk, .sb-nav a span, .sb-user .un, .sb-user .up, .sb-user .chevron { display: none; }
            .sb-nav a { justify-content: center; padding: 10px; }
            .sb-user .ui { justify-content: center; }
            .main { padding: 24px 20px; }
            .ph { flex-direction: column; gap: 16px; }
            .srch { width: 100%; }
            .grid { grid-template-columns: 1fr; }
        }
        @media (max-width: 600px) {
            .sb { width: 56px; padding: 12px 6px; }
            .main { padding: 16px 12px; }
            .sc { padding: 16px; }
            .sc-acts { flex-direction: column; }
        }
    </style>
</head>
<body>

<aside class="sb">
    <div class="sb-logo">
        <div class="ic">S</div>
        <span class="nm">Sentinal</span>
        <span class="bk">Free</span>
    </div>
    <nav class="sb-nav">
        <a class="active"><i class="ti ti-layout-dashboard" aria-hidden="true"></i><span>Home</span></a>
        <a><i class="ti ti-chart-bar" aria-hidden="true"></i><span>Status</span></a>
        <a><i class="ti ti-book" aria-hidden="true"></i><span>Documentation</span></a>
        <a><i class="ti ti-message-circle" aria-hidden="true"></i><span>Support</span></a>
        <a><i class="ti ti-star" aria-hidden="true"></i><span>Premium</span></a>
    </nav>
    <div class="sb-user">
        <div class="ui" id="userToggle">
            <div class="av"><%= user.username.charAt(0).toUpperCase() %></div>
            <div>
                <div class="un"><%= user.username %></div>
                <div class="up">Free Plan</div>
            </div>
            <i class="ti ti-chevron-down chevron" id="chevronIcon" aria-hidden="true"></i>
        </div>
        <div class="user-dropdown" id="userDropdown">
            <a href="/profile" class="di"><i class="ti ti-user" aria-hidden="true"></i><span>Profile</span></a>
            <div class="di"><i class="ti ti-settings" aria-hidden="true"></i><span>Settings</span></div>
            <div class="dd-div"></div>
            <a href="/premium" class="di prem-badge"><i class="ti ti-crown" aria-hidden="true"></i><span>Upgrade to Premium</span></a>
            <div class="dd-div"></div>
            <a href="/logout" class="di" style="color:#F87171"><i class="ti ti-logout" aria-hidden="true"></i><span>Logout</span></a>
        </div>
    </div>
</aside>

<main class="main">
    <div class="ph">
        <div>
            <h1>Server <span>Selection</span></h1>
            <p>Select a server you manage to configure your bot.</p>
        </div>
        <div class="pa">
            <div class="srch">
                <i class="ti ti-search" aria-hidden="true"></i>
                <input type="text" id="searchInput" placeholder="Search servers…" />
            </div>
            <button class="btn-rf" onclick="location.reload()"><i class="ti ti-refresh" aria-hidden="true"></i> Refresh</button>
        </div>
    </div>

    <div class="grid" id="serverGrid">
        <% if (guilds && guilds.length > 0) { %>
            <% guilds.forEach((guild, index) => { %>
                <div class="sc" style="animation-delay:<%= index * 0.07 %>s">
                    <div class="sc-head">
                        <div class="sc-ico"><%= guild.name.charAt(0).toUpperCase() %></div>
                        <div class="sc-info">
                            <div class="nm"><%= guild.name %></div>
                            <div class="ow">
                                <% if (guild.hasBot) { %>
                                    <span class="badge badge-on"><span class="badge-dot"></span> Online</span>
                                <% } else { %>
                                    <span class="badge badge-off"><span class="badge-dot"></span> Bot not installed</span>
                                <% } %>
                            </div>
                            <% if ((guild.permissions & 0x1) === 0x1) { %>
                                <span class="sc-role role-owner">👑 Owner</span>
                            <% } else if ((guild.permissions & 0x8) === 0x8) { %>
                                <span class="sc-role role-admin">🛡️ Admin</span>
                            <% } else { %>
                                <span class="sc-role role-none">No Admin</span>
                            <% } %>
                        </div>
                    </div>
                    <div class="sc-acts">
                        <% if (guild.hasBot) { %>
                            <a href="/servers/<%= guild.id %>" class="btn-cfg"><i class="ti ti-settings" aria-hidden="true"></i> Configure</a>
                        <% } else { %>
                            <a href="/invite/<%= guild.id %>" class="btn-inv"><i class="ti ti-plus" aria-hidden="true"></i> <span>Invite Bot</span></a>
                            <span class="btn-cfg disabled">Configure
