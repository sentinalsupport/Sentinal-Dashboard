                </div>
            </div>

        </div>

        <footer class="footer">
            © 2026 Sentinal — Made with ❤️
        </footer>
    </main>

    <script>
        // ===== MODULE NAVIGATION =====
        function showModule(module) {
            // Update sidebar active state
            document.querySelectorAll('.nav-item').forEach(el => el.classList.remove('active'));
            document.querySelectorAll('.nav-item').forEach(el => {
                if (el.textContent.trim().toLowerCase().includes(module)) {
                    el.classList.add('active');
                }
            });

            // Hide all module content
            document.querySelectorAll('.module-content').forEach(el => el.classList.remove('active'));

            // Show selected module content
            const target = document.getElementById('content-' + module);
            if (target) {
                target.classList.add('active');
                target.scrollIntoView({ behavior: 'smooth', block: 'start' });
            }
        }

        function closeModule() {
            document.querySelectorAll('.module-content').forEach(el => el.classList.remove('active'));
            document.getElementById('modulesGrid').scrollIntoView({ behavior: 'smooth' });
        }

        // ===== SAVE SETTINGS =====
        function saveModuleSettings(module) {
            let data = { guildId: '<%= guild ? guild.id : "" %>' };

            if (module === 'applications') {
                data.appChannel = document.getElementById('appChannel')?.value || '';
                data.appRole = document.getElementById('appRole')?.value || '';
            } else if (module === 'tickets') {
                data.ticketCategory = document.getElementById('ticketCategory')?.value || '';
                data.ticketSupportRole = document.getElementById('ticketSupportRole')?.value || '';
            } else if (module === 'verification') {
                data.verificationChannel = document.getElementById('verificationChannel')?.value || '';
                data.verificationRole = document.getElementById('verificationRole')?.value || '';
                data.autorole = document.getElementById('autorole')?.value || '';
            }

            fetch(`/api/config/<%= guild ? guild.id : '' %>`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    alert('✅ Settings saved successfully!');
                } else {
                    alert('❌ Error: ' + data.error);
                }
            })
            .catch(error => {
                alert('❌ Error saving settings: ' + error.message);
            });
        }
    </script>

</body>
</html>
