<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title || 'Server Settings — Sentinal' %></title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@400;500;600;700;800&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --ink: #060A10;
            --panel: #0D1520;
            --panel-raised: #111D2C;
            --panel-hover: #162033;
            --line: rgba(255,255,255,0.07);
            --line-bright: rgba(255,255,255,0.13);
            --text: #E6EDF6;
            --muted: #6C7A90;
            --muted-dim: #3E4A5C;
            --signal: #3DFFB8;
            --signal-tab: rgba(61,255,184,0.08);
            --signal-glow: rgba(61,255,184,0.15);
            --gold: #F5C842;
            --gold-tab: rgba(245,200,66,0.12);
            --violet: #8B7EFF;
            --violet-tab: rgba(139,126,255,0.12);
            --red: #F87171;
            --red-bg: rgba(248,113,113,0.08);
            --red-border: rgba(248,113,113,0.22);
            --discord: #5865F2;
            --discord-hover: #4752C4;
        }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Inter', -apple-system, sans-serif;
            background: var(--ink);
            color: var(--text);
            min-height: 100vh;
        }

        /* ─── NAVBAR ─── */
        .navbar {
            background: rgba(6,10,16,0.9);
            backdrop-filter: blur(28px) saturate(160%);
            border-bottom: 1px solid var(--line);
            padding: 0 40px;
            height: 64px;
            display: flex; align-items: center; justify-content: space-between;
            position: sticky; top: 0; z-index: 200;
        }
        .brand { display: flex; align-items: center; gap: 10px; text-decoration: none; }
        .brand-logo {
            width: 36px; height: 36px; border-radius: 10px;
            background: var(--panel-raised); border: 1px solid var(--line-bright);
            display: flex; align-items: center; justify-content: center;
        }
        .brand-logo svg { width: 20px; height: 20px; }
        .brand-name {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 17px; font-weight: 700; color: #fff; letter-spacing: -0.3px;
        }
        .nav-center { display: flex; align-items: center; gap: 4px; }
        .nav-center a {
            color: var(--muted); text-decoration: none; font-size: 13.5px; font-weight: 500;
            padding: 6px 14px; border-radius: 8px; transition: all 0.18s ease;
        }
        .nav-center a:hover { color: var(--text); background: rgba(255,255,255,0.05); }
        .nav-center a.active { color: #fff; }
        .nav-right { display: flex; align-items: center; gap: 12px; }
        .user-pill {
            display: flex; align-items: center; gap: 9px;
            background: var(--panel); border: 1px solid var(--line);
            border-radius: 100px; padding: 5px 14px 5px 6px;
        }
        .user-avatar {
            width: 28px; height: 28px; border-radius: 50%;
            background: var(--panel-raised); overflow: hidden;
            display: flex; align-items: center; justify-content: center;
            font-size: 12px; font-weight: 700;
        }
        .user-avatar img { width: 100%; height: 100%; object-fit: cover; }
        .user-name { font-size: 13px; font-weight: 500; color: var(--text); }
        .user-plan {
            font-size: 10px; font-weight: 600; color: var(--signal);
            background: var(--signal-tab); border: 1px solid rgba(61,255,184,0.22);
            border-radius: 100px; padding: 2px 8px; letter-spacing: 0.3px;
        }
        .logout-btn {
            background: transparent; border: 1px solid var(--line); border-radius: 8px;
            padding: 7px 12px; color: var(--muted); cursor: pointer; font-size: 13px;
            transition: all 0.18s ease; text-decoration: none;
            display: flex; align-items: center; gap: 6px;
        }
        .logout-btn:hover { background: var(--red-bg); border-color: var(--red-border); color: var(--red); }

        /* ─── PAGE LAYOUT ─── */
        .page-wrapper { max-width: 1200px; margin: 0 auto; padding: 0 32px 60px; display: flex; gap: 24px; align-items: flex-start; }

        /* ─── LEFT SIDEBAR ─── */
        .sidebar {
            width: 240px;
            flex-shrink: 0;
            background: var(--panel);
            border: 1px solid var(--line);
            border-radius: 14px;
            padding: 16px 0;
            position: sticky;
            top: 80px;
            max-height: calc(100vh - 100px);
            overflow-y: auto;
        }
        .sidebar::-webkit-scrollbar { width: 3px; }
        .sidebar::-webkit-scrollbar-track { background: transparent; }
        .sidebar::-webkit-scrollbar-thumb { background: var(--muted-dim); border-radius: 10px; }

        .sidebar .server-info {
            padding: 0 16px 14px;
            border-bottom: 1px solid var(--line);
            margin-bottom: 12px;
        }
        .sidebar .server-info .icon {
            width: 44px; height: 44px; border-radius: 12px;
            background: var(--panel-raised); border: 1px solid var(--line);
            display: flex; align-items: center; justify-content: center;
            font-size: 18px; font-weight: 700; overflow: hidden;
            color: var(--signal); margin-bottom: 8px;
        }
        .sidebar .server-info .icon img { width: 100%; height: 100%; object-fit: cover; }
        .sidebar .server-info .name {
            font-weight: 600; font-size: 14px; color: #fff;
        }
        .sidebar .server-info .plan {
            font-size: 11px; color: var(--signal);
            font-weight: 500;
        }
        .sidebar .server-info .upgrade {
            display: block; margin-top: 8px;
            padding: 4px 12px; border-radius: 6px;
            background: var(--gold-tab); color: var(--gold);
            font-size: 11px; font-weight: 600; text-decoration: none;
            text-align: center; border: 1px solid rgba(245,200,66,0.2);
            transition: all 0.18s ease;
        }
        .sidebar .server-info .upgrade:hover { background: rgba(245,200,66,0.18); }

        .sidebar .nav-section { padding: 0 12px; }
        .sidebar .section-title {
            font-size: 10px; font-weight: 700; text-transform: uppercase;
            letter-spacing: 0.8px; color: var(--muted-dim);
            padding: 6px 12px 4px;
        }
        .sidebar .nav-item {
            display: flex; align-items: center; gap: 10px;
            padding: 7px 12px; border-radius: 8px;
            color: var(--muted); text-decoration: none;
            font-size: 13px; font-weight: 500;
            transition: all 0.18s ease; cursor: pointer; border: none;
            background: none; width: 100%; text-align: left;
        }
        .sidebar .nav-item:hover { background: rgba(255,255,255,0.04); color: var(--text); }
        .sidebar .nav-item.active { background: var(--signal-tab); color: var(--signal); }
        .sidebar .nav-item i { width: 18px; font-size: 14px; color: var(--muted-dim); }
        .sidebar .nav-item.active i { color: var(--signal); }
        .sidebar .nav-item .badge {
            margin-left: auto; font-size: 9px; font-weight: 700;
            padding: 1px 8px; border-radius: 100px; text-transform: uppercase;
        }
        .sidebar .nav-item .badge.live { background: var(--signal-tab); color: var(--signal); }
        .sidebar .nav-item .badge.coming { background: var(--gold-tab); color: var(--gold); }
        .sidebar .nav-item .badge.new { background: var(--violet-tab); color: var(--violet); }

        .sidebar .divider { height: 1px; background: var(--line); margin: 8px 16px; }

        /* ─── RIGHT CONTENT ─── */
        .content {
            flex: 1;
            min-width: 0;
        }

        /* ─── SERVER HEADER (inside content) ─── */
        .server-header {
            display: flex; align-items: center; gap: 16px;
            padding: 20px 0 16px;
            border-bottom: 1px solid var(--line);
            margin-bottom: 24px;
        }
        .server-header .icon {
            width: 48px; height: 48px; border-radius: 12px;
            background: var(--panel-raised); border: 1px solid var(--line);
            display: flex; align-items: center; justify-content: center;
            font-size: 20px; font-weight: 700; overflow: hidden;
            flex-shrink: 0; color: var(--signal);
        }
        .server-header .icon img { width: 100%; height: 100%; object-fit: cover; }
        .server-header .info h1 {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 20px; font-weight: 700; color: #fff;
        }
        .server-header .info p {
            font-size: 13px; color: var(--muted);
        }
        .server-header .info p i { color: var(--signal); margin-right: 4px; }

        /* ─── MODULE PANELS ─── */
        .module-panel {
            display: none;
            animation: fadeIn 0.25s ease;
        }
        .module-panel.active {
            display: block;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(6px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .panel-header {
            display: flex; justify-content: space-between; align-items: center;
            margin-bottom: 16px; flex-wrap: wrap; gap: 12px;
        }
        .panel-header h2 {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 20px; font-weight: 700; color: #fff;
        }
        .panel-header h2 i { color: var(--signal); margin-right: 10px; }
        .panel-header .panel-actions { display: flex; gap: 8px; flex-wrap: wrap; }
        .panel-header .panel-actions .btn-sm {
            padding: 6px 16px; border-radius: 8px;
            font-size: 12px; font-weight: 600; cursor: pointer;
            border: 1px solid var(--line); background: transparent;
            color: var(--muted); transition: all 0.18s ease;
            text-decoration: none; display: inline-flex; align-items: center; gap: 6px;
        }
        .panel-header .panel-actions .btn-sm:hover {
            background: rgba(255,255,255,0.04); color: var(--text);
        }
        .panel-header .panel-actions .btn-sm.primary {
            background: var(--signal-tab); border-color: rgba(61,255,184,0.3);
            color: var(--signal);
        }
        .panel-header .panel-actions .btn-sm.primary:hover {
            background: rgba(61,255,184,0.18);
        }

        .panel-desc {
            font-size: 13px; color: var(--muted);
            margin-bottom: 20px;
        }

        .settings-group {
            background: var(--panel);
            border: 1px solid var(--line);
            border-radius: 12px;
            padding: 20px 24px;
            margin-bottom: 14px;
        }
        .settings-group .group-header {
            display: flex; justify-content: space-between; align-items: center;
            margin-bottom: 6px; flex-wrap: wrap; gap: 8px;
        }
        .settings-group .group-header h4 {
            font-size: 14px; font-weight: 600; color: #fff;
        }
        .settings-group .group-header .status-tag {
            font-size: 9px; font-weight: 700; text-transform: uppercase;
            padding: 2px 10px; border-radius: 100px;
            background: var(--signal-tab); color: var(--signal);
            border: 1px solid rgba(61,255,184,0.2);
        }
        .settings-group .group-desc {
            font-size: 12.5px; color: var(--muted);
            margin-bottom: 14px;
        }
        .form-group { margin-bottom: 14px; }
        .form-group:last-child { margin-bottom: 0; }
        .form-group label {
            display: block; font-size: 12px; font-weight: 600;
            margin-bottom: 4px; color: var(--text);
        }
        .form-group .form-hint {
            font-size: 11px; color: var(--muted-dim); margin-top: 2px;
        }
        .form-group input, .form-group select {
            width: 100%; padding: 9px 14px;
            border-radius: 8px; border: 1px solid var(--line);
            background: rgba(0,0,0,0.3); color: var(--text);
            font-size: 13px; font-family: 'Inter', sans-serif;
            transition: all 0.18s ease; outline: none;
        }
        .form-group input:focus, .form-group select:focus {
            border-color: var(--signal);
            box-shadow: 0 0 0 3px var(--signal-glow);
        }
        .form-group select option { background: var(--ink); }
        .form-actions {
            display: flex; gap: 10px; flex-wrap: wrap; margin-top: 14px;
        }
        .btn-save {
            padding: 8px 28px; border-radius: 8px; border: none;
            font-weight: 600; font-size: 13px; cursor: pointer;
            background: var(--signal); color: #04140F;
            transition: all 0.18s ease;
        }
        .btn-save:hover { transform: translateY(-1px); box-shadow: 0 4px 18px var(--signal-glow); }
        .btn-reset {
            padding: 8px 28px; border-radius: 8px;
            border: 1px solid var(--line); background: transparent;
            color: var(--muted); font-weight: 600; font-size: 13px; cursor: pointer;
            transition: all 0.18s ease;
        }
        .btn-reset:hover { background: rgba(255,255,255,0.04); color: var(--text); }

        .coming-soon {
            text-align: center; padding: 60px 20px;
            color: var(--muted);
        }
        .coming-soon i {
            font-size: 40px; color: var(--gold); margin-bottom: 16px; display: block;
        }
        .coming-soon h3 {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 18px; color: #fff; margin-bottom: 6px;
        }
        .coming-soon p { font-size: 13px; }

        .success-message {
            background: var(--signal-tab); border: 1px solid rgba(61,255,184,0.2);
            border-radius: 8px; padding: 10px 16px; color: var(--signal);
            font-size: 13px; margin-bottom: 16px;
        }
        .error-message {
            background: var(--red-bg); border: 1px solid var(--red-border);
            border-radius: 8px; padding: 10px 16px; color: var(--red);
            font-size: 13px; margin-bottom: 16px;
        }

        .footer {
            border-top: 1px solid var(--line); margin-top: 60px;
            padding: 24px 40px; text-align: center;
            color: var(--muted-dim); font-size: 12px;
            font-family: 'IBM Plex Mono', monospace; letter-spacing: 0.5px;
        }

        @media (max-width: 1024px) {
            .page-wrapper { padding: 0 24px 60px; gap: 20px; }
            .sidebar { width: 200px; }
        }
        @media (max-width: 768px) {
            .navbar { padding: 0 16px; }
            .nav-center { display: none; }
            .page-wrapper { padding: 0 16px 48px; flex-direction: column; }
            .sidebar {
                width: 100%; position: relative; top: 0;
                display: flex; flex-wrap: wrap; gap: 4px; padding: 12px;
                border-radius: 12px; max-height: none;
            }
            .sidebar .server-info { display: none; }
            .sidebar .nav-section { display: flex; flex-wrap: wrap; gap: 4px; }
            .sidebar .section-title { display: none; }
            .sidebar .nav-item { padding: 6px 12px; font-size: 12px; width: auto; }
            .sidebar .divider { display: none; }
            .server-header { flex-wrap: wrap; }
            .settings-group { padding: 16px; }
            .form-actions { flex-direction: column; }
            .form-actions button { width: 100%; justify-content: center; }
        }
    </style>
</head>
<body>

    <!-- ─── NAVBAR ─── -->
    <nav class="navbar">
        <a href="/dashboard" class="brand">
            <div class="brand-logo">
                <svg viewBox="0 0 245 240" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M104.4 103.9c-5.7 0-10.2 5-10.2 11.1s4.6 11.1 10.2 11.1c5.7 0 10.2-5 10.2-11.1.1-6.1-4.5-11.1-10.2-11.1zM140.9 103.9c-5.7 0-10.2 5-10.2 11.1s4.6 11.1 10.2 11.1c5.7 0 10.2-5 10.2-11.1s-4.5-11.1-10.2-11.1z" fill="#3DFFB8"/>
                    <path d="M189.5 20H55.5C44.7 20 36 28.7 36 39.5v140.9c0 10.8 8.7 19.5 19.5 19.5h113.5l-5.3-18.5 12.8 11.9 12.1 11.2L209 220V39.5C209 28.7 200.3 20 189.5 20zM155.7 152.1s-3.6-4.3-6.6-8.1c13.1-3.7 18.1-11.9 18.1-11.9-4.1 2.7-8 4.6-11.5 5.9-5 2.1-9.8 3.5-14.5 4.3-9.6 1.8-18.4 1.3-25.9-.1-5.7-1.1-10.6-2.6-14.7-4.3-2.3-.9-4.8-2-7.3-3.4-.3-.2-.6-.3-.9-.5-.2-.1-.3-.2-.4-.3-2-1.1-3.1-1.9-3.1-1.9 4.7 4.3 9.3 6.5 21.7 10.2-2.9 3.8-6.6 8.1-6.6 8.1-22 0-32.1-15.2-32.1-15.2 0-32.2 14.4-58.4 14.4-58.4 14.4-10.8 28.1-10.5 28.1-10.5l1 1.2C99.2 87.7 87.9 97.4 87.9 97.4s2.9-1.6 7.8-3.8c14.1-6.2 25.3-7.9 29.9-8.3.8-.1 1.5-.2 2.3-.2 8.2-1 17.5-1.3 27.2.2 12.9 2 26.7 7.5 40.8 17.3 0 0-10.8-10.2-28.5-13.7l1.4-1.6s13.7-.3 28.1 10.5c0 0 14.4 26.2 14.4 58.4 0 0-10.2 15.2-32.1 15.2z" fill="#3DFFB8"/>
                </svg>
            </div>
            <span class="brand-name">Sentinal</span>
        </a>
        <div class="nav-center">
            <a href="/dashboard">Home</a>
            <a href="/servers" class="active">Servers</a>
            <a href="#" onclick="window.open('https://discord.gg/UmqmewYWRd','_blank'); return false;">Support</a>
            <a href="#">Premium</a>
        </div>
        <div class="nav-right">
            <div class="user-pill">
                <div class="user-avatar">
                    <% if (locals.user && user.avatar) { %>
                        <img src="https://cdn.discordapp.com/avatars/<%= user.id %>/<%= user.avatar %>.png" alt="Avatar">
                    <% } else { %>
                        <%= locals.user ? (user.username ? user.username.charAt(0).toUpperCase() : 'U') : 'U' %>
                    <% } %>
                </div>
                <span class="user-name"><%= locals.user ? (user.global_name || user.username) : 'User' %></span>
                <span class="user-plan">Free</span>
            </div>
            <a href="/logout" class="logout-btn"><i class="fas fa-sign-out-alt"></i></a>
        </div>
    </nav>

    <!-- ─── PAGE ─── -->
    <div class="page-wrapper">

        <!-- ─── LEFT SIDEBAR ─── -->
        <aside class="sidebar">

            <!-- Server Info -->
            <div class="server-info">
                <div class="icon">
                    <% if (locals.guild && guild.icon) { %>
                        <img src="https://cdn.discordapp.com/icons/<%= guild.id %>/<%= guild.icon %>.png" alt="<%= guild.name %>">
                    <% } else { %>
                        <%= locals.guild ? (guild.name ? guild.name.charAt(0).toUpperCase() : '?') : '?' %>
                    <% } %>
                </div>
                <div class="name"><%= locals.guild ? guild.name : 'Server' %></div>
                <div class="plan">Free</div>
                <a href="#" class="upgrade" onclick="alert('Upgrade to Premium!')">Upgrade to Premium</a>
            </div>

            <!-- Modules -->
            <div class="nav-section">
                <div class="section-title">Modules</div>

                <button class="nav-item active" onclick="showModule('overview')">
                    <i class="fas fa-th-large"></i> Overview
                    <span class="badge live">Live</span>
                </button>

                <button class="nav-item" onclick="showModule('applications')">
                    <i class="fas fa-file-alt"></i> Applications
                    <span class="badge live">Live</span>
                </button>

                <button class="nav-item" onclick="showModule('tickets')">
                    <i class="fas fa-ticket"></i> Tickets
                    <span class="badge live">Live</span>
                </button>

                <button class="nav-item" onclick="showModule('security')">
                    <i class="fas fa-shield-halved"></i> Security
                    <span class="badge live">Live</span>
                </button>

                <button class="nav-item" onclick="showModule('automation')">
                    <i class="fas fa-robot"></i> Automation
                    <span class="badge coming">Soon</span>
                </button>

                <button class="nav-item" onclick="showModule('community')">
                    <i class="fas fa-users"></i> Community
                    <span class="badge coming">Soon</span>
                </button>

                <button class="nav-item" onclick="showModule('audit')">
                    <i class="fas fa-clipboard-list"></i> Audit & Logs
                    <span class="badge coming">Soon</span>
                </button>
            </div>

            <div class="divider"></div>

            <div class="nav-section">
                <div class="section-title">Search</div>
                <div style="padding: 0 12px;">
                    <input type="text" placeholder="Search for a feature..." style="width:100%; padding:8px 12px; border-radius:8px; border:1px solid var(--line); background:rgba(0,0,0,0.3); color:var(--text); font-size:12px; font-family:'Inter',sans-serif; outline:none;">
                </div>
            </div>

        </aside>

        <!-- ─── RIGHT CONTENT ─── -->
        <div class="content">

            <!-- ─── SERVER HEADER ─── -->
            <div class="server-header">
                <div class="icon">
                    <% if (locals.guild && guild.icon) { %>
                        <img src="https://cdn.discordapp.com/icons/<%= guild.id %>/<%= guild.icon %>.png" alt="<%= guild.name %>">
                    <% } else { %>
                        <%= locals.guild ? (guild.name ? guild.name.charAt(0).toUpperCase() : '?') : '?' %>
                    <% } %>
                </div>
                <div class="info">
                    <h1><%= locals.guild ? guild.name : 'Server' %></h1>
                    <p><i class="fas fa-users"></i> <%= locals.guild ? (guild.memberCount || 'N/A') : 'N/A' %> members</p>
                </div>
            </div>

            <!-- ─── SUCCESS / ERROR ─── -->
            <% if (locals.success) { %>
                <div class="success-message"><i class="fas fa-check-circle"></i> Settings saved successfully!</div>
            <% } %>
            <% if (locals.error) { %>
                <div class="error-message"><i class="fas fa-exclamation-circle"></i> <%= error %></div>
            <% } %>

            <!-- ─── MODULE PANELS ─── -->

            <!-- ─── OVERVIEW ─── -->
            <div class="module-panel active" id="module-overview">
                <div class="panel-header">
                    <h2><i class="fas fa-th-large"></i> Overview</h2>
                    <div class="panel-actions">
                        <a href="#" class="btn-sm primary" onclick="saveSettings()">Save All</a>
                    </div>
                </div>
                <p class="panel-desc">Configure basic server settings for Sentinal</p>

                <div class="settings-group">
                    <div class="group-header">
                        <h4>Command Prefix</h4>
                        <span class="status-tag">Live</span>
                    </div>
                    <div class="form-group">
                        <input type="text" id="prefix" value="<%= locals.config ? (config.prefix || '!') : '!' %>" placeholder="!">
                        <div class="form-hint">Example: !, ?, $, etc.</div>
                    </div>
                </div>

                <div class="settings-group">
                    <div class="group-header">
                        <h4>Language</h4>
