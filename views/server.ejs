<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title || 'Server Settings — Sentinal' %></title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Inter', -apple-system, sans-serif;
            background: #080E1A;
            color: #E8EDF5;
            min-height: 100vh;
        }
        .navbar {
            background: rgba(8, 14, 26, 0.92);
            backdrop-filter: blur(16px);
            border-bottom: 1px solid rgba(255, 255, 255, 0.04);
            padding: 0 32px;
            height: 64px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: sticky;
            top: 0;
            z-index: 100;
        }
        .navbar .brand {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 18px;
            font-weight: 700;
            color: #FFFFFF;
            text-decoration: none;
        }
        .navbar .brand .logo-icon {
            width: 32px;
            height: 32px;
            background: linear-gradient(135deg, #2563EB, #1D4ED8);
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 15px;
        }
        .navbar .brand span { color: #60A5FA; }
        .navbar .nav-links {
            display: flex;
            align-items: center;
            gap: 28px;
        }
        .navbar .nav-links a {
            color: #8B9BB5;
            text-decoration: none;
            font-size: 13px;
            font-weight: 500;
            transition: color 0.2s ease;
        }
        .navbar .nav-links a:hover { color: #E8EDF5; }
        .navbar .nav-links a.active {
            color: #FFFFFF;
            position: relative;
        }
        .navbar .nav-links a.active::after {
            content: '';
            position: absolute;
            bottom: -20px;
            left: 0;
            right: 0;
            height: 2px;
            background: #2563EB;
            border-radius: 2px;
        }
        .navbar .nav-right {
            display: flex;
            align-items: center;
            gap: 16px;
        }
        .navbar .user-avatar {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            background: linear-gradient(135deg, #2563EB, #1D4ED8);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 14px;
            font-weight: 600;
            color: #FFFFFF;
            overflow: hidden;
        }
        .navbar .user-avatar img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }
        .navbar .logout-btn {
            background: rgba(255, 255, 255, 0.06);
            color: #8B9BB5;
            padding: 6px 16px;
            border-radius: 100px;
            text-decoration: none;
            font-size: 12px;
            font-weight: 500;
            border: 1px solid rgba(255, 255, 255, 0.06);
            transition: all 0.2s ease;
            display: flex;
            align-items: center;
            gap: 6px;
        }
        .navbar .logout-btn:hover {
            background: rgba(239, 68, 68, 0.1);
            color: #EF4444;
            border-color: rgba(239, 68, 68, 0.2);
        }
        .container {
            max-width: 1100px;
            margin: 0 auto;
            padding: 32px;
        }
        .server-header {
            display: flex;
            align-items: center;
            gap: 20px;
            margin-bottom: 24px;
            flex-wrap: wrap;
        }
        .server-header .icon {
            width: 64px;
            height: 64px;
            border-radius: 16px;
            background: linear-gradient(135deg, #1E3A5F, #1A365D);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 28px;
            font-weight: 700;
            color: #60A5FA;
            overflow: hidden;
            flex-shrink: 0;
        }
        .server-header .icon img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }
        .server-header .info h1 {
            font-size: 26px;
            font-weight: 800;
        }
        .server-header .info p {
            color: #8B9BB5;
            font-size: 14px;
        }
        .server-header .back-btn {
            margin-left: auto;
            background: rgba(255, 255, 255, 0.04);
            color: #8B9BB5;
            padding: 8px 18px;
            border-radius: 8px;
            text-decoration: none;
            font-size: 13px;
            font-weight: 500;
            border: 1px solid rgba(255, 255, 255, 0.06);
            transition: all 0.2s ease;
        }
        .server-header .back-btn:hover {
            background: rgba(255, 255, 255, 0.08);
            color: #E8EDF5;
        }
        .settings-group {
            background: rgba(255, 255, 255, 0.02);
            border: 1px solid rgba(255, 255, 255, 0.04);
            border-radius: 14px;
            padding: 24px;
            margin-bottom: 16px;
        }
        .settings-group .group-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 8px;
            flex-wrap: wrap;
            gap: 8px;
        }
        .settings-group .group-header h4 {
            font-size: 15px;
            font-weight: 600;
            color: #FFFFFF;
        }
        .settings-group .group-desc {
            color: #8B9BB5;
            font-size: 13px;
            margin-bottom: 12px;
        }
        .form-group {
            margin-bottom: 14px;
        }
        .form-group label {
            display: block;
            color: #E8EDF5;
            font-size: 13px;
            font-weight: 500;
            margin-bottom: 4px;
        }
        .form-group .form-hint {
            color: #5A6B85;
            font-size: 12px;
            margin-top: 2px;
        }
        .form-group input,
        .form-group select {
            width: 100%;
            padding: 10px 14px;
            border-radius: 8px;
            border: 1px solid rgba(255, 255, 255, 0.06);
            background: rgba(0, 0, 0, 0.3);
            color: #E8EDF5;
            font-size: 13px;
            font-family: 'Inter', sans-serif;
            transition: all 0.2s ease;
            outline: none;
        }
        .form-group input:focus,
        .form-group select:focus {
            border-color: #2563EB;
            box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1);
        }
        .form-group input::placeholder {
            color: #475569;
        }
        .form-group select option {
            background: #0A1628;
        }
        .toggle-wrapper {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 8px 0;
        }
        .toggle {
            width: 44px;
            height: 24px;
            background: rgba(255, 255, 255, 0.06);
            border-radius: 12px;
            cursor: pointer;
            transition: all 0.3s ease;
            position: relative;
            flex-shrink: 0;
        }
        .toggle.active {
            background: #2563EB;
        }
        .toggle .toggle-slider {
            width: 18px;
            height: 18px;
            background: #FFFFFF;
            border-radius: 50%;
            position: absolute;
            top: 3px;
            left: 3px;
            transition: all 0.3s ease;
        }
        .toggle.active .toggle-slider {
            left: 23px;
        }
        .toggle-label {
            color: #E8EDF5;
            font-size: 13px;
            font-weight: 500;
        }
        .toggle-desc {
            color: #5A6B85;
            font-size: 12px;
        }
        .form-actions {
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
            margin-top: 16px;
        }
        .btn-save {
            padding: 10px 32px;
            border-radius: 8px;
            border: none;
            font-weight: 600;
            font-size: 14px;
            cursor: pointer;
            transition: all 0.2s ease;
            background: linear-gradient(135deg, #2563EB, #1D4ED8);
            color: #FFFFFF;
        }
        .btn-save:hover {
            transform: translateY(-1px);
            box-shadow: 0 8px 24px rgba(37, 99, 235, 0.25);
        }
        .btn-save:disabled {
            opacity: 0.5;
            cursor: not-allowed;
            transform: none;
        }
        .btn-reset {
            padding: 10px 32px;
            border-radius: 8px;
            border: 1px solid rgba(255, 255, 255, 0.06);
            font-weight: 600;
            font-size: 14px;
            cursor: pointer;
            transition: all 0.2s ease;
            background: transparent;
            color: #8B9BB5;
        }
        .btn-reset:hover {
            background: rgba(255, 255, 255, 0.04);
            color: #E8EDF5;
        }
        .footer {
            border-top: 1px solid rgba(255, 255, 255, 0.04);
            padding: 24px 32px;
            text-align: center;
            color: #5A6B85;
            font-size: 13px;
            margin-top: 20px;
        }
        .success-message {
            background: rgba(34, 197, 94, 0.1);
            border: 1px solid rgba(34, 197, 94, 0.2);
            border-radius: 8px;
            padding: 12px 16px;
            color: #4ADE80;
            font-size: 14px;
            margin-bottom: 20px;
        }
        @media (max-width: 768px) {
            .navbar { padding: 0 16px; height: 58px; flex-wrap: wrap; gap: 8px; }
            .navbar .nav-links { gap: 16px; }
            .navbar .nav-links a { font-size: 12px; }
            .container { padding: 16px; }
            .server-header { flex-wrap: wrap; }
            .server-header .back-btn { margin-left: 0; }
            .settings-group { padding: 16px; }
            .form-actions { flex-direction: column; }
            .form-actions button { width: 100%; justify-content: center; }
        }
    </style>
</head>
<body>
    <nav class="navbar">
        <a href="/dashboard" class="brand">
            <div class="logo-icon">⚡</div>
            Sentinal <span>Dashboard</span>
        </a>
        <div class="nav-links">
            <a href="/dashboard">Home</a>
            <a href="/servers" class="active">Servers</a>
            <a href="#" onclick="window.open('https://discord.gg/UmqmewYWRd', '_blank')">Support</a>
        </div>
        <div class="nav-right">
            <div class="user-avatar">
                <% if (user && user.avatar) { %>
                    <img src="https://cdn.discordapp.com/avatars/<%= user.id %>/<%= user.avatar %>.png" alt="Avatar">
                <% } else { %>
                    <%= user ? user.username ? user.username.charAt(0).toUpperCase() : 'U' : 'U' %>
                <% } %>
            </div>
            <a href="/logout" class="logout-btn"><i class="fas fa-sign-out-alt"></i> Logout</a>
        </div>
    </nav>

    <div class="container">
        <% if (locals.success) { %>
            <div class="success-message">
                <i class="fas fa-check-circle"></i> Settings saved successfully!
            </div>
        <% } %>

        <div class="server-header">
            <div class="icon">
                <% if (guild && guild.icon) { %>
                    <img src="https://cdn.discordapp.com/icons/<%= guild.id %>/<%= guild.icon %>.png" alt="<%= guild.name %>">
                <% } else { %>
                    <%= guild ? guild.name ? guild.name.charAt(0).toUpperCase() : '?' : '?' %>
                <% } %>
            </div>
            <div class="info">
                <h1><%= guild ? guild.name : 'Server' %></h1>
                <p><i class="fas fa-users"></i> <%= guild ? guild.memberCount || 'N/A' : 'N/A' %> members</p>
            </div>
            <a href="/servers" class="back-btn"><i class="fas fa-arrow-left"></i> Back</a>
        </div>

        <div class="settings-group">
            <div class="group-header">
                <h4>General Settings</h4>
            </div>
            <p class="group-desc">Configure basic server settings for Sentinal</p>
            <div class="form-group">
                <label for="prefix">Command Prefix</label>
                <input type="text" id="prefix" value="<%= config ? config.prefix || '!' : '!' %>" placeholder="!">
                <div class="form-hint">Example: !, ?, $, etc.</div>
            </div>
            <div class="form-group">
                <label for="language">Language</label>
                <select id="language">
                    <option value="en" <%= config && config.language === 'en' ? 'selected' : '' %>>English</option>
                    <option value="es" <%= config && config.language === 'es' ? 'selected' : '' %>>Español</option>
                    <option value="fr" <%= config && config.language === 'fr' ? 'selected' : '' %>>Français</option>
                    <option value="de" <%= config && config.language === 'de' ? 'selected' : '' %>>Deutsch</option>
                    <option value="pt" <%= config && config.language === 'pt' ? 'selected' : '' %>>Português</option>
                </select>
            </div>
            <div class="form-actions">
                <button class="btn-save" onclick="saveSettings()"><i class="fas fa-save"></i> Save Changes</button>
                <button class="btn-reset" onclick="resetSettings()"><i class="fas fa-undo"></i> Reset</button>
            </div>
        </div>
    </div>

    <footer class="footer">
        © 2026 Sentinal — Made with ❤️
    </footer>

    <script>
        function saveSettings() {
            const prefix = document.getElementById('prefix').value;
            const language = document.getElementById('language').value;

            const data = { prefix, language };

            fetch(`/api/config/<%= guild ? guild.id : '' %>`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    alert('✅ Settings saved successfully!');
                    location.reload();
                } else {
                    alert('❌ Error: ' + data.error);
                }
            })
            .catch(error => {
                alert('❌ Error saving settings: ' + error.message);
            });
        }

        function resetSettings() {
            if (confirm('Are you sure you want to reset all settings to default?')) {
                location.reload();
            }
        }
    </script>
</body>
</html>
