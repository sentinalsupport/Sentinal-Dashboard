<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= guild.name %> — BotCommand</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --purple: #7C3AED; --purple-light: #9D5CF5; --purple-dark: #5B21B6;
      --green: #10B981; --green-light: #34D399;
      --bg: #0D0D14; --surface: rgba(255,255,255,0.04); --border: rgba(255,255,255,0.08);
      --text: #F1F0FF; --muted: #8B8FAE; --red: #EF4444;
    }

    html, body { min-height: 100%; font-family: 'Inter', sans-serif; background: var(--bg); color: var(--text); }

    .bg-scene { position: fixed; inset: 0; z-index: 0; pointer-events: none; overflow: hidden; }
    .blob { position: absolute; border-radius: 50%; filter: blur(130px); opacity: 0.15; }
    .blob-1 { width: 600px; height: 600px; background: var(--purple); top: -200px; left: -150px; }
    .blob-2 { width: 400px; height: 400px; background: var(--green); bottom: -100px; right: -100px; }

    /* Nav */
    nav {
      position: sticky; top: 0; z-index: 100;
      display: flex; align-items: center; justify-content: space-between;
      padding: 0 40px; height: 64px;
      background: rgba(13,13,20,0.9); backdrop-filter: blur(20px);
      border-bottom: 1px solid var(--border);
    }
    .nav-logo { display: flex; align-items: center; gap: 10px; font-weight: 800; font-size: 17px; letter-spacing: -0.02em; }
    .nav-logo-icon { width: 32px; height: 32px; border-radius: 8px; background: linear-gradient(135deg, var(--purple), var(--purple-dark)); display: flex; align-items: center; justify-content: center; }
    .nav-logo-icon svg { width: 18px; height: 18px; fill: #fff; }
    .nav-right { display: flex; align-items: center; gap: 12px; }
    .btn-back {
      display: flex; align-items: center; gap: 6px;
      padding: 7px 14px; border-radius: 8px; border: 1px solid var(--border);
      background: transparent; color: var(--muted); font-size: 13px; font-weight: 500;
      cursor: pointer; text-decoration: none; transition: all 0.15s;
    }
    .btn-back:hover { color: var(--text); border-color: rgba(255,255,255,0.2); }
    .btn-back svg { width: 14px; height: 14px; fill: currentColor; }

    /* Layout */
    main { position: relative; z-index: 1; max-width: 860px; margin: 0 auto; padding: 40px 24px 80px; }

    /* Server header */
    .server-header {
      display: flex; align-items: center; gap: 20px; margin-bottom: 32px;
      padding: 28px 28px;
      background: var(--surface); backdrop-filter: blur(16px);
      border: 1px solid var(--border); border-radius: 20px;
    }
    .server-header-icon {
      width: 72px; height: 72px; border-radius: 20px; flex-shrink: 0;
      background: linear-gradient(135deg, var(--purple-dark), var(--purple));
      display: flex; align-items: center; justify-content: center;
      font-size: 28px; font-weight: 800; overflow: hidden;
    }
    .server-header-icon img { width: 100%; height: 100%; object-fit: cover; }
    .server-header-info h1 { font-size: 24px; font-weight: 800; letter-spacing: -0.02em; margin-bottom: 6px; }

    /* Stats bar */
    .stats-bar {
      display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 32px;
    }
    .stat-pill {
      display: flex; align-items: center; gap: 8px;
      background: var(--surface); border: 1px solid var(--border);
      border-radius: 10px; padding: 10px 16px;
      font-size: 13px; color: var(--muted);
    }
    .stat-pill strong { color: var(--text); font-weight: 600; }
    .stat-pill .dot { width: 7px; height: 7px; border-radius: 50%; }
    .dot-green { background: var(--green); box-shadow: 0 0 6px var(--green); }
    .dot-purple { background: var(--purple); box-shadow: 0 0 6px var(--purple); }
    .dot-muted { background: var(--muted); }

    /* Sections */
    .section {
      background: rgba(255,255,255,0.035); backdrop-filter: blur(12px);
      border: 1px solid var(--border); border-radius: 18px;
      margin-bottom: 20px; overflow: hidden;
    }
    .section-header {
      display: flex; align-items: center; gap: 12px;
      padding: 20px 24px; border-bottom: 1px solid var(--border);
    }
    .section-icon {
      width: 36px; height: 36px; border-radius: 10px;
      display: flex; align-items: center; justify-content: center; font-size: 17px;
    }
    .icon-purple { background: rgba(124,58,237,0.2); }
    .icon-green { background: rgba(16,185,129,0.15); }
    .icon-blue { background: rgba(59,130,246,0.15); }
    .icon-red { background: rgba(239,68,68,0.15); }
    .section-title { font-size: 15px; font-weight: 700; }
    .section-subtitle { font-size: 12px; color: var(--muted); margin-top: 1px; }
    .section-body { padding: 24px; display: flex; flex-direction: column; gap: 20px; }

    /* Form fields */
    .field { display: flex; flex-direction: column; gap: 7px; }
    .field label { font-size: 13px; font-weight: 600; color: var(--text); }
    .field .hint { font-size: 11px; color: var(--muted); }
    .field input[type="text"],
    .field select,
    .field textarea {
      background: rgba(255,255,255,0.05); border: 1px solid var(--border);
      border-radius: 10px; padding: 11px 14px;
      color: var(--text); font-family: 'Inter', sans-serif; font-size: 13px;
      outline: none; transition: border-color 0.15s;
      appearance: none; -webkit-appearance: none;
    }
    .field input[type="text"]:focus,
    .field select:focus,
    .field textarea:focus { border-color: var(--purple); box-shadow: 0 0 0 3px rgba(124,58,237,0.15); }
    .field textarea { resize: vertical; min-height: 80px; }
    .field select option { background: #1a1a2e; }

    /* Toggle */
    .toggle-row {
      display: flex; align-items: flex-start; justify-content: space-between; gap: 16px;
    }
    .toggle-info { flex: 1; }
    .toggle-info .toggle-label { font-size: 13px; font-weight: 600; margin-bottom: 2px; }
    .toggle-info .toggle-desc { font-size: 12px; color: var(--muted); line-height: 1.5; }
    .toggle-switch { position: relative; width: 44px; height: 24px; flex-shrink: 0; cursor: pointer; }
    .toggle-switch input { opacity: 0; width: 0; height: 0; position: absolute; }
    .toggle-slider {
      position: absolute; inset: 0; border-radius: 99px;
      background: rgba(255,255,255,0.1); transition: background 0.2s;
      border: 1px solid var(--border);
    }
    .toggle-slider::after {
      content: ''; position: absolute;
      width: 18px; height: 18px; border-radius: 50%;
      background: var(--muted); top: 2px; left: 2px;
      transition: all 0.2s;
    }
    .toggle-switch input:checked + .toggle-slider { background: rgba(16,185,129,0.35); border-color: rgba(16,185,129,0.5); }
    .toggle-switch input:checked + .toggle-slider::after { background: var(--green); left: 22px; box-shadow: 0 0 8px rgba(16,185,129,0.5); }

    /* Row layout for fields */
    .fields-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }

    /* Mod level */
    .mod-levels { display: flex; gap: 8px; flex-wrap: wrap; }
    .mod-level {
      flex: 1; min-width: 70px;
      padding: 10px 8px; border-radius: 10px;
      border: 1px solid var(--border); background: var(--surface);
      text-align: center; font-size: 12px; font-weight: 600; cursor: pointer;
      transition: all 0.15s; user-select: none;
    }
    .mod-level input { display: none; }
    .mod-level.selected-off { border-color: rgba(255,255,255,0.2); background: rgba(255,255,255,0.08); color: var(--text); }
    .mod-level.selected-low { border-color: rgba(245,158,11,0.5); background: rgba(245,158,11,0.1); color: #FCD34D; }
    .mod-level.selected-medium { border-color: rgba(249,115,22,0.5); background: rgba(249,115,22,0.1); color: #FB923C; }
    .mod-level.selected-high { border-color: rgba(239,68,68,0.5); background: rgba(239,68,68,0.15); color: #F87171; }

    /* Save bar */
    .save-bar {
      position: fixed; bottom: 0; left: 0; right: 0; z-index: 200;
      padding: 16px 24px;
      background: rgba(13,13,20,0.95); backdrop-filter: blur(20px);
      border-top: 1px solid var(--border);
      display: flex; align-items: center; justify-content: space-between; gap: 16px;
    }
    .save-bar-info { font-size: 13px; color: var(--muted); }
    .save-bar-info strong { color: var(--text); }
    .btn-save {
      padding: 12px 32px; border-radius: 10px; border: none;
      background: linear-gradient(135deg, var(--purple), var(--purple-dark));
      color: #fff; font-family: 'Inter', sans-serif; font-size: 14px; font-weight: 700;
      cursor: pointer; transition: all 0.15s;
      box-shadow: 0 4px 20px rgba(124,58,237,0.4);
    }
    .btn-save:hover { transform: translateY(-1px); box-shadow: 0 6px 28px rgba(124,58,237,0.55); }
    .btn-save:disabled { opacity: 0.6; cursor: not-allowed; transform: none; }

    /* Toast */
    #toast {
      position: fixed; top: 80px; right: 24px; z-index: 9999;
      padding: 14px 20px; border-radius: 12px;
      font-size: 14px; font-weight: 600; letter-spacing: 0.01em;
      display: flex; align-items: center; gap: 10px;
      transform: translateX(120%); transition: transform 0.3s cubic-bezier(0.34,1.56,0.64,1);
      pointer-events: none; max-width: 320px;
    }
    #toast.show { transform: translateX(0); }
    #toast.success { background: rgba(16,185,129,0.15); border: 1px solid rgba(16,185,129,0.3); color: var(--green-light); }
    #toast.error { background: rgba(239,68,68,0.15); border: 1px solid rgba(239,68,68,0.3); color: #FCA5A5; }

    @media (max-width: 640px) {
      nav { padding: 0 16px; }
      main { padding: 24px 16px 100px; }
      .server-header { padding: 20px; }
      .fields-row { grid-template-columns: 1fr; }
      .section-body { padding: 16px; }
      .save-bar { flex-direction: column; gap: 10px; }
      .btn-save { width: 100%; }
    }
  </style>
</head>
<body>
  <div class="bg-scene">
    <div class="blob blob-1"></div>
    <div class="blob blob-2"></div>
  </div>

  <div id="toast"></div>

  <nav>
    <div class="nav-logo">
      <div class="nav-logo-icon">
        <svg viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 14H9V8h2v8zm4 0h-2V8h2v8z"/></svg>
      </div>
      BotCommand
    </div>
    <div class="nav-right">
      <a href="/servers" class="btn-back">
        <svg viewBox="0 0 24 24"><path d="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z"/></svg>
        All servers
      </a>
    </div>
  </nav>

  <main>
    <!-- Server header -->
    <div class="server-header">
      <div class="server-header-icon">
        <% if (guild.iconUrl) { %>
          <img src="<%= guild.iconUrl %>" alt="<%= guild.name %>" />
        <% } else { %>
          <%= guild.name.charAt(0).toUpperCase() %>
        <% } %>
      </div>
      <div class="server-header-info">
        <h1><%= guild.name %></h1>
      </div>
    </div>

    <!-- Stats bar -->
    <div class="stats-bar" id="stats-bar">
      <div class="stat-pill">
        <div class="dot dot-purple"></div>
        <span>Loading stats…</span>
      </div>
    </div>

    <!-- Settings form -->
    <form id="config-form">

      <!-- General -->
      <div class="section">
        <div class="section-header">
          <div class="section-icon icon-purple">⚙️</div>
          <div>
            <div class="section-title">General</div>
            <div class="section-subtitle">Basic bot behavior for this server</div>
          </div>
        </div>
        <div class="section-body">
          <div class="field">
            <label for="prefix">Command prefix</label>
            <input type="text" id="prefix" name="prefix" value="<%= config.prefix || '!' %>" maxlength="10" placeholder="!" />
            <span class="hint">The character users type before bot commands (e.g. !help, ?help)</span>
          </div>
        </div>
      </div>

      <!-- Welcome -->
      <div class="section">
        <div class="section-header">
          <div class="section-icon icon-green">👋</div>
          <div>
            <div class="section-title">Welcome</div>
            <div class="section-subtitle">Greet new members automatically</div>
          </div>
        </div>
        <div class="section-body">
          <div class="fields-row">
            <div class="field">
              <label for="welcomeChannel">Welcome channel</label>
              <% if (channels.length > 0) { %>
                <select id="welcomeChannel" name="welcomeChannel">
                  <option value="">— Disabled —</option>
                  <% channels.forEach(ch => { %>
                    <option value="<%= ch.id %>" <%= config.welcomeChannel === ch.id ? 'selected' : '' %>>#<%= ch.name %></option>
                  <% }); %>
                </select>
              <% } else { %>
                <input type="text" id="welcomeChannel" name="welcomeChannel" value="<%= config.welcomeChannel || '' %>" placeholder="Channel ID" />
              <% } %>
            </div>
          </div>
          <div class="field">
            <label for="welcomeMessage">Welcome message</label>
            <textarea id="welcomeMessage" name="welcomeMessage" placeholder="Welcome to the server, {user}!"><%= config.welcomeMessage || '' %></textarea>
            <span class="hint">Use <code style="background:rgba(255,255,255,0.08);padding:1px 6px;border-radius:4px;">{user}</code> to mention the new member.</span>
          </div>
        </div>
      </div>

      <!-- Logging -->
      <div class="section">
        <div class="section-header">
          <div class="section-icon icon-blue">📋</div>
          <div>
            <div class="section-title">Logging</div>
            <div class="section-subtitle">Track server activity in a log channel</div>
          </div>
        </div>
        <div class="section-body">
          <div class="field">
            <label for="logChannel">Log channel</label>
            <% if (channels.length > 0) { %>
              <select id="logChannel" name="logChannel">
                <option value="">— None —</option>
                <% channels.forEach(ch => { %>
                  <option value="<%= ch.id %>" <%= config.logChannel === ch.id ? 'selected' : '' %>>#<%= ch.name %></option>
                <% }); %>
              </select>
            <% } else { %>
              <input type="text" id="logChannel" name="logChannel" value="<%= config.logChannel || '' %>" placeholder="Channel ID" />
            <% } %>
          </div>

          <label class="toggle-row">
            <div class="toggle-info">
              <div class="toggle-label">Log member joins & leaves</div>
              <div class="toggle-desc">Post a message when someone joins or leaves the server.</div>
            </div>
            <label class="toggle-switch">
              <input type="checkbox" name="logJoinLeave" id="logJoinLeave" value="true" <%= config.logJoinLeave ? 'checked' : '' %> />
              <span class="toggle-slider"></span>
            </label>
          </label>

          <label class="toggle-row">
            <div class="toggle-info">
              <div class="toggle-label">Log deleted messages</div>
              <div class="toggle-desc">Record messages that are deleted in the server.</div>
            </div>
            <label class="toggle-switch">
              <input type="checkbox" name="logMessageDelete" id="logMessageDelete" value="true" <%= config.logMessageDelete ? 'checked' : '' %> />
              <span class="toggle-slider"></span>
            </label>
          </label>
        </div>
      </div>

      <!-- Moderation -->
      <div class="section">
        <div class="section-header">
          <div class="section-icon icon-red">🛡️</div>
          <div>
            <div class="section-title">Moderation</div>
            <div class="section-subtitle">Auto-moderation and enforcement settings</div>
          </div>
        </div>
        <div class="section-body">
          <div class="field">
            <label>Moderation level</label>
            <div class="mod-levels" id="mod-levels">
              <% const levels = ['off','low','medium','high']; %>
              <% levels.forEach(level => { %>
                <div class="mod-level <%= config.modLevel === level ? 'selected-'+level : '' %>" data-value="<%= level %>" onclick="selectModLevel(this)">
                  <%= level.charAt(0).toUpperCase() + level.slice(1) %>
                </div>
              <% }); %>
            </div>
            <input type="hidden" name="modLevel" id="modLevel" value="<%= config.modLevel || 'off' %>" />
            <span class="hint">Controls how aggressively the bot filters spam, links, and rule violations.</span>
          </div>

          <label class="toggle-row">
            <div class="toggle-info">
              <div class="toggle-label">Auto-moderation</div>
              <div class="toggle-desc">Automatically warn or mute members based on the moderation level.</div>
            </div>
            <label class="toggle-switch">
              <input type="checkbox" name="autoMod" id="autoMod" value="true" <%= config.autoMod ? 'checked' : '' %> />
              <span class="toggle-slider"></span>
            </label>
          </label>
        </div>
      </div>

    </form>
  </main>

  <!-- Save bar -->
  <div class="save-bar">
    <div class="save-bar-info">Configuring <strong><%= guild.name %></strong></div>
    <button class="btn-save" id="save-btn" onclick="saveConfig()">Save changes</button>
  </div>

  <script>
    const GUILD_ID = '<%= guild.id %>';

    // Load stats
    fetch(`/api/servers/${GUILD_ID}/stats`)
      .then(r => r.json())
      .then(data => {
        const bar = document.getElementById('stats-bar');
        bar.innerHTML = `
          <div class="stat-pill">
            <div class="dot ${data.botPresent ? 'dot-green' : 'dot-muted'}"></div>
            <span>Bot: <strong>${data.botPresent ? 'Online' : 'Offline'}</strong></span>
          </div>
          ${data.memberCount ? `<div class="stat-pill"><div class="dot dot-purple"></div><span>Members: <strong>${data.memberCount.toLocaleString()}</strong></span></div>` : ''}
        `;
      })
      .catch(() => {
        document.getElementById('stats-bar').innerHTML = '<div class="stat-pill"><div class="dot dot-muted"></div><span>Stats unavailable</span></div>';
      });

    // Mod level selector
    function selectModLevel(el) {
      document.querySelectorAll('.mod-level').forEach(e => {
        e.className = 'mod-level';
      });
      const val = el.dataset.value;
      el.classList.add('selected-' + val);
      document.getElementById('modLevel').value = val;
    }

    // Save config
    async function saveConfig() {
      const btn = document.getElementById('save-btn');
      btn.disabled = true;
      btn.textContent = 'Saving…';

      const form = document.getElementById('config-form');
      const fd = new FormData(form);
      const data = {};
      for (let [k, v] of fd.entries()) data[k] = v;

      // Checkboxes: if not in FormData they're unchecked
      ['autoMod', 'logJoinLeave', 'logMessageDelete'].forEach(key => {
        data[key] = !!form.querySelector(`[name="${key}"]`)?.checked;
      });

      try {
        const res = await fetch(`/api/servers/${GUILD_ID}/config`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });
        const result = await res.json();
        if (result.success) {
          showToast('✅ Changes saved successfully', 'success');
        } else {
          showToast('❌ ' + (result.error || 'Failed to save'), 'error');
        }
      } catch (e) {
        showToast('❌ Network error. Try again.', 'error');
      }

      btn.disabled = false;
      btn.textContent = 'Save changes';
    }

    // Toast
    function showToast(msg, type) {
      const t = document.getElementById('toast');
      t.textContent = msg;
      t.className = `show ${type}`;
      setTimeout(() => { t.className = type; }, 3200);
    }
  </script>
</body>
</html>
