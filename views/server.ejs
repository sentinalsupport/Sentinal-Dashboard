<!-- Add this somewhere on the server settings page, maybe above the settings groups -->

<div class="server-actions" style="display: flex; gap: 12px; margin-bottom: 24px; flex-wrap: wrap;">
    <a href="<%= inviteLink %>" target="_blank" class="btn-invite" style="
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 12px 24px;
        border-radius: 8px;
        background: linear-gradient(135deg, #5865F2, #4752C4);
        color: #FFFFFF;
        text-decoration: none;
        font-weight: 600;
        font-size: 14px;
        transition: all 0.2s ease;
        border: none;
        cursor: pointer;
    ">
        <i class="fab fa-discord"></i> Invite Bot to Server
    </a>
    <a href="/servers" class="back-btn" style="
        padding: 12px 24px;
        border-radius: 8px;
        background: rgba(255, 255, 255, 0.04);
        color: #8B9BB5;
        text-decoration: none;
        font-size: 14px;
        font-weight: 500;
        border: 1px solid rgba(255, 255, 255, 0.06);
        transition: all 0.2s ease;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    ">
        <i class="fas fa-arrow-left"></i> Back to Servers
    </a>
</div>
