                        </div>
                        <div class="form-actions">
                            <button class="btn-save" onclick="saveSettings()"><i class="fas fa-save"></i> Save Changes</button>
                        </div>
                    </div>

                    <div class="settings-group">
                        <div class="group-header">
                            <h4>Templates</h4>
                            <span class="status-tag">Live</span>
                        </div>
                        <p class="group-desc">Create tickets for users to open in your server</p>
                        <div class="form-actions">
                            <button class="btn-save" onclick="alert('Ticket templates coming soon!')"><i class="fas fa-cog"></i> Configure</button>
                        </div>
                    </div>

                    <div class="settings-group">
                        <div class="group-header">
                            <h4>Quick Responses</h4>
                            <span class="status-tag">Live</span>
                        </div>
                        <p class="group-desc">Create quick responses to common questions</p>
                        <div class="form-actions">
                            <button class="btn-save" onclick="alert('Quick responses coming soon!')"><i class="fas fa-plus"></i> New</button>
                            <button class="btn-save" onclick="alert('Configure quick responses coming soon!')"><i class="fas fa-cog"></i> Configure</button>
                        </div>
