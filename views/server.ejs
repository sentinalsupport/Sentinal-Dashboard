            </div>

            <div class="module-content" id="content-giveaways">
                <div class="content-header">
                    <h2><i class="fas fa-gift"></i> Giveaways</h2>
                    <button class="close-btn" onclick="closeModule()"><i class="fas fa-times"></i></button>
                </div>
                <div style="text-align: center; padding: 40px 20px; color: #8B9BB5;">
                    <i class="fas fa-gift" style="font-size: 48px; color: #FBBF24; margin-bottom: 16px; display: block;"></i>
                    <h3 style="color: #E8EDF5; margin-bottom: 8px;">Coming Soon! 🚀</h3>
                    <p>Giveaway features with custom prizes, winners, and entry requirements are under development.</p>
                </div>
            </div>

            <div class="module-content" id="content-logs">
                <div class="content-header">
                    <h2><i class="fas fa-clipboard-list"></i> Audit & Logs</h2>
                    <button class="close-btn" onclick="closeModule()"><i class="fas fa-times"></i></button>
                </div>
                <div style="text-align: center; padding: 40px 20px; color: #8B9BB5;">
                    <i class="fas fa-clipboard-list" style="font-size: 48px; color: #EF4444; margin-bottom: 16px; display: block;"></i>
