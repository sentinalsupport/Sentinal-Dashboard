<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title || 'Server Settings — Sentinal' %></title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Inter', -apple-system, sans-serif;
            background: #0A0E17;
            color: #E8EDF5;
            min-height: 100vh;
            display: flex;
        }

        /* ========== SIDEBAR ========== */
        .sidebar {
            width: 280px;
            background: rgba(14, 20, 34, 0.95);
            border-right: 1px solid rgba(255, 255, 255, 0.04);
            padding: 24px 16px;
            height: 100vh;
            position: sticky;
            top: 0;
            overflow-y: auto;
            flex-shrink: 0;
        }
        .sidebar .logo {
            font-size: 20px;
            font-weight: 700;
            color: #FFFFFF;
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 0 12px 24px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.04);
            margin-bottom: 20px;
        }
        .sidebar .logo .logo-icon {
            width: 36px;
            height: 36px;
            background: linear-gradient(135deg, #2563EB, #1D4ED8);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
        }
        .sidebar .logo span { color: #60A5FA; }

        .sidebar .server-context {
            background: rgba(37, 99, 235, 0.08);
            border: 1px solid rgba(37, 99, 235, 0.15);
            border-radius: 10px;
            padding: 12px 16px;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 12px;
        }
        .sidebar .server-context .icon {
            width: 36px;
            height: 36px;
            border-radius: 8px;
            background: linear-gradient(135deg, #1E3A5F, #1A365D);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 16px;
            font-weight: 700;
            color: #60A5FA;
            overflow: hidden;
            flex-shrink: 0;
        }
        .sidebar .server-context .icon img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }
        .sidebar .server-context .info .name {
            font-size: 14px;
            font-weight: 600;
        }
        .sidebar .server-context .info .members {
            font-size: 12px;
            color: #8B9BB5;
        }
        .sidebar .server-context .back-link {
            margin-left: auto;
            color: #5A6B85;
            text-decoration: none;
            font-size: 14px;
        }
        .sidebar .server-context .back-link:hover {
            color: #E8EDF5;
        }

        .sidebar .nav-section {
            margin-bottom: 24px;
        }
        .sidebar .nav-section .section-title {
            font-size: 11px;
            font-weight: 600;
            color: #5A6B85;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            padding: 0 12px;
            margin-bottom: 8px;
        }
        .sidebar .nav-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 10px 12px;
            border-radius: 8px;
            color: #8B9BB5;
            text-decoration: none;
            font-size: 14px;
            font-weight: 500;
            transition: all 0.2s ease;
            cursor: pointer;
            border: none;
            background: none;
            width: 100%;
            text-align: left;
        }
        .sidebar .nav-item:hover {
            background: rgba(255, 255, 255, 0.04);
            color: #E8EDF5;
        }
        .sidebar .nav-item.active {
            background: rgba(37, 99, 235, 0.12);
            color: #60A5FA;
        }
        .sidebar .nav-item i {
            width: 20px;
            font-size: 16px;
        }
        .sidebar .nav-item .badge {
            margin-left: auto;
            font-size: 11px;
            padding: 2px 8px;
            border-radius: 12px;
        }
        .sidebar .nav-item .badge.live {
            background: rgba(34, 197, 94, 0.15);
            color: #4ADE80;
        }
        .sidebar .nav-item .badge.coming {
            background: rgba(245, 158, 11, 0.15);
            color: #FBBF24;
        }

        .sidebar .user-section {
            border-top: 1px solid rgba(255, 255, 255, 0.04);
            padding-top: 16px;
            margin-top: 16px;
        }
        .sidebar .user-section .user-info {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 8px 12px;
            border-radius: 8px;
        }
        .sidebar .user-section .user-info .avatar {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            background: linear-gradient(135deg, #2563EB, #1D4ED8);
            overflow: hidden;
            flex-shrink: 0;
        }
        .sidebar .user-section .user-info .avatar img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }
        .sidebar .user-section .user-info .name {
            font-size: 13px;
            font-weight: 600;
            color: #E8EDF5;
        }
        .sidebar .user-section .user-info .plan {
            font-size: 11px;
            color: #5A6B85;
        }

        /* ========== MAIN CONTENT ========== */
        .main-content {
            flex: 1;
            padding: 32px 40px;
            overflow-y: auto;
        }

        /* ========== MODULES PANEL ========== */
        .modules-panel {
            max-width: 1100px;
            margin: 0 auto;
        }
        .modules-panel .panel-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 32px;
            flex-wrap: wrap;
            gap: 16px;
        }
        .modules-panel .panel-header h1 {
            font-size: 28px;
            font-weight: 800;
        }
        .modules-panel .panel-header h1 span { color: #60A5FA; }
        .modules-panel .panel-header .subtitle {
            color: #8B9BB5;
            font-size: 14px;
        }

        .modules-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
            gap: 20px;
        }
        .module-card {
            background: rgba(255, 255, 255, 0.02);
            border: 1px solid rgba(255, 255, 255, 0.04);
            border-radius: 14px;
            padding: 24px;
            transition: all 0.3s ease;
            cursor: pointer;
        }
        .module-card:hover {
            border-color: rgba(37, 99, 235, 0.2);
            transform: translateY(-4px);
            box-shadow: 0 8px 24px rgba(0, 0, 0, 0.2);
        }
        .module-card .module-icon {
            width: 48px;
            height: 48px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 22px;
            margin-bottom: 16px;
        }
        .module-card .module-icon.applications { background: rgba(37, 99, 235, 0.15); color: #2563EB; }
        .module-card .module-icon.tickets { background: rgba(245, 158, 11, 0.15); color: #FBBF24; }
        .module-card .module-icon.verification { background: rgba(34, 197, 94, 0.15); color: #4ADE80; }
        .module-card .module-icon.automation { background: rgba(139, 92, 246, 0.15); color: #8B5CF6; }
        .module-card .module-icon.community { background: rgba(236, 72, 153, 0.15); color: #EC4899; }
        .module-card .module-icon.logs { background: rgba(239, 68, 68, 0.15); color: #EF4444; }
        .module-card .module-icon.giveaways { background: rgba(251, 191, 36, 0.15); color: #FBBF24; }

        .module-card h3 {
            font-size: 18px;
            font-weight: 700;
            margin-bottom: 4px;
        }
        .module-card p {
            color: #8B9BB5;
            font-size: 14px;
            line-height: 1.5;
            margin-bottom: 12px;
        }
        .module-card .module-footer {
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 8px;
        }
        .module-card .module-footer .status {
            font-size: 12px;
            font-weight: 500;
            padding: 4px 12px;
            border-radius: 12px;
        }
        .module-card .module-footer .status.live {
            background: rgba(34, 197, 94, 0.12);
            color: #4ADE80;
        }
        .module-card .module-footer .status.coming {
            background: rgba(245, 158, 11, 0.12);
            color: #FBBF24;
        }
        .module-card .module-footer .btn-config {
            padding: 6px 18px;
            border-radius: 6px;
            border: none;
            font-weight: 600;
            font-size: 13px;
            cursor: pointer;
            transition: all 0.2s ease;
            background: rgba(37, 99, 235, 0.12);
            color: #60A5FA;
            text-decoration: none;
        }
        .module-card .module-footer .btn-config:hover {
            background: rgba(37, 99, 235, 0.25);
        }
        .module-card .module-footer .btn-config.disabled {
            opacity: 0.4;
            cursor: not-allowed;
        }

        /* ========== MODULE CONTENT AREA ========== */
        .module-content {
            display: none;
            margin-top: 32px;
            background: rgba(255, 255, 255, 0.02);
            border: 1px solid rgba(255, 255, 255, 0.04);
            border-radius: 14px;
            padding: 32px;
        }
        .module-content.active {
            display: block;
        }
        .module-content .content-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
            flex-wrap: wrap;
            gap: 12px;
        }
        .module-content .content-header h2 {
            font-size: 22px;
            font-weight: 700;
        }
        .module-content .content-header h2 i { color: #2563EB; margin-right: 10px; }
        .module-content .content-header .close-btn {
            background: none;
            border: none;
            color: #5A6B85;
            font-size: 20px;
            cursor: pointer;
        }
        .module-content .content-header .close-btn:hover { color: #E8EDF5; }

        .form-group {
            margin-bottom: 16px;
        }
        .form-group label {
            display: block;
            color: #E8EDF5;
            font-size: 13px;
            font-weight: 500;
            margin-bottom: 4px;
        }
        .form-group .form-hint {
            color: #5A6B85;
            font-size: 12px;
            margin-top: 2px;
        }
        .form-group input,
        .form-group select,
        .form-group textarea {
            width: 100%;
            padding: 10px 14px;
            border-radius: 8px;
            border: 1px solid rgba(255, 255, 255, 0.06);
            background: rgba(0, 0, 0, 0.3);
            color: #E8EDF5;
            font-size: 13px;
            font-family: 'Inter', sans-serif;
            transition: all 0.2s ease;
            outline: none;
        }
        .form-group input:focus,
        .form-group select:focus,
        .form-group textarea:focus {
            border-color: #2563EB;
            box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1);
        }
        .form-group textarea {
            resize: vertical;
            min-height: 80px;
        }
        .form-group select option {
            background: #0A1628;
        }

        .form-actions {
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
            margin-top: 16px;
        }
        .btn-save {
            padding: 10px 32px;
            border-radius: 8px;
            border: none;
            font-weight: 600;
            font-size: 14px;
            cursor: pointer;
            transition: all 0.2s ease;
            background: linear-gradient(135deg, #2563EB, #1D4ED8);
            color: #FFFFFF;
        }
        .btn-save:hover {
            transform: translateY(-1px);
            box-shadow: 0 8px 24px rgba(37, 99, 235, 0.25);
        }
        .btn-save:disabled {
            opacity: 0.5;
            cursor: not-allowed;
            transform: none;
        }

        .success-message {
            background: rgba(34, 197, 94, 0.1);
            border: 1px solid rgba(34, 197, 94, 0.2);
            border-radius: 8px;
            padding: 12px 16px;
            color: #4ADE80;
            font-size: 14px;
            margin-bottom: 20px;
        }

        .footer {
            border-top: 1px solid rgba(255, 255, 255, 0.04);
            padding: 24px 32px;
            text-align: center;
            color: #5A6B85;
            font-size: 13px;
            margin-top: 40px;
        }

        @media (max-width: 1024px) {
            .sidebar { width: 240px; padding: 16px 12px; }
            .main-content { padding: 24px 24px; }
        }
        @media (max-width: 768px) {
            body { flex-direction: column; }
            .sidebar {
                width: 100%;
                height: auto;
                position: relative;
                padding: 16px;
                border-right: none;
                border-bottom: 1px solid rgba(255, 255, 255, 0.04);
            }
            .sidebar .nav-section { display: flex; flex-wrap: wrap; gap: 4px; }
            .sidebar .nav-section .section-title { display: none; }
            .sidebar .nav-item { padding: 8px 12px; font-size: 13px; }
            .sidebar .user-section { display: none; }
            .sidebar .server-context { margin-bottom: 12px; }
            .main-content { padding: 16px; }
            .modules-grid { grid-template-columns: 1fr; }
            .modules-panel .panel-header h1 { font-size: 22px; }
            .module-content { padding: 20px; }
        }
        @media (max-width: 480px) {
            .module-card { padding: 16px; }
            .module-content { padding: 16px; }
        }

        ::-webkit-scrollbar { width: 4px; height: 4px; }
        ::-webkit-scrollbar-track { background: #0A0E17; }
        ::-webkit-scrollbar-thumb { background: #1E4B8A; border-radius: 4px; }
        ::-webkit-scrollbar-thumb:hover { background: #2563EB; }
    </style>
</head>
<body>

    <!-- ========== SIDEBAR ========== -->
    <nav class="sidebar">
        <div class="logo">
            <div class="logo-icon">⚡</div>
            Sentinal <span>Dashboard</span>
        </div>

        <!-- ===== SERVER CONTEXT ===== -->
        <div class="server-context">
            <div class="icon">
                <% if (guild && guild.icon) { %>
                    <img src="https://cdn.discordapp.com/icons/<%= guild.id %>/<%= guild.icon %>.png" alt="<%= guild.name %>">
                <% } else { %>
                    <%= guild ? guild.name ? guild.name.charAt(0).toUpperCase() : '?' : '?' %>
                <% } %>
            </div>
            <div class="info">
                <div class="name"><%= guild ? guild.name : 'Server' %></div>
                <div class="members"><i class="fas fa-users"></i> <%= guild ? guild.memberCount || 'N/A' : 'N/A' %> members</div>
            </div>
            <a href="/servers" class="back-link"><i class="fas fa-arrow-left"></i></a>
        </div>

        <div class="nav-section">
            <div class="section-title">Modules</div>
            <button class="nav-item active" onclick="showModule('applications')">
                <i class="fas fa-file-alt"></i> Applications
                <span class="badge live">Live</span>
            </button>
            <button class="nav-item" onclick="showModule('tickets')">
                <i class="fas fa-ticket"></i> Tickets
                <span class="badge live">Live</span>
            </button>
            <button class="nav-item" onclick="showModule('verification')">
                <i class="fas fa-shield-halved"></i> Verification
                <span class="badge live">Live</span>
            </button>
            <button class="nav-item" onclick="showModule('automation')">
                <i class="fas fa-robot"></i> Automation
                <span class="badge coming">Soon</span>
            </button>
            <button class="nav-item" onclick="showModule('giveaways')">
                <i class="fas fa-gift"></i> Giveaways
                <span class="badge coming">Soon</span>
            </button>
            <button class="nav-item" onclick="showModule('logs')">
                <i class="fas fa-clipboard-list"></i> Audit & Logs
                <span class="badge coming">Soon</span>
            </button>
        </div>

        <div class="user-section">
            <div class="user-info">
                <div class="avatar">
                    <% if (user && user.avatar) { %>
                        <img src="https://cdn.discordapp.com/avatars/<%= user.id %>/<%= user.avatar %>.png" alt="Avatar">
                    <% } else { %>
                        <%= user ? user.username ? user.username.charAt(0).toUpperCase() : 'U' : 'U' %>
                    <% } %>
                </div>
                <div>
                    <div class="name"><%= user ? user.global_name || user.username : 'User' %></div>
                    <div class="plan"><i class="fas fa-circle" style="color: #4ADE80; font-size: 8px; margin-right: 4px;"></i> Free</div>
                </div>
                <a href="/logout" style="margin-left: auto; color: #5A6B85; text-decoration: none; font-size: 14px;">
                    <i class="fas fa-sign-out-alt"></i>
                </a>
            </div>
        </div>
    </nav>

    <!-- ========== MAIN CONTENT ========== -->
    <main class="main-content">
        <div class="modules-panel">

            <!-- ===== HEADER ===== -->
            <div class="panel-header">
                <div>
                    <h1>⚙️ <span><%= guild ? guild.name : 'Server' %></span></h1>
                    <div class="subtitle">Select a module to configure.</div>
                </div>
            </div>

            <!-- ===== MODULES GRID ===== -->
            <div class="modules-grid" id="modulesGrid">

                <!-- Applications -->
                <div class="module-card" onclick="showModule('applications')">
                    <div class="module-icon applications"><i class="fas fa-file-alt"></i></div>
                    <h3>Applications</h3>
                    <p>Create custom application forms for staff, partners, or events. Review and manage submissions.</p>
                    <div class="module-footer">
                        <span class="status live">● Live</span>
                        <button class="btn-config">Configure →</button>
                    </div>
                </div>

                <!-- Tickets -->
                <div class="module-card" onclick="showModule('tickets')">
                    <div class="module-icon tickets"><i class="fas fa-ticket"></i></div>
                    <h3>Tickets</h3>
                    <p>Create support tickets for users to open in your server. Manage transcripts and quick responses.</p>
                    <div class="module-footer">
                        <span class="status live">● Live</span>
                        <button class="btn-config">Configure →</button>
                    </div>
                </div>

                <!-- Verification -->
                <div class="module-card" onclick="showModule('verification')">
                    <div class="module-icon verification"><i class="fas fa-shield-halved"></i></div>
                    <h3>Verification</h3>
                    <p>Set up verification with auto-roles, welcome messages, and advanced security settings.</p>
                    <div class="module-footer">
                        <span class="status live">● Live</span>
                        <button class="btn-config">Configure →</button>
                    </div>
                </div>

                <!-- Automation -->
                <div class="module-card" onclick="showModule('automation')">
                    <div class="module-icon automation"><i class="fas fa-robot"></i></div>
                    <h3>Automation</h3>
                    <p>Auto-moderation, reaction roles, and scheduled tasks to automate your server management.</p>
                    <div class="module-footer">
                        <span class="status coming">● Coming Soon</span>
                        <button class="btn-config disabled" disabled>Coming Soon</button>
                    </div>
                </div>

                <!-- Giveaways -->
                <div class="module-card" onclick="showModule('giveaways')">
                    <div class="module-icon giveaways"><i class="fas fa-gift"></i></div>
                    <h3>Giveaways</h3>
                    <p>Create and manage giveaways with custom prizes, winners, and entry requirements.</p>
                    <div class="module-footer">
                        <span class="status coming">● Coming Soon</span>
                        <button class="btn-config disabled" disabled>Coming Soon</button>
                    </div>
                </div>

                <!-- Audit & Logs -->
                <div class="module-card" onclick="showModule('logs')">
                    <div class="module-icon logs"><i class="fas fa-clipboard-list"></i></div>
                    <h3>Audit & Logs</h3>
                    <p>View all moderation actions, member events, and system logs in one place.</p>
                    <div class="module-footer">
                        <span class="status coming">● Coming Soon</span>
                        <button class="btn-config disabled" disabled>Coming Soon</button>
                    </div>
                </div>

            </div>

            <!-- ===== MODULE CONTENT (Hidden until module is clicked) ===== -->

            <!-- Applications Content -->
            <div class="module-content" id="content-applications">
                <div class="content-header">
                    <h2><i class="fas fa-file-alt"></i> Applications Settings</h2>
                    <button class="close-btn" onclick="closeModule()"><i class="fas fa-times"></i></button>
                </div>
                <div class="form-group">
                    <label for="appChannel">Application Channel</label>
                    <input type="text" id="appChannel" placeholder="#channel-name or channel ID">
                    <div class="form-hint">Channel where applications will be sent</div>
                </div>
                <div class="form-group">
                    <label for="appRole">Reviewer Role</label>
                    <input type="text" id="appRole" placeholder="@role-name or role ID">
                    <div class="form-hint">Role that can review applications</div>
                </div>
                <div class="form-actions">
                    <button class="btn-save" onclick="saveModuleSettings('applications')"><i class="fas fa-save"></i> Save Changes</button>
                </div>
            </div>

            <!-- Tickets Content -->
            <div class="module-content" id="content-tickets">
                <div class="content-header">
                    <h2><i class="fas fa-ticket"></i> Tickets Settings</h2>
                    <button class="close-btn" onclick="closeModule()"><i class="fas fa-times"></i></button>
                </div>
                <div class="form-group">
                    <label for="ticketCategory">Ticket Category</label>
                    <input type="text" id="ticketCategory" placeholder="Category ID">
                    <div class="form-hint">Category where ticket channels will be created</div>
                </div>
                <div class="form-group">
                    <label for="ticketSupportRole">Support Role</label>
                    <input type="text" id="ticketSupportRole" placeholder="@role-name or role ID">
                    <div class="form-hint">Role that can view and manage tickets</div>
                </div>
                <div class="form-actions">
                    <button class="btn-save" onclick="saveModuleSettings('tickets')"><i class="fas fa-save"></i> Save Changes</button>
                </div>
            </div>

            <!-- Verification Content -->
            <div class="module-content" id="content-verification">
                <div class="content-header">
                    <h2><i class="fas fa-shield-halved"></i> Verification Settings</h2>
                    <button class="close-btn" onclick="closeModule()"><i class="fas fa-times"></i></button>
                </div>
                <div class="form-group">
                    <label for="verificationChannel">Verification Channel</label>
                    <input type="text" id="verificationChannel" placeholder="#channel-name or channel ID">
                    <div class="form-hint">Channel where verification will take place</div>
                </div>
                <div class="form-group">
                    <label for="verificationRole">Verified Role</label>
                    <input type="text" id="verificationRole" placeholder="@role-name or role ID">
                    <div class="form-hint">Role assigned after successful verification</div>
                </div>
                <div class="form-group">
                    <label for="autorole">Auto-Role</label>
                    <input type="text" id="autorole" placeholder="@role-name or role ID">
                    <div class="form-hint">Role automatically assigned to new members</div>
                </div>
                <div class="form-actions">
                    <button class="btn-save" onclick="saveModuleSettings('verification')"><i class="fas fa-save"></i> Save Changes</button>
                </div>
            </div>

            <!-- Coming Soon Content -->
            <div class="module-content" id="content-automation">
                <div class="content-header">
                    <h2><i class="fas fa-robot"></i> Automation</h2>
                    <button class="close-btn" onclick="closeModule()"><i class="fas fa-times"></i></button>
                </div>
                <div style="text-align: center; padding: 40px 20px; color: #8B9BB5;">
