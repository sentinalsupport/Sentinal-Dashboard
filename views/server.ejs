<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title || 'Server Settings — Sentinal' %></title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
            background: #080E1A;
            color: #E8EDF5;
            min-height: 100vh;
            -webkit-font-smoothing: antialiased;
        }
        ::-webkit-scrollbar { width: 4px; height: 4px; }
        ::-webkit-scrollbar-track { background: #080E1A; }
        ::-webkit-scrollbar-thumb { background: #1E4B8A; border-radius: 4px; }
        ::-webkit-scrollbar-thumb:hover { background: #2563EB; }
        .container { max-width: 1100px; margin: 0 auto; padding: 0 32px; }

        /* ===== NAVBAR ===== */
        .navbar {
            background: rgba(8, 14, 26, 0.92);
            backdrop-filter: blur(16px);
            border-bottom: 1px solid rgba(255, 255, 255, 0.04);
            padding: 0 32px;
            height: 64px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: sticky;
            top: 0;
            z-index: 100;
        }
        .navbar .brand {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 18px;
            font-weight: 700;
            color: #FFFFFF;
            text-decoration: none;
            letter-spacing: -0.3px;
        }
        .navbar .brand .logo-icon {
            width: 32px;
            height: 32px;
            background: linear-gradient(135deg, #2563EB, #1D4ED8);
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 15px;
        }
        .navbar .brand span { color: #60A5FA; }
        .navbar .nav-links {
            display: flex;
            align-items: center;
            gap: 28px;
        }
        .navbar .nav-links a {
            color: #8B9BB5;
            text-decoration: none;
            font-size: 13px;
            font-weight: 500;
            transition: color 0.2s ease;
            cursor: pointer;
        }
        .navbar .nav-links a:hover { color: #E8EDF5; }
        .navbar .nav-links a.active {
            color: #FFFFFF;
            position: relative;
        }
        .navbar .nav-links a.active::after {
            content: '';
            position: absolute;
            bottom: -20px;
            left: 0;
            right: 0;
            height: 2px;
            background: #2563EB;
            border-radius: 2px;
        }
        .navbar .nav-right {
            display: flex;
            align-items: center;
            gap: 16px;
        }
        .navbar .premium-btn {
            background: linear-gradient(135deg, #F59E0B, #D97706);
            color: #FFFFFF;
            padding: 6px 18px;
            border-radius: 100px;
            text-decoration: none;
            font-size: 12px;
            font-weight: 600;
            transition: all 0.2s ease;
            cursor: pointer;
        }
        .navbar .premium-btn:hover {
            transform: translateY(-1px);
            box-shadow: 0 4px 16px rgba(245, 158, 11, 0.25);
        }
        .navbar .logout-btn {
            background: rgba(255, 255, 255, 0.06);
            color: #8B9BB5;
            padding: 6px 16px;
            border-radius: 100px;
            text-decoration: none;
            font-size: 12px;
            font-weight: 500;
            border: 1px solid rgba(255, 255, 255, 0.06);
            transition: all 0.2s ease;
            display: flex;
            align-items: center;
            gap: 6px;
            cursor: pointer;
        }
        .navbar .logout-btn:hover {
            background: rgba(239, 68, 68, 0.1);
            color: #EF4444;
            border-color: rgba(239, 68, 68, 0.2);
        }
        .navbar .user-avatar {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            background: linear-gradient(135deg, #2563EB, #1D4ED8);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 14px;
            font-weight: 600;
            color: #FFFFFF;
        }
        .navbar .login-btn {
            background: linear-gradient(135deg, #2563EB, #1D4ED8);
            color: #FFFFFF;
            padding: 6px 20px;
            border-radius: 100px;
            text-decoration: none;
            font-size: 12px;
            font-weight: 600;
            transition: all 0.2s ease;
            border: none;
            cursor: pointer;
        }
        .navbar .login-btn:hover {
            transform: translateY(-1px);
            box-shadow: 0 4px 16px rgba(37, 99, 235, 0.25);
        }
        .navbar .status-badge {
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 12px;
            padding: 4px 12px;
            border-radius: 100px;
            background: rgba(34, 197, 94, 0.12);
            color: #4ADE80;
            border: 1px solid rgba(34, 197, 94, 0.15);
        }
        .navbar .status-badge .dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: #4ADE80;
            animation: pulse 2s infinite;
        }
        @keyframes pulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.3; }
        }

        /* ===== SERVER HEADER ===== */
        .server-header {
            padding: 32px 0 24px;
            display: flex;
            align-items: center;
            gap: 20px;
            flex-wrap: wrap;
        }
        .server-header .server-icon {
            width: 64px;
            height: 64px;
            border-radius: 16px;
            background: linear-gradient(135deg, #1E3A5F, #1A365D);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 28px;
            font-weight: 700;
            color: #60A5FA;
            border: 1px solid rgba(96, 165, 250, 0.08);
            overflow: hidden;
            flex-shrink: 0;
        }
        .server-header .server-icon img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }
        .server-header .server-info h1 {
            font-size: 26px;
            font-weight: 800;
            color: #FFFFFF;
            letter-spacing: -0.3px;
        }
        .server-header .server-info p {
            color: #8B9BB5;
            font-size: 14px;
        }
        .server-header .server-info p i {
            margin-right: 4px;
        }
        .server-header .back-btn {
            margin-left: auto;
            background: rgba(255, 255, 255, 0.04);
            color: #8B9BB5;
            padding: 8px 18px;
            border-radius: 8px;
            text-decoration: none;
            font-size: 13px;
            font-weight: 500;
            border: 1px solid rgba(255, 255, 255, 0.06);
            transition: all 0.2s ease;
        }
        .server-header .back-btn:hover {
            background: rgba(255, 255, 255, 0.08);
            color: #E8EDF5;
        }

        /* ===== SETTINGS TABS ===== */
        .settings-tabs {
            display: flex;
            gap: 4px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.04);
            margin-bottom: 24px;
            overflow-x: auto;
            padding-bottom: 0;
        }
        .settings-tabs .tab {
            padding: 10px 20px;
            border-radius: 8px 8px 0 0;
            color: #8B9BB5;
            font-size: 13px;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.2s ease;
            border: none;
            background: transparent;
            white-space: nowrap;
        }
        .settings-tabs .tab:hover {
            color: #E8EDF5;
            background: rgba(255, 255, 255, 0.02);
        }
        .settings-tabs .tab.active {
            color: #FFFFFF;
            background: rgba(37, 99, 235, 0.1);
            position: relative;
        }
        .settings-tabs .tab.active::after {
            content: '';
            position: absolute;
            bottom: -1px;
            left: 0;
            right: 0;
            height: 2px;
            background: #2563EB;
        }

        /* ===== SETTINGS PANELS ===== */
        .settings-panel {
            display: none;
            padding-bottom: 40px;
        }
        .settings-panel.active {
            display: block;
        }

        .settings-panel h3 {
            font-size: 18px;
            font-weight: 700;
            color: #FFFFFF;
            margin-bottom: 4px;
        }
        .settings-panel .panel-subtitle {
            color: #8B9BB5;
            font-size: 14px;
            margin-bottom: 20px;
        }

        /* ===== SETTINGS GROUPS ===== */
        .settings-group {
            background: rgba(255, 255, 255, 0.02);
            border: 1px solid rgba(255, 255, 255, 0.04);
            border-radius: 14px;
            padding: 24px;
            margin-bottom: 16px;
        }
        .settings-group .group-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 12px;
            flex-wrap: wrap;
            gap: 8px;
        }
        .settings-group .group-header h4 {
            font-size: 15px;
            font-weight: 600;
            color: #FFFFFF;
        }
        .settings-group .group-header .badge {
            font-size: 11px;
            font-weight: 500;
            padding: 2px 10px;
            border-radius: 100px;
            background: rgba(96, 165, 250, 0.1);
            color: #60A5FA;
        }
        .settings-group .group-desc {
            color: #8B9BB5;
            font-size: 13px;
            margin-bottom: 12px;
        }

        /* ===== FORM ELEMENTS ===== */
        .form-group {
            margin-bottom: 14px;
        }
        .form-group label {
            display: block;
            color: #E8EDF5;
            font-size: 13px;
            font-weight: 500;
            margin-bottom: 4px;
        }
        .form-group .form-hint {
            color: #5A6B85;
            font-size: 12px;
            margin-top: 2px;
        }
        .form-group input,
        .form-group select,
        .form-group textarea {
            width: 100%;
            padding: 10px 14px;
            border-radius: 8px;
            border: 1px solid rgba(255, 255, 255, 0.06);
            background: rgba(0, 0, 0, 0.3);
            color: #E8EDF5;
            font-size: 13px;
            font-family: 'Inter', sans-serif;
            transition: all 0.2s ease;
            outline: none;
        }
        .form-group input:focus,
        .form-group select:focus,
        .form-group textarea:focus {
            border-color: #2563EB;
            box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1);
        }
        .form-group input::placeholder {
            color: #475569;
        }
        .form-group textarea {
            resize: vertical;
            min-height: 80px;
        }
        .form-group select option {
            background: #0A1628;
        }

        /* ===== TOGGLE SWITCH ===== */
        .toggle-wrapper {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 8px 0;
        }
        .toggle {
            width: 44px;
            height: 24px;
            background: rgba(255, 255, 255, 0.06);
            border-radius: 12px;
            cursor: pointer;
            transition: all 0.3s ease;
            position: relative;
            flex-shrink: 0;
        }
        .toggle.active {
            background: #2563EB;
        }
        .toggle .toggle-slider {
            width: 18px;
            height: 18px;
            background: #FFFFFF;
            border-radius: 50%;
            position: absolute;
            top: 3px;
            left: 3px;
            transition: all 0.3s ease;
        }
        .toggle.active .toggle-slider {
            left: 23px;
        }
        .toggle-label {
            color: #E8EDF5;
            font-size: 13px;
            font-weight: 500;
        }
        .toggle-desc {
            color: #5A6B85;
            font-size: 12px;
        }

        /* ===== BUTTONS ===== */
        .btn-save {
            padding: 10px 32px;
            border-radius: 8px;
            border: none;
            font-weight: 600;
            font-size: 14px;
            cursor: pointer;
            transition: all 0.2s ease;
            background: linear-gradient(135deg, #2563EB, #1D4ED8);
            color: #FFFFFF;
        }
        .btn-save:hover {
            transform: translateY(-1px);
            box-shadow: 0 8px 24px rgba(37, 99, 235, 0.25);
        }
        .btn-save:disabled {
            opacity: 0.5;
            cursor: not-allowed;
            transform: none;
        }

        .btn-reset {
            padding: 10px 32px;
            border-radius: 8px;
            border: 1px solid rgba(255, 255, 255, 0.06);
            font-weight: 600;
            font-size: 14px;
            cursor: pointer;
            transition: all 0.2s ease;
            background: transparent;
            color: #8B9BB5;
        }
        .btn-reset:hover {
            background: rgba(255, 255, 255, 0.04);
            color: #E8EDF5;
        }

        .btn-danger {
            padding: 10px 32px;
            border-radius: 8px;
            border: none;
            font-weight: 600;
            font-size: 14px;
            cursor: pointer;
            transition: all 0.2s ease;
            background: #EF4444;
            color: #FFFFFF;
        }
        .btn-danger:hover {
            background: #DC2626;
            transform: translateY(-1px);
        }

        .form-actions {
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
            margin-top: 16px;
        }

        /* ===== FOOTER ===== */
        .footer {
            border-top: 1px solid rgba(255, 255, 255, 0.04);
            padding: 24px 0;
            margin-top: 20px;
        }
        .footer .footer-bottom {
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 8px;
            color: #5A6B85;
            font-size: 13px;
        }

        /* ===== RESPONSIVE ===== */
        @media (max-width: 768px) {
            .container { padding: 0 20px; }
            .navbar { padding: 0 20px; height: 58px; flex-wrap: wrap; gap: 8px; }
            .navbar .nav-links { gap: 16px; }
            .navbar .nav-links a { font-size: 12px; }
            .navbar .nav-links a.active::after { bottom: -17px; }
            .server-header { flex-wrap: wrap; }
            .server-header .back-btn { margin-left: 0; }
            .settings-tabs { gap: 2px; }
            .settings-tabs .tab { padding: 8px 14px; font-size: 12px; }
        }

        @media (max-width: 480px) {
            .navbar .nav-links { gap: 12px; }
            .navbar .nav-links a { font-size: 11px; }
            .navbar .brand { font-size: 15px; }
            .navbar .nav-right { gap: 8px; flex-wrap: wrap; }
            .server-header .server-info h1 { font-size: 20px; }
            .settings-group { padding: 16px; }
            .form-actions { flex-direction: column; }
            .form-actions button { width: 100%; justify-content: center; }
        }
    </style>
</head>
<body>
    <!-- ===== NAVBAR ===== -->
    <nav class="navbar">
        <a href="/dashboard" class="brand">
            <div class="logo-icon">⚡</div>
            Sentinal <span>Dashboard</span>
        </a>
        <div class="nav-links">
            <a href="/dashboard">Home</a>
            <a href="/servers" class="active">Servers</a>
            <a href="/premium">Premium</a>
            <a href="#" onclick="window.open('https://discord.gg/UmqmewYWRd', '_blank')">Support</a>
        </div>
        <div class="nav-right">
            <span class="status-badge"><span class="dot"></span> Online</span>
            <% if (typeof isAuthenticated !== 'undefined' && isAuthenticated === true) { %>
                <div class="user-avatar"><%= user ? user.username ? user.username.charAt(0).toUpperCase() : 'U' : 'U' %></div>
                <a href="/logout" class="logout-btn"><i class="fas fa-sign-out-alt"></i> Logout</a>
            <% } else { %>
                <a href="/login" class="login-btn"><i class="fas fa-sign-in-alt"></i> Login</a>
            <% } %>
        </div>
    </nav>

    <!-- ===== SERVER HEADER ===== -->
    <div class="container">
        <div class="server-header">
            <div class="server-icon">
                <% if (guild && guild.icon) { %>
                    <img src="https://cdn.discordapp.com/icons/<%= guild.id %>/<%= guild.icon %>.png" alt="<%= guild.name %>" />
                <% } else { %>
                    <%= guild ? guild.name ? guild.name.charAt(0).toUpperCase() : '?' : '?' %>
                <% } %>
            </div>
            <div class="server-info">
                <h1><%= guild ? guild.name : 'Server' %></h1>
                <p><i class="fas fa-users"></i> <%= guild ? guild.memberCount || 'N/A' : 'N/A' %> members · <i class="fas fa-hashtag"></i> <%= guild ? guild.channelCount || 'N/A' : 'N/A' %> channels</p>
            </div>
            <a href="/servers" class="back-btn"><i class="fas fa-arrow-left"></i> Back to Servers</a>
        </div>
    </div>

    <!-- ===== SETTINGS ===== -->
    <div class="container">
        <div class="settings-tabs">
            <button class="tab active" data-tab="general"><i class="fas fa-sliders-h"></i> General</button>
            <button class="tab" data-tab="moderation"><i class="fas fa-shield-alt"></i> Moderation</button>
            <button class="tab" data-tab="features"><i class="fas fa-puzzle-piece"></i> Features</button>
            <button class="tab" data-tab="premium"><i class="fas fa-crown"></i> Premium</button>
        </div>

        <!-- ===== GENERAL TAB ===== -->
        <div class="settings-panel active" id="panel-general">
            <h3>General Settings</h3>
            <p class="panel-subtitle">Configure basic server settings for Sentinal</p>

            <div class="settings-group">
                <div class="group-header">
                    <h4>Command Prefix</h4>
                    <span class="badge">Required</span>
                </div>
                <p class="group-desc">The prefix used for all bot commands in this server.</p>
                <div class="form-group">
                    <input type="text" id="prefix" value="<%= config ? config.prefix || '!' : '!' %>" placeholder="!">
                    <div class="form-hint">Example: !, ?, $, etc.</div>
                </div>
            </div>

            <div class="settings-group">
                <div class="group-header">
                    <h4>Language</h4>
                </div>
                <p class="group-desc">Set the language for bot responses.</p>
                <div class="form-group">
                    <select id="language">
                        <option value="en" <%= config && config.language === 'en' ? 'selected' : '' %>>English</option>
                        <option value="es" <%= config && config.language === 'es' ? 'selected' : '' %>>Español</option>
                        <option value="fr" <%= config && config.language === 'fr' ? 'selected' : '' %>>Français</option>
                        <option value="de" <%= config && config.language === 'de' ? 'selected' : '' %>>Deutsch</option>
                        <option value="pt" <%= config && config.language === 'pt' ? 'selected' : '' %>>Português</option>
                    </select>
                </div>
            </div>

            <div class="settings-group">
                <div class="group-header">
                    <h4>Dashboard Access</h4>
                </div>
                <p class="group-desc">Allow server members to access the dashboard.</p>
                <div class="toggle-wrapper">
                    <div class="toggle <%= config && config.dashboardEnabled !== false ? 'active' : '' %>" id="dashboardToggle">
                        <div class="toggle-slider"></div>
                    </div>
                    <div>
                        <div class="toggle-label">Enable Dashboard Access</div>
                        <div class="toggle-desc">Members with appropriate permissions can view server settings</div>
                    </div>
                </div>
            </div>

            <div class="form-actions">
                <button class="btn-save" onclick="saveSettings()"><i class="fas fa-save"></i> Save Changes</button>
                <button class="btn-reset" onclick="resetSettings()"><i class="fas fa-undo"></i> Reset</button>
            </div>
        </div>

        <!-- ===== MODERATION TAB ===== -->
        <div class="settings-panel" id="panel-moderation">
            <h3>Moderation Settings</h3>
            <p class="panel-subtitle">Configure moderation features for your server</p>

            <div class="settings-group">
                <div class="group-header">
                    <h4>Moderation Log Channel</h4>
                </div>
                <p class="group-desc">Channel where moderation actions will be logged.</p>
                <div class="form-group">
                    <input type="text" id="modLogChannel" value="<%= config && config.modLogChannel ? config.modLogChannel : '' %>" placeholder="#channel-name or channel ID">
                    <div class="form-hint">Leave blank to disable</div>
                </div>
            </div>

            <div class="settings-group">
                <div class="group-header">
                    <h4>Member Log Channel</h4>
                </div>
                <p class="group-desc">Channel where member join/leave events will be logged.</p>
                <div class="form-group">
                    <input type="text" id="memberLogChannel" value="<%= config && config.memberLogChannel ? config.memberLogChannel : '' %>" placeholder="#channel-name or channel ID">
                    <div class="form-hint">Leave blank to disable</div>
                </div>
            </div>

            <div class="settings-group">
                <div class="group-header">
                    <h4>Muted Role</h4>
                </div>
                <p class="group-desc">Role assigned to muted members.</p>
                <div class="form-group">
                    <input type="text" id="mutedRole" value="<%= config && config.mutedRole ? config.mutedRole : '' %>" placeholder="@role-name or role ID">
                    <div class="form-hint">Role must exist in your server</div>
                </div>
            </div>

            <div class="settings-group">
                <div class="group-header">
                    <h4>Admin Roles</h4>
                </div>
                <p class="group-desc">Roles that have full admin access to the bot.</p>
                <div class="form-group">
                    <input type="text" id="adminRoles" value="<%= config && config.adminRoles ? config.adminRoles.join(', ') : '' %>" placeholder="@role1, @role2, or role IDs">
                    <div class="form-hint">Separate multiple roles with commas</div>
                </div>
            </div>

            <div class="form-actions">
                <button class="btn-save" onclick="saveSettings()"><i class="fas fa-save"></i> Save Changes</button>
            </div>
        </div>

        <!-- ===== FEATURES TAB ===== -->
        <div class="settings-panel" id="panel-features">
            <h3>Feature Settings</h3>
            <p class="panel-subtitle">Enable or disable specific bot features</p>

            <div class="settings-group">
                <div class="group-header">
                    <h4>Applications</h4>
                </div>
                <p class="group-desc">Enable the application/forms system.</p>
                <div class="toggle-wrapper">
                    <div class="toggle <%= config && config.enabledFeatures && config.enabledFeatures.includes('applications') ? 'active' : 'active' %>" id="featureApplications">
                        <div class="toggle-slider"></div>
                    </div>
                    <div>
                        <div class="toggle-label">Enable Applications</div>
                        <div class="toggle-desc">Allow members to submit applications</div>
                    </div>
                </div>
                <div style="margin-top: 12px;">
                    <div class="form-group">
                        <input type="text" id="applicationChannel" value="<%= config && config.applicationChannel ? config.applicationChannel : '' %>" placeholder="#channel-name or channel ID">
                        <div class="form-hint">Channel where applications will be sent</div>
                    </div>
                </div>
            </div>

            <div class="settings-group">
                <div class="group-header">
                    <h4>Tickets</h4>
                </div>
                <p class="group-desc">Enable the ticketing system.</p>
                <div class="toggle-wrapper">
                    <div class="toggle <%= config && config.enabledFeatures && config.enabledFeatures.includes('tickets') ? 'active' : 'active' %>" id="featureTickets">
                        <div class="toggle-slider"></div>
                    </div>
                    <div>
                        <div class="toggle-label">Enable Tickets</div>
                        <div class="toggle-desc">Allow members to create support tickets</div>
                    </div>
                </div>
                <div style="margin-top: 12px;">
                    <div class="form-group">
                        <input type="text" id="ticketCategory" value="<%= config && config.ticketCategory ? config.ticketCategory : '' %>" placeholder="Category ID">
                        <div class="form-hint">Category where ticket channels will be created</div>
                    </div>
                    <div class="form-group">
                        <input type="text" id="ticketSupportRole" value="<%= config && config.ticketSupportRole ? config.ticketSupportRole : '' %>" placeholder="@role-name or role ID">
                        <div class="form-hint">Role that can view and manage tickets</div>
                    </div>
                </div>
            </div>

            <div class="settings-group">
                <div class="group-header">
                    <h4>Giveaways</h4>
                </div>
                <p class="group-desc">Enable the giveaway system.</p>
                <div class="toggle-wrapper">
                    <div class="toggle <%= config && config.enabledFeatures && config.enabledFeatures.includes('giveaways') ? 'active' : 'active' %>" id="featureGiveaways">
                        <div class="toggle-slider"></div>
                    </div>
                    <div>
                        <div class="toggle-label">Enable Giveaways</div>
                        <div class="toggle-desc">Allow members to host giveaways</div>
                    </div>
                </div>
                <div style="margin-top: 12px;">
                    <div class="form-group">
                        <input type="text" id="giveawayChannel" value="<%= config && config.giveawayChannel ? config.giveawayChannel : '' %>" placeholder="#channel-name or channel ID">
                        <div class="form-hint">Channel where giveaways will be hosted</div>
                    </div>
                </div>
            </div>

            <div class="settings-group">
                <div class="group-header">
                    <h4>Verification</h4>
                </div>
                <p class="group-desc">Enable the verification system to prevent bots.</p>
                <div class="toggle-wrapper">
                    <div class="toggle <%= config && config.verificationEnabled ? 'active' : '' %>" id="featureVerification">
                        <div class="toggle-slider"></div>
                    </div>
                    <div>
                        <div class="toggle-label">Enable Verification</div>
                        <div class="toggle-desc">Require members to verify before accessing the server</div>
                    </div>
                </div>
                <div style="margin-top: 12px;">
                    <div class="form-group">
                        <input type="text" id="verificationChannel" value="<%= config && config.verificationChannel ? config.verificationChannel : '' %>" placeholder="#channel-name or channel ID">
                        <div class="form-hint">Channel where verification will take place</div>
                    </div>
                    <div class="form-group">
                        <input type="text" id="verificationRole" value="<%= config && config.verificationRole ? config.verificationRole : '' %>" placeholder="@role-name or role ID">
                        <div class="form-hint">Role assigned after successful verification</div>
                    </div>
                </div>
            </div>

            <div class="form-actions">
                <button class="btn-save" onclick="saveSettings()"><i class="fas fa-save"></i> Save Changes</button>
            </div>
        </div>

        <!-- ===== PREMIUM TAB ===== -->
        <div class="settings-panel" id="panel-premium">
            <h3>Premium Features</h3>
            <p class="panel-subtitle">Unlock advanced features for your server</p>

            <div class="settings-group" style="background: linear-gradient(135deg, rgba(245, 158, 11, 0.04), rgba(217, 119, 6, 0.01)); border-color: rgba(245, 158, 11, 0.1);">
                <div class="group-header">
                    <h4 style="color: #FBBF24;">⭐ Premium Status</h4>
                    <span class="badge" style="background: rgba(245, 158, 11, 0.15); color: #FBBF24;">
                        <%= config && config.premium ? 'Active' : 'Inactive' %>
                    </span>
                </div>
                <p class="group-desc">Premium gives you access to advanced features and priority support.</p>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin: 16px 0;">
                    <div style="background: rgba(255,255,255,0.03); border-radius: 10px; padding: 16px; text-align: center; border: 1px solid rgba(255,255,255,0.04);">
                        <div style="font-size: 28px; font-weight: 800; color: #FBBF24;">$7.99</div>
                        <div style="color: #8B9BB5; font-size: 13px;">/ month</div>
                        <div style="margin-top: 8px; font-weight: 600; color: #E8EDF5;">Sentinal+</div>
                        <div style="margin-top: 4px; color: #5A6B85; font-size: 12px;">5 servers included</div>
                    </div>
                    <div style="background: rgba(245, 158, 11, 0.05); border-radius: 10px; padding: 16px; text-align: center; border: 1px solid rgba(245, 158, 11, 0.15);">
                        <div style="font-size: 28px; font-weight: 800; color: #FBBF24;">$13.99</div>
                        <div style="color: #8B9BB5; font-size: 13px;">/ month</div>
                        <div style="margin-top: 8px; font-weight: 600; color: #E8EDF5;">Sentinal++</div>
                        <div style="margin-top: 4px; color: #5A6B85; font-size: 12px;">Unlimited servers</div>
                    </div>
                </div>

                <div style="display: flex; gap: 8px; flex-wrap: wrap; justify-content: center;">
                    <span style="background: rgba(255,255,255,0.03); padding: 4px 12px; border-radius: 6px; font-size: 12px; color: #8B9BB5;">
                        <i class="fas fa-check" style="color: #FBBF24;"></i> Custom roles
                    </span>
                    <span style="background: rgba(255,255,255,0.03); padding: 4px 12px; border-radius: 6px; font-size: 12px; color: #8B9BB5;">
                        <i class="fas fa-check" style="color: #FBBF24;"></i> Advanced tickets
                    </span>
                    <span style="background: rgba(255,255,255,0.03); padding: 4px 12px; border-radius: 6px; font-size: 12px; color: #8B9BB5;">
                        <i class="fas fa-check" style="color: #FBBF24;"></i> Priority support
                    </span>
                    <span style="background: rgba(255,255,255,0.03); padding: 4px 12px; border-radius: 6px; font-size: 12px; color: #8B9BB5;">
                        <i class="fas fa-check" style="color: #FBBF24;"></i> Custom messages
                    </span>
                </div>

                <div style="margin-top: 16px;">
                    <button class="btn-save" style="background: linear-gradient(135deg, #F59E0B, #D97706); width: 100%;" onclick="upgradePremium()">
                        <i class="fas fa-crown"></i> Upgrade to Premium
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- ===== FOOTER ===== -->
    <footer class="footer">
        <div class="container">
            <div class="footer-bottom">
                <span>© 2026 Sentinal — Discord application bot</span>
                <span>Made with ❤️</span>
            </div>
        </div>
    </footer>

    <script>
        // ===== TAB SWITCHING =====
        document.querySelectorAll('.settings-tabs .tab').forEach(function(tab) {
            tab.addEventListener('click', function() {
                // Remove active from all tabs
                document.querySelectorAll('.settings-tabs .tab').forEach(function(t) {
                    t.classList.remove('active');
                });
                this.classList.add('active');

                // Hide all panels
                document.querySelectorAll('.settings-panel').forEach(function(p) {
                    p.classList.remove('active');
                });

                // Show selected panel
                const panelId = 'panel-' + this.getAttribute('data-tab');
                document.getElementById(panelId).classList.add('active');
            });
        });

        // ===== TOGGLE SWITCHES =====
        document.querySelectorAll('.toggle').forEach(function(toggle) {
            toggle.addEventListener('click', function() {
                this.classList.toggle('active');
            });
        });

        // ===== SAVE SETTINGS =====
        function saveSettings() {
            const prefix = document.getElementById('prefix').value;
            const language = document.getElementById('language').value;
            const modLogChannel = document.getElementById('modLogChannel').value;
            const memberLogChannel = document.getElementById('memberLogChannel').value;
            const mutedRole = document.getElementById('mutedRole').value;
            const adminRoles = document.getElementById('adminRoles').value;
            const applicationChannel = document.getElementById('applicationChannel').value;
            const ticketCategory = document.getElementById('ticketCategory').value;
            const ticketSupportRole = document.getElementById('ticketSupportRole').value;
            const giveawayChannel = document.getElementById('giveawayChannel').value;
            const verificationChannel = document.getElementById('verificationChannel').value;
            const verificationRole = document.getElementById('verificationRole').value;

            const dashboardEnabled = document.getElementById('dashboardToggle').classList.contains('active');
            const applications = document.getElementById('featureApplications').classList.contains('active');
            const tickets = document.getElementById('featureTickets').classList.contains('active');
            const giveaways = document.getElementById('featureGiveaways').classList.contains('active');
            const verification = document.getElementById('featureVerification').classList.contains('active');

            const enabledFeatures = [];
            if (applications) enabledFeatures.push('applications');
            if (tickets) enabledFeatures.push('tickets');
            if (giveaways) enabledFeatures.push('giveaways');
            if (verification) enabledFeatures.push('verification');

            const data = {
                prefix,
                language,
                modLogChannel,
                memberLogChannel,
                mutedRole,
                adminRoles: adminRoles ? adminRoles.split(',').map(r => r.trim()) : [],
                applicationChannel,
                ticketCategory,
                ticketSupportRole,
                giveawayChannel,
                verificationChannel,
                verificationRole,
                verificationEnabled: verification,
                dashboardEnabled,
                enabledFeatures
            };

            // Send to server
            fetch(`/api/config/<%= guild ? guild.id : '' %>`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify(data)
            })
            .then(response => response.json())
            .then(data => {
                alert('✅ Settings saved successfully!');
                console.log('Saved:', data);
            })
            .catch(error => {
                alert('❌ Error saving settings: ' + error.message);
            });
        }

        // ===== RESET SETTINGS =====
        function resetSettings() {
            if (confirm('Are you sure you want to reset all settings to default?')) {
                location.reload();
            }
        }

        // ===== UPGRADE PREMIUM =====
        function upgradePremium() {
            <% if (typeof isAuthenticated !== 'undefined' && isAuthenticated === true) { %>
                alert('⭐ Upgrade to Premium!\n\nChoose Sentinal+ ($7.99/month) or Sentinal++ ($13.99/month)\n\nYou will be redirected to checkout.');
                window.location.href = '/checkout';
            <% } else { %>
                alert('Please login first to upgrade to Premium! 🔐');
                window.location.href = '/login';
            <% } %>
        }

        // ===== NAVIGATION ACTIVE STATE =====
        document.querySelectorAll('.nav-links a').forEach(function(link) {
            link.addEventListener('click', function(e) {
                document.querySelectorAll('.nav-links a').forEach(function(l) {
                    l.classList.remove('active');
                });
                this.classList.add('active');
            });
        });
    </script>
</body>
</html>
