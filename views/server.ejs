                        <div class="form-actions">
                            <button class="btn-save" onclick="saveSettings()"><i class="fas fa-save"></i> Save Changes</button>
                        </div>
                    </div>

                    <div class="settings-group">
                        <div class="group-header">
                            <h4>Panels</h4>
                            <span class="status-tag">Live</span>
                        </div>
                        <p class="group-desc">Manage your application panels</p>
                        <div class="form-actions">
                            <button class="btn-save" onclick="alert('Manage panels coming soon!')"><i class="fas fa-cog"></i> Configure</button>
                        </div>
                    </div>

                    <div class="settings-group">
                        <div class="group-header">
                            <h4>Submissions</h4>
                            <span class="status-tag">Live</span>
                        </div>
                        <p class="group-desc">View and manage all application submissions</p>
                        <div class="form-actions">
                            <button class="btn-save" onclick="alert('View submissions coming soon!')"><i class="fas fa-list"></i> View All</button>
                        </div>
                    </div>
                </div>

                <!-- ─── TICKETS ─── -->
                <div class="module-panel" id="module-tickets">
                    <div class="panel-header">
                        <h2><i class="fas fa-ticket"></i> Tickets</h2>
                        <div class="panel-actions">
                            <a href="#" class="btn-sm primary" onclick="alert('Create new ticket template')">+ New</a>
                        </div>
                    </div>
