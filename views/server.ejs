                        </div>
                        <div class="form-actions">
                            <button class="btn-save" onclick="saveSettings()"><i class="fas fa-save"></i> Save Changes</button>
                        </div>
                    </div>

                    <div class="settings-group">
                        <div class="group-header">
                            <h4>Welcome Messages</h4>
                            <span class="status-tag">Live</span>
                        </div>
                        <div class="form-group">
                            <label for="welcomeChannel">Welcome Channel</label>
                            <input type="text" id="welcomeChannel" value="<%= locals.config ? (config.welcomeChannel || '') : '' %>" placeholder="#channel-name or channel ID">
                            <div class="form-hint">Channel where welcome messages will be sent</div>
                        </div>
                        <div class="form-group">
                            <label for="welcomeMessage">Welcome Message</label>
                            <input type="text" id="welcomeMessage" value="<%= locals.config ? (config.welcomeMessage || 'Welcome {user} to {server}!') : 'Welcome {user} to {server}!' %>" placeholder="Welcome {user} to {server}!">
                            <div class="form-hint">Use {user} for member mention, {server} for server name</div>
                        </div>
                        <div class="form-actions">
                            <button class="btn-save" onclick="saveSettings()"><i class="fas fa-save"></i> Save Changes</button>
                        </div>
                    </div>

                    <div class="settings-group">
                        <div class="group-header">
                            <h4>Leave Messages</h4>
                            <span class="status-tag">Live</span>
                        </div>
                        <div class="form-group">
                            <label for="memberLogChannel">Leave Log Channel</label>
                            <input type="text" id="memberLogChannel" value="<%= locals.config ? (config.memberLogChannel || '') : '' %>" placeholder="#channel-name or channel ID">
                            <div class="form-hint">Channel where member leave logs will be sent</div>
                        </div>
                        <div class="form-actions">
                            <button class="btn-save" onclick="saveSettings()"><i class="fas fa-save"></i> Save Changes</button>
                        </div>
                    </div>
                </div>

                <!-- ─── AUTOMATION (Coming Soon) ─── -->
                <div class="module-panel" id="module-automation">
                    <div class="panel-header">
                        <h2><i class="fas fa-robot"></i> Automation</h2>
                    </div>
                    <div class="coming-soon">
                        <i class="fas fa-robot"></i>
                        <h3>Coming Soon! 🚀</h3>
                        <p>Auto-moderation, reaction roles, and scheduled tasks are under development.</p>
                    </div>
                </div>

                <!-- ─── COMMUNITY (Coming Soon) ─── -->
                <div class="module-panel" id="module-community">
                    <div class="panel-header">
                        <h2><i class="fas fa-users"></i> Community</h2>
                    </div>
                    <div class="coming-soon">
                        <i class="fas fa-users"></i>
                        <h3>Coming Soon! 🚀</h3>
                        <p>Leveling, giveaways, and community engagement features are under development.</p>
                    </div>
                </div>

                <!-- ─── AUDIT & LOGS (Coming Soon) ─── -->
                <div class="module-panel" id="module-audit">
                    <div class="panel-header">
                        <h2><i class="fas fa-clipboard-list"></i> Audit & Logs</h2>
                    </div>
                    <div class="coming-soon">
                        <i class="fas fa-clipboard-list"></i>
                        <h3>Coming Soon! 🚀</h3>
                        <p>Audit logs and moderation history features are under development.</p>
                    </div>
                </div>

                <!-- ─── PREMIUM ─── -->
                <div class="module-panel" id="module-premium">
                    <div class="panel-header">
                        <h2><i class="fas fa-crown" style="color:var(--gold);"></i> Premium</h2>
                    </div>
                    <div style="display:grid; grid-template-columns:1fr 1fr; gap:16px;">
                        <div style="background:var(--panel); border:1px solid var(--line); border-radius:12px; padding:24px; text-align:center;">
                            <div style="font-size:28px; font-weight:700; color:var(--gold);">$7.99</div>
                            <div style="font-size:13px; color:var(--muted);">/ month</div>
                            <div style="font-weight:600; margin:8px 0;">Sentinal+</div>
                            <button class="btn-save" onclick="alert('Upgrade to Sentinal+ for $7.99/month')" style="width:100%;">Upgrade</button>
                        </div>
                        <div style="background:var(--panel); border:2px solid var(--gold); border-radius:12px; padding:24px; text-align:center; position:relative;">
                            <div style="position:absolute; top:-10px; left:50%; transform:translateX(-50%); background:var(--gold); color:#04140F; font-size:10px; font-weight:700; padding:2px 12px; border-radius:100px; text-transform:uppercase;">Popular</div>
                            <div style="font-size:28px; font-weight:700; color:var(--gold);">$13.99</div>
                            <div style="font-size:13px; color:var(--muted);">/ month</div>
                            <div style="font-weight:600; margin:8px 0;">Sentinal++</div>
                            <button class="btn-save" onclick="alert('Upgrade to Sentinal++ for $13.99/month')" style="width:100%;">Upgrade</button>
                        </div>
                    </div>
                </div>

            </div><!-- /settings-content -->
        </div><!-- /settings-layout -->
    </div>

    <!-- ─── FOOTER ─── -->
    <footer class="footer">
        © 2026 SENTINAL — STATUS: OPERATIONAL
    </footer>

    <script>
        // ─── MODULE NAVIGATION ───
        function showModule(module) {
            // Update sidebar active state
            document.querySelectorAll('.settings-sidebar .nav-item').forEach(el => {
                el.classList.remove('active');
            });
            document.querySelectorAll('.settings-sidebar .nav-item').forEach(el => {
                if (el.textContent.trim().toLowerCase().includes(module)) {
                    el.classList.add('active');
                }
            });

            // Hide all panels
            document.querySelectorAll('.module-panel').forEach(el => {
                el.classList.remove('active');
            });

            // Show selected panel
            const target = document.getElementById('module-' + module);
            if (target) {
                target.classList.add('active');
                target.scrollIntoView({ behavior: 'smooth', block: 'start' });
            }
        }

        // ─── SAVE SETTINGS ───
        function saveSettings() {
            const data = {
                prefix: document.getElementById('prefix')?.value || '',
                language: document.getElementById('language')?.value || '',
                applicationChannel: document.getElementById('appChannel')?.value || '',
                ticketCategory: document.getElementById('ticketCategory')?.value || '',
                ticketSupportRole: document.getElementById('ticketSupportRole')?.value || '',
                verificationChannel: document.getElementById('verificationChannel')?.value || '',
                verificationRole: document.getElementById('verificationRole')?.value || '',
                autorole: document.getElementById('autorole')?.value || '',
                welcomeChannel: document.getElementById('welcomeChannel')?.value || '',
                welcomeMessage: document.getElementById('welcomeMessage')?.value || '',
                memberLogChannel: document.getElementById('memberLogChannel')?.value || ''
            };

            fetch(`/api/config/<%= locals.guild ? guild.id : '' %>`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    alert('✅ Settings saved successfully!');
                    location.reload();
                } else {
                    alert('❌ Error: ' + data.error);
                }
            })
            .catch(error => {
                alert('❌ Error saving settings: ' + error.message);
            });
        }

        function resetSettings() {
            if (confirm('Are you sure you want to reset all settings to default?')) {
                location.reload();
            }
        }
    </script>

</body>
</html>
