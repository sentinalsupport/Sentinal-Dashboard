<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title || 'Server Settings — Sentinal' %></title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Inter', -apple-system, sans-serif;
            background: #0A0E17;
            color: #E8EDF5;
            min-height: 100vh;
            display: flex;
        }

        /* ========== SIDEBAR ========== */
        .sidebar {
            width: 280px;
            background: rgba(14, 20, 34, 0.95);
            border-right: 1px solid rgba(255, 255, 255, 0.04);
            padding: 24px 16px;
            height: 100vh;
            position: sticky;
            top: 0;
            overflow-y: auto;
            flex-shrink: 0;
        }
        .sidebar .logo {
            font-size: 20px;
            font-weight: 700;
            color: #FFFFFF;
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 0 12px 24px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.04);
            margin-bottom: 20px;
        }
        .sidebar .logo .logo-icon {
            width: 36px;
            height: 36px;
            background: linear-gradient(135deg, #2563EB, #1D4ED8);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
        }
        .sidebar .logo span { color: #60A5FA; }

        .sidebar .server-context {
            background: rgba(37, 99, 235, 0.08);
            border: 1px solid rgba(37, 99, 235, 0.15);
            border-radius: 10px;
            padding: 12px 16px;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 12px;
        }
        .sidebar .server-context .icon {
            width: 36px;
            height: 36px;
            border-radius: 8px;
            background: linear-gradient(135deg, #1E3A5F, #1A365D);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 16px;
            font-weight: 700;
            color: #60A5FA;
            overflow: hidden;
            flex-shrink: 0;
        }
        .sidebar .server-context .icon img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }
        .sidebar .server-context .info .name {
            font-size: 14px;
            font-weight: 600;
        }
        .sidebar .server-context .info .members {
            font-size: 12px;
            color: #8B9BB5;
        }

        .sidebar .nav-section {
            margin-bottom: 24px;
        }
        .sidebar .nav-section .section-title {
            font-size: 11px;
            font-weight: 600;
            color: #5A6B85;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            padding: 0 12px;
            margin-bottom: 8px;
        }
        .sidebar .nav-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 10px 12px;
            border-radius: 8px;
            color: #8B9BB5;
            text-decoration: none;
            font-size: 14px;
            font-weight: 500;
            transition: all 0.2s ease;
            cursor: pointer;
            border: none;
            background: none;
            width: 100%;
            text-align: left;
        }
        .sidebar .nav-item:hover {
            background: rgba(255, 255, 255, 0.04);
            color: #E8EDF5;
        }
        .sidebar .nav-item.active {
            background: rgba(37, 99, 235, 0.12);
            color: #60A5FA;
        }
        .sidebar .nav-item i {
            width: 20px;
            font-size: 16px;
        }
        .sidebar .nav-item .badge {
            margin-left: auto;
            background: rgba(239, 68, 68, 0.15);
            color: #EF4444;
            font-size: 11px;
            padding: 2px 8px;
            border-radius: 12px;
        }
        .sidebar .nav-item .badge.coming {
            background: rgba(245, 158, 11, 0.15);
            color: #FBBF24;
        }
        .sidebar .nav-item .badge.live {
            background: rgba(34, 197, 94, 0.15);
            color: #4ADE80;
        }

        .sidebar .user-section {
            border-top: 1px solid rgba(255, 255, 255, 0.04);
            padding-top: 16px;
            margin-top: 16px;
        }
        .sidebar .user-section .user-info {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 8px 12px;
            border-radius: 8px;
        }
        .sidebar .user-section .user-info .avatar {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            background: linear-gradient(135deg, #2563EB, #1D4ED8);
            overflow: hidden;
            flex-shrink: 0;
        }
        .sidebar .user-section .user-info .avatar img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }
        .sidebar .user-section .user-info .name {
            font-size: 13px;
            font-weight: 600;
            color: #E8EDF5;
        }
        .sidebar .user-section .user-info .plan {
            font-size: 11px;
            color: #5A6B85;
        }

        /* ========== MAIN CONTENT ========== */
        .main-content {
            flex: 1;
            padding: 32px 40px;
            overflow-y: auto;
        }

        /* ========== SETTINGS AREA ========== */
        .settings-area {
            max-width: 800px;
            margin: 0 auto;
        }
        .settings-area .page-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 32px;
            flex-wrap: wrap;
            gap: 16px;
        }
        .settings-area .page-header h1 {
            font-size: 28px;
            font-weight: 800;
        }
        .settings-area .page-header h1 span { color: #60A5FA; }
        .settings-area .page-header .subtitle {
            color: #8B9BB5;
            font-size: 14px;
        }

        .settings-group {
            background: rgba(255, 255, 255, 0.02);
            border: 1px solid rgba(255, 255, 255, 0.04);
            border-radius: 14px;
            padding: 24px;
            margin-bottom: 16px;
        }
        .settings-group .group-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 8px;
            flex-wrap: wrap;
            gap: 8px;
        }
        .settings-group .group-header h4 {
            font-size: 15px;
            font-weight: 600;
            color: #FFFFFF;
        }
        .settings-group .group-header .status {
            font-size: 11px;
            padding: 2px 10px;
            border-radius: 12px;
            font-weight: 500;
        }
        .settings-group .group-header .status.live {
            background: rgba(34, 197, 94, 0.15);
            color: #4ADE80;
        }
        .settings-group .group-header .status.coming {
            background: rgba(245, 158, 11, 0.15);
            color: #FBBF24;
        }
        .settings-group .group-desc {
            color: #8B9BB5;
            font-size: 13px;
            margin-bottom: 12px;
        }
        .form-group {
            margin-bottom: 14px;
        }
        .form-group label {
            display: block;
            color: #E8EDF5;
            font-size: 13px;
            font-weight: 500;
            margin-bottom: 4px;
        }
        .form-group .form-hint {
            color: #5A6B85;
            font-size: 12px;
            margin-top: 2px;
        }
        .form-group input,
        .form-group select {
            width: 100%;
            padding: 10px 14px;
            border-radius: 8px;
            border: 1px solid rgba(255, 255, 255, 0.06);
            background: rgba(0, 0, 0, 0.3);
            color: #E8EDF5;
            font-size: 13px;
            font-family: 'Inter', sans-serif;
            transition: all 0.2s ease;
            outline: none;
        }
        .form-group input:focus,
        .form-group select:focus {
            border-color: #2563EB;
            box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1);
        }
        .form-group input::placeholder {
            color: #475569;
        }
        .form-group select option {
            background: #0A1628;
        }
        .form-actions {
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
            margin-top: 16px;
        }
        .btn-save {
            padding: 10px 32px;
            border-radius: 8px;
            border: none;
            font-weight: 600;
            font-size: 14px;
            cursor: pointer;
            transition: all 0.2s ease;
            background: linear-gradient(135deg, #2563EB, #1D4ED8);
            color: #FFFFFF;
        }
        .btn-save:hover {
            transform: translateY(-1px);
            box-shadow: 0 8px 24px rgba(37, 99, 235, 0.25);
        }
        .btn-reset {
            padding: 10px 32px;
            border-radius: 8px;
            border: 1px solid rgba(255, 255, 255, 0.06);
            font-weight: 600;
            font-size: 14px;
            cursor: pointer;
            transition: all 0.2s ease;
            background: transparent;
            color: #8B9BB5;
        }
        .btn-reset:hover {
            background: rgba(255, 255, 255, 0.04);
            color: #E8EDF5;
        }

        .success-message {
            background: rgba(34, 197, 94, 0.1);
            border: 1px solid rgba(34, 197, 94, 0.2);
            border-radius: 8px;
            padding: 12px 16px;
            color: #4ADE80;
            font-size: 14px;
            margin-bottom: 20px;
        }
        .error-message {
            background: rgba(239, 68, 68, 0.1);
            border: 1px solid rgba(239, 68, 68, 0.2);
            border-radius: 8px;
            padding: 12px 16px;
            color: #EF4444;
            font-size: 14px;
            margin-bottom: 20px;
        }

        .footer {
            border-top: 1px solid rgba(255, 255, 255, 0.04);
            padding: 24px 32px;
            text-align: center;
            color: #5A6B85;
            font-size: 13px;
            margin-top: 40px;
        }

        @media (max-width: 1024px) {
            .sidebar { width: 240px; padding: 16px 12px; }
            .main-content { padding: 24px 24px; }
        }
        @media (max-width: 768px) {
            body { flex-direction: column; }
            .sidebar {
                width: 100%;
                height: auto;
                position: relative;
                padding: 16px;
                border-right: none;
                border-bottom: 1px solid rgba(255, 255, 255, 0.04);
            }
            .sidebar .nav-section { display: flex; flex-wrap: wrap; gap: 4px; }
            .sidebar .nav-section .section-title { display: none; }
            .sidebar .nav-item { padding: 8px 12px; font-size: 13px; }
            .sidebar .user-section { display: none; }
            .sidebar .server-context { display: none; }
            .main-content { padding: 16px; }
            .settings-area .page-header h1 { font-size: 22px; }
            .settings-group { padding: 16px; }
            .form-actions { flex-direction: column; }
            .form-actions button { width: 100%; justify-content: center; }
        }
        @media (max-width: 480px) {
            .settings-group { padding: 12px; }
        }

        ::-webkit-scrollbar { width: 4px; height: 4px; }
        ::-webkit-scrollbar-track { background: #0A0E17; }
        ::-webkit-scrollbar-thumb { background: #1E4B8A; border-radius: 4px; }
        ::-webkit-scrollbar-thumb:hover { background: #2563EB; }
    </style>
</head>
<body>

    <!-- ========== SIDEBAR ========== -->
    <nav class="sidebar">
        <div class="logo">
            <div class="logo-icon">⚡</div>
            Sentinal <span>Dashboard</span>
        </div>

        <!-- ===== SERVER CONTEXT (Shows which server you're managing) ===== -->
        <div class="server-context">
            <div class="icon">
                <% if (guild && guild.icon) { %>
                    <img src="https://cdn.discordapp.com/icons/<%= guild.id %>/<%= guild.icon %>.png" alt="<%= guild.name %>">
                <% } else { %>
                    <%= guild ? guild.name ? guild.name.charAt(0).toUpperCase() : '?' : '?' %>
                <% } %>
            </div>
            <div class="info">
                <div class="name"><%= guild ? guild.name : 'Server' %></div>
                <div class="members"><i class="fas fa-users"></i> <%= guild ? guild.memberCount || 'N/A' : 'N/A' %> members</div>
            </div>
            <a href="/servers" style="margin-left: auto; color: #5A6B85; text-decoration: none; font-size: 12px;">
                <i class="fas fa-arrow-left"></i>
            </a>
        </div>

        <div class="nav-section">
            <div class="section-title">Modules</div>
            <a href="#" class="nav-item active" onclick="showModule('general')">
                <i class="fas fa-sliders-h"></i> General
                <span class="badge live">Live</span>
            </a>
            <a href="#" class="nav-item" onclick="showModule('applications')">
                <i class="fas fa-file-alt"></i> Applications
                <span class="badge live">Live</span>
            </a>
            <a href="#" class="nav-item" onclick="showModule('tickets')">
                <i class="fas fa-ticket"></i> Tickets
                <span class="badge live">Live</span>
            </a>
            <a href="#" class="nav-item" onclick="showModule('verification')">
                <i class="fas fa-shield-halved"></i> Verification
                <span class="badge live">Live</span>
            </a>
            <a href="#" class="nav-item" onclick="alert('Coming soon! 🚀')">
                <i class="fas fa-robot"></i> Automation
                <span class="badge coming">Soon</span>
            </a>
            <a href="#" class="nav-item" onclick="alert('Coming soon! 🚀')">
                <i class="fas fa-gift"></i> Giveaways
                <span class="badge coming">Soon</span>
            </a>
        </div>

        <div class="user-section">
            <div class="user-info">
                <div class="avatar">
                    <% if (user && user.avatar) { %>
                        <img src="https://cdn.discordapp.com/avatars/<%= user.id %>/<%= user.avatar %>.png" alt="Avatar">
                    <% } else { %>
                        <%= user ? user.username ? user.username.charAt(0).toUpperCase() : 'U' : 'U' %>
                    <% } %>
                </div>
                <div>
                    <div class="name"><%= user ? user.global_name || user.username : 'User' %></div>
                    <div class="plan"><i class="fas fa-circle" style="color: #4ADE80; font-size: 8px; margin-right: 4px;"></i> Free</div>
                </div>
                <a href="/logout" style="margin-left: auto; color: #5A6B85; text-decoration: none; font-size: 14px;">
                    <i class="fas fa-sign-out-alt"></i>
                </a>
            </div>
        </div>
    </nav>

    <!-- ========== MAIN CONTENT ========== -->
    <main class="main-content">
        <div class="settings-area">

            <!-- ===== HEADER ===== -->
            <div class="page-header">
                <div>
                    <h1>⚙️ <span><%= guild ? guild.name : 'Server' %></span> Settings</h1>
                    <div class="subtitle">Configure modules for this server.</div>
                </div>
            </div>

            <% if (locals.success) { %>
                <div class="success-message"><i class="fas fa-check-circle"></i> Settings saved successfully!</div>
            <% } %>
            <% if (locals.error) { %>
                <div class="error-message"><i class="fas fa-exclamation-circle"></i> <%= error %></div>
            <% } %>

            <!-- ===== GENERAL SETTINGS (Default View) ===== -->
            <div id="module-general">
                <div class="settings-group">
                    <div class="group-header">
                        <h4><i class="fas fa-sliders-h" style="color: #2563EB;"></i> General Settings</h4>
                        <span class="status live">Live</span>
                    </div>
                    <p class="group-desc">Configure basic server settings for Sentinal</p>
                    <div class="form-group">
                        <label for="prefix">Command Prefix</label>
                        <input type="text" id="prefix" value="<%= config ? config.prefix || '!' : '!' %>" placeholder="!">
                        <div class="form-hint">Example: !, ?, $, etc.</div>
                    </div>
                    <div class="form-group">
                        <label for="language">Language</label>
                        <select id="language">
                            <option value="en" <%= config && config.language === 'en' ? 'selected' : '' %>>English</option>
                            <option value="es" <%= config && config.language === 'es' ? 'selected' : '' %>>Español</option>
                            <option value="fr" <%= config && config.language === 'fr' ? 'selected' : '' %>>Français</option>
                            <option value="de" <%= config && config.language === 'de' ? 'selected' : '' %>>Deutsch</option>
                            <option value="pt" <%= config && config.language === 'pt' ? 'selected' : '' %>>Português</option>
                        </select>
                    </div>
                    <div class="form-actions">
                        <button class="btn-save" onclick="saveSettings()"><i class="fas fa-save"></i> Save Changes</button>
                        <button class="btn-reset" onclick="resetSettings()"><i class="fas fa-undo"></i> Reset</button>
                    </div>
                </div>
            </div>

            <!-- ===== APPLICATIONS SETTINGS ===== -->
            <div id="module-applications" style="display: none;">
                <div class="settings-group">
                    <div class="group-header">
                        <h4><i class="fas fa-file-alt" style="color: #2563EB;"></i> Applications</h4>
                        <span class="status live">Live</span>
                    </div>
                    <p class="group-desc">Create and manage application forms for your server.</p>
                    <div class="form-group">
                        <label for="appChannel">Application Channel</label>
                        <input type="text" id="appChannel" placeholder="#channel-name or channel ID">
                        <div class="form-hint">Channel where applications will be sent</div>
                    </div>
                    <div class="form-group">
                        <label for="appRole">Reviewer Role</label>
                        <input type="text" id="appRole" placeholder="@role-name or role ID">
                        <div class="form-hint">Role that can review applications</div>
                    </div>
                    <div class="form-actions">
                        <button class="btn-save" onclick="saveSettings()"><i class="fas fa-save"></i> Save Changes</button>
                    </div>
                </div>
            </div>

            <!-- ===== TICKETS SETTINGS ===== -->
            <div id="module-tickets" style="display: none;">
                <div class="settings-group">
                    <div class="group-header">
                        <h4><i class="fas fa-ticket" style="color: #2563EB;"></i> Tickets</h4>
                        <span class="status live">Live</span>
                    </div>
                    <p class="group-desc">Configure the ticket system for support requests.</p>
                    <div class="form-group">
                        <label for="ticketCategory">Ticket Category</label>
                        <input type="text" id="ticketCategory" placeholder="Category ID">
                        <div class="form-hint">Category where ticket channels will be created</div>
                    </div>
                    <div class="form-group">
                        <label for="ticketSupportRole">Support Role</label>
                        <input type="text" id="ticketSupportRole" placeholder="@role-name or role ID">
                        <div class="form-hint">Role that can view and manage tickets</div>
                    </div>
                    <div class="form-actions">
                        <button class="btn-save" onclick="saveSettings()"><i class="fas fa-save"></i> Save Changes</button>
                    </div>
                </div>
            </div>

            <!-- ===== VERIFICATION SETTINGS ===== -->
            <div id="module-verification" style="display: none;">
                <div class="settings-group">
                    <div class="group-header">
                        <h4><i class="fas fa-shield-halved" style="color: #2563EB;"></i> Verification</h4>
                        <span class="status live">Live</span>
                    </div>
                    <p class="group-desc">Set up verification, auto-roles, and welcome messages.</p>
                    <div class="form-group">
                        <label for="verificationChannel">Verification Channel</label>
                        <input type="text" id="verificationChannel" placeholder="#channel-name or channel ID">
                        <div class="form-hint">Channel where verification will take place</div>
                    </div>
                    <div class="form-group">
                        <label for="verificationRole">Verified Role</label>
                        <input type="text" id="verificationRole" placeholder="@role-name or role ID">
                        <div class="form-hint">Role assigned after successful verification</div>
                    </div>
                    <div class="form-group">
                        <label for="autorole">Auto-Role</label>
                        <input type="text" id="autorole" placeholder="@role-name or role ID">
                        <div class="form-hint">Role automatically assigned to new members</div>
                    </div>
                    <div class="form-actions">
                        <button class="btn-save" onclick="saveSettings()"><i class="fas fa-save"></i> Save Changes</button>
                    </div>
                </div>
            </div>

        </div>

        <footer class="footer">
            © 2026 Sentinal — Made with ❤️
        </footer>
    </main>

    <script>
        // ===== MODULE NAVIGATION =====
        function showModule(module) {
            // Update sidebar active state
            document.querySelectorAll('.nav-item').forEach(el => el.classList.remove('active'));
            document.querySelectorAll('.nav-item').forEach(el => {
                if (el.textContent.trim().toLowerCase().includes(module)) {
                    el.classList.add('active');
                }
            });

            // Hide all modules
            const modules = ['general', 'applications', 'tickets', 'verification'];
            modules.forEach(m => {
                const el = document.getElementById('module-' + m);
                if (el) el.style.display = 'none';
            });

            // Show selected module
            const target = document.getElementById('module-' + module);
            if (target) {
                target.style.display = 'block';
                target.scrollIntoView({ behavior: 'smooth' });
            }
        }

        // ===== SAVE SETTINGS =====
        function saveSettings() {
            const prefix = document.getElementById('prefix')?.value || '';
            const language = document.getElementById('language')?.value || '';
            const appChannel = document.getElementById('appChannel')?.value || '';
            const appRole = document.getElementById('appRole')?.value || '';
            const ticketCategory = document.getElementById('ticketCategory')?.value || '';
            const ticketSupportRole = document.getElementById('ticketSupportRole')?.value || '';
            const verificationChannel = document.getElementById('verificationChannel')?.value || '';
            const verificationRole = document.getElementById('verificationRole')?.value || '';
            const autorole = document.getElementById('autorole')?.value || '';

            const data = { 
                prefix, language, appChannel, appRole, 
                ticketCategory, ticketSupportRole,
                verificationChannel, verificationRole, autorole
            };

            fetch(`/api/config/<%= guild ? guild.id : '' %>`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    alert('✅ Settings saved successfully!');
                    location.reload();
                } else {
                    alert('❌ Error: ' + data.error);
                }
            })
            .catch(error => {
                alert('❌ Error saving settings: ' + error.message);
            });
        }

        function resetSettings() {
            if (confirm('Are you sure you want to reset all settings to default?')) {
                location.reload();
            }
        }

        // ===== INVITE BOT =====
        function inviteBot() {
            const clientId = '<%= process.env.DISCORD_CLIENT_ID || "1493217033956102215" %>';
            const inviteLink = `https://discord.com/oauth2/authorize?client_id=${clientId}&permissions=8&integration_type=0&scope=bot+applications.commands`;
            window.open(inviteLink, '_blank');
        }
    </script>

</body>
</html>
