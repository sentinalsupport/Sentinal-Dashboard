<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title || 'Server Settings — Sentinal' %></title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@400;500;600;700;800&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --ink: #060A10;
            --panel: #0D1520;
            --panel-raised: #111D2C;
            --panel-hover: #162033;
            --line: rgba(255,255,255,0.07);
            --line-bright: rgba(255,255,255,0.13);
            --text: #E6EDF6;
            --muted: #6C7A90;
            --muted-dim: #3E4A5C;
            --signal: #3DFFB8;
            --signal-tab: rgba(61,255,184,0.10);
            --signal-glow: rgba(61,255,184,0.15);
            --gold: #F5C842;
            --red: #F87171;
            --red-bg: rgba(248,113,113,0.08);
            --red-border: rgba(248,113,113,0.22);
            --discord: #5865F2;
            --discord-hover: #4752C4;
        }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Inter', -apple-system, sans-serif;
            background: var(--ink);
            color: var(--text);
            min-height: 100vh;
        }

        /* ─── NAVBAR ─── */
        .navbar {
            background: rgba(6,10,16,0.85);
            backdrop-filter: blur(24px) saturate(150%);
            border-bottom: 1px solid var(--line);
            padding: 0 40px;
            height: 64px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: sticky;
            top: 0;
            z-index: 200;
        }
        .brand {
            display: flex; align-items: center; gap: 10px;
            text-decoration: none;
        }
        .brand-logo {
            width: 36px; height: 36px;
            border-radius: 10px;
            background: var(--panel-raised);
            border: 1px solid var(--line-bright);
            display: flex; align-items: center; justify-content: center;
        }
        .brand-logo svg { width: 20px; height: 20px; }
        .brand-name {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 17px; font-weight: 700;
            color: #fff; letter-spacing: -0.3px;
        }
        .nav-center {
            display: flex; align-items: center; gap: 4px;
        }
        .nav-center a {
            color: var(--muted); text-decoration: none;
            font-size: 13.5px; font-weight: 500;
            padding: 6px 14px; border-radius: 8px;
            transition: all 0.18s ease;
        }
        .nav-center a:hover { color: var(--text); background: rgba(255,255,255,0.05); }
        .nav-center a.active { color: #fff; }
        .nav-right { display: flex; align-items: center; gap: 12px; }
        .user-pill {
            display: flex; align-items: center; gap: 9px;
            background: var(--panel); border: 1px solid var(--line);
            border-radius: 100px; padding: 5px 14px 5px 6px;
        }
        .user-avatar {
            width: 28px; height: 28px; border-radius: 50%;
            background: var(--panel-raised); overflow: hidden;
            display: flex; align-items: center; justify-content: center;
            font-size: 12px; font-weight: 700;
        }
        .user-avatar img { width: 100%; height: 100%; object-fit: cover; }
        .user-name { font-size: 13px; font-weight: 500; color: var(--text); }
        .user-plan {
            font-size: 10px; font-weight: 600;
            color: var(--signal); background: var(--signal-tab);
            border: 1px solid rgba(61,255,184,0.22);
            border-radius: 100px; padding: 2px 8px; letter-spacing: 0.3px;
        }
        .logout-btn {
            background: transparent; border: 1px solid var(--line);
            border-radius: 8px; padding: 7px 12px;
            color: var(--muted); cursor: pointer; font-size: 13px;
            transition: all 0.18s ease; text-decoration: none;
            display: flex; align-items: center; gap: 6px;
        }
        .logout-btn:hover { background: var(--red-bg); border-color: var(--red-border); color: var(--red); }

        /* ─── LAYOUT ─── */
        .page-wrapper { max-width: 900px; margin: 0 auto; padding: 40px 32px 60px; }

        /* ─── SERVER HEADER ─── */
        .server-header {
            display: flex; align-items: center; gap: 16px;
            margin-bottom: 24px;
        }
        .server-header .icon {
            width: 56px; height: 56px;
            border-radius: 14px;
            background: var(--panel-raised);
            border: 1px solid var(--line);
            display: flex; align-items: center; justify-content: center;
            font-size: 24px; font-weight: 700;
            overflow: hidden; flex-shrink: 0;
            color: var(--signal);
        }
        .server-header .icon img { width: 100%; height: 100%; object-fit: cover; }
        .server-header .info h1 {
            font-size: 24px; font-weight: 700; color: #fff;
        }
        .server-header .info p {
            font-size: 13px; color: var(--muted);
        }

        /* ─── SERVER ACTIONS ─── */
        .server-actions {
            display: flex; gap: 12px;
            margin-bottom: 28px; flex-wrap: wrap;
        }
        .btn-invite {
            display: inline-flex; align-items: center; gap: 8px;
            padding: 10px 24px; border-radius: 10px;
            background: var(--discord); color: #fff;
            text-decoration: none; font-weight: 600; font-size: 13px;
            transition: all 0.2s ease;
        }
        .btn-invite:hover {
            transform: translateY(-2px);
            background: var(--discord-hover);
            box-shadow: 0 4px 16px rgba(88,101,242,0.3);
        }
        .btn-back {
            display: inline-flex; align-items: center; gap: 8px;
            padding: 10px 24px; border-radius: 10px;
            background: rgba(255,255,255,0.05);
            color: var(--muted); text-decoration: none;
            font-weight: 500; font-size: 13px;
            border: 1px solid var(--line);
            transition: all 0.2s ease;
        }
        .btn-back:hover { background: rgba(255,255,255,0.08); color: var(--text); }
        .status-badge {
            display: inline-flex; align-items: center; gap: 8px;
            padding: 10px 20px; border-radius: 10px;
            background: var(--signal-tab); color: var(--signal);
            border: 1px solid rgba(61,255,184,0.2);
            font-weight: 500; font-size: 13px;
        }

        /* ─── SETTINGS GROUPS ─── */
        .settings-group {
            background: var(--panel);
            border: 1px solid var(--line);
            border-radius: 12px;
            padding: 24px;
            margin-bottom: 16px;
        }
        .settings-group .group-header {
            display: flex; justify-content: space-between; align-items: center;
            margin-bottom: 8px; flex-wrap: wrap; gap: 8px;
        }
        .settings-group .group-header h4 {
            font-size: 15px; font-weight: 600; color: #fff;
        }
        .settings-group .group-header .status {
            font-size: 10px; padding: 2px 12px; border-radius: 100px;
            font-weight: 600;
        }
        .settings-group .group-header .status.live {
            background: var(--signal-tab); color: var(--signal);
            border: 1px solid rgba(61,255,184,0.2);
        }
        .settings-group .group-header .status.coming {
            background: rgba(255,255,255,0.05); color: var(--muted);
            border: 1px solid var(--line);
        }
        .settings-group .group-desc {
            font-size: 13px; color: var(--muted);
            margin-bottom: 14px;
        }
        .form-group { margin-bottom: 14px; }
        .form-group label {
            display: block; font-size: 13px; font-weight: 500;
            margin-bottom: 4px; color: var(--text);
        }
        .form-group .form-hint {
            font-size: 12px; color: var(--muted-dim); margin-top: 2px;
        }
        .form-group input, .form-group select {
            width: 100%; padding: 10px 14px;
            border-radius: 8px; border: 1px solid var(--line);
            background: rgba(0,0,0,0.3); color: var(--text);
            font-size: 13px; font-family: 'Inter', sans-serif;
            transition: all 0.18s ease; outline: none;
        }
        .form-group input:focus, .form-group select:focus {
            border-color: var(--signal);
            box-shadow: 0 0 0 3px var(--signal-glow);
        }
        .form-group select option { background: var(--ink); }
        .form-actions {
            display: flex; gap: 12px; flex-wrap: wrap; margin-top: 16px;
        }
        .btn-save {
            padding: 10px 32px; border-radius: 8px; border: none;
            font-weight: 600; font-size: 14px; cursor: pointer;
            background: var(--signal); color: #04140F;
            transition: all 0.18s ease;
        }
        .btn-save:hover {
            transform: translateY(-1px);
            box-shadow: 0 4px 18px var(--signal-glow);
        }
        .btn-reset {
            padding: 10px 32px; border-radius: 8px;
            border: 1px solid var(--line); background: transparent;
            color: var(--muted); font-weight: 600; font-size: 14px; cursor: pointer;
            transition: all 0.18s ease;
        }
        .btn-reset:hover { background: rgba(255,255,255,0.04); color: var(--text); }

        .success-message {
            background: var(--signal-tab); border: 1px solid rgba(61,255,184,0.2);
            border-radius: 8px; padding: 12px 16px; color: var(--signal);
            font-size: 14px; margin-bottom: 20px;
        }
        .error-message {
            background: var(--red-bg); border: 1px solid var(--red-border);
            border-radius: 8px; padding: 12px 16px; color: var(--red);
            font-size: 14px; margin-bottom: 20px;
        }

        /* ─── FOOTER ─── */
        .footer {
            border-top: 1px solid var(--line); margin-top: 60px;
            padding: 24px 40px; text-align: center;
            color: var(--muted-dim); font-size: 12px;
            font-family: 'IBM Plex Mono', monospace; letter-spacing: 0.5px;
        }

        @media (max-width: 768px) {
            .navbar { padding: 0 16px; }
            .nav-center { display: none; }
            .page-wrapper { padding: 24px 16px 48px; }
            .server-header { flex-wrap: wrap; }
            .server-actions { flex-direction: column; }
            .server-actions .btn-invite, .server-actions .btn-back { width: 100%; justify-content: center; }
            .settings-group { padding: 16px; }
            .form-actions { flex-direction: column; }
            .form-actions button { width: 100%; justify-content: center; }
        }
    </style>
</head>
<body>

    <!-- ─── NAVBAR ─── -->
    <nav class="navbar">
        <a href="/dashboard" class="brand">
            <div class="brand-logo">
                <svg viewBox="0 0 245 240" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M104.4 103.9c-5.7 0-10.2 5-10.2 11.1s4.6 11.1 10.2 11.1c5.7 0 10.2-5 10.2-11.1.1-6.1-4.5-11.1-10.2-11.1zM140.9 103.9c-5.7 0-10.2 5-10.2 11.1s4.6 11.1 10.2 11.1c5.7 0 10.2-5 10.2-11.1s-4.5-11.1-10.2-11.1z" fill="#3DFFB8"/>
                    <path d="M189.5 20H55.5C44.7 20 36 28.7 36 39.5v140.9c0 10.8 8.7 19.5 19.5 19.5h113.5l-5.3-18.5 12.8 11.9 12.1 11.2L209 220V39.5C209 28.7 200.3 20 189.5 20zM155.7 152.1s-3.6-4.3-6.6-8.1c13.1-3.7 18.1-11.9 18.1-11.9-4.1 2.7-8 4.6-11.5 5.9-5 2.1-9.8 3.5-14.5 4.3-9.6 1.8-18.4 1.3-25.9-.1-5.7-1.1-10.6-2.6-14.7-4.3-2.3-.9-4.8-2-7.3-3.4-.3-.2-.6-.3-.9-.5-.2-.1-.3-.2-.4-.3-2-1.1-3.1-1.9-3.1-1.9 4.7 4.3 9.3 6.5 21.7 10.2-2.9 3.8-6.6 8.1-6.6 8.1-22 0-32.1-15.2-32.1-15.2 0-32.2 14.4-58.4 14.4-58.4 14.4-10.8 28.1-10.5 28.1-10.5l1 1.2C99.2 87.7 87.9 97.4 87.9 97.4s2.9-1.6 7.8-3.8c14.1-6.2 25.3-7.9 29.9-8.3.8-.1 1.5-.2 2.3-.2 8.2-1 17.5-1.3 27.2.2 12.9 2 26.7 7.5 40.8 17.3 0 0-10.8-10.2-28.5-13.7l1.4-1.6s13.7-.3 28.1 10.5c0 0 14.4 26.2 14.4 58.4 0 0-10.2 15.2-32.1 15.2z" fill="#3DFFB8"/>
                </svg>
            </div>
            <span class="brand-name">Sentinal</span>
        </a>
        <div class="nav-center">
            <a href="/dashboard">Home</a>
            <a href="/servers" class="active">Servers</a>
            <a href="#" onclick="window.open('https://discord.gg/UmqmewYWRd','_blank'); return false;">Support</a>
        </div>
        <div class="nav-right">
            <div class="user-pill">
                <div class="user-avatar">
                    <% if (user && user.avatar) { %>
                        <img src="https://cdn.discordapp.com/avatars/<%= user.id %>/<%= user.avatar %>.png" alt="Avatar">
                    <% } else { %>
                        <%= user ? (user.username ? user.username.charAt(0).toUpperCase() : 'U') : 'U' %>
                    <% } %>
                </div>
                <span class="user-name"><%= user ? user.global_name || user.username : 'User' %></span>
                <span class="user-plan">Free</span>
            </div>
            <a href="/logout" class="logout-btn"><i class="fas fa-sign-out-alt"></i></a>
        </div>
    </nav>

    <!-- ─── PAGE ─── -->
    <div class="page-wrapper">

        <!-- SUCCESS / ERROR MESSAGES -->
        <% if (locals.success) { %>
            <div class="success-message"><i class="fas fa-check-circle"></i> Settings saved successfully!</div>
        <% } %>
        <% if (locals.error) { %>
            <div class="error-message"><i class="fas fa-exclamation-circle"></i> <%= error %></div>
        <% } %>

        <!-- ─── SERVER HEADER ─── -->
        <div class="server-header">
            <div class="icon">
                <% if (guild && guild.icon) { %>
                    <img src="https://cdn.discordapp.com/icons/<%= guild.id %>/<%= guild.icon %>.png" alt="<%= guild.name %>">
                <% } else { %>
                    <%= guild ? (guild.name ? guild.name.charAt(0).toUpperCase() : '?') : '?' %>
                <% } %>
            </div>
            <div class="info">
                <h1><%= guild ? guild.name : 'Server' %></h1>
                <p><i class="fas fa-users"></i> <%= guild ? (guild.memberCount || 'N/A') : 'N/A' %> members</p>
            </div>
        </div>

        <!-- ─── SERVER ACTIONS ─── -->
        <div class="server-actions">
            <% if (locals.botInServer) { %>
                <span class="status-badge"><i class="fas fa-check-circle"></i> Bot is in this server</span>
            <% } else { %>
                <a href="<%= locals.inviteLink || '#' %>" target="_blank" class="btn-invite">
                    <i class="fab fa-discord"></i> Invite Bot to Server
                </a>
            <% } %>
            <a href="/servers" class="btn-back"><i class="fas fa-arrow-left"></i> Back to Servers</a>
        </div>

        <!-- ─── GENERAL SETTINGS ─── -->
        <div class="settings-group">
            <div class="group-header">
                <h4><i class="fas fa-sliders-h" style="color:var(--signal);"></i> General Settings</h4>
                <span class="status live">Live</span>
            </div>
            <p class="group-desc">Configure basic server settings for Sentinal</p>
            <div class="form-group">
                <label for="prefix">Command Prefix</label>
                <input type="text" id="prefix" value="<%= locals.config ? (config.prefix || '!') : '!' %>" placeholder="!">
                <div class="form-hint">Example: !, ?, $, etc.</div>
            </div>
            <div class="form-group">
                <label for="language">Language</label>
                <select id="language">
                    <option value="en" <%= (locals.config && config.language === 'en') ? 'selected' : '' %>>English</option>
                    <option value="es" <%= (locals.config && config.language === 'es') ? 'selected' : '' %>>Español</option>
                    <option value="fr" <%= (locals.config && config.language === 'fr') ? 'selected' : '' %>>Français</option>
                    <option value="de" <%= (locals.config && config.language === 'de') ? 'selected' : '' %>>Deutsch</option>
                    <option value="pt" <%= (locals.config && config.language === 'pt') ? 'selected' : '' %>>Português</option>
                </select>
            </div>
            <div class="form-actions">
                <button class="btn-save" onclick="saveSettings()"><i class="fas fa-save"></i> Save Changes</button>
                <button class="btn-reset" onclick="resetSettings()"><i class="fas fa-undo"></i> Reset</button>
            </div>
        </div>

        <!-- ─── APPLICATIONS ─── -->
        <div class="settings-group">
            <div class="group-header">
                <h4><i class="fas fa-file-alt" style="color:var(--signal);"></i> Applications</h4>
                <span class="status live">Live</span>
            </div>
            <p class="group-desc">Create and manage application forms for your server.</p>
            <div class="form-group">
                <label for="appChannel">Application Channel</label>
                <input type="text" id="appChannel" value="<%= locals.config ? (config.applicationChannel || '') : '' %>" placeholder="#channel-name or channel ID">
                <div class="form-hint">Channel where applications will be sent</div>
            </div>
            <div class="form-group">
                <label for="appRole">Reviewer Role</label>
                <input type="text" id="appRole" placeholder="@role-name or role ID">
                <div class="form-hint">Role that can review applications</div>
            </div>
            <div class="form-actions">
                <button class="btn-save" onclick="saveSettings()"><i class="fas fa-save"></i> Save Changes</button>
            </div>
        </div>

        <!-- ─── TICKETS ─── -->
        <div class="settings-group">
            <div class="group-header">
                <h4><i class="fas fa-ticket" style="color:var(--signal);"></i> Tickets</h4>
                <span class="status live">Live</span>
            </div>
            <p class="group-desc">Configure the ticket system for support requests.</p>
            <div class="form-group">
                <label for="ticketCategory">Ticket Category</label>
                <input type="text" id="ticketCategory" value="<%= locals.config ? (config.ticketCategory || '') : '' %>" placeholder="Category ID">
                <div class="form-hint">Category where ticket channels will be created</div>
            </div>
            <div class="form-group">
                <label for="ticketSupportRole">Support Role</label>
                <input type="text" id="ticketSupportRole" value="<%= locals.config ? (config.ticketSupportRole || '') : '' %>" placeholder="@role-name or role ID">
                <div class="form-hint">Role that can view and manage tickets</div>
            </div>
            <div class="form-actions">
                <button class="btn-save" onclick="saveSettings()"><i class="fas fa-save"></i> Save Changes</button>
            </div>
        </div>

        <!-- ─── VERIFICATION ─── -->
        <div class="settings-group">
            <div class="group-header">
                <h4><i class="fas fa-shield-halved" style="color:var(--signal);"></i> Verification</h4>
                <span class="status live">Live</span>
            </div>
            <p class="group-desc">Set up verification, auto-roles, and welcome messages.</p>
            <div class="form-group">
                <label for="verificationChannel">Verification Channel</label>
                <input type="text" id="verificationChannel" value="<%= locals.config ? (config.verificationChannel || '') : '' %>" placeholder="#channel-name or channel ID">
                <div class="form-hint">Channel where verification will take place</div>
            </div>
            <div class="form-group">
                <label for="verificationRole">Verified Role</label>
                <input type="text" id="verificationRole" value="<%= locals.config ? (config.verificationRole || '') : '' %>" placeholder="@role-name or role ID">
                <div class="form-hint">Role assigned after successful verification</div>
            </div>
            <div class="form-group">
                <label for="autorole">Auto-Role</label>
                <input type="text" id="autorole" value="<%= locals.config ? (config.autorole || '') : '' %>" placeholder="@role-name or role ID">
                <div class="form-hint">Role automatically assigned to new members</div>
            </div>
            <div class="form-actions">
                <button class="btn-save" onclick="saveSettings()"><i class="fas fa-save"></i> Save Changes</button>
            </div>
        </div>

    </div>

    <!-- ─── FOOTER ─── -->
    <footer class="footer">
        © 2026 SENTINAL — STATUS: OPERATIONAL
    </footer>

    <script>
        function saveSettings() {
            const data = {
                prefix: document.getElementById('prefix')?.value || '',
                language: document.getElementById('language')?.value || '',
                applicationChannel: document.getElementById('appChannel')?.value || '',
                ticketCategory: document.getElementById('ticketCategory')?.value || '',
                ticketSupportRole: document.getElementById('ticketSupportRole')?.value || '',
                verificationChannel: document.getElementById('verificationChannel')?.value || '',
                verificationRole: document.getElementById('verificationRole')?.value || '',
                autorole: document.getElementById('autorole')?.value || ''
            };

            fetch(`/api/config/<%= locals.guild ? guild.id : '' %>`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    alert('✅ Settings saved successfully!');
                    location.reload();
                } else {
                    alert('❌ Error: ' + data.error);
                }
            })
            .catch(error => {
                alert('❌ Error saving settings: ' + error.message);
            });
        }

        function resetSettings() {
            if (confirm('Are you sure you want to reset all settings to default?')) {
                location.reload();
            }
        }
    </script>

</body>
</html>
