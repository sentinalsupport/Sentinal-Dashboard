<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sentinal — Login</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
            min-height: 100vh;
            background: #080E1A;
            display: flex;
            justify-content: center;
            align-items: center;
            overflow: hidden;
            position: relative;
        }

        .bg-gradient {
            position: fixed;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(ellipse at 20% 50%, rgba(37, 99, 235, 0.15) 0%, transparent 60%),
                        radial-gradient(ellipse at 80% 50%, rgba(96, 165, 250, 0.10) 0%, transparent 60%),
                        radial-gradient(ellipse at 50% 100%, rgba(59, 130, 246, 0.08) 0%, transparent 50%);
            animation: rotateBg 30s linear infinite;
            z-index: 0;
        }

        @keyframes rotateBg {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }

        .grid-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-image: 
                linear-gradient(rgba(255, 255, 255, 0.02) 1px, transparent 1px),
                linear-gradient(90deg, rgba(255, 255, 255, 0.02) 1px, transparent 1px);
            background-size: 60px 60px;
            z-index: 0;
            animation: gridMove 20s linear infinite;
        }

        @keyframes gridMove {
            0% { transform: translate(0, 0); }
            100% { transform: translate(60px, 60px); }
        }

        .orb {
            position: fixed;
            border-radius: 50%;
            filter: blur(100px);
            z-index: 0;
            animation: orbFloat 12s ease-in-out infinite;
        }

        .orb-1 {
            top: -10%;
            right: -5%;
            width: 500px;
            height: 500px;
            background: rgba(37, 99, 235, 0.20);
            animation-delay: 0s;
        }

        .orb-2 {
            bottom: -15%;
            left: -10%;
            width: 450px;
            height: 450px;
            background: rgba(99, 102, 241, 0.15);
            animation-delay: -4s;
        }

        .orb-3 {
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 600px;
            height: 600px;
            background: rgba(59, 130, 246, 0.06);
            animation: orbPulse 8s ease-in-out infinite;
            filter: blur(120px);
        }

        @keyframes orbFloat {
            0%, 100% { transform: translate(0, 0) scale(1); }
            33% { transform: translate(30px, -40px) scale(1.1); }
            66% { transform: translate(-20px, 20px) scale(0.9); }
        }

        @keyframes orbPulse {
            0%, 100% { transform: translate(-50%, -50%) scale(1); opacity: 0.3; }
            50% { transform: translate(-50%, -50%) scale(1.5); opacity: 0.6; }
        }

        .login-card {
            position: relative;
            z-index: 1;
            background: rgba(10, 22, 40, 0.75);
            backdrop-filter: blur(40px);
            -webkit-backdrop-filter: blur(40px);
            border-radius: 32px;
            padding: 50px 55px 45px;
            text-align: center;
            border: 1px solid rgba(255, 255, 255, 0.06);
            box-shadow: 
                0 0 60px rgba(37, 99, 235, 0.08),
                0 30px 80px rgba(0, 0, 0, 0.4),
                inset 0 1px 0 rgba(255, 255, 255, 0.04);
            max-width: 440px;
            width: 100%;
            animation: cardIn 0.8s cubic-bezier(0.16, 1, 0.3, 1);
        }

        @keyframes cardIn {
            0% {
                opacity: 0;
                transform: translateY(40px) scale(0.96);
            }
            100% {
                opacity: 1;
                transform: translateY(0) scale(1);
            }
        }

        .login-card::before {
            content: '';
            position: absolute;
            inset: -1px;
            border-radius: 32px;
            padding: 1px;
            background: linear-gradient(135deg, rgba(96, 165, 250, 0.2), transparent 40%, transparent 60%, rgba(96, 165, 250, 0.1));
            -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
            -webkit-mask-composite: xor;
            mask-composite: exclude;
            pointer-events: none;
        }

        .logo-wrapper {
            width: 72px;
            height: 72px;
            margin: 0 auto 18px;
            background: linear-gradient(135deg, rgba(37, 99, 235, 0.2), rgba(96, 165, 250, 0.08));
            border-radius: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            border: 1px solid rgba(96, 165, 250, 0.1);
            transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
        }

        .logo-wrapper:hover {
            transform: scale(1.05) rotate(-5deg);
            border-color: rgba(96, 165, 250, 0.2);
            box-shadow: 0 0 40px rgba(37, 99, 235, 0.1);
        }

        .logo-wrapper .logo {
            font-size: 34px;
            line-height: 1;
        }

        .badge {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            background: rgba(37, 99, 235, 0.10);
            color: #60A5FA;
            padding: 4px 14px 4px 12px;
            border-radius: 100px;
            font-size: 10px;
            font-weight: 600;
            letter-spacing: 0.3px;
            text-transform: uppercase;
            margin-bottom: 14px;
            border: 1px solid rgba(96, 165, 250, 0.06);
        }

        .badge .dot-pulse {
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: #4ADE80;
            display: inline-block;
            animation: pulseDot 2s ease-in-out infinite;
        }

        @keyframes pulseDot {
            0%, 100% { opacity: 1; transform: scale(1); }
            50% { opacity: 0.3; transform: scale(0.8); }
        }

        .login-card h1 {
            font-size: 30px;
            font-weight: 800;
            color: #FFFFFF;
            margin-bottom: 4px;
            letter-spacing: -0.5px;
        }

        .login-card h1 .highlight {
            background: linear-gradient(135deg, #60A5FA, #3B82F6, #2563EB);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
        }

        .login-card .subtitle {
            color: #8B9BB5;
            margin-bottom: 28px;
            font-size: 14px;
            font-weight: 400;
            line-height: 1.7;
        }

        .login-card .subtitle span {
            color: #60A5FA;
            font-weight: 500;
        }

        .features {
            display: flex;
            gap: 8px;
            justify-content: center;
            margin-bottom: 28px;
            flex-wrap: wrap;
        }

        .feature-tag {
            background: rgba(255, 255, 255, 0.03);
            padding: 5px 14px;
            border-radius: 100px;
            font-size: 11px;
            color: #8B9BB5;
            border: 1px solid rgba(255, 255, 255, 0.04);
            display: flex;
            align-items: center;
            gap: 5px;
            transition: all 0.3s ease;
        }

        .feature-tag:hover {
            background: rgba(255, 255, 255, 0.06);
            border-color: rgba(96, 165, 250, 0.1);
            transform: translateY(-2px);
        }

        .discord-btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
            background: linear-gradient(135deg, #5865F2, #4752C4);
            color: white;
            padding: 14px 40px;
            border-radius: 60px;
            text-decoration: none;
            font-weight: 600;
            font-size: 15px;
            width: 100%;
            transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
            border: none;
            cursor: pointer;
            position: relative;
            overflow: hidden;
        }

        .discord-btn::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.1), transparent);
            transition: left 0.6s;
        }

        .discord-btn:hover::before {
            left: 100%;
        }

        .discord-btn:hover {
            transform: translateY(-2px) scale(1.01);
            box-shadow: 0 20px 50px rgba(88, 101, 242, 0.30);
            background: linear-gradient(135deg, #6873F5, #5865F2);
        }

        .discord-btn:active {
            transform: scale(0.98);
        }

        .discord-btn svg {
            width: 20px;
            height: 20px;
            fill: white;
            flex-shrink: 0;
        }

        .divider {
            display: flex;
            align-items: center;
            gap: 16px;
            margin: 22px 0 18px;
        }

        .divider::before,
        .divider::after {
            content: '';
            flex: 1;
            height: 1px;
            background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.06), transparent);
        }

        .divider span {
            color: #475569;
            font-size: 11px;
            font-weight: 500;
            letter-spacing: 0.5px;
            text-transform: uppercase;
        }

        .login-card .footer-text {
            color: #475569;
            font-size: 12px;
            line-height: 1.6;
        }

        .login-card .footer-text a {
            color: #60A5FA;
            text-decoration: none;
            transition: color 0.3s ease;
        }

        .login-card .footer-text a:hover {
            color: #93BBFC;
            text-decoration: underline;
        }

        @media (max-width: 640px) {
            .login-card {
                padding: 36px 28px 32px;
                border-radius: 24px;
                margin: 20px;
                max-width: 100%;
            }
            .login-card h1 { font-size: 24px; }
            .logo-wrapper { width: 60px; height: 60px; border-radius: 16px; }
            .logo-wrapper .logo { font-size: 28px; }
            .orb-1 { width: 300px; height: 300px; }
            .orb-2 { width: 250px; height: 250px; }
            .orb-3 { width: 400px; height: 400px; }
            .features { gap: 6px; }
            .feature-tag { font-size: 10px; padding: 4px 10px; }
            .discord-btn { padding: 12px 24px; font-size: 14px; }
            .discord-btn svg { width: 18px; height: 18px; }
        }

        @media (max-width: 400px) {
            .login-card { padding: 28px 20px 24px; }
            .login-card h1 { font-size: 20px; }
            .logo-wrapper { width: 50px; height: 50px; border-radius: 14px; }
            .logo-wrapper .logo { font-size: 22px; }
            .badge { font-size: 9px; padding: 3px 10px; }
            .discord-btn { padding: 10px 18px; font-size: 13px; }
            .discord-btn svg { width: 16px; height: 16px; }
        }
    </style>
</head>
<body>
    <div class="bg-gradient"></div>
    <div class="grid-overlay"></div>
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>
    <div class="orb orb-3"></div>

    <div class="login-card">
        <div class="logo-wrapper">
            <div class="logo">⚡</div>
        </div>

        <div class="badge">
            <span class="dot-pulse"></span>
            Live • 99.9% Uptime
        </div>

        <h1>Welcome to <span class="highlight">Sentinal</span></h1>
        <p class="subtitle">
            The complete Discord <span>application</span> &amp; <span>management</span> suite
        </p>

        <div class="features">
            <span class="feature-tag"><span>📊</span> Analytics</span>
            <span class="feature-tag"><span>🛡️</span> Moderation</span>
            <span class="feature-tag"><span>⚡</span> Custom</span>
            <span class="feature-tag"><span>🎫</span> Tickets</span>
        </div>

        <a href="/auth/discord" class="discord-btn">
            <svg viewBox="0 0 24 24">
                <path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.128 13.107 13.107 0 0 1-1.872.892.076.076 0 0 0-.041.106c.352.699.764 1.364 1.226 1.994a.078.078 0 0 0 .084.028 19.9 19.9 0 0 0 5.993-3.03.082.082 0 0 0 .031-.057c.419-4.477-.434-9.011-3.682-13.02a.07.07 0 0 0-.032-.027zM8.524 14.036c-1.167 0-2.115-1.078-2.115-2.396s.948-2.396 2.115-2.396c1.167 0 2.115 1.078 2.115 2.396s-.948 2.396-2.115 2.396zm6.95 0c-1.167 0-2.115-1.078-2.115-2.396s.948-2.396 2.115-2.396c1.167 0 2.115 1.078 2.115 2.396s-.948 2.396-2.115 2.396z" />
            </svg>
            Continue with Discord
        </a>

        <div class="divider">
            <span>Secure • Fast • Reliable</span>
        </div>

        <p class="footer-text">
            By continuing, you agree to our <a href="#">Terms of Service</a> &amp; <a href="#">Privacy Policy</a>
        </p>
    </div>
</body>
</html>
