<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title || 'Login — Sentinal' %></title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Inter', -apple-system, sans-serif;
            background: #080E1A;
            color: #E8EDF5;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .login-container {
            background: rgba(255, 255, 255, 0.02);
            border: 1px solid rgba(255, 255, 255, 0.04);
            border-radius: 20px;
            padding: 48px;
            max-width: 420px;
            width: 100%;
            text-align: center;
        }
        .login-container .logo {
            font-size: 48px;
            margin-bottom: 16px;
        }
        .login-container h1 {
            font-size: 28px;
            font-weight: 800;
            margin-bottom: 8px;
        }
        .login-container p {
            color: #8B9BB5;
            font-size: 14px;
            margin-bottom: 32px;
            line-height: 1.6;
        }
        .login-btn {
            display: inline-flex;
            align-items: center;
            gap: 12px;
            padding: 14px 36px;
            border-radius: 100px;
            background: #5865F2;
            color: #FFFFFF;
            text-decoration: none;
            font-weight: 600;
            font-size: 16px;
            transition: all 0.2s ease;
            border: none;
            cursor: pointer;
        }
        .login-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 24px rgba(88, 101, 242, 0.3);
        }
        .login-btn i {
            font-size: 20px;
        }
        .error-message {
            background: rgba(239, 68, 68, 0.1);
            border: 1px solid rgba(239, 68, 68, 0.2);
            border-radius: 8px;
            padding: 12px;
            color: #EF4444;
            font-size: 13px;
            margin-bottom: 16px;
        }
        .footer-text {
            margin-top: 24px;
            color: #5A6B85;
            font-size: 12px;
        }
        .footer-text a {
            color: #5865F2;
            text-decoration: none;
        }
    </style>
</head>
<body>
    <div class="login-container">
        <div class="logo">🛡️</div>
        <h1>Welcome to Sentinal</h1>
        <p>Sign in with Discord to manage your servers and bot settings.</p>

        <% if (locals.error) { %>
            <div class="error-message">
                <i class="fas fa-exclamation-circle"></i> <%= error %>
            </div>
        <% } %>

        <a href="<%= discordAuthUrl %>" class="login-btn">
            <i class="fab fa-discord"></i> Login with Discord
        </a>

        <div class="footer-text">
            By logging in, you agree to our <a href="#">Terms of Service</a>
        </div>
    </div>
</body>
</html>
