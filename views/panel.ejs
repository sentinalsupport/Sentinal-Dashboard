<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title || 'Panels — Sentinal' %></title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@400;500;600;700;800&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --ink: #060A10;
            --panel: #0D1520;
            --panel-raised: #111D2C;
            --panel-hover: #162033;
            --line: rgba(255,255,255,0.07);
            --line-bright: rgba(255,255,255,0.13);
            --text: #E6EDF6;
            --muted: #6C7A90;
            --muted-dim: #3E4A5C;
            --signal: #3DFFB8;
            --signal-tab: rgba(61,255,184,0.10);
            --signal-glow: rgba(61,255,184,0.15);
            --gold: #F5C842;
            --gold-tab: rgba(245,200,66,0.12);
            --violet: #8B7EFF;
            --violet-tab: rgba(139,126,255,0.12);
            --red: #F87171;
            --red-bg: rgba(248,113,113,0.08);
            --red-border: rgba(248,113,113,0.22);
            --discord: #5865F2;
        }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Inter', -apple-system, sans-serif;
            background: var(--ink);
            color: var(--text);
            min-height: 100vh;
        }

        .navbar {
            background: rgba(6,10,16,0.9);
            backdrop-filter: blur(28px) saturate(160%);
            border-bottom: 1px solid var(--line);
            padding: 0 40px;
            height: 64px;
            display: flex; align-items: center; justify-content: space-between;
            position: sticky; top: 0; z-index: 200;
        }
        .brand { display: flex; align-items: center; gap: 10px; text-decoration: none; }
        .brand-logo {
            width: 36px; height: 36px; border-radius: 10px;
            background: var(--panel-raised); border: 1px solid var(--line-bright);
            display: flex; align-items: center; justify-content: center;
        }
        .brand-logo svg { width: 20px; height: 20px; }
        .brand-name {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 17px; font-weight: 700; color: #fff; letter-spacing: -0.3px;
        }
        .nav-center { display: flex; align-items: center; gap: 4px; }
        .nav-center a {
            color: var(--muted); text-decoration: none; font-size: 13.5px; font-weight: 500;
            padding: 6px 14px; border-radius: 8px; transition: all 0.18s ease;
        }
        .nav-center a:hover { color: var(--text); background: rgba(255,255,255,0.05); }
        .nav-center a.active { color: #fff; }
        .nav-right { display: flex; align-items: center; gap: 12px; }
        .user-pill {
            display: flex; align-items: center; gap: 9px;
            background: var(--panel); border: 1px solid var(--line);
            border-radius: 100px; padding: 5px 14px 5px 6px;
        }
        .user-avatar {
            width: 28px; height: 28px; border-radius: 50%;
            background: var(--panel-raised); overflow: hidden;
            display: flex; align-items: center; justify-content: center;
            font-size: 12px; font-weight: 700;
        }
        .user-avatar img { width: 100%; height: 100%; object-fit: cover; }
        .user-name { font-size: 13px; font-weight: 500; color: var(--text); }
        .user-plan {
            font-size: 10px; font-weight: 600; color: var(--signal);
            background: var(--signal-tab); border: 1px solid rgba(61,255,184,0.22);
            border-radius: 100px; padding: 2px 8px; letter-spacing: 0.3px;
        }
        .logout-btn {
            background: transparent; border: 1px solid var(--line); border-radius: 8px;
            padding: 7px 12px; color: var(--muted); cursor: pointer; font-size: 13px;
            transition: all 0.18s ease; text-decoration: none;
            display: flex; align-items: center; gap: 6px;
        }
        .logout-btn:hover { background: var(--red-bg); border-color: var(--red-border); color: var(--red); }

        .page-wrapper { max-width: 1100px; margin: 0 auto; padding: 0 32px 60px; }

        .page-header {
            display: flex; justify-content: space-between; align-items: center;
            padding: 28px 0 20px;
            border-bottom: 1px solid var(--line);
            margin-bottom: 28px;
            flex-wrap: wrap;
            gap: 16px;
        }
        .page-header .left h1 {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 24px; font-weight: 700; color: #fff;
        }
        .page-header .left p {
            font-size: 13px; color: var(--muted);
        }
        .page-header .left h1 i {
            color: var(--signal);
            margin-right: 10px;
        }

        .btn-primary {
            padding: 10px 24px; border-radius: 10px;
            background: var(--signal); color: #04140F;
            border: none; font-weight: 700; font-size: 13px;
            cursor: pointer; transition: all 0.18s ease;
            text-decoration: none; display: inline-flex; align-items: center; gap: 8px;
        }
        .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 4px 18px var(--signal-glow); }

        .btn-secondary {
            padding: 8px 20px; border-radius: 8px;
            background: transparent; color: var(--muted);
            border: 1px solid var(--line); font-weight: 600; font-size: 13px;
            cursor: pointer; transition: all 0.18s ease;
            text-decoration: none; display: inline-flex; align-items: center; gap: 7px;
        }
        .btn-secondary:hover { background: rgba(255,255,255,0.04); color: var(--text); }

        .btn-danger {
            padding: 8px 20px; border-radius: 8px;
            background: var(--red-bg); color: var(--red);
            border: 1px solid var(--red-border); font-weight: 600; font-size: 13px;
            cursor: pointer; transition: all 0.18s ease;
            text-decoration: none; display: inline-flex; align-items: center; gap: 7px;
        }
        .btn-danger:hover { background: var(--red); color: #fff; }

        .section-card {
            background: var(--panel);
            border: 1px solid var(--line);
            border-radius: 12px;
            padding: 24px;
            margin-bottom: 16px;
        }
        .section-card .section-header {
            display: flex; justify-content: space-between; align-items: center;
            margin-bottom: 6px; flex-wrap: wrap; gap: 8px;
        }
        .section-card .section-header h3 {
            font-size: 15px; font-weight: 600; color: #fff;
        }
        .section-card .section-header .badge {
            font-size: 10px; font-weight: 600;
            padding: 2px 10px; border-radius: 100px;
            background: var(--signal-tab); color: var(--signal);
            border: 1px solid rgba(61,255,184,0.2);
        }
        .section-card .section-desc {
            font-size: 13px; color: var(--muted);
            margin-bottom: 16px;
        }

        .panel-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 14px;
            margin-bottom: 16px;
        }

        .panel-item {
            background: var(--panel-raised);
            border: 1px solid var(--line);
            border-radius: 10px;
            padding: 18px 20px;
            display: flex;
            flex-direction: column;
            gap: 10px;
            transition: all 0.2s ease;
        }
        .panel-item:hover {
            border-color: var(--line-bright);
        }
        .panel-item .panel-header {
            display: flex; justify-content: space-between; align-items: center;
        }
        .panel-item .panel-header .panel-name {
            font-weight: 600;
            font-size: 15px;
        }
        .panel-item .panel-header .panel-status {
            font-size: 10px; font-weight: 600;
            padding: 2px 10px; border-radius: 100px;
        }
        .panel-item .panel-header .panel-status.active {
            background: var(--signal-tab); color: var(--signal);
            border: 1px solid rgba(61,255,184,0.2);
        }
        .panel-item .panel-header .panel-status.inactive {
            background: var(--muted-dim); color: var(--muted);
            border: 1px solid var(--line);
        }
        .panel-item .panel-desc {
            font-size: 13px; color: var(--muted);
        }
        .panel-item .panel-actions {
            display: flex; gap: 8px; flex-wrap: wrap;
            margin-top: 4px;
        }
        .panel-item .panel-actions .btn-sm {
            padding: 5px 14px; border-radius: 6px;
            font-size: 12px; font-weight: 600;
            cursor: pointer; border: 1px solid var(--line);
            background: transparent; color: var(--muted);
            text-decoration: none; transition: all 0.18s ease;
        }
        .panel-item .panel-actions .btn-sm:hover {
            background: rgba(255,255,255,0.04); color: var(--text);
        }
        .panel-item .panel-actions .btn-sm.primary {
            background: var(--signal-tab); border-color: rgba(61,255,184,0.3);
            color: var(--signal);
        }
        .panel-item .panel-actions .btn-sm.primary:hover {
            background: rgba(61,255,184,0.2);
        }
        .panel-item .panel-actions .btn-sm.danger {
            color: var(--red); border-color: var(--red-border);
        }
        .panel-item .panel-actions .btn-sm.danger:hover {
            background: var(--red-bg);
        }

        .empty-state {
            text-align: center; padding: 60px 20px;
            color: var(--muted);
        }
        .empty-state i {
            font-size: 40px; color: var(--signal);
            margin-bottom: 16px; display: block;
        }
        .empty-state h3 {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 17px; color: #fff; margin-bottom: 4px;
        }
        .empty-state p { font-size: 13px; }

        .form-group { margin-bottom: 14px; }
        .form-group label {
            display: block; font-size: 12px; font-weight: 600;
            margin-bottom: 4px; color: var(--text);
        }
        .form-group .form-hint {
            font-size: 11px; color: var(--muted-dim); margin-top: 2px;
        }
        .form-group input, .form-group select {
            width: 100%; padding: 9px 14px;
            border-radius: 8px; border: 1px solid var(--line);
            background: rgba(0,0,0,0.3); color: var(--text);
            font-size: 13px; font-family: 'Inter', sans-serif;
            transition: all 0.18s ease; outline: none;
        }
        .form-group input:focus, .form-group select:focus {
            border-color: var(--signal);
            box-shadow: 0 0 0 3px var(--signal-glow);
        }
        .form-group select option { background: var(--ink); }

        .modal-overlay {
            display: none;
            position: fixed; inset: 0;
            background: rgba(0,0,0,0.7);
            backdrop-filter: blur(4px);
            z-index: 300;
            align-items: center; justify-content: center;
            padding: 20px;
        }
        .modal-overlay.active {
            display: flex;
        }
        .modal {
            background: var(--panel);
            border: 1px solid var(--line);
            border-radius: 16px;
            padding: 32px;
            max-width: 500px;
            width: 100%;
            max-height: 90vh;
            overflow-y: auto;
        }
        .modal .modal-header {
            display: flex; justify-content: space-between; align-items: center;
            margin-bottom: 20px;
        }
        .modal .modal-header h2 {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 20px; font-weight: 700; color: #fff;
        }
        .modal .modal-header .close-btn {
            background: none; border: none;
            color: var(--muted); font-size: 20px; cursor: pointer;
        }
        .modal .modal-header .close-btn:hover { color: var(--text); }
        .modal .form-actions {
            display: flex; gap: 10px; flex-wrap: wrap;
            margin-top: 16px;
        }
        .modal .btn-save {
            padding: 8px 28px; border-radius: 8px; border: none;
            font-weight: 600; font-size: 13px; cursor: pointer;
            background: var(--signal); color: #04140F;
            transition: all 0.18s ease;
        }
        .modal .btn-save:hover { transform: translateY(-1px); box-shadow: 0 4px 18px var(--signal-glow); }
        .modal .btn-cancel {
            padding: 8px 28px; border-radius: 8px;
            border: 1px solid var(--line); background: transparent;
            color: var(--muted); font-weight: 600; font-size: 13px; cursor: pointer;
            transition: all 0.18s ease;
        }
        .modal .btn-cancel:hover { background: rgba(255,255,255,0.04); color: var(--text); }

        .footer {
            border-top: 1px solid var(--line); margin-top: 60px;
            padding: 24px 40px; text-align: center;
            color: var(--muted-dim); font-size: 12px;
            font-family: 'IBM Plex Mono', monospace; letter-spacing: 0.5px;
        }

        @media (max-width: 768px) {
            .navbar { padding: 0 16px; }
            .nav-center { display: none; }
            .page-wrapper { padding: 0 16px 48px; }
            .section-card { padding: 16px; }
            .panel-grid { grid-template-columns: 1fr; }
            .page-header { flex-direction: column; align-items: stretch; }
            .page-header .btn-primary { width: 100%; justify-content: center; }
            .modal { padding: 20px; }
        }
    </style>
</head>
<body>

    <nav class="navbar">
        <a href="/dashboard" class="brand">
            <div class="brand-logo">
                <svg viewBox="0 0 245 240" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M104.4 103.9c-5.7 0-10.2 5-10.2 11.1s4.6 11.1 10.2 11.1c5.7 0 10.2-5 10.2-11.1.1-6.1-4.5-11.1-10.2-11.1zM140.9 103.9c-5.7 0-10.2 5-10.2 11.1s4.6 11.1 10.2 11.1c5.7 0 10.2-5 10.2-11.1s-4.5-11.1-10.2-11.1z" fill="#3DFFB8"/>
                    <path d="M189.5 20H55.5C44.7 20 36 28.7 36 39.5v140.9c0 10.8 8.7 19.5 19.5 19.5h113.5l-5.3-18.5 12.8 11.9 12.1 11.2L209 220V39.5C209 28.7 200.3 20 189.5 20zM155.7 152.1s-3.6-4.3-6.6-8.1c13.1-3.7 18.1-11.9 18.1-11.9-4.1 2.7-8 4.6-11.5 5.9-5 2.1-9.8 3.5-14.5 4.3-9.6 1.8-18.4 1.3-25.9-.1-5.7-1.1-10.6-2.6-14.7-4.3-2.3-.9-4.8-2-7.3-3.4-.3-.2-.6-.3-.9-.5-.2-.1-.3-.2-.4-.3-2-1.1-3.1-1.9-3.1-1.9 4.7 4.3 9.3 6.5 21.7 10.2-2.9 3.8-6.6 8.1-6.6 8.1-22 0-32.1-15.2-32.1-15.2 0-32.2 14.4-58.4 14.4-58.4 14.4-10.8 28.1-10.5 28.1-10.5l1 1.2C99.2 87.7 87.9 97.4 87.9 97.4s2.9-1.6 7.8-3.8c14.1-6.2 25.3-7.9 29.9-8.3.8-.1 1.5-.2 2.3-.2 8.2-1 17.5-1.3 27.2.2 12.9 2 26.7 7.5 40.8 17.3 0 0-10.8-10.2-28.5-13.7l1.4-1.6s13.7-.3 28.1 10.5c0 0 14.4 26.2 14.4 58.4 0 0-10.2 15.2-32.1 15.2z" fill="#3DFFB8"/>
                </svg>
            </div>
            <span class="brand-name">Sentinal</span>
        </a>
        <div class="nav-center">
            <a href="/dashboard">Home</a>
            <a href="/servers">Servers</a>
            <a href="#" onclick="window.open('https://discord.gg/UmqmewYWRd','_blank'); return false;">Support</a>
            <a href="#">Premium</a>
        </div>
        <div class="nav-right">
            <div class="user-pill">
                <div class="user-avatar">
                    <% if (locals.user && user.avatar) { %>
                        <img src="https://cdn.discordapp.com/avatars/<%= user.id %>/<%= user.avatar %>.png" alt="Avatar">
                    <% } else { %>
                        <%= locals.user ? (user.username ? user.username.charAt(0).toUpperCase() : 'U') : 'U' %>
                    <% } %>
                </div>
                <span class="user-name"><%= locals.user ? (user.global_name || user.username) : 'User' %></span>
                <span class="user-plan">Free</span>
            </div>
            <a href="/logout" class="logout-btn"><i class="fas fa-sign-out-alt"></i></a>
        </div>
    </nav>

    <div class="page-wrapper">

        <div class="page-header">
            <div class="left">
                <h1><i class="fas fa-layer-group"></i> Panels</h1>
                <p>Manage your application panels</p>
            </div>
            <button class="btn-primary" onclick="openCreatePanel()">
                <i class="fas fa-plus"></i> New Panel
            </button>
        </div>

        <!-- Panel Grid -->
        <div class="panel-grid">
            <% if (locals.panels && panels.length > 0) { %>
                <% panels.forEach(function(panel) { %>
                    <div class="panel-item">
                        <div class="panel-header">
                            <span class="panel-name"><%= panel.name || 'Untitled Panel' %></span>
                            <span class="panel-status <%= panel.enabled ? 'active' : 'inactive' %>">
                                <%= panel.enabled ? 'Active' : 'Inactive' %>
                            </span>
                        </div>
                        <div class="panel-desc"><%= panel.description || 'No description' %></div>
                        <div class="panel-actions">
                            <a href="/panels/edit/<%= panel._id %>?guildId=<%= locals.guild ? guild.id : '' %>" class="btn-sm primary">
                                <i class="fas fa-edit"></i> Edit
                            </a>
                            <button class="btn-sm" onclick="togglePanel('<%= panel._id %>')">
                                <i class="fas fa-<%= panel.enabled ? 'pause' : 'play' %>"></i> <%= panel.enabled ? 'Disable' : 'Enable' %>
                            </button>
                            <button class="btn-sm danger" onclick="deletePanel('<%= panel._id %>')">
                                <i class="fas fa-trash"></i> Delete
                            </button>
                        </div>
                    </div>
                <% }); %>
            <% } else { %>
                <div class="empty-state">
                    <i class="fas fa-layer-group"></i>
                    <h3>No Panels Created</h3>
                    <p>Create your first application panel to get started.</p>
                    <button class="btn-primary" onclick="openCreatePanel()" style="margin-top:12px;">
                        <i class="fas fa-plus"></i> Create Panel
                    </button>
                </div>
            <% } %>
        </div>

    </div>

    <!-- Create Panel Modal -->
    <div class="modal-overlay" id="createPanelModal">
        <div class="modal">
            <div class="modal-header">
                <h2>Create New Panel</h2>
                <button class="close-btn" onclick="closeModal('createPanelModal')">&times;</button>
            </div>
            <div class="form-group">
                <label for="panelName">Panel Name</label>
                <input type="text" id="panelName" placeholder="Staff Applications" value="Staff Applications">
                <div class="form-hint">The name of your application panel</div>
            </div>
            <div class="form-group">
                <label for="panelDescription">Description</label>
                <input type="text" id="panelDescription" placeholder="Apply for staff positions" value="Apply for staff positions">
                <div class="form-hint">A brief description of this panel</div>
            </div>
            <div class="form-group">
                <label for="panelChannel">Channel</label>
                <input type="text" id="panelChannel" placeholder="#applications" value="#applications">
                <div class="form-hint">Channel where the panel will be displayed</div>
            </div>
            <div class="form-group">
                <label for="panelApplication">Application Form</label>
                <select id="panelApplication">
                    <option value="">Select an application form...</option>
                    <option value="staff">Staff Application</option>
                    <option value="partner">Partner Application</option>
                    <option value="event">Event Application</option>
                </select>
                <div class="form-hint">The application form this panel will use</div>
            </div>
            <div class="form-actions">
                <button class="btn-save" onclick="createPanel()">Create Panel</button>
                <button class="btn-cancel" onclick="closeModal('createPanelModal')">Cancel</button>
            </div>
        </div>
    </div>

    <footer class="footer">
        © 2026 SENTINAL — STATUS: OPERATIONAL
    </footer>

    <script>
        function openCreatePanel() {
            document.getElementById('createPanelModal').classList.add('active');
        }

        function closeModal(id) {
            document.getElementById(id).classList.remove('active');
        }

        function createPanel() {
            const data = {
                name: document.getElementById('panelName').value,
                description: document.getElementById('panelDescription').value,
                channel: document.getElementById('panelChannel').value,
                applicationId: document.getElementById('panelApplication').value,
                enabled: true,
                guildId: '<%= locals.guild ? guild.id : "" %>'
            };

            fetch('/api/panels', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    alert('✅ Panel created successfully!');
                    location.reload();
                } else {
                    alert('❌ Error: ' + data.error);
                }
            })
            .catch(error => {
                alert('❌ Error creating panel: ' + error.message);
            });
        }

        function togglePanel(panelId) {
            fetch(`/api/panels/${panelId}/toggle`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' }
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    location.reload();
                } else {
                    alert('❌ Error: ' + data.error);
                }
            })
            .catch(error => {
                alert('❌ Error toggling panel: ' + error.message);
            });
        }

        function deletePanel(panelId) {
            if (confirm('Are you sure you want to delete this panel?')) {
                fetch(`/api/panels/${panelId}`, {
                    method: 'DELETE'
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        alert('✅ Panel deleted successfully!');
                        location.reload();
                    } else {
                        alert('❌ Error: ' + data.error);
                    }
                })
                .catch(error => {
                    alert('❌ Error deleting panel: ' + error.message);
                });
            }
        }
    </script>

</body>
</html>
