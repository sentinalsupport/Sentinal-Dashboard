<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title || 'Applications — Sentinal' %></title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@400;500;600;700;800&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --ink: #060A10;
            --panel: #0D1520;
            --panel-raised: #111D2C;
            --panel-hover: #162033;
            --line: rgba(255,255,255,0.07);
            --line-bright: rgba(255,255,255,0.13);
            --text: #E6EDF6;
            --muted: #6C7A90;
            --muted-dim: #3E4A5C;
            --signal: #3DFFB8;
            --signal-tab: rgba(61,255,184,0.08);
            --signal-glow: rgba(61,255,184,0.15);
            --gold: #F5C842;
            --gold-tab: rgba(245,200,66,0.12);
            --violet: #8B7EFF;
            --violet-tab: rgba(139,126,255,0.12);
            --red: #F87171;
            --red-bg: rgba(248,113,113,0.08);
            --red-border: rgba(248,113,113,0.22);
            --discord: #5865F2;
            --discord-hover: #4752C4;
        }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Inter', -apple-system, sans-serif;
            background: var(--ink);
            color: var(--text);
            min-height: 100vh;
            overflow-x: hidden;
        }

        /* ─── NAVBAR ─── */
        .navbar {
            background: rgba(6,10,16,0.9);
            backdrop-filter: blur(28px) saturate(160%);
            border-bottom: 1px solid var(--line);
            padding: 0 48px;
            height: 72px;
            display: flex; align-items: center; justify-content: space-between;
            position: sticky; top: 0; z-index: 200;
        }
        .brand { display: flex; align-items: center; gap: 12px; text-decoration: none; }
        .brand-logo {
            width: 40px; height: 40px; border-radius: 12px;
            background: var(--panel-raised); border: 1px solid var(--line-bright);
            display: flex; align-items: center; justify-content: center;
        }
        .brand-logo svg { width: 22px; height: 22px; }
        .brand-name {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 20px; font-weight: 700; color: #fff; letter-spacing: -0.3px;
        }
        .nav-center { display: flex; align-items: center; gap: 8px; }
        .nav-center a {
            color: var(--muted); text-decoration: none; font-size: 15px; font-weight: 500;
            padding: 8px 18px; border-radius: 10px; transition: all 0.18s ease;
        }
        .nav-center a:hover { color: var(--text); background: rgba(255,255,255,0.05); }
        .nav-center a.active { color: #fff; }
        .nav-right { display: flex; align-items: center; gap: 16px; }
        .user-pill {
            display: flex; align-items: center; gap: 12px;
            background: var(--panel); border: 1px solid var(--line);
            border-radius: 100px; padding: 6px 18px 6px 8px;
        }
        .user-avatar {
            width: 32px; height: 32px; border-radius: 50%;
            background: var(--panel-raised); overflow: hidden;
            display: flex; align-items: center; justify-content: center;
            font-size: 14px; font-weight: 700;
        }
        .user-avatar img { width: 100%; height: 100%; object-fit: cover; }
        .user-name { font-size: 14px; font-weight: 500; color: var(--text); }
        .user-plan {
            font-size: 11px; font-weight: 600; color: var(--signal);
            background: var(--signal-tab); border: 1px solid rgba(61,255,184,0.22);
            border-radius: 100px; padding: 3px 10px; letter-spacing: 0.3px;
        }
        .logout-btn {
            background: transparent; border: 1px solid var(--line); border-radius: 10px;
            padding: 8px 14px; color: var(--muted); cursor: pointer; font-size: 14px;
            transition: all 0.18s ease; text-decoration: none;
            display: flex; align-items: center; gap: 8px;
        }
        .logout-btn:hover { background: var(--red-bg); border-color: var(--red-border); color: var(--red); }

        /* ─── PAGE ─── */
        .page-wrapper {
            max-width: 1200px;
            margin: 0 auto;
            padding: 32px 48px 60px;
        }

        /* ─── TOAST ─── */
        .toast-container {
            position: fixed;
            bottom: 24px;
            right: 24px;
            z-index: 9999;
            display: flex;
            flex-direction: column;
            gap: 10px;
            max-width: 380px;
            width: 100%;
        }
        .toast {
            background: var(--panel);
            border: 1px solid var(--line);
            border-radius: 12px;
            padding: 14px 20px;
            display: flex;
            align-items: center;
            gap: 12px;
            box-shadow: 0 8px 32px rgba(0,0,0,0.4);
            animation: slideIn 0.3s ease;
            backdrop-filter: blur(10px);
            border-left: 4px solid var(--signal);
        }
        .toast .toast-icon { color: var(--signal); font-size: 18px; flex-shrink: 0; }
        .toast .toast-content { flex: 1; font-size: 13px; color: var(--text); line-height: 1.4; }
        .toast .toast-close {
            background: none; border: none;
            color: var(--muted-dim); cursor: pointer;
            font-size: 14px; padding: 4px;
        }
        .toast .toast-close:hover { color: var(--text); }
        .toast.error { border-left-color: var(--red); }
        .toast.error .toast-icon { color: var(--red); }
        @keyframes slideIn {
            from { opacity: 0; transform: translateX(40px); }
            to { opacity: 1; transform: translateX(0); }
        }
        @keyframes slideOut {
            from { opacity: 1; transform: translateX(0); }
            to { opacity: 0; transform: translateX(40px); }
        }
        .toast.hiding { animation: slideOut 0.3s ease forwards; }

        /* ─── PAGE HEADER ─── */
        .page-header {
            display: flex; justify-content: space-between; align-items: center;
            padding: 20px 0 16px;
            border-bottom: 1px solid var(--line);
            margin-bottom: 28px;
            flex-wrap: wrap;
            gap: 16px;
        }
        .page-header .left h1 {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 24px; font-weight: 700; color: #fff;
        }
        .page-header .left p {
            font-size: 14px; color: var(--muted);
        }
        .page-header .left h1 i {
            color: var(--signal);
            margin-right: 10px;
        }

        /* ─── GETTING STARTED ─── */
        .getting-started {
            background: var(--panel);
            border: 1px solid var(--line);
            border-radius: 14px;
            padding: 28px 32px;
            margin-bottom: 24px;
        }
        .getting-started h2 {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 18px; font-weight: 700; color: #fff;
            margin-bottom: 12px;
        }
        .getting-started ol {
            list-style: none;
            padding: 0;
            margin: 0 0 12px 0;
        }
        .getting-started ol li {
            font-size: 14px; color: var(--muted);
            padding: 4px 0;
            display: flex; align-items: flex-start;
            gap: 10px;
            line-height: 1.6;
        }
        .getting-started ol li .num { color: var(--signal); font-weight: 700; font-size: 14px; min-width: 20px; }
        .getting-started .help-link { color: var(--signal); text-decoration: none; font-size: 13px; font-weight: 500; }
        .getting-started .help-link:hover { text-decoration: underline; }

        /* ─── KEY FEATURES ─── */
        .key-features {
            background: var(--panel);
            border: 1px solid var(--line);
            border-radius: 14px;
            padding: 28px 32px;
            margin-bottom: 24px;
        }
        .key-features h2 {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 18px; font-weight: 700; color: #fff;
            margin-bottom: 12px;
        }
        .key-features ul {
            list-style: none;
            padding: 0; margin: 0;
        }
        .key-features ul li {
            font-size: 14px; color: var(--muted);
            padding: 4px 0;
            display: flex; align-items: center; gap: 10px;
        }
        .key-features ul li i { color: var(--signal); font-size: 14px; width: 18px; }

        /* ─── CREATE APP SECTION ─── */
        .create-app-section {
            display: flex; gap: 20px; margin-bottom: 28px; flex-wrap: wrap;
        }
        .create-app-card {
            background: var(--panel);
            border: 1px solid var(--line);
            border-radius: 14px;
            padding: 24px 28px;
            flex: 1; min-width: 280px;
            display: flex; align-items: center; gap: 20px;
            transition: all 0.2s ease;
        }
        .create-app-card:hover { border-color: var(--line-bright); }
        .create-app-card .icon-wrap {
            width: 48px; height: 48px; border-radius: 12px;
            background: var(--signal-tab); border: 1px solid rgba(61,255,184,0.2);
            display: flex; align-items: center; justify-content: center;
            font-size: 20px; color: var(--signal); flex-shrink: 0;
        }
        .create-app-card .info h3 { font-size: 15px; font-weight: 600; color: #fff; margin-bottom: 2px; }
        .create-app-card .info p { font-size: 13px; color: var(--muted); }
        .create-app-card .info .watch-link { color: var(--signal); text-decoration: none; font-size: 13px; font-weight: 500; }
        .create-app-card .info .watch-link:hover { text-decoration: underline; }

        /* ─── APPLICATIONS HEADER ─── */
        .apps-header {
            display: flex; justify-content: space-between; align-items: center;
            margin-bottom: 16px; flex-wrap: wrap; gap: 12px;
        }
        .apps-header .left h3 {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 18px; font-weight: 700; color: #fff;
        }
        .apps-header .left .count { font-size: 13px; color: var(--muted); }
        .apps-header .right { display: flex; align-items: center; gap: 12px; flex-wrap: wrap; }
        .apps-header .right .search-apps {
            padding: 8px 16px; border-radius: 10px;
            border: 1px solid var(--line); background: var(--panel);
            color: var(--text); font-size: 13px; font-family: 'Inter', sans-serif;
            outline: none; width: 220px;
        }
        .apps-header .right .search-apps:focus { border-color: var(--signal); box-shadow: 0 0 0 3px var(--signal-glow); }
        .apps-header .right .search-apps::placeholder { color: var(--muted-dim); }
        .btn-new {
            padding: 10px 24px; border-radius: 10px;
            background: var(--signal); color: #04140F;
            border: none; font-weight: 700; font-size: 13px;
            cursor: pointer; transition: all 0.18s ease;
            text-decoration: none; display: inline-flex; align-items: center; gap: 8px;
            white-space: nowrap;
        }
        .btn-new:hover { transform: translateY(-2px); box-shadow: 0 4px 18px var(--signal-glow); }

        /* ─── APP CARDS GRID ─── */
        .apps-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
            gap: 16px;
            margin-bottom: 8px;
        }

        /* ─── APP CARD ─── */
        .app-card {
            background: var(--panel);
            border: 1px solid var(--line);
            border-radius: 14px;
            padding: 20px 24px;
            transition: all 0.2s ease;
            display: flex;
            flex-direction: column;
        }
        .app-card:hover {
            border-color: var(--line-bright);
        }
        .app-card .app-card-header {
            display: flex; justify-content: space-between; align-items: center;
            margin-bottom: 6px;
        }
        .app-card .app-card-header .app-name {
            font-weight: 600;
            font-size: 16px;
            color: #fff;
        }
        .app-card .app-card-header .app-status {
            font-size: 10px; font-weight: 600;
            padding: 2px 12px; border-radius: 100px;
        }
        .app-card .app-card-header .app-status.enabled {
            background: var(--signal-tab); color: var(--signal);
            border: 1px solid rgba(61,255,184,0.2);
        }
        .app-card .app-card-header .app-status.disabled {
            background: var(--muted-dim); color: var(--muted);
            border: 1px solid var(--line);
        }
        .app-card .app-card-desc {
            font-size: 13px;
            color: var(--muted);
            margin-bottom: 14px;
            line-height: 1.5;
            flex: 1;
        }
        .app-card .app-card-actions {
            display: flex; gap: 8px; flex-wrap: wrap;
            margin-top: auto;
        }
        .app-card .app-card-actions .btn-edit,
        .app-card .app-card-actions .btn-toggle,
        .app-card .app-card-actions .btn-delete {
            padding: 6px 14px;
            border-radius: 8px;
            font-size: 12px;
            font-weight: 600;
            cursor: pointer;
            border: 1px solid var(--line);
            background: transparent;
            color: var(--muted);
            transition: all 0.18s ease;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 6px;
        }
        .app-card .app-card-actions .btn-edit:hover {
            background: rgba(61,255,184,0.1);
            color: var(--signal);
            border-color: rgba(61,255,184,0.2);
        }
        .app-card .app-card-actions .btn-toggle:hover {
            background: rgba(245,200,66,0.1);
            color: var(--gold);
            border-color: rgba(245,200,66,0.2);
        }
        .app-card .app-card-actions .btn-delete:hover {
            background: var(--red-bg);
            color: var(--red);
            border-color: var(--red-border);
        }

        /* ─── EMPTY STATE ─── */
        .empty-state {
            background: var(--panel);
            border: 1px solid var(--line);
            border-radius: 14px;
            padding: 60px 20px;
            text-align: center;
            color: var(--muted);
        }
        .empty-state i { font-size: 40px; color: var(--signal); margin-bottom: 16px; display: block; }
        .empty-state h3 { font-family: 'Space Grotesk', sans-serif; font-size: 18px; color: #fff; margin-bottom: 4px; }
        .empty-state p { font-size: 14px; }

        /* ─── MODAL ─── */
        .modal-overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,0.8);
            backdrop-filter: blur(8px);
            z-index: 1000;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }
        .modal-overlay.active { display: flex; }
        .modal {
            background: var(--panel);
            border: 1px solid var(--line);
            border-radius: 16px;
            padding: 32px;
            max-width: 480px;
            width: 100%;
            max-height: 90vh;
            overflow-y: auto;
            animation: fadeIn 0.25s ease;
        }
        .modal .modal-header {
            display: flex; justify-content: space-between; align-items: center;
            margin-bottom: 20px;
        }
        .modal .modal-header h2 {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 22px; font-weight: 700; color: #fff;
        }
        .modal .modal-header .close-btn {
            background: none; border: none;
            color: var(--muted); font-size: 24px; cursor: pointer;
            padding: 4px 8px; border-radius: 8px;
            transition: all 0.18s ease;
        }
        .modal .modal-header .close-btn:hover { color: var(--text); background: rgba(255,255,255,0.04); }
        .modal .form-group { margin-bottom: 6px; }
        .modal .form-group label {
            display: block; font-size: 13px; font-weight: 600;
            margin-bottom: 4px; color: var(--text);
        }
        .modal .form-group .form-hint {
            font-size: 11px; color: var(--muted-dim); margin-top: 2px;
        }
        .modal .form-group input {
            width: 100%; padding: 10px 14px;
            border-radius: 10px; border: 1px solid var(--line);
            background: rgba(0,0,0,0.3); color: var(--text);
            font-size: 13px; font-family: 'Inter', sans-serif;
            transition: all 0.18s ease; outline: none;
        }
        .modal .form-group input:focus {
            border-color: var(--signal);
            box-shadow: 0 0 0 3px var(--signal-glow);
        }
        .modal .form-group input.error {
            border-color: var(--red);
            box-shadow: 0 0 0 3px var(--red-border);
        }
        .modal .form-group .error-msg {
            color: var(--red);
            font-size: 12px;
            margin-top: 4px;
            display: none;
        }
        .modal .form-group .error-msg.show { display: block; }
        .modal .form-actions {
            display: flex; gap: 12px; flex-wrap: wrap;
            margin-top: 20px;
        }
        .modal .btn-save {
            padding: 10px 32px; border-radius: 10px;
            border: none; font-weight: 700; font-size: 14px;
            cursor: pointer; transition: all 0.18s ease;
            background: var(--signal); color: #04140F;
        }
        .modal .btn-save:hover { transform: translateY(-2px); box-shadow: 0 4px 18px var(--signal-glow); }
        .modal .btn-save:disabled {
            opacity: 0.5;
            cursor: not-allowed;
            transform: none !important;
            box-shadow: none !important;
        }
        .modal .btn-cancel {
            padding: 10px 32px; border-radius: 10px;
            border: 1px solid var(--line); background: transparent;
            color: var(--muted); font-weight: 600; font-size: 14px;
            cursor: pointer; transition: all 0.18s ease;
        }
        .modal .btn-cancel:hover { background: rgba(255,255,255,0.04); color: var(--text); }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(8px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .footer {
            border-top: 1px solid var(--line);
            margin-top: 60px;
            padding: 28px 48px;
            text-align: center;
            color: var(--muted-dim);
            font-size: 13px;
            font-family: 'IBM Plex Mono', monospace;
            letter-spacing: 0.5px;
        }

        @media (max-width: 768px) {
            .navbar { padding: 0 16px; height: 64px; flex-wrap: wrap; }
            .nav-center { display: none; }
            .page-wrapper { padding: 16px; }
            .page-header { flex-direction: column; align-items: stretch; }
            .apps-header { flex-direction: column; align-items: stretch; }
            .apps-header .right { flex-direction: column; }
            .apps-header .right .search-apps { width: 100%; }
            .btn-new { justify-content: center; }
            .create-app-section { flex-direction: column; }
            .create-app-card { flex-direction: column; text-align: center; }
            .getting-started, .key-features { padding: 20px; }
            .apps-grid { grid-template-columns: 1fr; }
            .app-card { padding: 16px 18px; }
            .modal { padding: 24px; }
            .footer { padding: 20px 16px; }
        }
    </style>
</head>
<body>

    <!-- ─── NAVBAR ─── -->
    <nav class="navbar">
        <a href="/dashboard" class="brand">
            <div class="brand-logo">
                <svg viewBox="0 0 245 240" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M104.4 103.9c-5.7 0-10.2 5-10.2 11.1s4.6 11.1 10.2 11.1c5.7 0 10.2-5 10.2-11.1.1-6.1-4.5-11.1-10.2-11.1zM140.9 103.9c-5.7 0-10.2 5-10.2 11.1s4.6 11.1 10.2 11.1c5.7 0 10.2-5 10.2-11.1s-4.5-11.1-10.2-11.1z" fill="#3DFFB8"/>
                    <path d="M189.5 20H55.5C44.7 20 36 28.7 36 39.5v140.9c0 10.8 8.7 19.5 19.5 19.5h113.5l-5.3-18.5 12.8 11.9 12.1 11.2L209 220V39.5C209 28.7 200.3 20 189.5 20zM155.7 152.1s-3.6-4.3-6.6-8.1c13.1-3.7 18.1-11.9 18.1-11.9-4.1 2.7-8 4.6-11.5 5.9-5 2.1-9.8 3.5-14.5 4.3-9.6 1.8-18.4 1.3-25.9-.1-5.7-1.1-10.6-2.6-14.7-4.3-2.3-.9-4.8-2-7.3-3.4-.3-.2-.6-.3-.9-.5-.2-.1-.3-.2-.4-.3-2-1.1-3.1-1.9-3.1-1.9 4.7 4.3 9.3 6.5 21.7 10.2-2.9 3.8-6.6 8.1-6.6 8.1-22 0-32.1-15.2-32.1-15.2 0-32.2 14.4-58.4 14.4-58.4 14.4-10.8 28.1-10.5 28.1-10.5l1 1.2C99.2 87.7 87.9 97.4 87.9 97.4s2.9-1.6 7.8-3.8c14.1-6.2 25.3-7.9 29.9-8.3.8-.1 1.5-.2 2.3-.2 8.2-1 17.5-1.3 27.2.2 12.9 2 26.7 7.5 40.8 17.3 0 0-10.8-10.2-28.5-13.7l1.4-1.6s13.7-.3 28.1 10.5c0 0 14.4 26.2 14.4 58.4 0 0-10.2 15.2-32.1 15.2z" fill="#3DFFB8"/>
                </svg>
            </div>
            <span class="brand-name">Sentinal</span>
        </a>
        <div class="nav-center">
            <a href="/dashboard">Home</a>
            <a href="/servers" class="active">Servers</a>
            <a href="#" onclick="window.open('https://discord.gg/UmqmewYWRd','_blank'); return false;">Support</a>
            <a href="#">Premium</a>
        </div>
        <div class="nav-right">
            <div class="user-pill">
                <div class="user-avatar">
                    <% if (locals.user && user.avatar) { %>
                        <img src="https://cdn.discordapp.com/avatars/<%= user.id %>/<%= user.avatar %>.png" alt="Avatar">
                    <% } else { %>
                        <%= locals.user ? (user.username ? user.username.charAt(0).toUpperCase() : 'U') : 'U' %>
                    <% } %>
                </div>
                <span class="user-name"><%= locals.user ? (user.global_name || user.username) : 'User' %></span>
                <span class="user-plan">Free</span>
            </div>
            <a href="/logout" class="logout-btn"><i class="fas fa-sign-out-alt"></i></a>
        </div>
    </nav>

    <div class="page-wrapper">

        <!-- ─── TOAST CONTAINER ─── -->
        <div class="toast-container" id="toastContainer"></div>

        <!-- ─── MODAL ─── -->
        <div class="modal-overlay" id="newAppModal">
            <div class="modal">
                <div class="modal-header">
                    <h2><i class="fas fa-plus" style="color:var(--signal); margin-right:10px;"></i> Give your application a name</h2>
                    <button class="close-btn" onclick="closeModal()">&times;</button>
                </div>
                <form id="newAppForm" onsubmit="createApplication(event)">
                    <div class="form-group">
                        <input type="text" id="appName" placeholder="Enter application name..." required>
                        <div class="form-hint">A short, descriptive name for your application</div>
                        <div class="error-msg" id="nameError">Please enter a valid application name without profanity.</div>
                    </div>
                    <div class="form-actions">
                        <button type="button" class="btn-cancel" onclick="closeModal()">Cancel</button>
                        <button type="submit" class="btn-save" id="createBtn">Create Application</button>
                    </div>
                </form>
            </div>
        </div>

        <!-- ─── PAGE HEADER ─── -->
        <div class="page-header">
            <div class="left">
                <h1><i class="fas fa-file-alt"></i> Applications</h1>
                <p>Create forms for your members to fill out</p>
            </div>
        </div>

        <!-- ─── GETTING STARTED ─── -->
        <div class="getting-started">
            <h2>Getting started</h2>
            <ol>
                <li><span class="num">1.</span> Create a new application and give it a name</li>
                <li><span class="num">2.</span> Open it by clicking the edit button</li>
                <li><span class="num">3.</span> Configure your applications settings</li>
                <li><span class="num">4.</span> Members in your server can use <code style="background:var(--panel-raised); padding:2px 8px; border-radius:4px; color:var(--signal); font-size:12px;">/apply</code> or you can make an application button</li>
            </ol>
            <a href="#" class="help-link" onclick="showToast('Support server coming soon!', 'info')">Need help? Join our support server.</a>
        </div>

        <!-- ─── KEY FEATURES ─── -->
        <div class="key-features">
            <h2>Key Features</h2>
            <ul>
                <li><i class="fas fa-check"></i> Create and manage multiple apps</li>
                <li><i class="fas fa-check"></i> Customizable app templates</li>
                <li><i class="fas fa-check"></i> Advanced settings and configs</li>
                <li><i class="fas fa-check"></i> Control all role interactions</li>
            </ul>
        </div>

        <!-- ─── CREATE APP SECTION ─── -->
        <div class="create-app-section">
            <div class="create-app-card">
                <div class="icon-wrap"><i class="fas fa-play"></i></div>
                <div class="info">
                    <h3>Creating an application</h3>
                    <p>Learn how to create an application and configure it</p>
                    <a href="#" class="watch-link" onclick="showToast('Video tutorial coming soon!', 'info')">Click to watch →</a>
                </div>
            </div>
            <div class="create-app-card">
                <div class="icon-wrap"><i class="fas fa-file"></i></div>
                <div class="info">
                    <h3>Creating an application</h3>
                    <p>Learn how to create an application and configure it</p>
                    <a href="#" class="watch-link" onclick="showToast('Documentation coming soon!', 'info')">Click to watch →</a>
                </div>
            </div>
        </div>

        <!-- ─── APPLICATIONS HEADER ─── -->
        <div class="apps-header">
            <div class="left">
                <h3>Applications: <span class="count" id="appCount"><%= locals.applications ? applications.length : 0 %>/5</span></h3>
            </div>
            <div class="right">
                <input type="text" class="search-apps" placeholder="Search applications..." id="searchApps" onkeyup="filterApps()">
                <button class="btn-new" onclick="openModal()">
                    <i class="fas fa-plus"></i> New Application
                </button>
            </div>
        </div>

        <!-- ─── APPLICATIONS GRID ─── -->
        <% if (locals.applications && applications.length > 0) { %>
            <div class="apps-grid" id="appsList">
                <% applications.forEach(function(app) { %>
                    <div class="app-card" data-name="<%= app.name.toLowerCase() %>">
                        <div class="app-card-header">
                            <span class="app-name"><%= app.name %></span>
                            <span class="app-status <%= app.enabled ? 'enabled' : 'disabled' %>">
                                <%= app.enabled ? '● Enabled' : '● Disabled' %>
                            </span>
                        </div>
                        <div class="app-card-desc"><%= app.description || 'No description' %></div>
                        <div class="app-card-actions">
                            <a href="/applications/edit/<%= app._id %>?guildId=<%= locals.guild ? guild.id : '' %>" class="btn-edit">
                                <i class="fas fa-edit"></i> Edit
                            </a>
                            <button class="btn-toggle" onclick="toggleApplication('<%= app._id %>')">
                                <i class="fas fa-<%= app.enabled ? 'pause' : 'play' %>"></i>
                                <%= app.enabled ? 'Disable' : 'Enable' %>
                            </button>
                            <button class="btn-delete" onclick="deleteApplication('<%= app._id %>')">
                                <i class="fas fa-trash"></i> Delete
                            </button>
                        </div>
                    </div>
                <% }); %>
            </div>
        <% } else { %>
            <!-- ─── EMPTY STATE ─── -->
            <div class="empty-state" id="appsList">
                <i class="fas fa-file-alt"></i>
                <h3>No applications yet</h3>
                <p>Create your first application to get started.</p>
            </div>
        <% } %>

    </div>

    <footer class="footer">
        © 2026 SENTINAL — STATUS: OPERATIONAL
    </footer>

    <script>
        // ─── PROFANITY FILTER ───
        const BANNED_WORDS = [
            'nigger', 'nigga', 'niger', 'niggar',
            'fuck', 'fucking', 'shit', 'bitch', 'bastard',
            'cunt', 'dick', 'pussy', 'asshole', 'motherfucker',
            'retard', 'retarded', 'fag', 'faggot', 'tranny',
            'kike', 'spic', 'chink', 'gook', 'wetback',
            'coon', 'jiggaboo', 'moolie', 'nazi', 'hitler',
            'whore', 'slut', 'cocksucker', 'cum', 'cumshot',
            'fucktard', 'tard', 'mongoloid', 'midget'
        ];

        function containsProfanity(text) {
            const lower = text.toLowerCase().trim();
            for (const word of BANNED_WORDS) {
                const regex = new RegExp('\\b' + word + '\\b|' + word, 'i');
                if (regex.test(lower)) return true;
            }
            return false;
        }

        // ─── TOAST ───
        function showToast(message, type = 'info') {
            const container = document.getElementById('toastContainer');
            const toast = document.createElement('div');
            toast.className = 'toast ' + type;
            toast.innerHTML = `
                <span class="toast-icon"><i class="fas fa-${type === 'success' ? 'check-circle' : 'exclamation-circle'}"></i></span>
                <span class="toast-content">${message}</span>
                <button class="toast-close" onclick="this.closest('.toast').classList.add('hiding'); setTimeout(() => this.closest('.toast').remove(), 300);">
                    <i class="fas fa-times"></i>
                </button>
            `;
            container.appendChild(toast);
            setTimeout(() => {
                if (toast.parentNode) {
                    toast.classList.add('hiding');
                    setTimeout(() => { if (toast.parentNode) toast.remove(); }, 300);
                }
            }, 4000);
        }

        // ─── MODAL ───
        function openModal() {
            document.getElementById('newAppModal').classList.add('active');
            document.getElementById('appName').value = '';
            document.getElementById('appName').classList.remove('error');
            document.getElementById('nameError').classList.remove('show');
            document.getElementById('createBtn').disabled = false;
            setTimeout(() => document.getElementById('appName').focus(), 100);
        }

        function closeModal() {
            document.getElementById('newAppModal').classList.remove('active');
            document.getElementById('newAppForm').reset();
            document.getElementById('appName').classList.remove('error');
            document.getElementById('nameError').classList.remove('show');
            document.getElementById('createBtn').disabled = false;
        }

        // ─── REAL-TIME PROFANITY CHECK ───
        document.getElementById('appName').addEventListener('input', function() {
            const value = this.value;
            const errorEl = document.getElementById('nameError');
            const btn = document.getElementById('createBtn');
            
            if (value.length === 0) {
                this.classList.remove('error');
                errorEl.classList.remove('show');
                btn.disabled = false;
                return;
            }
            
            if (containsProfanity(value)) {
                this.classList.add('error');
                errorEl.textContent = '❌ Application name contains inappropriate language. Please choose a different name.';
                errorEl.classList.add('show');
                btn.disabled = true;
            } else {
                this.classList.remove('error');
                errorEl.classList.remove('show');
                btn.disabled = false;
            }
        });

        // ─── CREATE APPLICATION ───
        function createApplication(event) {
            event.preventDefault();
            
            const name = document.getElementById('appName').value.trim();
            const btn = document.getElementById('createBtn');
            
            if (containsProfanity(name)) {
                document.getElementById('appName').classList.add('error');
                document.getElementById('nameError').textContent = '❌ Application name contains inappropriate language. Please choose a different name.';
                document.getElementById('nameError').classList.add('show');
                return;
            }
            
            if (name.length === 0) {
                showToast('❌ Please enter an application name.', 'error');
                return;
            }

            btn.disabled = true;
            btn.textContent = 'Creating...';

            const data = {
                name: name,
                guildId: '<%= locals.guild ? guild.id : "" %>'
            };

            fetch('/api/applications', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    showToast('✅ Application "' + name + '" created successfully!', 'success');
                    closeModal();
                    setTimeout(() => location.reload(), 1500);
                } else {
                    showToast('❌ Error: ' + data.error, 'error');
                    btn.disabled = false;
                    btn.textContent = 'Create Application';
                }
            })
            .catch(error => {
                showToast('❌ Error creating application: ' + error.message, 'error');
                btn.disabled = false;
                btn.textContent = 'Create Application';
            });
        }

        // ─── TOGGLE APPLICATION ───
        function toggleApplication(appId) {
            fetch(`/api/applications/${appId}/toggle`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' }
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    showToast('✅ Application toggled successfully!', 'success');
                    setTimeout(() => location.reload(), 1000);
                } else {
                    showToast('❌ Error: ' + data.error, 'error');
                }
            })
            .catch(error => {
                showToast('❌ Error toggling application: ' + error.message, 'error');
            });
        }

        // ─── DELETE APPLICATION ───
        function deleteApplication(appId) {
            if (confirm('Are you sure you want to delete this application?')) {
                fetch(`/api/applications/${appId}`, {
                    method: 'DELETE'
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        showToast('✅ Application deleted successfully!', 'success');
                        setTimeout(() => location.reload(), 1000);
                    } else {
                        showToast('❌ Error: ' + data.error, 'error');
                    }
                })
                .catch(error => {
                    showToast('❌ Error deleting application: ' + error.message, 'error');
                });
            }
        }

        // ─── SEARCH ───
        function filterApps() {
            const query = document.getElementById('searchApps').value.toLowerCase().trim();
            const cards = document.querySelectorAll('.app-card');
            
            cards.forEach(card => {
                const name = card.getAttribute('data-name') || '';
                card.style.display = name.includes(query) ? '' : 'none';
            });
        }

        // ─── CLOSE MODAL ON ESC ───
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') closeModal();
        });

        // ─── CLOSE MODAL ON OVERLAY CLICK ───
        document.querySelector('.modal-overlay').addEventListener('click', function(e) {
            if (e.target === this) closeModal();
        });
    </script>

</body>
</html>
