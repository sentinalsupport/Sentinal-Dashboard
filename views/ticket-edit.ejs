<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title || 'Edit Template — Sentinal' %></title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/dashboard.css">
    <style>
        /* Additional styles for ticket edit page */
        .page-wrapper {
            max-width: 1100px;
            margin: 0 auto;
            padding: 24px 32px 60px;
        }

        .page-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 20px 0 16px;
            border-bottom: 1px solid var(--border-soft);
            margin-bottom: 24px;
            flex-wrap: wrap;
            gap: 16px;
        }

        .page-header .left h1 {
            font-size: 24px;
            font-weight: 700;
            margin: 0;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .page-header .left h1 i {
            color: var(--accent);
        }

        .page-header .left p {
            color: var(--text-secondary);
            font-size: 14px;
            margin: 4px 0 0;
        }

        .page-header .right .btn-back {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 8px 20px;
            border-radius: var(--radius-md);
            background: transparent;
            color: var(--text-secondary);
            text-decoration: none;
            font-weight: 500;
            font-size: 13px;
            border: 1px solid var(--border-soft);
            transition: all 0.18s ease;
        }

        .page-header .right .btn-back:hover {
            background: var(--bg-input-alt);
            color: var(--text-primary);
        }

        .section-card {
            background: var(--bg-card);
            border: 1px solid var(--border-soft);
            border-radius: var(--radius-lg);
            padding: 24px 28px;
            margin-bottom: 16px;
        }

        .section-card .section-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 6px;
            flex-wrap: wrap;
            gap: 8px;
        }

        .section-card .section-header h3 {
            font-size: 15px;
            font-weight: 600;
            margin: 0;
            color: var(--text-primary);
        }

        .section-card .section-header .badge {
            font-size: 10px;
            font-weight: 600;
            padding: 2px 10px;
            border-radius: 100px;
            background: var(--accent-soft);
            color: var(--accent);
            border: 1px solid rgba(99, 102, 241, 0.2);
        }

        .section-card .section-desc {
            font-size: 13px;
            color: var(--text-secondary);
            margin-bottom: 14px;
        }

        .form-group {
            margin-bottom: 14px;
        }

        .form-group label {
            display: block;
            font-size: 12px;
            font-weight: 600;
            margin-bottom: 4px;
            color: var(--text-primary);
        }

        .form-group .form-hint {
            font-size: 11px;
            color: var(--text-muted);
            margin-top: 2px;
        }

        .form-group input,
        .form-group select,
        .form-group textarea {
            width: 100%;
            padding: 10px 14px;
            border-radius: var(--radius-sm);
            border: 1px solid var(--border);
            background: var(--bg-input);
            color: var(--text-primary);
            font-size: 13px;
            font-family: 'Inter', sans-serif;
            transition: all 0.18s ease;
            outline: none;
        }

        .form-group textarea {
            resize: vertical;
            min-height: 60px;
        }

        .form-group input:focus,
        .form-group select:focus,
        .form-group textarea:focus {
            border-color: var(--accent);
            box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.15);
        }

        .form-group select option {
            background: var(--bg-page);
        }

        .form-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 16px;
        }

        .form-actions {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
            margin-top: 16px;
        }

        .btn-save {
            padding: 10px 28px;
            border-radius: var(--radius-md);
            border: none;
            font-weight: 600;
            font-size: 13px;
            cursor: pointer;
            background: var(--accent);
            color: white;
            transition: all 0.18s ease;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

        .btn-save:hover {
            background: var(--accent-hover);
            transform: translateY(-1px);
            box-shadow: 0 4px 18px rgba(99, 102, 241, 0.25);
        }

        .btn-secondary {
            padding: 8px 20px;
            border-radius: var(--radius-md);
            background: transparent;
            color: var(--text-secondary);
            border: 1px solid var(--border-soft);
            font-weight: 600;
            font-size: 13px;
            cursor: pointer;
            transition: all 0.18s ease;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 7px;
        }

        .btn-secondary:hover {
            background: var(--bg-input-alt);
            color: var(--text-primary);
        }

        .btn-danger {
            padding: 8px 20px;
            border-radius: var(--radius-md);
            background: var(--danger-soft);
            color: var(--danger);
            border: 1px solid rgba(239, 68, 68, 0.25);
            font-weight: 600;
            font-size: 13px;
            cursor: pointer;
            transition: all 0.18s ease;
            display: inline-flex;
            align-items: center;
            gap: 7px;
        }

        .btn-danger:hover {
            background: rgba(239, 68, 68, 0.2);
        }

        .toggle-wrapper {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .toggle-wrapper span {
            font-size: 13px;
            font-weight: 500;
            color: var(--text-primary);
        }

        .question-item {
            background: var(--bg-input);
            border: 1px solid var(--border-soft);
            border-radius: var(--radius-md);
            padding: 16px 18px;
            margin-bottom: 10px;
        }

        .question-item .q-header {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 6px;
        }

        .question-item .q-header .q-number {
            font-weight: 700;
            font-size: 13px;
            color: var(--accent);
        }

        .question-item .q-header .q-title {
            font-weight: 600;
            font-size: 14px;
            color: var(--text-primary);
        }

        .question-item .q-desc {
            font-size: 12px;
            color: var(--text-secondary);
            margin-bottom: 6px;
        }

        .question-item .q-type {
            font-size: 11px;
            color: var(--text-secondary);
            background: var(--bg-card);
            padding: 2px 10px;
            border-radius: 100px;
            border: 1px solid var(--border-soft);
            display: inline-block;
        }

        .question-item .q-actions {
            display: flex;
            gap: 6px;
            margin-top: 8px;
        }

        .question-item .q-actions button {
            background: none;
            border: none;
            color: var(--text-secondary);
            cursor: pointer;
            padding: 4px 10px;
            border-radius: var(--radius-sm);
            font-size: 12px;
            font-weight: 500;
            transition: all 0.18s ease;
        }

        .question-item .q-actions button:hover {
            background: var(--bg-input-alt);
            color: var(--text-primary);
        }

        .question-item .q-actions button.danger:hover {
            background: var(--danger-soft);
            color: var(--danger);
        }

        @media (max-width: 768px) {
            .page-wrapper {
                padding: 16px;
            }
            .page-header {
                flex-direction: column;
                align-items: stretch;
            }
            .form-row {
                grid-template-columns: 1fr;
            }
            .section-card {
                padding: 16px;
            }
        }
    </style>
</head>
<body>
    <!-- Use the existing layout from dashboard.ejs -->
    <div class="layout">
        <!-- Sidebar -->
        <aside class="sidebar">
            <div class="brand">
                <span class="brand-icon">🛡️</span>
                Sentinal
            </div>

            <div class="server-switcher">
                <div class="server-avatar"></div>
                <div>
                    <div class="server-name"><%= locals.guild ? guild.name : 'No Server Selected' %></div>
                    <div class="server-plan">Free</div>
                </div>
            </div>

            <nav class="nav">
                <a href="/dashboard" class="nav-link nav-top">
                    <span><span class="nav-icon">🏠</span> Dashboard</span>
                </a>

                <div class="nav-group">
                    <a href="/servers" class="nav-link">
                        <span><span class="nav-icon">🖥️</span> Servers</span>
                    </a>
                    <div class="nav-sub">
                        <a href="/servers/<%= locals.guild ? guild.id : '' %>/applications" class="nav-link">
                            <span><span class="nav-icon">📄</span> Applications</span>
                        </a>
                        <a href="/servers/<%= locals.guild ? guild.id : '' %>/tickets" class="nav-link active">
                            <span><span class="nav-icon">🎫</span> Tickets</span>
                        </a>
                        <a href="/servers/<%= locals.guild ? guild.id : '' %>/panels" class="nav-link">
                            <span><span class="nav-icon">📋</span> Panels</span>
                        </a>
                    </div>
                </div>
            </nav>

            <div class="sidebar-footer">
                <a href="#" class="support-link">
                    <span>💬</span> Support
                </a>
                <div class="user-card">
                    <div class="user-avatar">
                        <%= locals.user ? (user.global_name ? user.global_name.charAt(0).toUpperCase() : user.username.charAt(0).toUpperCase()) : 'U' %>
                    </div>
                    <div>
                        <div class="user-name"><%= locals.user ? (user.global_name || user.username) : 'User' %></div>
                        <div class="user-plan-badge">FREE</div>
                    </div>
                </div>
            </div>
        </aside>

        <!-- Main Content -->
        <main class="content">
            <div class="page-wrapper">
                <div class="page-header">
                    <div class="left">
                        <h1>
                            <i class="fas fa-ticket"></i>
                            <%= locals.template ? template.name : 'Edit Template' %>
                        </h1>
                        <p>Configure your ticket template settings</p>
                    </div>
                    <div class="right">
                        <a href="/servers/<%= locals.guild ? guild.id : '' %>/tickets" class="btn-back">
                            <i class="fas fa-arrow-left"></i> Back to Templates
                        </a>
                    </div>
                </div>

                <!-- Toast Container -->
                <div id="toastContainer" style="position: fixed; bottom: 24px; right: 24px; z-index: 9999; display: flex; flex-direction: column; gap: 10px; max-width: 380px; width: 100%;"></div>

                <!-- ─── REQUIREMENTS ─── -->
                <div class="section-card">
                    <div class="section-header">
                        <h3>Requirements</h3>
                        <span class="badge">Live</span>
                    </div>

                    <div class="form-group">
                        <label for="templateName">Template name</label>
                        <input type="text" id="templateName" value="<%= locals.template ? template.name : 'When' %>" placeholder="The name of the ticket.">
                        <div class="form-hint">The name of the ticket.</div>
                    </div>

                    <div class="form-group">
                        <label for="ticketCategory">Ticket Category</label>
                        <input type="text" id="ticketCategory" value="<%= locals.template ? template.category || '' : '' %>" placeholder="Select a category">
                        <div class="form-hint">The category that user created tickets will be under.</div>
                    </div>

                    <div class="form-group">
                        <label for="ticketChannel">Ticket Channel Name</label>
                        <input type="text" id="ticketChannel" value="<%= locals.template ? template.channelName || '{ticket-creator-username}-{total-tickets-opened}' : '{ticket-creator-username}-{total-tickets-opened}' %>">
                        <div class="form-hint">Customize the name of the channel that is made when a user opens a ticket.</div>
                    </div>

                    <div class="form-group">
                        <label for="maxTickets">Max concurrent open tickets</label>
                        <input type="number" id="maxTickets" value="<%= locals.template ? template.maxTickets || 3 : 3 %>" min="1" max="10">
                        <div class="form-hint">The maximum number of tickets a user may have open at once.</div>
                    </div>
                </div>

                <!-- ─── TICKET ACCESS CONTROL ─── -->
                <div class="section-card">
                    <div class="section-header">
                        <h3>Ticket access control</h3>
                        <span class="badge">Live</span>
                    </div>

                    <div class="form-group">
                        <label>Blocked Roles: <span id="blockedCount">0/10</span></label>
                        <select id="blockedRoles" class="role-select" multiple data-role-target="blocked" data-max="10">
                            <% if (locals.roles) { %>
                                <% roles.forEach(role => { %>
                                    <option value="<%= role.id %>"><%= role.name %></option>
                                <% }) %>
                            <% } %>
                        </select>
                        <div class="form-hint">Members with any one of these roles will not be able to open a ticket.</div>
                    </div>

                    <div class="form-group">
                        <label>Match Mode</label>
                        <div class="segmented" data-group="blocked-match-mode">
                            <button class="segment active" type="button" data-value="all">Has all roles</button>
                            <button class="segment" type="button" data-value="any">Has any role</button>
                        </div>
                        <div class="match-mode-desc">User is blocked only if they have <strong>ALL</strong> of the listed roles.</div>
                    </div>

                    <div class="form-group">
                        <label>Required Roles: <span id="requiredCount">0/10</span></label>
                        <select id="requiredRoles" class="role-select" multiple data-role-target="required" data-max="10">
                            <% if (locals.roles) { %>
                                <% roles.forEach(role => { %>
                                    <option value="<%= role.id %>"><%= role.name %></option>
                                <% }) %>
                            <% } %>
                        </select>
                        <div class="form-hint">Members with all of these roles will be able to open a ticket.</div>
                    </div>

                    <div class="form-group">
                        <label>Match Mode</label>
                        <div class="segmented" data-group="required-match-mode">
                            <button class="segment active" type="button" data-value="all">Has all roles</button>
                            <button class="segment" type="button" data-value="any">Has any role</button>
                        </div>
                        <div class="match-mode-desc">User is required only if they have <strong>ALL</strong> of the listed roles.</div>
                    </div>
                </div>

                <!-- ─── SUPPORT TEAM & PERMISSIONS ─── -->
                <div class="section-card">
                    <div class="section-header">
                        <h3>Support Team & Permissions</h3>
                        <span class="badge">Live</span>
                    </div>

                    <div class="form-group">
                        <label>Support Team Roles: <span id="supportCount">0/1</span></label>
                        <select id="supportRoles" class="role-select" multiple data-role-target="support" data-max="1">
                            <% if (locals.roles) { %>
                                <% roles.forEach(role => { %>
                                    <option value="<%= role.id %>"><%= role.name %></option>
                                <% }) %>
                            <% } %>
                        </select>
                        <div class="form-hint">The roles which will be able to view and manage tickets.</div>
                    </div>

                    <div class="form-group">
                        <div class="toggle-wrapper">
                            <button class="toggle on" type="button" role="switch" aria-checked="true" data-action="toggle" id="ticketClaiming">
                                <span class="toggle-knob"></span>
                            </button>
                            <span>Ticket Claiming</span>
                        </div>
                        <div class="form-hint">Allows support team members to claim a ticket via the claim button.</div>
                    </div>

                    <div class="form-group">
                        <label for="actionOnLeave">Action on User Leave</label>
                        <select id="actionOnLeave" class="select-input upper-select">
                            <option value="nothing">NOTHING</option>
                            <option value="close">Close Ticket</option>
                            <option value="transfer">Transfer Ticket</option>
                        </select>
                        <div class="form-hint">If a user leaves the server, the bot will perform the specified action on the ticket.</div>
                    </div>

                    <div class="form-group">
                        <div class="toggle-wrapper">
                            <button class="toggle on" type="button" role="switch" aria-checked="true" data-action="toggle" id="pingSupport">
                                <span class="toggle-knob"></span>
                            </button>
                            <span>Ping Support Roles</span>
                        </div>
                        <div class="form-hint">If any support roles have been added, the bot will automatically ping them when a ticket is created.</div>
                    </div>

                    <div class="form-group">
                        <div class="toggle-wrapper">
                            <button class="toggle" type="button" role="switch" aria-checked="false" data-action="toggle" id="rateSupport">
                                <span class="toggle-knob"></span>
                            </button>
                            <span>Rate Support Experience Enabled</span>
                        </div>
                        <div class="form-hint">If enabled, the user that opened the ticket can rate the support experience.</div>
                    </div>
                </div>

                <!-- ─── TICKET FORM ─── -->
                <div class="section-card">
                    <div class="section-header">
                        <h3>Ticket Form</h3>
                        <span class="badge">Live</span>
                    </div>
                    <div class="section-desc">The form which will be opened when a user attempts to open a ticket.</div>

                    <div class="form-group">
                        <label for="formDescription">Form Introduction</label>
                        <textarea id="formDescription" rows="2"><%= locals.template ? template.formDescription || 'Please explain your issue in full detail' : 'Please explain your issue in full detail' %></textarea>
                        <div class="form-hint">This text will be shown at the top of the ticket form.</div>
                    </div>

                    <div class="section-desc" style="margin-top:12px;">
                        <strong>Questions: <span id="questionCount">1</span>/5</strong>
                    </div>

                    <div id="questions-list">
                        <!-- Questions will be rendered here -->
                        <% if (locals.template && template.questions && template.questions.length) { %>
                            <% template.questions.forEach((question, index) => { %>
                                <div class="question-item" data-index="<%= index %>">
                                    <div class="q-header">
                                        <span class="q-number">●</span>
                                        <span class="q-title">Question <%= index + 1 %></span>
                                    </div>
                                    <div class="q-desc">
                                        <strong>Question title</strong><br>
                                        <%= question.title || 'Untitled Question' %>
                                    </div>
                                    <div class="q-desc">
                                        <strong>Description</strong><br>
                                        <%= question.description || 'No description' %>
                                    </div>
                                    <div class="q-desc">
                                        <strong>Placeholder</strong><br>
                                        <%= question.placeholder || 'No placeholder' %>
                                    </div>
                                    <div>
                                        <span class="q-type"><%= question.type || 'short' %></span>
                                        <span class="q-type" style="margin-left:4px;">Min: <%= question.minLength || 1 %></span>
                                        <span class="q-type" style="margin-left:4px;">Max: <%= question.maxLength || 500 %></span>
                                    </div>
                                    <div class="q-actions">
                                        <button onclick="editQuestion(<%= index %>)"><i class="fas fa-edit"></i> Edit</button>
                                        <button class="danger" onclick="deleteQuestion(<%= index %>)"><i class="fas fa-trash"></i> Delete</button>
                                    </div>
                                </div>
                            <% }) %>
                        <% } else { %>
                            <!-- Default question -->
                            <div class="question-item" data-index="0">
                                <div class="q-header">
                                    <span class="q-number">●</span>
                                    <span class="q-title">Question 1</span>
                                </div>
                                <div class="q-desc">
                                    <strong>Question title</strong><br>
                                    Do you like capybara?
                                </div>
                                <div class="q-desc">
                                    <strong>Description</strong><br>
                                    Please explain your answer in full detail
                                </div>
                                <div class="q-desc">
                                    <strong>Placeholder</strong><br>
                                    Please describe your issue in full detail.
                                </div>
                                <div>
                                    <span class="q-type">Short</span>
                                    <span class="q-type" style="margin-left:4px;">Min: 1</span>
                                    <span class="q-type" style="margin-left:4px;">Max: 500</span>
                                </div>
                                <div class="q-actions">
                                    <button onclick="editQuestion(0)"><i class="fas fa-edit"></i> Edit</button>
                                    <button class="danger" onclick="deleteQuestion(0)"><i class="fas fa-trash"></i> Delete</button>
                                </div>
                            </div>
                        <% } %>
                    </div>

                    <div style="display:flex; gap:10px; flex-wrap:wrap; margin-top:12px; align-items:center;">
                        <button class="btn-secondary" id="add-question-btn">
                            <i class="fas fa-plus"></i> New question
                        </button>
                        <span style="font-size:12px; color:var(--text-muted);"><span id="questions-used-count">1</span>/5 questions used.</span>
                    </div>

                    <div class="form-actions" style="margin-top:16px;">
                        <button class="btn-save" onclick="saveTemplate()">
                            <i class="fas fa-save"></i> Save Changes
                        </button>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <script>
        // ============================================================
        // Ticket Edit Page - Client-side interactivity
        // ============================================================

        document.addEventListener('DOMContentLoaded', function() {
            initToggles();
            initSegmentedControls();
            initRoleSelects();
            updateQuestionCounts();
            
            // Add question button listener
            const addBtn = document.getElementById('add-question-btn');
            if (addBtn) {
                addBtn.addEventListener('click', addQuestion);
            }
        });

        // ---------------- Toggles ----------------
        function initToggles() {
            document.querySelectorAll('.toggle[data-action="toggle"]').forEach((btn) => {
                btn.addEventListener('click', function() {
                    const isOn = this.classList.toggle('on');
                    this.setAttribute('aria-checked', String(isOn));
                });
            });
        }

        // ---------------- Segmented controls ----------------
        function initSegmentedControls() {
            document.querySelectorAll('.segmented').forEach((group) => {
                group.querySelectorAll('.segment').forEach((seg) => {
                    seg.addEventListener('click', function() {
                        group.querySelectorAll('.segment').forEach((s) => s.classList.remove('active'));
                        this.classList.add('active');

                        // Update the descriptive text
                        const desc = this.closest('.form-group')?.querySelector('.match-mode-desc');
                        if (desc) {
                            const mode = this.dataset.value;
                            const isBlocked = group.dataset.group === 'blocked-match-mode';
                            const verb = isBlocked ? 'blocked' : 'required';
                            desc.innerHTML = mode === 'all'
                                ? `User is ${verb} only if they have <strong>ALL</strong> of the listed roles.`
                                : `User is ${verb} if they have <strong>ANY</strong> of the listed roles.`;
                        }
                    });
                });
            });
        }

        // ---------------- Role multi-selects with live counts ----------------
        function initRoleSelects() {
            document.querySelectorAll('.role-select').forEach((select) => {
                const targetId = select.dataset.roleTarget + 'Count';
                const countTarget = document.getElementById(targetId);
                const max = select.dataset.max ? parseInt(select.dataset.max, 10) : 10;

                function updateCount() {
                    const count = Array.from(select.selectedOptions).filter((o) => o.value !== '').length;
                    if (countTarget) {
                        countTarget.textContent = `${count}/${max}`;
                    }
                }

                select.addEventListener('change', function() {
                    const selected = Array.from(this.selectedOptions).filter((o) => o.value !== '');

                    if (selected.length > max) {
                        // Deselect the most recently added option past the max
                        selected[selected.length - 1].selected = false;
                        showToast(`You can select up to ${max} role${max === 1 ? '' : 's'} here.`, 'error');
                    }

                    updateCount();
                });

                updateCount();
            });
        }

        // ---------------- Toast notifications ----------------
        function showToast(message, type = 'info') {
            const container = document.getElementById('toastContainer');
            if (!container) return;
            
            const toast = document.createElement('div');
            toast.className = 'toast ' + (type === 'success' ? 'success' : type === 'error' ? 'error' : '');
            const icon = type === 'success' ? 'check-circle' : type === 'error' ? 'exclamation-circle' : 'info-circle';
            
            toast.innerHTML = `
                <span class="toast-icon"><i class="fas fa-${icon}"></i></span>
                <span class="toast-content">${message}</span>
                <button class="toast-close" onclick="this.closest('.toast').classList.add('hiding'); setTimeout(() => this.closest('.toast').remove(), 300);">
                    <i class="fas fa-times"></i>
                </button>
            `;
            container.appendChild(toast);
            
            setTimeout(() => {
                if (toast.parentNode) {
                    toast.classList.add('hiding');
                    setTimeout(() => { if (toast.parentNode) toast.remove(); }, 300);
                }
            }, 4000);
        }

        // ---------------- Question management ----------------
        let questionCounter = 0;

        function addQuestion() {
            const list = document.getElementById('questions-list');
            const count = list.querySelectorAll('.question-item').length;
            
            if (count >= 5) {
                showToast('Maximum 5 questions allowed.', 'error');
                return;
            }

            const newIndex = count;
            const questionHtml = `
                <div class="question-item" data-index="${newIndex}">
                    <div class="q-header">
                        <span class="q-number">●</span>
                        <span class="q-title">Question ${newIndex + 1}</span>
                    </div>
                    <div class="q-desc">
                        <strong>Question title</strong><br>
                        New Question
                    </div>
                    <div class="q-desc">
                        <strong>Description</strong><br>
                        Please explain your answer in full detail
                    </div>
                    <div class="q-desc">
                        <strong>Placeholder</strong><br>
                        Please describe your issue in full detail.
                    </div>
                    <div>
                        <span class="q-type">Short</span>
                        <span class="q-type" style="margin-left:4px;">Min: 1</span>
                        <span class="q-type" style="margin-left:4px;">Max: 500</span>
                    </div>
                    <div class="q-actions">
                        <button onclick="editQuestion(${newIndex})"><i class="fas fa-edit"></i> Edit</button>
                        <button class="danger" onclick="deleteQuestion(${newIndex})"><i class="fas fa-trash"></i> Delete</button>
                    </div>
                </div>
            `;
            
            list.insertAdjacentHTML('beforeend', questionHtml);
            updateQuestionCounts();
            showToast('New question added!', 'success');
        }

        function deleteQuestion(index) {
            const items = document.querySelectorAll('.question-item');
            if (items.length <= 1) {
                showToast('Cannot delete the last question. Add a new one first.', 'error');
                return;
            }
            
            const item = document.querySelector(`.question-item[data-index="${index}"]`);
            if (item) {
                item.remove();
                updateQuestionCounts();
                showToast('Question deleted.', 'info');
            }
        }

        function editQuestion(index) {
            // This would open an edit modal or form
            // For now, just show a toast
            showToast('Edit mode coming soon! Click "Add Question" to create new ones.', 'info');
        }

        function updateQuestionCounts() {
            const items = document.querySelectorAll('.question-item');
            const count = items.length;
            
            const countElement = document.getElementById('questionCount');
            const usedElement = document.getElementById('questions-used-count');
            
            if (countElement) countElement.textContent = count;
            if (usedElement) usedElement.textContent = count;
            
            // Update question numbers
            items.forEach((item, i) => {
                item.dataset.index = i;
                const title = item.querySelector('.q-title');
                if (title) {
                    title.textContent = `Question ${i + 1}`;
                }
            });
        }

        // ---------------- Save template ----------------
        function saveTemplate() {
            // Collect all question data from the DOM
            const questionItems = document.querySelectorAll('.question-item');
            const questions = [];
            
            questionItems.forEach((item, index) => {
                // Extract question data from the displayed content
                const titleEl = item.querySelector('.q-desc:first-of-type');
                const descEl = item.querySelector('.q-desc:nth-of-type(2)');
                const placeholderEl = item.querySelector('.q-desc:nth-of-type(3)');
                const typeEl = item.querySelector('.q-type:first-of-type');
                
                const title = titleEl ? titleEl.textContent.replace('Question title', '').trim() : `Question ${index + 1}`;
                const description = descEl ? descEl.textContent.replace('Description', '').trim() : 'Please explain your answer in full detail';
                const placeholder = placeholderEl ? placeholderEl.textContent.replace('Placeholder', '').trim() : 'Please describe your issue in full detail.';
                const type = typeEl ? typeEl.textContent.trim().toLowerCase() : 'short';
                
                // Extract min/max from the displayed values
                const typeElements = item.querySelectorAll('.q-type');
                let minLength = 1;
                let maxLength = 500;
                
                if (typeElements.length >= 3) {
                    const minText = typeElements[1].textContent;
                    const maxText = typeElements[2].textContent;
                    const minMatch = minText.match(/Min:\s*(\d+)/);
                    const maxMatch = maxText.match(/Max:\s*(\d+)/);
                    if (minMatch) minLength = parseInt(minMatch[1]);
                    if (maxMatch) maxLength = parseInt(maxMatch[1]);
                }
                
                questions.push({
                    title: title,
                    description: description,
                    placeholder: placeholder,
                    type: type,
                    required: true,
                    minLength: minLength,
                    maxLength: maxLength
                });
            });

            const data = {
                name: document.getElementById('templateName').value,
                category: document.getElementById('ticketCategory').value,
                channelName: document.getElementById('ticketChannel').value,
                maxTickets: parseInt(document.getElementById('maxTickets').value) || 3,
                blockedRoles: Array.from(document.getElementById('blockedRoles').selectedOptions).map(o => o.value),
                requiredRoles: Array.from(document.getElementById('requiredRoles').selectedOptions).map(o => o.value),
                supportRoles: Array.from(document.getElementById('supportRoles').selectedOptions).map(o => o.value),
                ticketClaiming: document.getElementById('ticketClaiming').classList.contains('on'),
                actionOnLeave: document.getElementById('actionOnLeave').value,
                pingSupport: document.getElementById('pingSupport').classList.contains('on'),
                rateSupport: document.getElementById('rateSupport').classList.contains('on'),
                formDescription: document.getElementById('formDescription').value,
                questions: questions,
                guildId: '<%= locals.guild ? guild.id : "" %>'
            };

            const templateId = '<%= locals.template ? template._id : "" %>';
            const url = templateId ? `/api/tickets/${templateId}` : '/api/tickets';
            const method = templateId ? 'PUT' : 'POST';

            fetch(url, {
                method: method,
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    showToast('✅ Template saved successfully!', 'success');
                } else {
                    showToast('❌ Error: ' + (data.error || 'Unknown error'), 'error');
                }
            })
            .catch(error => {
                showToast('❌ Error saving template: ' + error.message, 'error');
            });
        }

        // Make functions globally accessible for onclick handlers
        window.addQuestion = addQuestion;
        window.deleteQuestion = deleteQuestion;
        window.editQuestion = editQuestion;
        window.saveTemplate = saveTemplate;
        window.showToast = showToast;
    </script>
</body>
</html>
