    <script>
        var templateId = '<%= template ? template._id : "" %>';
        var guildId = '<%= guild.id %>';
        var MAX_BUTTONS = 7;
        var buttons = [];
        var templatesData = <%= JSON.stringify(templates || []) %>;

        // ===== TOAST =====
        function showToast(message, type) {
            type = type || 'info';
            var container = document.getElementById('toastContainer');
            var toast = document.createElement('div');
            toast.className = 'toast ' + type;
            var icon = type === 'success' ? 'check-circle' : type === 'error' ? 'exclamation-circle' : 'info-circle';
            toast.innerHTML = `
                <span class="toast-icon"><i class="fas fa-${icon}"></i></span>
                <span class="toast-content">${message}</span>
                <button class="toast-close" onclick="this.parentElement.remove();">
                    <i class="fas fa-times"></i>
                </button>
            `;
            container.appendChild(toast);
            setTimeout(function() {
                if (toast.parentElement) {
                    toast.classList.add('hiding');
                    setTimeout(function() { if (toast.parentElement) toast.remove(); }, 300);
                }
            }, 4000);
        }

        // ===== TAB SWITCHING =====
        function switchTab(tab) {
            // Update sidebar
            document.querySelectorAll('.sidebar-left .nav-item').forEach(function(el) {
                el.classList.remove('active');
                if (el.textContent.trim().toLowerCase().includes(tab)) {
                    el.classList.add('active');
                }
            });
            // Update tab headers
            document.querySelectorAll('.tab-btn').forEach(function(el) {
                el.classList.remove('active');
                if (el.dataset.tab === tab) {
                    el.classList.add('active');
                }
            });
            // Update content
            document.querySelectorAll('.tab-content').forEach(function(el) {
                el.classList.remove('active');
                if (el.id === 'tab-' + tab) {
                    el.classList.add('active');
                }
            });
        }

        // ===== CHANNEL NAME =====
        function updateChannelName() {
            var preset = document.getElementById('channelNamePreset');
            var customInput = document.getElementById('channelName');
            if (preset.value === 'custom') {
                customInput.style.display = 'block';
                customInput.value = '';
                customInput.focus();
            } else {
                customInput.style.display = 'block';
                customInput.value = preset.value;
            }
        }

        // ===== TOGGLE SWITCH =====
        function toggleSwitch(el) {
            el.classList.toggle('active');
            var isActive = el.classList.contains('active');
            document.getElementById('autoCloseEnabled').value = isActive ? 'true' : 'false';
            document.getElementById('autoCloseSettings').style.display = isActive ? 'grid' : 'none';
        }

        // ===== PERMISSIONS =====
        function updatePermissions() {
            var preset = document.getElementById('permissionPreset').value;
            var checkboxes = document.querySelectorAll('#permissionGrid input[type="checkbox"]');

            var presets = {
                support: { close: true, delete: false, rename: false, claim: true, adduser: false, removeuser: false },
                moderator: { close: true, delete: true, rename: true, claim: true, adduser: true, removeuser: true },
                admin: { close: true, delete: true, rename: true, claim: true, adduser: true, removeuser: true }
            };

            if (preset !== 'custom') {
                var p = presets[preset];
                checkboxes.forEach(function(cb) {
                    var name = cb.name.replace('perm_', '');
                    cb.checked = p[name] || false;
                });
            }
        }

        // ===== ROLE CHIP PICKER =====
        var ROLE_PICK_LIMIT = 3;

        function renderRoleChips() {
            var select = document.getElementById('supportRoles');
            var grid = document.getElementById('roleChipGrid');
            var countLabel = document.getElementById('rolePickerCount');
            if (!select || !grid) return;

            var options = Array.from(select.options);
            var selectedCount = options.filter(function(o) { return o.selected; }).length;

            grid.innerHTML = '';
            if (options.length === 0) {
                var empty = document.createElement('div');
                empty.className = 'role-chip-empty';
                empty.textContent = 'No roles found on this server';
                empty.style.cssText = 'font-size: 13px; color: var(--muted-dim); padding: 6px 0;';
                grid.appendChild(empty);
                return;
            }

            options.forEach(function(opt) {
                var atLimit = selectedCount >= ROLE_PICK_LIMIT;
                var btn = document.createElement('button');
                btn.type = 'button';
                btn.className = 'role-chip-btn' + (opt.selected ? ' selected' : '') + (!opt.selected && atLimit ? ' disabled' : '');
                btn.style.cssText = 'display: inline-flex; align-items: center; gap: 6px; padding: 6px 12px; border-radius: 100px; border: 1px solid var(--line); background: var(--panel-raised); color: var(--text); font-size: 12px; font-weight: 600; cursor: pointer; transition: all 0.15s ease; user-select: none; font-family: Inter, sans-serif;';

                var dot = document.createElement('span');
                dot.className = 'role-chip-dot';
                dot.style.cssText = 'width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; background: ' + (opt.dataset.color || '#3DFFB8') + ';';
                btn.appendChild(dot);

                var label = document.createElement('span');
                label.textContent = opt.textContent.trim();
                btn.appendChild(label);

                if (opt.selected) {
                    var remove = document.createElement('span');
                    remove.className = 'role-chip-remove';
                    remove.innerHTML = '<i class="fas fa-times"></i>';
                    remove.style.cssText = 'font-size: 10px; opacity: 0.7; display: inline-flex;';
                    btn.appendChild(remove);
                }

                btn.addEventListener('click', function() {
                    if (opt.selected) {
                        opt.selected = false;
                    } else {
                        var currentCount = Array.from(select.options).filter(function(o) { return o.selected; }).length;
                        if (currentCount >= ROLE_PICK_LIMIT) return;
                        opt.selected = true;
                    }
                    select.dispatchEvent(new Event('change'));
                    renderRoleChips();
                });

                grid.appendChild(btn);
            });

            countLabel.textContent = selectedCount + '/' + ROLE_PICK_LIMIT + ' selected';
            countLabel.style.color = selectedCount >= ROLE_PICK_LIMIT ? 'var(--signal)' : 'var(--muted)';
        }

        // ===== CUSTOM BUTTONS =====
        function renderButtons() {
            var grid = document.getElementById('buttonGrid');
            var countLabel = document.getElementById('buttonBadge');
            var addBtn = document.getElementById('addButtonBtn');

            grid.innerHTML = '';
            if (countLabel) countLabel.textContent = buttons.length;

            addBtn.disabled = buttons.length >= MAX_BUTTONS;

            var colorOptions = ['primary', 'secondary', 'success', 'danger'];
            var colorLabels = ['Primary (Blue)', 'Secondary (Grey)', 'Success (Green)', 'Danger (Red)'];
            var colorClasses = {
                primary: 'preview-primary',
                secondary: 'preview-secondary',
                success: 'preview-success',
                danger: 'preview-danger'
            };

            buttons.forEach(function(btn, index) {
                var card = document.createElement('div');
                card.className = 'button-card';

                var templateOptions = '<option value="">Select template...</option>';
                if (templatesData && templatesData.length > 0) {
                    templatesData.forEach(function(t) {
                        var selected = (btn && btn.templateId === t._id) ? 'selected' : '';
                        templateOptions += '<option value="' + t._id + '" ' + selected + '>' + t.name + '</option>';
                    });
                }

                card.innerHTML = `
                    <div class="card-header">
                        <span class="btn-label">Button ${index + 1}</span>
                        <button type="button" class="btn-remove" onclick="removeButton(${index})">
                            <i class="fas fa-times"></i>
                        </button>
                    </div>
                    <div class="card-row">
                        <div class="form-group">
                            <label>Label</label>
                            <input type="text" class="form-control" value="${btn.label || ''}" placeholder="Support" onchange="updateButton(${index}, 'label', this.value)">
                        </div>
                        <div class="form-group">
                            <label>Emoji</label>
                            <input type="text" class="form-control" value="${btn.emoji || ''}" placeholder="🎫" onchange="updateButton(${index}, 'emoji', this.value)">
                        </div>
                    </div>
                    <div class="card-row">
                        <div class="form-group">
                            <label>Color</label>
                            <select class="form-control" onchange="updateButton(${index}, 'color', this.value)">
                                ${colorOptions.map(function(c) {
                                    return `<option value="${c}" ${btn.color === c ? 'selected' : ''}>${colorLabels[colorOptions.indexOf(c)]}</option>`;
                                }).join('')}
                            </select>
                        </div>
                        <div class="form-group">
                            <label>Template</label>
                            <select class="form-control" onchange="updateButton(${index}, 'templateId', this.value)">
                                ${templateOptions}
                            </select>
                        </div>
                    </div>
                    <div class="card-preview ${colorClasses[btn.color] || 'preview-primary'}">
                        ${btn.emoji || '📩'} ${btn.label || 'Button Label'}
                    </div>
                `;

                grid.appendChild(card);
            });

            updatePreviewButtons();
        }

        function addButton() {
            if (buttons.length >= MAX_BUTTONS) return;
            buttons.push({ label: '', emoji: '', color: 'primary', templateId: '' });
            renderButtons();
        }

        function removeButton(index) {
            buttons.splice(index, 1);
            renderButtons();
        }

        function updateButton(index, field, value) {
            buttons[index][field] = value;
            renderButtons();
        }

        function loadButtons() {
            var templateButtons = <%= template ? (template.customButtons ? JSON.stringify(template.customButtons) : '[]') : '[]' %>;
            if (Array.isArray(templateButtons)) {
                buttons = templateButtons;
            } else {
                buttons = [];
            }
            renderButtons();
        }

        // ===== PREVIEW =====
        function updatePreview() {
            var message = document.getElementById('welcomeMessage') ? document.getElementById('welcomeMessage').value : 'Welcome {mention}! A member of our support team will assist you shortly.';
            var previewMessage = document.getElementById('previewMessage');
            if (previewMessage) previewMessage.textContent = message;

            var embedTitle = document.getElementById('embedTitle');
            var embedDesc = document.getElementById('embedDescription');
            var embedFooter = document.getElementById('embedFooter');
            var embedColor = document.getElementById('embedColor');

            var previewEmbed = document.getElementById('previewEmbed');
            var previewEmbedTitle = document.getElementById('previewEmbedTitle');
            var previewEmbedDesc = document.getElementById('previewEmbedDesc');
            var previewEmbedFooter = document.getElementById('previewEmbedFooter');

            if (embedTitle && embedTitle.value) {
                previewEmbed.style.display = 'block';
                if (previewEmbedTitle) previewEmbedTitle.textContent = embedTitle.value;
            } else {
                previewEmbed.style.display = 'none';
            }

            if (embedDesc && embedDesc.value) {
                if (previewEmbedDesc) previewEmbedDesc.textContent = embedDesc.value;
            }

            if (embedFooter && embedFooter.value) {
                if (previewEmbedFooter) previewEmbedFooter.textContent = embedFooter.value;
            }

            if (embedColor && previewEmbed) {
                previewEmbed.style.borderLeftColor = embedColor.value;
            }
        }

        function updatePreviewButtons() {
            var container = document.getElementById('previewButtons');
            if (!container) return;

            container.innerHTML = '';
            if (buttons.length === 0) {
                container.innerHTML = '<button class="preview-btn primary">🟢 Claim</button><button class="preview-btn secondary">📝 Note</button><button class="preview-btn danger">🔒 Close</button>';
                return;
            }

            buttons.forEach(function(btn) {
                var colorMap = { primary: 'primary', secondary: 'secondary', success: 'success', danger: 'danger' };
                var btnEl = document.createElement('button');
                btnEl.className = 'preview-btn ' + (colorMap[btn.color] || 'primary');
                btnEl.textContent = (btn.emoji || '📩') + ' ' + (btn.label || 'Button');
                container.appendChild(btnEl);
            });
        }

        // ===== SAVE TEMPLATE =====
        async function saveTemplate(event) {
            if (event) event.preventDefault();

            var supportRolesSelect = document.getElementById('supportRoles');
            var supportRoles = Array.from(supportRolesSelect.selectedOptions).map(function(opt) { return opt.value; }).filter(function(v) { return v; });

            var data = {
                name: document.getElementById('name').value,
                description: document.getElementById('description').value,
                status: document.getElementById('status').value,
                category: document.getElementById('category').value,
                transcriptChannel: document.getElementById('transcriptChannel').value,
                channelName: document.getElementById('channelName').value,
                topic: document.getElementById('topic').value,
                welcomeMessage: document.getElementById('welcomeMessage') ? document.getElementById('welcomeMessage').value : '',
                supportRoles: supportRoles,
                maxTickets: parseInt(document.getElementById('maxTickets').value) || 3,
                cooldown: parseInt(document.getElementById('cooldown').value) || 600,
                pinWelcome: document.querySelector('input[name="pinWelcome"]') ? document.querySelector('input[name="pinWelcome"]').checked : false,
                autoMentionSupport: document.querySelector('input[name="autoMentionSupport"]') ? document.querySelector('input[name="autoMentionSupport"]').checked : true,
                lockOnClose: document.querySelector('input[name="lockOnClose"]') ? document.querySelector('input[name="lockOnClose"]').checked : true,
                deleteOnClose: document.querySelector('input[name="deleteOnClose"]') ? document.querySelector('input[name="deleteOnClose"]').checked : false,
                autoClose: {
                    enabled: document.getElementById('autoCloseEnabled').value === 'true',
                    timeout: parseInt(document.getElementById('autoCloseTimeout').value) || 0,
                    reminder: parseInt(document.getElementById('autoCloseReminder').value) || 15
                },
                permissions: {
                    closeTicket: document.querySelector('input[name="perm_close"]') ? document.querySelector('input[name="perm_close"]').checked : false,
                    deleteTicket: document.querySelector('input[name="perm_delete"]') ? document.querySelector('input[name="perm_delete"]').checked : false,
                    renameTicket: document.querySelector('input[name="perm_rename"]') ? document.querySelector('input[name="perm_rename"]').checked : false,
                    claimTicket: document.querySelector('input[name="perm_claim"]') ? document.querySelector('input[name="perm_claim"]').checked : false,
                    addUser: document.querySelector('input[name="perm_adduser"]') ? document.querySelector('input[name="perm_adduser"]').checked : false,
                    removeUser: document.querySelector('input[name="perm_removeuser"]') ? document.querySelector('input[name="perm_removeuser"]').checked : false
                },
                customButtons: buttons
            };

            try {
                var url = templateId ? '/api/tickets/' + templateId : '/api/tickets';
                var method = templateId ? 'PUT' : 'POST';

                var response = await fetch(url, {
                    method: method,
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });
                var result = await response.json();
                if (result.success) {
                    showToast('✅ Template saved successfully!', 'success');
                    if (!templateId) {
                        setTimeout(function() {
                            window.location.href = '/servers/' + guildId + '/tickets/templates';
                        }, 1500);
                    }
                } else {
                    showToast('❌ Error: ' + result.error, 'error');
                }
            } catch (error) {
                showToast('❌ Error: ' + error.message, 'error');
            }
        }

        // ===== PUBLISH TEMPLATE =====
        function publishTemplate() {
            showToast('🚀 Publishing panel to Discord...', 'info');
            // This would call the publish API
            // For now, just save and then redirect
            saveTemplate();
            setTimeout(function() {
                window.location.href = '/servers/' + guildId + '/panels';
            }, 2000);
        }

        // ===== DELETE TEMPLATE =====
        function deleteTemplate() {
            if (!templateId) return;
            if (!confirm('Are you sure you want to delete this template? This action cannot be undone.')) return;

            fetch('/api/tickets/' + templateId, {
                method: 'DELETE',
                headers: { 'Content-Type': 'application/json' }
            })
            .then(function(response) { return response.json(); })
            .then(function(data) {
                if (data.success) {
                    showToast('✅ Template deleted successfully!', 'success');
                    setTimeout(function() {
                        window.location.href = '/servers/' + guildId + '/tickets/templates';
                    }, 1500);
                } else {
                    showToast('❌ Error: ' + data.error, 'error');
                }
            })
            .catch(function(error) {
                showToast('❌ Error: ' + error.message, 'error');
            });
        }

        // ===== INIT =====
        document.addEventListener('DOMContentLoaded', function() {
            renderRoleChips();
            loadButtons();
            updateChannelName();
            updatePreview();

            // Add welcome message listener if it exists
            var welcomeMsg = document.getElementById('welcomeMessage');
            if (welcomeMsg) {
                welcomeMsg.addEventListener('input', updatePreview);
            }
        });

        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', function() {
                renderRoleChips();
                loadButtons();
                updateChannelName();
                updatePreview();
            });
        } else {
            renderRoleChips();
            loadButtons();
            updateChannelName();
            updatePreview();
        }

        // ===== EXPOSE FUNCTIONS =====
        window.showToast = showToast;
        window.switchTab = switchTab;
        window.updateChannelName = updateChannelName;
        window.toggleSwitch = toggleSwitch;
        window.updatePermissions = updatePermissions;
        window.saveTemplate = saveTemplate;
        window.publishTemplate = publishTemplate;
        window.deleteTemplate = deleteTemplate;
        window.renderRoleChips = renderRoleChips;
        window.addButton = addButton;
        window.removeButton = removeButton;
        window.updateButton = updateButton;
        window.buttons = buttons;
        window.renderButtons = renderButtons;
        window.loadButtons = loadButtons;
        window.updatePreview = updatePreview;
        window.updatePreviewButtons = updatePreviewButtons;
    </script>

</body>
</html>
