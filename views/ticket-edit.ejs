                    <button class="tab-btn" data-tab="panel" onclick="switchTab('panel')">Panel</button>
                    <button class="tab-btn" data-tab="embed" onclick="switchTab('embed')">Embed</button>
                    <button class="tab-btn" data-tab="buttons" onclick="switchTab('buttons')">Buttons</button>
                    <button class="tab-btn" data-tab="roles" onclick="switchTab('roles')">Roles</button>
                    <button class="tab-btn" data-tab="permissions" onclick="switchTab('permissions')">Permissions</button>
                    <button class="tab-btn" data-tab="automation" onclick="switchTab('automation')">Automation</button>
                    <button class="tab-btn" data-tab="advanced" onclick="switchTab('advanced')">Advanced</button>
