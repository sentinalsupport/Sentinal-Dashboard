<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title || 'Edit Template — Sentinal' %></title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@400;500;600;700;800&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --ink: #060A10;
            --panel: #0D1520;
            --panel-raised: #111D2C;
            --panel-hover: #162033;
            --line: rgba(255,255,255,0.07);
            --line-bright: rgba(255,255,255,0.13);
            --text: #E6EDF6;
            --muted: #6C7A90;
            --muted-dim: #3E4A5C;
            --signal: #3DFFB8;
            --signal-tab: rgba(61,255,184,0.08);
            --signal-glow: rgba(61,255,184,0.15);
            --signal-hover: rgba(61,255,184,0.18);
            --gold: #F5C842;
            --gold-tab: rgba(245,200,66,0.12);
            --violet: #8B7EFF;
            --violet-tab: rgba(139,126,255,0.12);
            --red: #F87171;
            --red-bg: rgba(248,113,113,0.08);
            --red-border: rgba(248,113,113,0.22);
            --discord: #5865F2;
            --discord-hover: #4752C4;
        }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Inter', -apple-system, sans-serif;
            background: var(--ink);
            color: var(--text);
            min-height: 100vh;
            overflow-x: hidden;
        }

        /* ===== NAVBAR ===== */
        .navbar {
            background: rgba(6,10,16,0.9);
            backdrop-filter: blur(28px) saturate(160%);
            border-bottom: 1px solid var(--line);
            padding: 0 48px;
            height: 72px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: sticky;
            top: 0;
            z-index: 200;
        }
        .brand { display: flex; align-items: center; gap: 12px; text-decoration: none; }
        .brand-logo {
            width: 40px; height: 40px; border-radius: 12px;
            background: var(--panel-raised); border: 1px solid var(--line-bright);
            display: flex; align-items: center; justify-content: center;
        }
        .brand-logo svg { width: 22px; height: 22px; }
        .brand-name {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 20px; font-weight: 700; color: #fff; letter-spacing: -0.3px;
        }
        .nav-center { display: flex; align-items: center; gap: 8px; }
        .nav-center a {
            color: var(--muted); text-decoration: none; font-size: 15px; font-weight: 500;
            padding: 8px 18px; border-radius: 10px; transition: all 0.18s ease;
        }
        .nav-center a:hover { color: var(--text); background: rgba(255,255,255,0.05); }
        .nav-center a.active { color: #fff; }
        .nav-right {
            display: flex;
            align-items: center;
            gap: 16px;
        }
        .nav-right .actions {
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .user-pill {
            display: flex;
            align-items: center;
            gap: 12px;
            background: var(--panel);
            border: 1px solid var(--line);
            border-radius: 100px;
            padding: 6px 18px 6px 8px;
        }
        .user-avatar {
            width: 32px; height: 32px; border-radius: 50%;
            background: var(--panel-raised); overflow: hidden;
            display: flex; align-items: center; justify-content: center;
            font-size: 14px; font-weight: 700;
        }
        .user-avatar img { width: 100%; height: 100%; object-fit: cover; }
        .user-name { font-size: 14px; font-weight: 500; color: var(--text); }
        .user-plan {
            font-size: 11px; font-weight: 600; color: var(--signal);
            background: var(--signal-tab); border: 1px solid rgba(61,255,184,0.22);
            border-radius: 100px; padding: 3px 10px; letter-spacing: 0.3px;
        }
        .logout-btn {
            background: transparent; border: 1px solid var(--line); border-radius: 10px;
            padding: 8px 14px; color: var(--muted); cursor: pointer; font-size: 14px;
            transition: all 0.18s ease; text-decoration: none;
            display: flex; align-items: center; gap: 8px;
        }
        .logout-btn:hover { background: var(--red-bg); border-color: var(--red-border); color: var(--red); }

        .navbar .btn-save {
            padding: 8px 20px;
            border-radius: 8px;
            border: none;
            background: var(--signal);
            color: var(--ink);
            font-weight: 700;
            font-size: 13px;
            cursor: pointer;
            transition: all 0.2s ease;
            font-family: 'Inter', sans-serif;
            display: inline-flex;
            align-items: center;
            gap: 6px;
        }
        .navbar .btn-save:hover {
            transform: translateY(-1px);
            box-shadow: 0 4px 20px var(--signal-glow);
        }
        .navbar .btn-publish {
            padding: 8px 20px;
            border-radius: 8px;
            border: none;
            background: var(--violet);
            color: #fff;
            font-weight: 700;
            font-size: 13px;
            cursor: pointer;
            transition: all 0.2s ease;
            font-family: 'Inter', sans-serif;
            display: inline-flex;
            align-items: center;
            gap: 6px;
        }
        .navbar .btn-publish:hover {
            transform: translateY(-1px);
            box-shadow: 0 4px 20px rgba(139,126,255,0.3);
        }
        .navbar .btn-cancel {
            padding: 8px 20px;
            border-radius: 8px;
            border: 1px solid var(--line);
            background: transparent;
            color: var(--text);
            font-weight: 600;
            font-size: 13px;
            cursor: pointer;
            transition: all 0.2s ease;
            font-family: 'Inter', sans-serif;
            display: inline-flex;
            align-items: center;
            gap: 6px;
        }
        .navbar .btn-cancel:hover { background: rgba(255,255,255,0.05); }

        /* ===== PAGE WRAPPER ===== */
        .page-wrapper {
            max-width: 100%;
            margin: 0;
            padding: 32px 48px 60px 5px;
            display: flex;
            gap: 32px;
            align-items: flex-start;
            min-height: calc(100vh - 72px);
        }

        /* ===== LEFT SIDEBAR ===== */
        .sidebar-left {
            width: 240px;
            flex-shrink: 0;
            background: var(--panel);
            border: 1px solid var(--line);
            border-radius: 14px;
            padding: 16px 12px;
            position: sticky;
            top: 88px;
            height: calc(100vh - 108px);
            overflow-y: auto;
        }
        .sidebar-left::-webkit-scrollbar { width: 3px; }
        .sidebar-left::-webkit-scrollbar-track { background: transparent; }
        .sidebar-left::-webkit-scrollbar-thumb { background: var(--muted-dim); border-radius: 10px; }

        .sidebar-left .nav-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 10px 14px;
            border-radius: 10px;
            color: var(--muted);
            text-decoration: none;
            font-size: 13px;
            font-weight: 500;
            transition: all 0.18s ease;
            cursor: pointer;
            border: none;
            background: none;
            width: 100%;
            text-align: left;
            margin-bottom: 2px;
        }
        .sidebar-left .nav-item:hover {
            background: rgba(255,255,255,0.04);
            color: var(--text);
        }
        .sidebar-left .nav-item.active {
            background: var(--signal-tab);
            color: var(--signal);
        }
        .sidebar-left .nav-item i {
            width: 18px;
            font-size: 14px;
            color: var(--muted-dim);
        }
        .sidebar-left .nav-item.active i { color: var(--signal); }
        .sidebar-left .nav-item .badge {
            margin-left: auto;
            font-size: 7px;
            font-weight: 700;
            padding: 2px 8px;
            border-radius: 100px;
            text-transform: uppercase;
        }
        .sidebar-left .nav-item .badge.live { background: var(--signal-tab); color: var(--signal); }
        .sidebar-left .divider { height: 1px; background: var(--line); margin: 8px 0; }

        /* ===== CONTENT AREA ===== */
        .content {
            flex: 1;
            min-width: 0;
        }

        /* ===== TABS ===== */
        .tabs-container {
            background: var(--panel);
            border: 1px solid var(--line);
            border-radius: 14px;
            overflow: hidden;
        }
        .tabs-header {
            display: flex;
            gap: 4px;
            padding: 12px 20px 0 20px;
            border-bottom: 1px solid var(--line);
            overflow-x: auto;
            background: var(--panel-raised);
        }
        .tabs-header .tab-btn {
            padding: 10px 20px;
            border: none;
            background: none;
            color: var(--muted);
            font-weight: 500;
            font-size: 13px;
            cursor: pointer;
            border-bottom: 2px solid transparent;
            transition: all 0.2s ease;
            font-family: 'Inter', sans-serif;
            white-space: nowrap;
        }
        .tabs-header .tab-btn:hover { color: var(--text); }
        .tabs-header .tab-btn.active {
            color: var(--signal);
            border-bottom-color: var(--signal);
        }
        .tabs-body {
            padding: 24px;
        }
        .tab-content { display: none; }
        .tab-content.active { display: block; }

        /* ===== FORM ELEMENTS ===== */
        .form-group { margin-bottom: 20px; }
        .form-group:last-child { margin-bottom: 0; }
        .form-group label {
            display: block;
            font-weight: 600;
            font-size: 13px;
            color: var(--text);
            margin-bottom: 4px;
        }
        .form-group label .label-desc {
            font-weight: 400;
            font-size: 11px;
            color: var(--muted);
            margin-left: 6px;
        }
        .form-group .help-text {
            font-size: 11px;
            color: var(--muted);
            margin-top: 4px;
        }
        .form-control {
            width: 100%;
            padding: 8px 14px;
            border-radius: 8px;
            border: 1px solid var(--line);
            background: var(--panel-raised);
            color: var(--text);
            font-size: 13px;
            font-family: 'Inter', sans-serif;
            transition: all 0.18s ease;
        }
        .form-control:focus {
            outline: none;
            border-color: var(--signal);
            box-shadow: 0 0 0 3px var(--signal-glow);
        }
        .form-control::placeholder { color: var(--muted-dim); }
        select.form-control { appearance: none; cursor: pointer; }
        textarea.form-control {
            resize: vertical;
            min-height: 60px;
            font-family: 'Inter', sans-serif;
        }

        .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }

        /* ===== BUTTON GRID ===== */
        .button-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
            gap: 12px;
            margin-top: 12px;
        }
        .button-card {
            background: var(--panel-raised);
            border: 1px solid var(--line);
            border-radius: 10px;
            padding: 14px 16px;
            transition: all 0.2s ease;
            position: relative;
        }
        .button-card:hover { border-color: var(--line-bright); }
        .button-card .card-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 8px;
        }
        .button-card .card-header .btn-label {
            font-weight: 600;
            font-size: 13px;
            color: var(--text);
            font-family: 'Space Grotesk', sans-serif;
        }
        .button-card .card-header .btn-remove {
            background: none;
            border: none;
            color: var(--muted-dim);
            cursor: pointer;
            font-size: 12px;
            padding: 2px 6px;
            transition: all 0.18s ease;
        }
        .button-card .card-header .btn-remove:hover { color: var(--red); }
        .button-card .card-row {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
        }
        .button-card .card-row .form-group {
            flex: 1;
            min-width: 70px;
            margin-bottom: 0;
        }
        .button-card .card-row .form-group label {
            font-size: 10px;
            color: var(--muted);
            font-weight: 500;
            margin-bottom: 2px;
        }
        .button-card .card-row .form-control {
            padding: 4px 8px;
            font-size: 12px;
            min-height: 30px;
        }
        .button-card .card-preview {
            margin-top: 8px;
            padding: 4px 12px;
            border-radius: 4px;
            font-size: 12px;
            font-weight: 600;
            display: inline-block;
            background: var(--signal-tab);
            color: var(--signal);
            border: 1px solid rgba(61,255,184,0.2);
        }
        .btn-add-button {
            padding: 12px 16px;
            border: 2px dashed var(--line);
            border-radius: 10px;
            background: transparent;
            color: var(--muted);
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.18s ease;
            font-family: 'Inter', sans-serif;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            width: 100%;
            margin-top: 12px;
        }
        .btn-add-button:hover {
            border-color: var(--signal);
            color: var(--signal);
            background: var(--signal-tab);
        }
        .btn-add-button:disabled {
            opacity: 0.4;
            cursor: not-allowed;
        }
        .button-count {
            font-size: 11px;
            color: var(--muted);
            margin-left: 6px;
        }

        /* ===== PREVIEW SIDEBAR ===== */
        .preview-sidebar {
            width: 340px;
            flex-shrink: 0;
            position: sticky;
            top: 88px;
            height: calc(100vh - 108px);
            overflow-y: auto;
            padding: 0 0 20px 0;
        }
        .preview-sidebar::-webkit-scrollbar { width: 3px; }
        .preview-sidebar::-webkit-scrollbar-track { background: transparent; }
        .preview-sidebar::-webkit-scrollbar-thumb { background: var(--muted-dim); border-radius: 10px; }

        .preview-card {
            background: var(--panel);
            border: 1px solid var(--line);
            border-radius: 14px;
            padding: 20px;
        }
        .preview-card .preview-title {
            font-size: 12px;
            font-weight: 600;
            color: var(--muted);
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 12px;
        }

        .discord-preview {
            background: #1a1a2e;
            border-radius: 10px;
            padding: 14px;
            border: 1px solid var(--line);
        }
        .discord-preview .preview-header {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 10px;
        }
        .discord-preview .preview-header .avatar {
            width: 28px;
            height: 28px;
            border-radius: 50%;
            background: var(--signal);
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            font-size: 12px;
            color: var(--ink);
            flex-shrink: 0;
        }
        .discord-preview .preview-header .name {
            font-weight: 600;
            font-size: 13px;
            color: var(--text);
        }
        .discord-preview .preview-header .time {
            font-size: 11px;
            color: var(--muted-dim);
            margin-left: auto;
        }
        .discord-preview .preview-message {
            color: var(--text);
            font-size: 13px;
            line-height: 1.5;
            padding: 6px 0;
            white-space: pre-wrap;
            word-break: break-word;
        }
        .discord-preview .preview-embed {
            background: var(--panel-raised);
            border-left: 4px solid var(--signal);
            border-radius: 4px;
            padding: 10px 14px;
            margin-top: 6px;
        }
        .discord-preview .preview-embed .embed-title {
            font-weight: 700;
            font-size: 14px;
            color: #fff;
        }
        .discord-preview .preview-embed .embed-desc {
            font-size: 13px;
            color: var(--muted);
            margin-top: 4px;
        }
        .discord-preview .preview-embed .embed-footer {
            font-size: 11px;
            color: var(--muted-dim);
            margin-top: 6px;
        }
        .discord-preview .preview-buttons {
            display: flex;
            flex-wrap: wrap;
            gap: 6px;
            margin-top: 10px;
        }
        .discord-preview .preview-buttons .preview-btn {
            padding: 3px 12px;
            border-radius: 4px;
            font-size: 12px;
            font-weight: 500;
            border: none;
            cursor: default;
        }
        .preview-btn.primary { background: #5865F2; color: #fff; }
        .preview-btn.secondary { background: #4e5d73; color: #fff; }
        .preview-btn.success { background: #57F287; color: #000; }
        .preview-btn.danger { background: #ED4245; color: #fff; }

        /* ===== TOAST ===== */
        .toast-container {
            position: fixed;
            bottom: 24px;
            right: 24px;
            z-index: 9999;
            display: flex;
            flex-direction: column;
            gap: 10px;
            max-width: 380px;
            width: 100%;
        }
        .toast {
            background: var(--panel);
            border: 1px solid var(--line);
            border-radius: 12px;
            padding: 14px 20px;
            display: flex;
            align-items: center;
            gap: 12px;
            box-shadow: 0 8px 32px rgba(0,0,0,0.4);
            animation: slideIn 0.3s ease;
            backdrop-filter: blur(10px);
            border-left: 4px solid var(--signal);
        }
        .toast .toast-icon { color: var(--signal); font-size: 18px; flex-shrink: 0; }
        .toast .toast-content { flex: 1; font-size: 13px; color: var(--text); line-height: 1.4; }
        .toast .toast-close {
            background: none;
            border: none;
            color: var(--muted-dim);
            cursor: pointer;
            font-size: 14px;
            padding: 4px;
        }
        .toast .toast-close:hover { color: var(--text); }
        .toast.error { border-left-color: var(--red); }
        .toast.error .toast-icon { color: var(--red); }
        .toast.success { border-left-color: var(--signal); }
        .toast.success .toast-icon { color: var(--signal); }
        @keyframes slideIn {
            from { opacity: 0; transform: translateX(40px); }
            to { opacity: 1; transform: translateX(0); }
        }
        @keyframes slideOut {
            from { opacity: 1; transform: translateX(0); }
            to { opacity: 0; transform: translateX(40px); }
        }
        .toast.hiding { animation: slideOut 0.3s ease forwards; }

        .footer {
            border-top: 1px solid var(--line);
            margin-top: 60px;
            padding: 28px 48px;
            text-align: center;
            color: var(--muted-dim);
            font-size: 13px;
            font-family: 'IBM Plex Mono', monospace;
            letter-spacing: 0.5px;
        }

        @media (max-width: 1400px) {
            .preview-sidebar { width: 280px; }
        }
        @media (max-width: 1200px) {
            .page-wrapper { padding: 24px 32px 60px 5px; gap: 24px; }
            .sidebar-left { width: 200px; }
            .preview-sidebar { width: 260px; }
        }
        @media (max-width: 992px) {
            .page-wrapper { flex-direction: column; }
            .sidebar-left {
                width: 100%;
                position: relative;
                top: 0;
                height: auto;
                display: flex;
                flex-wrap: wrap;
                gap: 4px;
                padding: 12px;
                border-radius: 12px;
                max-height: none;
            }
            .sidebar-left .nav-item { padding: 6px 14px; font-size: 13px; width: auto; }
            .sidebar-left .divider { display: none; }
            .preview-sidebar {
                width: 100%;
                position: relative;
                top: 0;
                height: auto;
                max-height: none;
            }
            .content { flex-direction: column; }
        }
        @media (max-width: 768px) {
            .navbar { padding: 0 16px; height: 64px; flex-wrap: wrap; }
            .nav-center { display: none; }
            .page-wrapper { padding: 16px; flex-direction: column; }
            .tabs-header { padding: 8px 12px 0 12px; }
            .tabs-body { padding: 16px; }
            .form-row { grid-template-columns: 1fr; }
            .button-grid { grid-template-columns: 1fr; }
            .navbar .actions .btn-label { display: none; }
            .footer { padding: 20px 16px; }
            .toast-container { bottom: 16px; right: 16px; max-width: calc(100% - 32px); }
        }
    </style>
</head>
<body>

    <!-- ===== NAVBAR ===== -->
    <nav class="navbar">
        <a href="/dashboard" class="brand">
            <div class="brand-logo">
                <svg viewBox="0 0 245 240" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M104.4 103.9c-5.7 0-10.2 5-10.2 11.1s4.6 11.1 10.2 11.1c5.7 0 10.2-5 10.2-11.1.1-6.1-4.5-11.1-10.2-11.1zM140.9 103.9c-5.7 0-10.2 5-10.2 11.1s4.6 11.1 10.2 11.1c5.7 0 10.2-5 10.2-11.1s-4.5-11.1-10.2-11.1z" fill="#3DFFB8"/>
