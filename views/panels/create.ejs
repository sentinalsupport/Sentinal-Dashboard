    <div class="toast-container" id="toastContainer"></div>

    <div class="page-wrapper">

        <!-- ===== PAGE HEADER ===== -->
        <div class="page-header">
            <div>
                <h1 id="templateHeaderName"><%= template ? template.name : 'Create Template' %></h1>
                <p>Define how a ticket behaves in your server</p>
            </div>
            <div class="header-actions">
                <button class="btn btn-cancel-header" onclick="window.location.href='/servers/<%= guild.id %>/tickets/templates'"><i class="fas fa-times"></i> Cancel</button>
                <button class="btn btn-draft-header" onclick="saveDraft()"><i class="fas fa-file-alt"></i> Draft</button>
                <button class="btn btn-save-header" onclick="saveTemplate(event)"><i class="fas fa-save"></i> Save</button>
                <button class="btn btn-publish-header" onclick="publishTemplate()"><i class="fas fa-rocket"></i> Publish</button>
            </div>
        </div>

        <!-- ===== FORM CONTAINER ===== -->
        <div class="form-container">
            <form id="templateForm" method="POST" action="/servers/<%= guild.id %>/tickets/<%= template ? template._id : 'create' %>" onsubmit="return false;">
                <input type="hidden" name="guildId" value="<%= guild.id %>">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">

                <!-- ===== BASIC INFORMATION ===== -->
                <div class="form-section">
                    <div class="section-title">Basic Information</div>
                    <div class="section-desc">Configure the basic details for this ticket template.</div>

                    <div class="settings-card">
                        <div class="card-label">Template name</div>
                        <div class="card-desc">The name of the ticket.</div>
                        <input type="text" id="name" name="name" class="form-control" value="<%= template ? template.name : '' %>" placeholder="e.g., Support" required oninput="document.getElementById('templateHeaderName').textContent = this.value || 'Create Template'">
                    </div>

                    <div class="settings-card">
                        <div class="card-label">Ticket Logging Channel</div>
                        <div class="card-desc">The channel where closed tickets will be logged.</div>
                        <select id="transcriptChannel" name="transcriptChannel" class="form-control">
                            <option value="">None</option>
                            <% if (channels) { %>
                                <% channels.filter(function(c) { return c.type === 0; }).forEach(function(ch) { %>
                                    <option value="<%= ch.id %>" <%= template && template.transcriptChannel === ch.id ? 'selected' : '' %>>#<%= ch.name %></option>
                                <% }) %>
                            <% } %>
                        </select>
                        <div class="validation-error" id="loggingChannelError" style="display: none;">Please select a logging channel</div>
                    </div>

                    <div class="settings-card">
                        <div class="card-label">Ticket category</div>
                        <div class="card-desc">Tickets will be created under this category.</div>
                        <select id="category" name="category" class="form-control">
                            <option value="">None</option>
                            <% if (channels) { %>
                                <% channels.filter(function(c) { return c.type === 4; }).forEach(function(cat) { %>
                                    <option value="<%= cat.id %>" <%= template && template.category === cat.id ? 'selected' : '' %>><%= cat.name %></option>
                                <% }) %>
                            <% } %>
                        </select>
                        <div class="validation-error" id="categoryError" style="display: none;">Please select a category</div>
                    </div>

                    <div class="settings-card">
                        <div class="card-label">Ticket Channel Name</div>
                        <div class="card-desc">Format: <code>{ticket-creator-username}-{total-tickets-opened}</code></div>
                        <input type="text" id="channelName" name="channelName" class="form-control" value="<%= template ? template.channelName || '{ticket-creator-username}-{total-tickets-opened}' : '{ticket-creator-username}-{total-tickets-opened}' %>" placeholder="ticket-creator-username-total-tickets-opened">
                        <div style="font-size: 11px; color: var(--muted); margin-top: 4px;">Variables: {user} · {id} · {number} · {ticket-creator-username} · {total-tickets-opened}</div>
                    </div>
                </div>

                <!-- ===== CAN TICKET CREATOR CLOSE TICKET ===== -->
                <div class="form-section">
                    <div class="section-title">Ticket Permissions</div>
                    <div class="section-desc">Control who can close tickets and access controls.</div>

                    <div class="settings-card">
                        <div class="card-label">Can Ticket Creator Close Ticket</div>
                        <div class="card-desc">If enabled, the ticket creator can close their own ticket. Otherwise only support team members may close it.</div>
                        <div class="toggle-wrapper">
                            <div class="toggle <%= template && template.creatorCanClose ? 'active' : '' %>" onclick="toggleBool(this, 'creatorCanClose')"><div class="toggle-knob"></div></div>
                            <span class="toggle-label"><%= template && template.creatorCanClose ? 'Enabled' : 'Disabled' %></span>
                        </div>
                        <input type="hidden" name="creatorCanClose" id="creatorCanClose" value="<%= template && template.creatorCanClose ? 'true' : 'false' %>">
                    </div>
                </div>

                <!-- ===== TICKET ACCESS CONTROL ===== -->
                <div class="form-section">
                    <div class="section-title">Ticket Access Control</div>
                    <div class="section-desc">Configure role-based access restrictions for tickets.</div>

                    <!-- Blocked Roles -->
                    <div class="settings-card">
                        <div class="card-label">Blocked Roles</div>
                        <div class="card-desc">Users with these roles cannot create tickets.</div>
                        <div class="role-selector-wrapper">
                            <select id="blockedRoles" name="blockedRoles" multiple style="display:none;">
                                <% if (roles) { %>
                                    <% roles.forEach(function(role) { %>
                                        <option value="<%= role.id %>" data-color="<%= role.color ? (typeof role.color === 'number' ? '#' + role.color.toString(16).padStart(6,'0') : role.color) : '#3DFFB8' %>" <%= template && template.blockedRoles && template.blockedRoles.indexOf(role.id) !== -1 ? 'selected' : '' %>><%= role.name.charAt(0) === '@' ? role.name : '@' + role.name %></option>
                                    <% }) %>
                                <% } %>
                            </select>
                            <div class="role-chip-grid" id="blockedRolesGrid"></div>
                            <span class="counter" id="blockedRolesCount">Blocked Roles: 0/10</span>
                        </div>
                        <div class="match-mode-selector">
                            <button type="button" class="btn-match active" data-mode="hasAny" onclick="setMatchMode('blocked', 'hasAny')">Has any role</button>
                            <button type="button" class="btn-match" data-mode="hasAll" onclick="setMatchMode('blocked', 'hasAll')">Has all roles</button>
                        </div>
                        <div class="card-desc" style="margin-top: 6px;">Users must match the selected mode to be blocked from creating tickets.</div>
                    </div>

                    <!-- Required Roles -->
                    <div class="settings-card">
                        <div class="card-label">Required Roles</div>
                        <div class="card-desc">Users must have at least one of these roles to create tickets.</div>
                        <div class="role-selector-wrapper">
                            <select id="requiredRoles" name="requiredRoles" multiple style="display:none;">
                                <% if (roles) { %>
                                    <% roles.forEach(function(role) { %>
                                        <option value="<%= role.id %>" data-color="<%= role.color ? (typeof role.color === 'number' ? '#' + role.color.toString(16).padStart(6,'0') : role.color) : '#3DFFB8' %>" <%= template && template.requiredRoles && template.requiredRoles.indexOf(role.id) !== -1 ? 'selected' : '' %>><%= role.name.charAt(0) === '@' ? role.name : '@' + role.name %></option>
                                    <% }) %>
                                <% } %>
                            </select>
                            <div class="role-chip-grid" id="requiredRolesGrid"></div>
                            <span class="counter" id="requiredRolesCount">Required Roles: 0/10</span>
                        </div>
                        <div class="match-mode-selector">
                            <button type="button" class="btn-match active" data-mode="hasAny" onclick="setMatchMode('required', 'hasAny')">Has any role</button>
                            <button type="button" class="btn-match" data-mode="hasAll" onclick="setMatchMode('required', 'hasAll')">Has all roles</button>
                        </div>
                        <div class="card-desc" style="margin-top: 6px;">Users must match the selected mode to be allowed to create tickets.</div>
                    </div>
                </div>

                <!-- ===== MAX CONCURRENT TICKETS ===== -->
                <div class="form-section">
                    <div class="section-title">Ticket Limits</div>
                    <div class="section-desc">Configure limits on ticket creation.</div>

                    <div class="settings-card">
                        <div class="card-label">Max Concurrent Open Tickets</div>
                        <div class="card-desc">Maximum number of tickets a user can have open at once.</div>
                        <input type="number" id="maxTickets" name="maxTickets" class="form-control" value="<%= template ? template.maxTickets || 3 : 3 %>" min="1" max="10">
                    </div>
                </div>

                <!-- ===== SUPPORT TEAM & PERMISSIONS ===== -->
                <div class="form-section">
                    <div class="section-title">Support Team & Permissions</div>
                    <div class="section-desc">Configure support team roles and permissions.</div>

                    <div class="settings-card">
                        <div class="card-label">Support Team Roles</div>
                        <div class="card-desc">Users with these roles can manage tickets.</div>
                        <div class="role-selector-wrapper">
                            <select id="supportRoles" name="supportRoles" multiple style="display:none;">
                                <% if (roles) { %>
                                    <% roles.forEach(function(role) { %>
                                        <option value="<%= role.id %>" data-color="<%= role.color ? (typeof role.color === 'number' ? '#' + role.color.toString(16).padStart(6,'0') : role.color) : '#3DFFB8' %>" <%= template && template.supportRoles && template.supportRoles.indexOf(role.id) !== -1 ? 'selected' : '' %>><%= role.name.charAt(0) === '@' ? role.name : '@' + role.name %></option>
                                    <% }) %>
                                <% } %>
                            </select>
                            <div class="role-chip-grid" id="supportRolesGrid"></div>
                            <span class="counter" id="supportRolesCount">Support Team Roles: 0/25</span>
                        </div>
                    </div>

                    <div class="settings-card">
                        <div class="card-label">Ping Support Roles</div>
                        <div class="card-desc">Support roles will be automatically pinged when a ticket is created.</div>
                        <div class="toggle-wrapper">
                            <div class="toggle <%= template && template.autoMentionSupport !== undefined ? (template.autoMentionSupport ? 'active' : '') : 'active' %>" onclick="toggleBool(this, 'autoMentionSupport')"><div class="toggle-knob"></div></div>
                            <span class="toggle-label"><%= template && template.autoMentionSupport !== undefined ? (template.autoMentionSupport ? 'Enabled' : 'Disabled') : 'Enabled' %></span>
                        </div>
                        <input type="hidden" name="autoMentionSupport" id="autoMentionSupport" value="<%= template && template.autoMentionSupport !== undefined ? (template.autoMentionSupport ? 'true' : 'false') : 'true' %>">
                    </div>

                    <div class="settings-card">
                        <div class="card-label">Rate Support Experience Enabled</div>
                        <div class="card-desc">Users can rate their support experience after ticket closure.</div>
                        <div class="toggle-wrapper">
                            <div class="toggle <%= template && template.rateSupport ? 'active' : '' %>" onclick="toggleBool(this, 'rateSupport')"><div class="toggle-knob"></div></div>
                            <span class="toggle-label"><%= template && template.rateSupport ? 'Enabled' : 'Disabled' %></span>
                        </div>
                        <input type="hidden" name="rateSupport" id="rateSupport" value="<%= template && template.rateSupport ? 'true' : 'false' %>">
                    </div>

                    <div class="settings-card">
                        <div class="card-label">Ticket Claiming</div>
                        <div class="card-desc">Staff can claim tickets to show ownership.</div>
                        <div class="toggle-wrapper">
                            <div class="toggle <%= template && template.ticketClaiming ? 'active' : '' %>" onclick="toggleBool(this, 'ticketClaiming')"><div class="toggle-knob"></div></div>
                            <span class="toggle-label"><%= template && template.ticketClaiming ? 'Enabled' : 'Disabled' %></span>
                        </div>
                        <input type="hidden" name="ticketClaiming" id="ticketClaiming" value="<%= template && template.ticketClaiming ? 'true' : 'false' %>">
                    </div>
                </div>

                <!-- ===== TICKET LIFECYCLE ===== -->
                <div class="form-section">
                    <div class="section-title">Ticket Lifecycle</div>
                    <div class="section-desc">Configure what happens when a user leaves or tickets are closed.</div>

                    <div class="settings-card">
                        <div class="card-label">Action on User Leave</div>
                        <div class="card-desc">What happens when a user leaves the server while their ticket is open.</div>
                        <select id="actionOnLeave" name="actionOnLeave" class="form-control">
                            <option value="nothing" <%= template && template.actionOnLeave === 'nothing' ? 'selected' : '' %>>NOTHING</option>
                            <option value="close" <%= template && template.actionOnLeave === 'close' ? 'selected' : '' %>>CLOSE</option>
                            <option value="delete" <%= template && template.actionOnLeave === 'delete' ? 'selected' : '' %>>DELETE</option>
                            <option value="archive" <%= template && template.actionOnLeave === 'archive' ? 'selected' : '' %>>ARCHIVE</option>
                        </select>
                    </div>
                </div>

                <!-- ===== TICKET FORM (QUESTIONS) ===== -->
                <div class="form-section">
                    <div class="section-title">Ticket Form</div>
                    <div class="section-desc">The form which will be opened when a user attempts to open a ticket.</div>

                    <div id="questionsContainer">
                        <div id="questionsGrid">
                            <!-- Questions rendered by JS -->
                        </div>
                    </div>
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 8px;">
                        <span id="questionsCount">Questions: 0/5</span>
                        <button type="button" class="btn-add" id="addQuestionBtn" onclick="addQuestion()" style="width: auto; padding: 6px 16px; margin-top: 0;">
                            <i class="fas fa-plus"></i> Add Question
                        </button>
                    </div>
                </div>

                <!-- ===== ACTION BAR ===== -->
                <div class="action-bar">
                    <button type="button" class="btn btn-cancel-action" onclick="window.location.href='/servers/<%= guild.id %>/tickets/templates'"><i class="fas fa-times"></i> Cancel</button>
                    <button type="button" class="btn btn-draft" onclick="saveDraft()"><i class="fas fa-file-alt"></i> Save Draft</button>
                    <button type="button" class="btn btn-save-action" onclick="saveTemplate(event)"><i class="fas fa-save"></i> Save Changes</button>
                    <button type="button" class="btn btn-publish-action" onclick="publishTemplate()"><i class="fas fa-rocket"></i> Publish Panel</button>
                </div>

            </form>
        </div>

    </div>

    <footer class="footer">
        © 2026 SENTINAL — STATUS: OPERATIONAL
    </footer>

    <script>
        // ===== STATE =====
        var MAX_QUESTIONS = 5;
        var questions = [];

        // ===== TOAST =====
        function showToast(message, type) {
            type = type || 'info';
            var container = document.getElementById('toastContainer');
            var toast = document.createElement('div');
            toast.className = 'toast ' + type;
            var icon = type === 'success' ? 'check-circle' : type === 'error' ? 'exclamation-circle' : 'info-circle';
            toast.innerHTML = `
                <span class="toast-icon"><i class="fas fa-${icon}"></i></span>
                <span class="toast-content">${message}</span>
                <button class="toast-close" onclick="this.parentElement.remove();">
                    <i class="fas fa-times"></i>
                </button>
            `;
            document.getElementById('toastContainer').appendChild(toast);
            setTimeout(function() {
                if (toast.parentElement) {
                    toast.classList.add('hiding');
                    setTimeout(function() { if (toast.parentElement) toast.remove(); }, 300);
                }
            }, 4000);
        }

        // ===== TOGGLES =====
        function toggleBool(el, id) {
            el.classList.toggle('active');
            var isActive = el.classList.contains('active');
            document.getElementById(id).value = isActive ? 'true' : 'false';
            // Update label text
            var label = el.parentElement.querySelector('.toggle-label');
            if (label) label.textContent = isActive ? 'Enabled' : 'Disabled';
        }

        // ===== ROLE CHIPS (generic) =====
        var ROLE_LIMITS = {
            blockedRoles: 10,
            requiredRoles: 10,
            supportRoles: 25
        };

        // Bot role IDs to filter out
        var BOT_ROLE_IDS = ['1493217033956102215'];
        var BOT_ROLE_NAMES = ['Sentinal', 'ProBot', 'Tickets v2', 'Tickets'];

        function isBotRole(name) {
            if (!name) return false;
            name = name.trim();
            if (name === '@everyone' || name === '@here') return true;
            for (var i = 0; i < BOT_ROLE_NAMES.length; i++) {
                if (name.includes(BOT_ROLE_NAMES[i])) return true;
                if (name.toLowerCase().includes('bot')) return true;
            }
            return false;
        }

        function renderRoleChips(selectId, gridId, countId, label) {
            var select = document.getElementById(selectId);
            var grid = document.getElementById(gridId);
            var countEl = document.getElementById(countId);
            if (!select || !grid) return;

            // Filter out @everyone and bot roles
            var options = Array.from(select.options).filter(function(opt) {
                var name = opt.textContent.trim();
                return !isBotRole(name) && !BOT_ROLE_IDS.includes(opt.value);
            });

            var selectedCount = options.filter(function(o) { return o.selected; }).length;

            grid.innerHTML = '';
            if (options.length === 0) {
                grid.innerHTML = '<div style="font-size: 13px; color: var(--muted-dim); padding: 6px 0;">No roles found</div>';
                return;
            }

            var limit = ROLE_LIMITS[selectId] || 10;

            options.forEach(function(opt) {
                var atLimit = selectedCount >= limit;
                var chip = document.createElement('span');
                chip.className = 'role-chip' + (opt.selected ? ' selected' : '') + (!opt.selected && atLimit ? ' disabled' : '');
                chip.innerHTML = `
                    <span class="dot" style="background: ${opt.dataset.color || '#3DFFB8'};"></span>
                    ${opt.textContent.trim()}
                    ${opt.selected ? '<span class="remove"><i class="fas fa-times"></i></span>' : ''}
                `;
                chip.addEventListener('click', function() {
                    if (opt.selected) {
                        opt.selected = false;
                    } else {
                        var currentCount = options.filter(function(o) { return o.selected; }).length;
                        if (currentCount >= limit) return;
                        opt.selected = true;
                    }
                    // Sync actual select
                    var allOptions = Array.from(select.options);
                    allOptions.forEach(function(o) {
                        var isSelected = options.some(function(opt2) {
                            return opt2.value === o.value && opt2.selected;
                        });
                        o.selected = isSelected;
                    });
                    select.dispatchEvent(new Event('change'));
                    renderRoleChips(selectId, gridId, countId, label);
                });
                grid.appendChild(chip);
            });

            if (countEl) {
                countEl.textContent = (label || 'Roles') + ': ' + selectedCount + '/' + limit;
                countEl.style.color = selectedCount >= limit ? 'var(--signal)' : 'var(--muted)';
            }
        }

        // ===== MATCH MODE =====
        function setMatchMode(type, mode) {
            var container = null;
            var cards = document.querySelectorAll('.settings-card');
            for (var i = 0; i < cards.length; i++) {
                if (cards[i].querySelector('.match-mode-selector')) {
                    var label = cards[i].querySelector('.card-label');
                    var isBlocked = label && label.textContent.trim() === 'Blocked Roles';
                    var isRequired = label && label.textContent.trim() === 'Required Roles';
                    if ((type === 'blocked' && isBlocked) || (type === 'required' && isRequired)) {
                        container = cards[i];
                        break;
                    }
                }
            }
            if (!container) return;

            var btns = container.querySelectorAll('.match-mode-selector .btn-match');
            btns.forEach(function(btn) {
                btn.classList.toggle('active', btn.dataset.mode === mode);
            });

            var inputId = type + 'MatchMode';
            var existing = document.getElementById(inputId);
            if (!existing) {
                var input = document.createElement('input');
                input.type = 'hidden';
                input.name = inputId;
                input.id = inputId;
                container.appendChild(input);
            }
            document.getElementById(inputId).value = mode;
        }

        // ===== QUESTIONS =====
        function renderQuestions() {
            var grid = document.getElementById('questionsGrid');
            var countEl = document.getElementById('questionsCount');
            var addBtn = document.getElementById('addQuestionBtn');

            grid.innerHTML = '';
            if (countEl) countEl.textContent = 'Questions: ' + questions.length + '/' + MAX_QUESTIONS;
            if (addBtn) addBtn.disabled = questions.length >= MAX_QUESTIONS;

            questions.forEach(function(q, index) {
                var card = document.createElement('div');
                card.className = 'question-card';
                card.innerHTML = `
                    <div class="question-header">
                        <span class="q-title">${q.title || 'Question ' + (index + 1)}</span>
                        <button type="button" class="q-remove" onclick="removeQuestion(${index})"><i class="fas fa-times"></i></button>
                    </div>
                    <div class="q-row">
                        <div class="q-field">
                            <label>Question Title</label>
                            <input type="text" class="form-control" value="${q.title || ''}" placeholder="e.g. Do you like capybaras?" onchange="updateQuestion(${index}, 'title', this.value)">
                        </div>
                        <div class="q-field">
                            <label>Description</label>
                            <input type="text" class="form-control" value="${q.description || ''}" placeholder="Brief description" onchange="updateQuestion(${index}, 'description', this.value)">
                        </div>
                    </div>
                    <div class="q-row">
                        <div class="q-field">
                            <label>Placeholder</label>
                            <input type="text" class="form-control" value="${q.placeholder || ''}" placeholder="Placeholder text" onchange="updateQuestion(${index}, 'placeholder', this.value)">
                        </div>
                        <div class="q-field">
                            <label>Question Type</label>
                            <select class="form-control" onchange="updateQuestion(${index}, 'type', this.value)">
                                <option value="short" ${q.type === 'short' ? 'selected' : ''}>Short</option>
                                <option value="paragraph" ${q.type === 'paragraph' ? 'selected' : ''}>Paragraph</option>
                            </select>
                        </div>
                    </div>
                    <div class="q-toggle-row">
                        <div class="mini-toggle ${q.required ? 'active' : ''}" onclick="toggleQuestionBool(${index}, 'required')"><div class="knob"></div></div>
                        <span class="q-toggle-label">Required Answer</span>
                    </div>
                    <div class="q-row">
                        <div class="q-field">
                            <label>Minimum Answer Length</label>
                            <input type="number" class="form-control" value="${q.minLength || 1}" min="0" onchange="updateQuestion(${index}, 'minLength', parseInt(this.value) || 0)">
                        </div>
                        <div class="q-field">
                            <label>Maximum Answer Length</label>
                            <input type="number" class="form-control" value="${q.maxLength || 500}" min="1" onchange="updateQuestion(${index}, 'maxLength', parseInt(this.value) || 1)">
                        </div>
                    </div>
                `;
                grid.appendChild(card);
            });
        }

        function addQuestion() {
            if (questions.length >= MAX_QUESTIONS) return;
            questions.push({
                title: '',
                description: '',
                placeholder: '',
                type: 'paragraph',
                required: false,
                minLength: 1,
                maxLength: 500
            });
            renderQuestions();
        }

        function removeQuestion(index) {
            questions.splice(index, 1);
            renderQuestions();
        }

        function updateQuestion(index, field, value) {
            questions[index][field] = value;
            renderQuestions();
        }

        function toggleQuestionBool(index, field) {
            questions[index][field] = !questions[index][field];
            renderQuestions();
        }

        function loadQuestions() {
            var existing = <%= template ? (template.questions ? JSON.stringify(template.questions) : '[]') : '[]' %>;
            if (Array.isArray(existing) && existing.length > 0) {
                questions = existing;
            } else {
                questions = [{
                    title: 'Do you like capybaras?',
                    description: 'Please explain your answer in full detail.',
                    placeholder: 'Please describe your issue in full detail.',
                    type: 'paragraph',
                    required: true,
                    minLength: 1,
                    maxLength: 500
                }];
            }
            renderQuestions();
        }

        // ===== SAVE FUNCTIONS =====
        function collectFormData() {
            // Collect role selections
            var blockedRoles = Array.from(document.getElementById('blockedRoles').selectedOptions).map(function(o) { return o.value; });
            var requiredRoles = Array.from(document.getElementById('requiredRoles').selectedOptions).map(function(o) { return o.value; });
            var supportRoles = Array.from(document.getElementById('supportRoles').selectedOptions).map(function(o) { return o.value; });

            return {
                name: document.getElementById('name').value,
                transcriptChannel: document.getElementById('transcriptChannel').value,
                category: document.getElementById('category').value,
                channelName: document.getElementById('channelName').value,
                creatorCanClose: document.getElementById('creatorCanClose').value === 'true',
                blockedRoles: blockedRoles,
                blockedMatchMode: document.getElementById('blockedMatchMode') ? document.getElementById('blockedMatchMode').value : 'hasAny',
                requiredRoles: requiredRoles,
                requiredMatchMode: document.getElementById('requiredMatchMode') ? document.getElementById('requiredMatchMode').value : 'hasAny',
                maxTickets: parseInt(document.getElementById('maxTickets').value) || 3,
                supportRoles: supportRoles,
                autoMentionSupport: document.getElementById('autoMentionSupport').value === 'true',
                rateSupport: document.getElementById('rateSupport').value === 'true',
                ticketClaiming: document.getElementById('ticketClaiming').value === 'true',
                actionOnLeave: document.getElementById('actionOnLeave').value,
                questions: questions
            };
        }

        async function saveTemplate(event) {
            if (event) event.preventDefault();

            var data = collectFormData();
            if (!data.name || !data.name.trim()) {
                showToast('❌ Please enter a template name', 'error');
                return;
            }

            // Validate logging channel and category
            if (!data.transcriptChannel) {
                document.getElementById('loggingChannelError').style.display = 'block';
                showToast('❌ Please select a logging channel', 'error');
                return;
            } else {
                document.getElementById('loggingChannelError').style.display = 'none';
            }

            if (!data.category) {
                document.getElementById('categoryError').style.display = 'block';
                showToast('❌ Please select a category', 'error');
                return;
            } else {
                document.getElementById('categoryError').style.display = 'none';
            }

            try {
                var url = '/api/tickets' + (templateId ? '/' + templateId : '');
                var method = templateId ? 'PUT' : 'POST';

                var response = await fetch(url, {
                    method: method,
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });
                var result = await response.json();
                if (result.success) {
                    showToast('✅ Template saved successfully!', 'success');
                    if (!templateId) {
                        setTimeout(function() {
                            window.location.href = '/servers/' + guildId + '/tickets/templates';
                        }, 1500);
                    }
                } else {
                    showToast('❌ Error: ' + (result.error || 'Unknown error'), 'error');
                }
            } catch (error) {
                showToast('❌ Error: ' + error.message, 'error');
            }
        }

        function saveDraft() {
            document.getElementById('status') ? document.getElementById('status').value = 'draft' : null;
            saveTemplate();
            showToast('📝 Saved as draft', 'info');
        }

        function publishTemplate() {
            document.getElementById('status') ? document.getElementById('status').value = 'active' : null;
            saveTemplate();
            showToast('🚀 Publishing panel to Discord...', 'info');
            setTimeout(function() {
                window.location.href = '/servers/' + guildId + '/panels';
            }, 2000);
        }

        // ===== INIT =====
        var templateId = '<%= template ? template._id : "" %>';
        var guildId = '<%= guild.id %>';

        document.addEventListener('DOMContentLoaded', function() {
            // Render role chips
            renderRoleChips('blockedRoles', 'blockedRolesGrid', 'blockedRolesCount', 'Blocked Roles');
            renderRoleChips('requiredRoles', 'requiredRolesGrid', 'requiredRolesCount', 'Required Roles');
            renderRoleChips('supportRoles', 'supportRolesGrid', 'supportRolesCount', 'Support Team Roles');

            // Load questions
            loadQuestions();

            // Set initial match modes
            var blockedMode = '<%= template && template.blockedMatchMode ? template.blockedMatchMode : "hasAny" %>';
            var requiredMode = '<%= template && template.requiredMatchMode ? template.requiredMatchMode : "hasAny" %>';
            setMatchMode('blocked', blockedMode);
            setMatchMode('required', requiredMode);

            // Update toggle labels
            document.querySelectorAll('.toggle-wrapper').forEach(function(wrapper) {
                var toggle = wrapper.querySelector('.toggle');
                var label = wrapper.querySelector('.toggle-label');
                if (toggle && label) {
                    label.textContent = toggle.classList.contains('active') ? 'Enabled' : 'Disabled';
                }
            });
        });

        // ===== EXPOSE =====
        window.showToast = showToast;
        window.toggleBool = toggleBool;
        window.renderRoleChips = renderRoleChips;
        window.setMatchMode = setMatchMode;
        window.addQuestion = addQuestion;
        window.removeQuestion = removeQuestion;
        window.updateQuestion = updateQuestion;
        window.toggleQuestionBool = toggleQuestionBool;
        window.saveTemplate = saveTemplate;
        window.saveDraft = saveDraft;
        window.publishTemplate = publishTemplate;
    </script>
</body>
</html>
