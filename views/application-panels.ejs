<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title || 'Application Panels — Sentinal' %></title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@400;500;600;700;800&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --ink: #060A10;
            --panel: #0D1520;
            --panel-raised: #111D2C;
            --panel-hover: #162033;
            --line: rgba(255,255,255,0.07);
            --line-bright: rgba(255,255,255,0.13);
            --text: #E6EDF6;
            --muted: #6C7A90;
            --muted-dim: #3E4A5C;
            --signal: #3DFFB8;
            --signal-tab: rgba(61,255,184,0.08);
            --signal-glow: rgba(61,255,184,0.15);
            --gold: #F5C842;
            --gold-tab: rgba(245,200,66,0.12);
            --violet: #8B7EFF;
            --violet-tab: rgba(139,126,255,0.12);
            --red: #F87171;
            --red-bg: rgba(248,113,113,0.08);
            --red-border: rgba(248,113,113,0.22);
            --discord: #5865F2;
            --discord-hover: #4752C4;
        }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Inter', -apple-system, sans-serif;
            background: var(--ink);
            color: var(--text);
            min-height: 100vh;
            overflow-x: hidden;
        }

        .navbar {
            background: rgba(6,10,16,0.9);
            backdrop-filter: blur(28px) saturate(160%);
            border-bottom: 1px solid var(--line);
            padding: 0 48px;
            height: 72px;
            display: flex; align-items: center; justify-content: space-between;
            position: sticky; top: 0; z-index: 200;
        }
        .brand { display: flex; align-items: center; gap: 12px; text-decoration: none; }
        .brand-logo {
            width: 40px; height: 40px; border-radius: 12px;
            background: var(--panel-raised); border: 1px solid var(--line-bright);
            display: flex; align-items: center; justify-content: center;
        }
        .brand-logo svg { width: 22px; height: 22px; }
        .brand-name {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 20px; font-weight: 700; color: #fff; letter-spacing: -0.3px;
        }
        .nav-center { display: flex; align-items: center; gap: 8px; }
        .nav-center a {
            color: var(--muted); text-decoration: none; font-size: 15px; font-weight: 500;
            padding: 8px 18px; border-radius: 10px; transition: all 0.18s ease;
        }
        .nav-center a:hover { color: var(--text); background: rgba(255,255,255,0.05); }
        .nav-center a.active { color: #fff; }
        .nav-right { display: flex; align-items: center; gap: 16px; }
        .user-pill {
            display: flex; align-items: center; gap: 12px;
            background: var(--panel); border: 1px solid var(--line);
            border-radius: 100px; padding: 6px 18px 6px 8px;
        }
        .user-avatar {
            width: 32px; height: 32px; border-radius: 50%;
            background: var(--panel-raised); overflow: hidden;
            display: flex; align-items: center; justify-content: center;
            font-size: 14px; font-weight: 700;
        }
        .user-avatar img { width: 100%; height: 100%; object-fit: cover; }
        .user-name { font-size: 14px; font-weight: 500; color: var(--text); }
        .user-plan {
            font-size: 11px; font-weight: 600; color: var(--signal);
            background: var(--signal-tab); border: 1px solid rgba(61,255,184,0.22);
            border-radius: 100px; padding: 3px 10px; letter-spacing: 0.3px;
        }
        .logout-btn {
            background: transparent; border: 1px solid var(--line); border-radius: 10px;
            padding: 8px 14px; color: var(--muted); cursor: pointer; font-size: 14px;
            transition: all 0.18s ease; text-decoration: none;
            display: flex; align-items: center; gap: 8px;
        }
        .logout-btn:hover { background: var(--red-bg); border-color: var(--red-border); color: var(--red); }

        .page-wrapper {
            max-width: 1400px;
            margin: 0 auto;
            padding: 32px 48px 60px;
            display: flex;
            gap: 32px;
            align-items: flex-start;
            min-height: calc(100vh - 72px);
        }

        .sidebar {
            width: 255px;
            flex-shrink: 0;
            background: var(--panel);
            border: 1px solid var(--line);
            border-radius: 14px;
            padding: 16px 18px;
            position: sticky;
            top: 88px;
            height: calc(100vh - 108px);
            overflow-y: auto;
            overflow-x: hidden;
        }
        .sidebar::-webkit-scrollbar { width: 3px; }
        .sidebar::-webkit-scrollbar-track { background: transparent; }
        .sidebar::-webkit-scrollbar-thumb { background: var(--muted-dim); border-radius: 10px; }

        .sidebar .server-info {
            padding-bottom: 14px;
            border-bottom: 1px solid var(--line);
            margin-bottom: 12px;
        }
        .sidebar .server-info .icon {
            width: 40px; height: 40px; border-radius: 10px;
            background: var(--panel-raised); border: 1px solid var(--line);
            display: flex; align-items: center; justify-content: center;
            font-size: 16px; font-weight: 700; overflow: hidden;
            color: var(--signal); margin-bottom: 6px;
        }
        .sidebar .server-info .icon img { width: 100%; height: 100%; object-fit: cover; }
        .sidebar .server-info .name {
            font-weight: 600; font-size: 13px; color: #fff;
        }
        .sidebar .server-info .plan {
            font-size: 10px; color: var(--signal);
            font-weight: 500;
        }
        .sidebar .server-info .upgrade {
            display: block; margin-top: 6px;
            padding: 4px 10px; border-radius: 6px;
            background: var(--gold-tab); color: var(--gold);
            font-size: 10px; font-weight: 600; text-decoration: none;
            text-align: center; border: 1px solid rgba(245,200,66,0.2);
        }
        .sidebar .server-info .upgrade:hover { background: rgba(245,200,66,0.18); }

        .sidebar .nav-section { padding: 0; }
        .sidebar .section-title {
            font-size: 9px; font-weight: 700; text-transform: uppercase;
            letter-spacing: 0.8px; color: var(--muted-dim);
            padding: 8px 8px 4px;
        }
        .sidebar .nav-item {
            display: flex; align-items: center; gap: 10px;
            padding: 7px 10px;
            border-radius: 8px;
            color: var(--muted); text-decoration: none;
            font-size: 12px; font-weight: 500;
            transition: all 0.18s ease; cursor: pointer; border: none;
            background: none; width: 100%; text-align: left;
        }
        .sidebar .nav-item:hover { background: rgba(255,255,255,0.04); color: var(--text); }
        .sidebar .nav-item.active { background: var(--signal-tab); color: var(--signal); }
        .sidebar .nav-item i { width: 16px; font-size: 13px; color: var(--muted-dim); }
        .sidebar .nav-item.active i { color: var(--signal); }
        .sidebar .nav-item .badge {
            margin-left: auto; font-size: 7px; font-weight: 700;
            padding: 1px 6px; border-radius: 100px; text-transform: uppercase;
        }
        .sidebar .nav-item .badge.live { background: var(--signal-tab); color: var(--signal); }
        .sidebar .nav-item .badge.coming { background: var(--gold-tab); color: var(--gold); }
        .sidebar .nav-item .badge.new { background: var(--violet-tab); color: var(--violet); }

        .sidebar .divider { height: 1px; background: var(--line); margin: 8px 0; }

        .content {
            flex: 1;
            min-width: 0;
        }

        .status-bar {
            display: flex; align-items: center; gap: 12px;
            padding: 12px 16px;
            background: var(--panel);
            border-radius: 12px;
            border: 1px solid var(--line);
            margin-bottom: 24px;
        }
        .status-bar .dot { color: #34d399; font-size: 12px; font-weight: 600; }
        .status-bar .text { color: var(--muted); font-size: 13px; }
        .status-bar .time { margin-left: auto; color: var(--muted-dim); font-size: 12px; }

        .page-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 24px;
            flex-wrap: wrap;
            gap: 16px;
        }
        .page-header h1 {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 28px;
            font-weight: 700;
            color: #fff;
        }
        .page-header p {
            color: var(--muted);
            font-size: 16px;
            margin-top: 4px;
        }

        .btn-primary {
            padding: 10px 24px;
            background: var(--signal);
            color: var(--ink);
            border: none;
            border-radius: 10px;
            font-weight: 700;
            font-size: 14px;
            cursor: pointer;
            transition: all 0.2s ease;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            font-family: 'Inter', sans-serif;
        }
        .btn-primary:hover {
            transform: translateY(-1px);
            box-shadow: 0 4px 20px var(--signal-glow);
        }
        .btn-secondary {
            padding: 8px 20px;
            border-radius: 8px;
            background: transparent;
            color: var(--muted);
            border: 1px solid var(--line);
            font-weight: 600;
            font-size: 13px;
            cursor: pointer;
            transition: all 0.18s ease;
            font-family: 'Inter', sans-serif;
        }
        .btn-secondary:hover {
            background: rgba(255,255,255,0.04);
            color: var(--text);
        }
        .btn-danger {
            padding: 8px 20px;
            border-radius: 8px;
            background: var(--red-bg);
            color: var(--red);
            border: 1px solid var(--red-border);
            font-weight: 600;
            font-size: 13px;
            cursor: pointer;
            transition: all 0.18s ease;
            font-family: 'Inter', sans-serif;
        }
        .btn-danger:hover {
            background: rgba(248,113,113,0.2);
        }

        .panels-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
            gap: 20px;
            margin-top: 20px;
        }

        .panel-card {
            background: var(--panel);
            border: 1px solid var(--line);
            border-radius: 14px;
            padding: 22px 24px;
            transition: all 0.2s ease;
        }
        .panel-card:hover {
            border-color: var(--line-bright);
            transform: translateY(-2px);
        }
        .panel-card .card-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 10px;
        }
        .panel-card .card-title {
            font-size: 16px;
            font-weight: 600;
            color: #fff;
        }
        .panel-card .card-type {
            font-size: 10px;
            font-weight: 700;
            padding: 2px 12px;
            border-radius: 100px;
            background: var(--signal-tab);
            color: var(--signal);
            border: 1px solid rgba(61,255,184,0.2);
            text-transform: uppercase;
        }
        .panel-card .card-desc {
            color: var(--muted);
            font-size: 14px;
            margin-bottom: 16px;
            line-height: 1.5;
        }
        .panel-card .card-stats {
            display: flex;
            gap: 20px;
            padding-bottom: 12px;
            border-bottom: 1px solid var(--line);
            margin-bottom: 12px;
        }
        .panel-card .card-stats span {
            font-size: 13px;
            color: var(--muted);
        }
        .panel-card .card-stats span strong {
            color: var(--text);
        }
        .panel-card .card-actions {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
        }

        .section-card {
            background: var(--panel);
            border: 1px solid var(--line);
            border-radius: 14px;
            padding: 24px 28px;
            margin-bottom: 16px;
        }
        .section-card .section-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 6px;
            flex-wrap: wrap;
            gap: 8px;
        }
        .section-card .section-header h3 {
            font-size: 15px;
            font-weight: 600;
            color: var(--text);
        }
        .section-card .section-header .badge {
            font-size: 10px;
            font-weight: 600;
            padding: 2px 10px;
            border-radius: 100px;
            background: var(--signal-tab);
            color: var(--signal);
            border: 1px solid rgba(61,255,184,0.2);
        }
        .section-card .section-desc {
            font-size: 13px;
            color: var(--muted);
            margin-bottom: 14px;
        }

        .form-group {
            margin-bottom: 14px;
        }
        .form-group label {
            display: block;
            font-size: 12px;
            font-weight: 600;
            margin-bottom: 4px;
            color: var(--text);
        }
        .form-group .form-hint {
            font-size: 11px;
            color: var(--muted-dim);
            margin-top: 2px;
        }
        .form-group input,
        .form-group select,
        .form-group textarea {
            width: 100%;
            padding: 10px 14px;
            border-radius: 8px;
            border: 1px solid var(--line);
            background: var(--ink);
            color: var(--text);
            font-size: 13px;
            font-family: 'Inter', sans-serif;
            outline: none;
            transition: all 0.2s ease;
        }
        .form-group input:focus,
        .form-group select:focus,
        .form-group textarea:focus {
            border-color: var(--signal);
            box-shadow: 0 0 0 3px var(--signal-glow);
        }
        .form-group select option {
            background: var(--ink);
        }
        .form-group select[multiple] {
            min-height: 80px;
        }
        .form-group select[multiple] option {
            padding: 6px 8px;
        }
        .form-group select[multiple] option:checked {
            background: var(--signal-tab);
            color: var(--signal);
        }

        .toggle-wrapper {
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .toggle-wrapper span {
            font-size: 13px;
            font-weight: 500;
            color: var(--text);
        }
        .toggle {
            width: 44px;
            height: 24px;
            background: var(--muted-dim);
            border-radius: 12px;
            cursor: pointer;
            transition: all 0.3s ease;
            position: relative;
            border: none;
            flex-shrink: 0;
        }
        .toggle.active {
            background: var(--signal);
        }
        .toggle .toggle-slider {
            width: 18px;
            height: 18px;
            background: #fff;
            border-radius: 50%;
            position: absolute;
            top: 3px;
            left: 3px;
            transition: all 0.3s ease;
        }
        .toggle.active .toggle-slider {
            left: 23px;
        }

        .premium-badge {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            font-size: 10px;
            font-weight: 700;
            color: var(--gold);
            background: var(--gold-tab);
            padding: 2px 10px;
            border-radius: 100px;
            border: 1px solid rgba(245,200,66,0.2);
            margin-left: 8px;
        }
        .premium-feature {
            opacity: 0.6;
            position: relative;
        }
        .premium-feature::after {
            content: '🔒 PREMIUM';
            position: absolute;
            top: 8px;
            right: 8px;
            font-size: 9px;
            font-weight: 700;
            color: var(--gold);
            background: var(--gold-tab);
            padding: 2px 10px;
            border-radius: 100px;
            border: 1px solid rgba(245,200,66,0.2);
        }
        .premium-feature .toggle,
        .premium-feature select,
        .premium-feature input {
            opacity: 0.5;
            cursor: not-allowed;
        }

        /* Multi-Select */
        .multi-select-wrapper {
            position: relative;
            width: 100%;
        }
        .multi-select-wrapper .dropdown-toggle {
            width: 100%;
            padding: 10px 14px;
            border-radius: 8px;
            border: 1px solid var(--line);
            background: var(--ink);
            color: var(--text);
            font-size: 13px;
            font-family: 'Inter', sans-serif;
            cursor: pointer;
            display: flex;
            justify-content: space-between;
            align-items: center;
            transition: all 0.2s ease;
            text-align: left;
        }
        .multi-select-wrapper .dropdown-toggle:hover {
            border-color: var(--line-bright);
        }
        .multi-select-wrapper .dropdown-toggle:focus {
            border-color: var(--signal);
            box-shadow: 0 0 0 3px var(--signal-glow);
        }
        .multi-select-wrapper .dropdown-toggle .selected-text {
            color: var(--muted);
            font-weight: 400;
        }
        .multi-select-wrapper .dropdown-toggle .arrow {
            color: var(--muted);
            transition: transform 0.2s ease;
            font-size: 12px;
        }
        .multi-select-wrapper .dropdown-toggle .arrow.open {
            transform: rotate(180deg);
        }
        .multi-select-dropdown {
            display: none;
            position: absolute;
            top: calc(100% + 4px);
            left: 0;
            right: 0;
            background: var(--panel);
            border: 1px solid var(--line);
            border-radius: 8px;
            padding: 8px;
            z-index: 100;
            max-height: 220px;
            overflow-y: auto;
            box-shadow: 0 8px 32px rgba(0,0,0,0.4);
        }
        .multi-select-dropdown::-webkit-scrollbar {
            width: 4px;
        }
        .multi-select-dropdown::-webkit-scrollbar-track {
            background: transparent;
        }
        .multi-select-dropdown::-webkit-scrollbar-thumb {
            background: var(--muted-dim);
            border-radius: 10px;
        }
        .multi-select-dropdown.open {
            display: block;
            animation: fadeIn 0.15s ease;
        }
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(-4px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .multi-select-dropdown .search-input {
            width: 100%;
            padding: 8px 12px;
            border-radius: 6px;
            border: 1px solid var(--line);
            background: var(--ink);
            color: var(--text);
            font-size: 13px;
            font-family: 'Inter', sans-serif;
            outline: none;
            margin-bottom: 6px;
        }
        .multi-select-dropdown .search-input:focus {
            border-color: var(--signal);
            box-shadow: 0 0 0 3px var(--signal-glow);
        }
        .multi-select-dropdown .option-item {
            padding: 6px 10px;
            border-radius: 6px;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 10px;
            transition: all 0.15s ease;
            color: var(--text);
            font-size: 13px;
            user-select: none;
        }
        .multi-select-dropdown .option-item:hover {
            background: var(--panel-hover);
        }
        .multi-select-dropdown .option-item .checkbox {
            width: 18px;
            height: 18px;
            border-radius: 4px;
            border: 2px solid var(--muted-dim);
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            transition: all 0.15s ease;
        }
        .multi-select-dropdown .option-item .checkbox.checked {
            background: var(--signal);
            border-color: var(--signal);
        }
        .multi-select-dropdown .option-item .checkbox.checked::after {
            content: '✓';
            color: var(--ink);
            font-size: 12px;
            font-weight: 700;
        }
        .multi-select-dropdown .option-item .role-color-dot {
            width: 10px;
            height: 10px;
            border-radius: 50%;
            flex-shrink: 0;
        }
        .multi-select-dropdown .option-item .role-name {
            flex: 1;
        }
        .multi-select-dropdown .no-results {
            padding: 12px;
            text-align: center;
            color: var(--muted-dim);
            font-size: 13px;
        }
        .selected-roles-display {
            display: flex;
            flex-wrap: wrap;
            gap: 6px;
            margin-top: 8px;
            min-height: 28px;
        }
        .selected-role-tag {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            padding: 2px 10px 2px 6px;
            border-radius: 100px;
            font-size: 11px;
            font-weight: 500;
            background: var(--signal-tab);
            color: var(--signal);
            border: 1px solid rgba(61,255,184,0.2);
            animation: tagIn 0.2s ease;
        }
        @keyframes tagIn {
            from { opacity: 0; transform: scale(0.9); }
            to { opacity: 1; transform: scale(1); }
        }
        .selected-role-tag .role-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            display: inline-block;
            flex-shrink: 0;
        }
        .selected-role-tag .remove-role {
            cursor: pointer;
            font-size: 12px;
            opacity: 0.6;
            transition: all 0.15s ease;
            background: none;
            border: none;
            color: var(--signal);
            padding: 0 2px;
            line-height: 1;
        }
        .selected-role-tag .remove-role:hover {
            opacity: 1;
        }

        .match-mode {
            margin-top: 8px;
            padding: 8px 12px;
            background: var(--panel-raised);
            border-radius: 6px;
            border: 1px solid var(--line);
        }
        .match-mode-desc {
            font-size: 12px;
            color: var(--muted);
        }
        .match-mode-desc strong {
            color: var(--text);
        }

        /* Questions */
        .question-item {
            background: var(--panel-raised);
            border: 1px solid var(--line);
            border-radius: 10px;
            padding: 16px 18px;
            margin-bottom: 10px;
        }
        .question-item .q-header {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 6px;
        }
        .question-item .q-header .q-number {
            font-weight: 700;
            font-size: 13px;
            color: var(--signal);
        }
        .question-item .q-header .q-title {
            font-weight: 600;
            font-size: 14px;
            color: #fff;
        }
        .question-item .q-desc {
            font-size: 12px;
            color: var(--muted);
            margin-bottom: 6px;
        }
        .question-item .q-desc strong {
            color: var(--text);
        }
        .question-item .q-actions {
            display: flex;
            gap: 6px;
            margin-top: 8px;
        }
        .question-item .q-actions button {
            background: none;
            border: none;
            color: var(--muted);
            cursor: pointer;
            padding: 4px 10px;
            border-radius: 6px;
            font-size: 12px;
            font-weight: 500;
            transition: all 0.18s ease;
        }
        .question-item .q-actions button:hover {
            background: rgba(255,255,255,0.04);
            color: var(--text);
        }
        .question-item .q-actions button.danger:hover {
            background: var(--red-bg);
            color: var(--red);
        }
        .question-item .q-row {
            display: flex;
            gap: 16px;
            margin-top: 10px;
            flex-wrap: wrap;
        }
        .question-item .q-row .q-field {
            flex: 1;
            min-width: 100px;
        }
        .question-item .q-row .q-field label {
            font-size: 11px;
            font-weight: 600;
            color: var(--muted);
            display: block;
            margin-bottom: 2px;
        }
        .question-item .q-row .q-field input,
        .question-item .q-row .q-field select {
            width: 100%;
            padding: 6px 10px;
            border-radius: 6px;
            border: 1px solid var(--line);
            background: var(--ink);
            color: var(--text);
            font-size: 12px;
            font-family: 'Inter', sans-serif;
            outline: none;
        }
        .question-item .q-row .q-field input:focus,
        .question-item .q-row .q-field select:focus {
            border-color: var(--signal);
        }
        .question-item .q-row .q-field .toggle {
            width: 36px;
            height: 20px;
        }
        .question-item .q-row .q-field .toggle .toggle-slider {
            width: 14px;
            height: 14px;
            top: 3px;
            left: 3px;
        }
        .question-item .q-row .q-field .toggle.active .toggle-slider {
            left: 19px;
        }

        .action-buttons {
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
            align-items: center;
            margin-top: 16px;
        }
        .btn-save-draft {
            padding: 10px 24px;
            border-radius: 10px;
            border: 1px solid var(--line);
            background: transparent;
            color: var(--muted);
            font-weight: 600;
            font-size: 14px;
            cursor: pointer;
            transition: all 0.2s ease;
            font-family: 'Inter', sans-serif;
        }
        .btn-save-draft:hover {
            background: var(--panel-hover);
            color: var(--text);
            border-color: var(--line-bright);
        }
        .btn-save-panel {
            padding: 10px 32px;
            border-radius: 10px;
            border: none;
            background: var(--violet);
            color: #fff;
            font-weight: 700;
            font-size: 14px;
            cursor: pointer;
            transition: all 0.2s ease;
            font-family: 'Inter', sans-serif;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }
        .btn-save-panel:hover {
            background: #7a6fe6;
            transform: translateY(-1px);
            box-shadow: 0 4px 18px rgba(139,126,255,0.3);
        }
        .btn-send-panel {
            padding: 10px 32px;
            border-radius: 10px;
            border: none;
            background: var(--signal);
            color: var(--ink);
            font-weight: 700;
            font-size: 14px;
            cursor: pointer;
            transition: all 0.2s ease;
            font-family: 'Inter', sans-serif;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }
        .btn-send-panel:hover {
            transform: translateY(-1px);
            box-shadow: 0 4px 18px var(--signal-glow);
        }
        .btn-send-panel:disabled,
        .btn-save-panel:disabled,
        .btn-save-draft:disabled {
            opacity: 0.4;
            cursor: not-allowed;
            transform: none;
            box-shadow: none;
        }

        .toast-container {
            position: fixed;
            bottom: 24px;
            right: 24px;
            z-index: 9999;
            display: flex;
            flex-direction: column;
            gap: 10px;
            max-width: 380px;
            width: 100%;
        }
        .toast {
            background: var(--panel);
            border: 1px solid var(--line);
            border-radius: 12px;
            padding: 14px 20px;
            display: flex;
            align-items: center;
            gap: 12px;
            box-shadow: 0 8px 32px rgba(0,0,0,0.4);
            animation: slideIn 0.3s ease;
            backdrop-filter: blur(10px);
            border-left: 4px solid var(--signal);
        }
        .toast .toast-icon { color: var(--signal); font-size: 18px; flex-shrink: 0; }
        .toast .toast-content { flex: 1; font-size: 13px; color: var(--text); line-height: 1.4; }
        .toast .toast-close {
            background: none; border: none;
            color: var(--muted-dim); cursor: pointer;
            font-size: 14px; padding: 4px;
        }
        .toast .toast-close:hover { color: var(--text); }
        .toast.error { border-left-color: var(--red); }
        .toast.error .toast-icon { color: var(--red); }
        .toast.success { border-left-color: var(--signal); }
        .toast.success .toast-icon { color: var(--signal); }
        @keyframes slideIn {
            from { opacity: 0; transform: translateX(40px); }
            to { opacity: 1; transform: translateX(0); }
        }
        @keyframes slideOut {
            from { opacity: 1; transform: translateX(0); }
            to { opacity: 0; transform: translateX(40px); }
        }
        .toast.hiding { animation: slideOut 0.3s ease forwards; }

        .footer {
            border-top: 1px solid var(--line);
            margin-top: 60px;
            padding: 28px 48px;
            text-align: center;
            color: var(--muted-dim);
            font-size: 13px;
            font-family: 'IBM Plex Mono', monospace;
            letter-spacing: 0.5px;
        }

        .modal-overlay {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0,0,0,0.7);
            backdrop-filter: blur(8px);
            z-index: 10000;
            align-items: center;
            justify-content: center;
        }
        .modal-overlay.active {
            display: flex;
        }
        .modal-box {
            background: var(--panel);
            border: 1px solid var(--line);
            border-radius: 16px;
            padding: 32px;
            max-width: 420px;
            width: 100%;
            text-align: center;
            animation: modalIn 0.3s ease;
        }
        @keyframes modalIn {
            from { opacity: 0; transform: scale(0.95) translateY(10px); }
            to { opacity: 1; transform: scale(1) translateY(0); }
        }
        .modal-box .modal-icon {
            font-size: 48px;
            margin-bottom: 12px;
        }
        .modal-box h3 {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 20px;
            color: #fff;
            margin-bottom: 8px;
        }
        .modal-box p {
            color: var(--muted);
            font-size: 14px;
            margin-bottom: 24px;
            line-height: 1.5;
        }
        .modal-box .modal-actions {
            display: flex;
            gap: 10px;
            justify-content: center;
        }
        .modal-box .modal-actions button {
            padding: 8px 24px;
            border-radius: 8px;
            font-weight: 600;
            font-size: 14px;
            cursor: pointer;
            border: none;
            transition: all 0.2s ease;
            font-family: 'Inter', sans-serif;
        }
        .modal-box .modal-actions .btn-cancel {
            background: transparent;
            color: var(--muted);
            border: 1px solid var(--line);
        }
        .modal-box .modal-actions .btn-cancel:hover {
            background: rgba(255,255,255,0.04);
            color: var(--text);
        }
        .modal-box .modal-actions .btn-confirm-delete {
            background: var(--red);
            color: #fff;
        }
        .modal-box .modal-actions .btn-confirm-delete:hover {
            background: #dc2626;
        }

        .view-toggle {
            display: flex;
            gap: 8px;
            background: var(--panel);
            border: 1px solid var(--line);
            border-radius: 10px;
            padding: 4px;
        }
        .view-toggle button {
            padding: 8px 20px;
            border-radius: 8px;
            border: none;
            background: transparent;
            color: var(--muted);
            font-weight: 600;
            font-size: 13px;
            cursor: pointer;
            transition: all 0.18s ease;
            font-family: 'Inter', sans-serif;
        }
        .view-toggle button.active {
            background: var(--signal-tab);
            color: var(--signal);
        }
        .view-toggle button:hover:not(.active) {
            background: rgba(255,255,255,0.04);
            color: var(--text);
        }

        .back-btn {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 8px 16px;
            border-radius: 8px;
            background: transparent;
            color: var(--muted);
            border: 1px solid var(--line);
            font-weight: 600;
            font-size: 13px;
            cursor: pointer;
            transition: all 0.18s ease;
            text-decoration: none;
            font-family: 'Inter', sans-serif;
        }
        .back-btn:hover {
            background: rgba(255,255,255,0.04);
            color: var(--text);
        }

        .hidden {
            display: none !important;
        }

        .search-bar {
            display: flex;
            align-items: center;
            gap: 12px;
            background: var(--panel);
            border: 1px solid var(--line);
            border-radius: 10px;
            padding: 8px 16px;
            flex: 1;
            max-width: 400px;
        }
        .search-bar input {
            background: transparent;
            border: none;
            color: var(--text);
            font-size: 14px;
            outline: none;
            width: 100%;
            font-family: 'Inter', sans-serif;
        }
        .search-bar input::placeholder {
            color: var(--muted-dim);
        }
        .search-bar i {
            color: var(--muted-dim);
        }

        .panels-header-actions {
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
            align-items: center;
        }

        @media (max-width: 1024px) {
            .page-wrapper { padding: 24px 32px 60px; gap: 24px; }
            .sidebar { width: 220px; }
        }
        @media (max-width: 768px) {
            .navbar { padding: 0 16px; height: 64px; flex-wrap: wrap; }
            .nav-center { display: none; }
            .page-wrapper { padding: 16px; flex-direction: column; }
            .sidebar {
                width: 100%; position: relative; top: 0;
                display: flex; flex-wrap: wrap; gap: 4px; padding: 12px;
                border-radius: 12px; max-height: none; height: auto;
            }
            .sidebar .server-info { display: none; }
            .sidebar .nav-section { display: flex; flex-wrap: wrap; gap: 4px; }
            .sidebar .section-title { display: none; }
            .sidebar .nav-item { padding: 6px 14px; font-size: 13px; width: auto; }
            .sidebar .divider { display: none; }
            .panels-grid { grid-template-columns: 1fr; }
            .panel-card { padding: 18px 20px; }
            .page-header { flex-direction: column; align-items: stretch; }
            .panels-header-actions { flex-direction: column; width: 100%; }
            .search-bar { max-width: 100%; }
            .action-buttons { flex-direction: column; width: 100%; }
            .action-buttons button { width: 100%; justify-content: center; }
            .designer-actions { flex-direction: column; gap: 12px; }
            .designer-actions .btn-back { width: 100%; justify-content: center; }
            .view-toggle { width: 100%; }
            .view-toggle button { flex: 1; text-align: center; }
            .question-item .q-row { flex-direction: column; }
            .footer { padding: 20px 16px; }
            .toast-container { bottom: 16px; right: 16px; max-width: calc(100% - 32px); }
        }
    </style>
</head>
<body>

    <nav class="navbar">
        <a href="/dashboard" class="brand">
            <div class="brand-logo">
                <svg viewBox="0 0 245 240" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M104.4 103.9c-5.7 0-10.2 5-10.2 11.1s4.6 11.1 10.2 11.1c5.7 0 10.2-5 10.2-11.1.1-6.1-4.5-11.1-10.2-11.1zM140.9 103.9c-5.7 0-10.2 5-10.2 11.1s4.6 11.1 10.2 11.1c5.7 0 10.2-5 10.2-11.1s-4.5-11.1-10.2-11.1z" fill="#3DFFB8"/>
                    <path d="M189.5 20H55.5C44.7 20 36 28.7 36 39.5v140.9c0 10.8 8.7 19.5 19.5 19.5h113.5l-5.3-18.5 12.8 11.9 12.1 11.2L209 220V39.5C209 28.7 200.3 20 189.5 20zM155.7 152.1s-3.6-4.3-6.6-8.1c13.1-3.7 18.1-11.9 18.1-11.9-4.1 2.7-8 4.6-11.5 5.9-5 2.1-9.8 3.5-14.5 4.3-9.6 1.8-18.4 1.3-25.9-.1-5.7-1.1-10.6-2.6-14.7-4.3-2.3-.9-4.8-2-7.3-3.4-.3-.2-.6-.3-.9-.5-.2-.1-.3-.2-.4-.3-2-1.1-3.1-1.9-3.1-1.9 4.7 4.3 9.3 6.5 21.7 10.2-2.9 3.8-6.6 8.1-6.6 8.1-22 0-32.1-15.2-32.1-15.2 0-32.2 14.4-58.4 14.4-58.4 14.4-10.8 28.1-10.5 28.1-10.5l1 1.2C99.2 87.7 87.9 97.4 87.9 97.4s2.9-1.6 7.8-3.8c14.1-6.2 25.3-7.9 29.9-8.3.8-.1 1.5-.2 2.3-.2 8.2-1 17.5-1.3 27.2.2 12.9 2 26.7 7.5 40.8 17.3 0 0-10.8-10.2-28.5-13.7l1.4-1.6s13.7-.3 28.1 10.5c0 0 14.4 26.2 14.4 58.4 0 0-10.2 15.2-32.1 15.2z" fill="#3DFFB8"/>
                </svg>
            </div>
            <span class="brand-name">Sentinal</span>
        </a>
        <div class="nav-center">
            <a href="/dashboard">Home</a>
            <a href="/servers" class="active">Servers</a>
            <a href="#" onclick="window.open('https://discord.gg/UmqmewYWRd','_blank'); return false;">Support</a>
            <a href="#">Premium</a>
        </div>
        <div class="nav-right">
            <div class="user-pill">
                <div class="user-avatar">
                    <% if (locals.user && user.avatar) { %>
                        <img src="https://cdn.discordapp.com/avatars/<%= user.id %>/<%= user.avatar %>.png" alt="Avatar">
                    <% } else { %>
                        <%= locals.user ? (user.username ? user.username.charAt(0).toUpperCase() : 'U') : 'U' %>
                    <% } %>
                </div>
                <span class="user-name"><%= locals.user ? (user.global_name || user.username) : 'User' %></span>
                <span class="user-plan">Free</span>
            </div>
            <a href="/logout" class="logout-btn"><i class="fas fa-sign-out-alt"></i></a>
        </div>
    </nav>

    <div class="toast-container" id="toastContainer"></div>

    <!-- Delete Confirmation Modal -->
    <div class="modal-overlay" id="deleteModal">
        <div class="modal-box">
            <div class="modal-icon">⚠️</div>
            <h3>Delete Panel?</h3>
            <p>Are you sure you want to delete the panel "<span id="deletePanelName"></span>"? This action cannot be undone.</p>
            <div class="modal-actions">
                <button class="btn-cancel" onclick="closeDeleteModal()">Cancel</button>
                <button class="btn-confirm-delete" onclick="confirmDelete()">Delete Panel</button>
            </div>
        </div>
    </div>

    <div class="page-wrapper">

        <!-- ─── LEFT SIDEBAR ─── -->
        <aside class="sidebar">
            <div class="server-info">
                <div class="icon">
                    <% if (locals.guild && guild.icon) { %>
                        <img src="https://cdn.discordapp.com/icons/<%= guild.id %>/<%= guild.icon %>.png" alt="<%= guild.name %>">
                    <% } else { %>
                        <%= locals.guild ? (guild.name ? guild.name.charAt(0).toUpperCase() : '?') : '?' %>
                    <% } %>
                </div>
                <div class="name"><%= locals.guild ? guild.name : 'Server' %></div>
                <div class="plan">Free</div>
                <a href="#" class="upgrade" onclick="showToast('Upgrade to Premium!', 'info')">Upgrade to Premium</a>
            </div>

            <div class="nav-section">
                <div class="section-title">Modules</div>
                <a href="/servers/<%= locals.guild ? guild.id : '' %>" class="nav-item">
                    <i class="fas fa-th-large"></i> Overview
                </a>
                <a href="/servers/<%= locals.guild ? guild.id : '' %>/applications" class="nav-item">
                    <i class="fas fa-file-alt"></i> Applications
                    <span class="badge live">Live</span>
                </a>
                <a href="/servers/<%= locals.guild ? guild.id : '' %>/tickets" class="nav-item">
                    <i class="fas fa-ticket"></i> Tickets
                    <span class="badge live">Live</span>
                </a>
                <a href="/servers/<%= locals.guild ? guild.id : '' %>/panels" class="nav-item active">
                    <i class="fas fa-clipboard"></i> Panels
                    <span class="badge live">Live</span>
                </a>
            </div>

            <div class="divider"></div>

            <div class="nav-section">
                <div class="section-title">Support</div>
                <button class="nav-item" onclick="showToast('Support server coming soon!', 'info')">
                    <i class="fas fa-headset"></i> Support Server
                </button>
            </div>
        </aside>

        <!-- ─── RIGHT CONTENT ─── -->
        <div class="content">

            <!-- Status Bar -->
            <div class="status-bar">
                <span class="dot">●</span>
                <span class="text">All Systems Operational</span>
                <span class="time"><%= new Date().toLocaleString() %></span>
            </div>

            <!-- ============================================================ -->
            <!-- VIEW TOGGLE -->
            <!-- ============================================================ -->
            <div style="display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:12px; margin-bottom:24px;">
                <div class="view-toggle">
                    <button class="active" onclick="switchView('list')" id="viewListBtn">
                        <i class="fas fa-list"></i> List View
                    </button>
                    <button onclick="switchView('create')" id="viewCreateBtn">
                        <i class="fas fa-plus"></i> Create New
                    </button>
                </div>
                <div id="listActions" style="display:flex; gap:12px; align-items:center;">
                    <div class="search-bar">
                        <i class="fas fa-search"></i>
                        <input type="text" placeholder="Search panels..." id="panelSearch" onkeyup="searchPanels()">
                    </div>
                </div>
            </div>

            <!-- ============================================================ -->
            <!-- LIST VIEW -->
            <!-- ============================================================ -->
            <div id="listView">
                <div class="page-header">
                    <div>
                        <h1>Application Panels</h1>
                        <p>Manage and view all your application panels.</p>
                    </div>
                    <div class="panels-header-actions">
                        <button class="btn-primary" onclick="switchView('create')">
                            <i class="fas fa-plus"></i> Create Panel
                        </button>
                    </div>
                </div>

                <% if (panels && panels.length > 0) { %>
                    <div class="panels-grid" id="panelsGrid">
                        <% panels.forEach(panel => { %>
                            <div class="panel-card" data-panel-id="<%= panel._id %>" data-name="<%= panel.name || 'Untitled Panel' %>">
                                <div class="card-header">
                                    <span class="card-title"><%= panel.name || 'Untitled Panel' %></span>
                                    <span class="card-type"><%= panel.type || 'Ticket' %></span>
                                </div>
                                <div class="card-desc">
                                    <%= panel.description || 'No description provided.' %>
                                </div>
                                <div class="card-stats">
                                    <span>📋 <strong><%= panel.buttons ? panel.buttons.length : 0 %></strong> buttons</span>
                                    <span>🎫 <strong><%= panel.tickets ? panel.tickets.length : 0 %></strong> tickets</span>
                                </div>
                                <div class="card-actions">
                                    <button class="btn-secondary" onclick="editPanel('<%= panel._id %>')">
                                        <i class="fas fa-edit"></i> Edit
                                    </button>
                                    <button class="btn-danger" onclick="openDeleteModal('<%= panel._id %>', '<%= panel.name %>')">
                                        <i class="fas fa-trash"></i> Delete
                                    </button>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                <% } else { %>
                    <div style="text-align:center; padding:60px 20px; background:var(--panel); border:2px dashed var(--line); border-radius:14px; margin-top:20px;">
                        <div style="font-size:56px; color:var(--muted-dim); margin-bottom:16px;">📋</div>
                        <h3 style="font-family:'Space Grotesk',sans-serif; font-size:24px; color:#fff; margin-bottom:8px;">No panels yet</h3>
                        <p style="color:var(--muted); font-size:16px; margin-bottom:24px;">Create your first panel to get started!</p>
                        <button class="btn-primary" onclick="switchView('create')">
                            <i class="fas fa-plus"></i> Create First Panel
                        </button>
                    </div>
                <% } %>
            </div>

            <!-- ============================================================ -->
            <!-- CREATE/EDIT VIEW -->
            <!-- ============================================================ -->
            <div id="createView" class="hidden">
                <div style="display:flex; align-items:center; gap:12px; margin-bottom:24px;">
                    <button class="back-btn" onclick="switchView('list')">
                        <i class="fas fa-arrow-left"></i> Back to Panels
                    </button>
                    <h2 style="font-family:'Space Grotesk',sans-serif; font-size:24px; font-weight:700; color:#fff; margin:0;">
                        <%= editingPanel ? 'Edit Panel' : 'Create New Panel' %>
                    </h2>
                    <span id="panelStatusBadge" style="font-size:10px; font-weight:600; padding:2px 10px; border-radius:100px; background:var(--signal-tab); color:var(--signal); border:1px solid rgba(61,255,184,0.2); display:none;">Draft</span>
                </div>

                <!-- ============================================================ -->
                <!-- BASIC SETTINGS -->
                <!-- ============================================================ -->
                <div class="section-card">
                    <div class="section-header">
                        <h3>Basic Settings</h3>
                        <span class="badge">Required</span>
                    </div>

                    <div class="form-group">
                        <label for="panelName">Panel Name</label>
                        <input type="text" id="panelName" value="<%= editingPanel ? editingPanel.name : 'Panel' %>" placeholder="Enter a name for this panel">
                        <div class="form-hint">A descriptive name to identify this panel in your dashboard.</div>
                    </div>

                    <div class="form-group">
                        <label for="ticketCategory">Ticket Category</label>
                        <select id="ticketCategory">
                            <option value="">Select a category...</option>
                            <option value="Support" <%= editingPanel && editingPanel.config?.ticketConfig?.category === 'Support' ? 'selected' : '' %>>Support</option>
                            <option value="Billing" <%= editingPanel && editingPanel.config?.ticketConfig?.category === 'Billing' ? 'selected' : '' %>>Billing</option>
                            <option value="Technical" <%= editingPanel && editingPanel.config?.ticketConfig?.category === 'Technical' ? 'selected' : '' %>>Technical</option>
                            <option value="General" <%= editingPanel && editingPanel.config?.ticketConfig?.category === 'General' ? 'selected' : '' %>>General</option>
                        </select>
                        <div class="form-hint">The category that user created tickets will be under.</div>
                    </div>

                    <div class="form-group">
                        <label for="ticketChannelName">Ticket Channel Name</label>
                        <input type="text" id="ticketChannelName" value="<%= editingPanel ? editingPanel.config?.ticketConfig?.channelName || '{ticket-creator-username}-{total-tickets-opened}' : '{ticket-creator-username}-{total-tickets-opened}' %>">
                        <div class="form-hint">Customize the name of the channel that is made when a user opens a ticket. Variables: <code>{ticket-creator-username}</code> <code>{total-tickets-opened}</code></div>
                    </div>

                    <div class="form-group">
                        <div class="toggle-wrapper">
                            <button class="toggle <%= editingPanel && editingPanel.config?.ticketConfig?.canClose !== false ? 'active' : 'active' %>" type="button" role="switch" aria-checked="true" onclick="toggleSwitch(this)" id="canClose">
                                <span class="toggle-slider"></span>
                            </button>
                            <span>Can Ticket Creator Close Ticket</span>
                        </div>
                        <div class="form-hint">If enabled, the user that opened the ticket can close it themselves. If disabled, only support team members can close it.</div>
                    </div>
                </div>

                <!-- ============================================================ -->
                <!-- TICKET ACCESS CONTROL -->
                <!-- ============================================================ -->
                <div class="section-card">
                    <div class="section-header">
                        <h3>Ticket Access Control</h3>
                        <span class="badge">Live</span>
                    </div>

                    <!-- Blocked Roles -->
                    <div class="form-group">
                        <label>Blocked Roles: <span id="blockedCount">0/10</span></label>
                        <div class="multi-select-wrapper" id="blockedRolesWrapper">
                            <button class="dropdown-toggle" onclick="toggleDropdown('blocked')">
                                <span class="selected-text">Select some roles...</span>
                                <span class="arrow">▼</span>
                            </button>
                            <div class="multi-select-dropdown" id="blockedDropdown">
                                <input class="search-input" placeholder="Search roles..." onkeyup="filterRoles('blocked', this.value)">
                                <div class="options-list" id="blockedOptions"></div>
                            </div>
                        </div>
                        <div class="selected-roles-display" id="blockedSelected"></div>
                        <div class="form-hint">Members with any one of these roles will not be able to open a ticket.</div>
                        <div class="match-mode">
                            <div class="match-mode-desc">User is blocked if they have <strong>ANY</strong> of the listed roles.</div>
                        </div>
                    </div>

                    <!-- Required Roles -->
                    <div class="form-group">
                        <label>Required Roles: <span id="requiredCount">0/10</span></label>
                        <div class="multi-select-wrapper" id="requiredRolesWrapper">
                            <button class="dropdown-toggle" onclick="toggleDropdown('required')">
                                <span class="selected-text">Select some roles...</span>
                                <span class="arrow">▼</span>
                            </button>
                            <div class="multi-select-dropdown" id="requiredDropdown">
                                <input class="search-input" placeholder="Search roles..." onkeyup="filterRoles('required', this.value)">
                                <div class="options-list" id="requiredOptions"></div>
                            </div>
                        </div>
                        <div class="selected-roles-display" id="requiredSelected"></div>
                        <div class="form-hint">Members with any of these roles will be able to open a ticket.</div>
                        <div class="match-mode">
                            <div class="match-mode-desc">User is required if they have <strong>ANY</strong> of the listed roles.</div>
                        </div>
                    </div>

                    <div class="form-group">
                        <label for="maxTickets">Max concurrent open tickets</label>
                        <select id="maxTickets" style="max-width:200px;">
                            <option value="1" <%= editingPanel && editingPanel.config?.ticketConfig?.maxTickets === 1 ? 'selected' : '' %>>1</option>
                            <option value="2" <%= editingPanel && editingPanel.config?.ticketConfig?.maxTickets === 2 ? 'selected' : '' %>>2</option>
                            <option value="3" <%= editingPanel && editingPanel.config?.ticketConfig?.maxTickets === 3 ? 'selected' : '' %> selected>3</option>
                        </select>
                        <div class="form-hint">The maximum number of tickets a user may have open at once. If they reach this limit, they won't be able to open any new tickets until they close or resolve an existing one.</div>
                    </div>
                </div>

                <!-- ============================================================ -->
                <!-- SUPPORT TEAM & PERMISSIONS -->
                <!-- ============================================================ -->
                <div class="section-card">
                    <div class="section-header">
                        <h3>Support Team & Permissions</h3>
                        <span class="badge">Live</span>
                    </div>

                    <!-- Support Roles -->
                    <div class="form-group">
                        <label>Support Team Roles: <span id="supportCount">0/2</span></label>
                        <div class="multi-select-wrapper" id="supportRolesWrapper">
                            <button class="dropdown-toggle" onclick="toggleDropdown('support')">
                                <span class="selected-text">Select some roles...</span>
                                <span class="arrow">▼</span>
                            </button>
                            <div class="multi-select-dropdown" id="supportDropdown">
                                <input class="search-input" placeholder="Search roles..." onkeyup="filterRoles('support', this.value)">
                                <div class="options-list" id="supportOptions"></div>
                            </div>
                        </div>
                        <div class="selected-roles-display" id="supportSelected"></div>
                        <div class="form-hint">The roles which will be able to view and manage tickets. You can choose up to 2 roles.</div>
                    </div>

                    <div class="form-group">
                        <div class="toggle-wrapper">
                            <button class="toggle <%= editingPanel && editingPanel.config?.ticketConfig?.pingSupport !== false ? 'active' : 'active' %>" type="button" role="switch" aria-checked="true" onclick="toggleSwitch(this)" id="pingSupport">
                                <span class="toggle-slider"></span>
                            </button>
                            <span>Ping Support Roles</span>
                        </div>
                        <div class="form-hint">If any support roles have been added to the ticket template, the bot will automatically ping them when a ticket is created.</div>
                    </div>

                    <div class="form-group">
                        <div class="toggle-wrapper">
                            <button class="toggle <%= editingPanel && editingPanel.config?.ticketConfig?.ticketClaiming !== false ? 'active' : 'active' %>" type="button" role="switch" aria-checked="true" onclick="toggleSwitch(this)" id="ticketClaiming">
                                <span class="toggle-slider"></span>
                            </button>
                            <span>Ticket Claiming</span>
                        </div>
                        <div class="form-hint">Allows support team members to claim a ticket via the claim button or /ticket claim, assigning the ticket to themselves.</div>
                    </div>

                    <div class="form-group premium-feature">
                        <label>Action on User Leave <span class="premium-badge"><i class="fas fa-crown"></i> PREMIUM</span></label>
                        <select style="max-width:300px;" disabled>
                            <option value="nothing">NOTHING</option>
                            <option value="close">Close Ticket</option>
                            <option value="transfer">Transfer Ticket</option>
                        </select>
                        <div class="form-hint">If a user leaves the server, the bot will perform the specified action on the ticket.</div>
                    </div>
                </div>

                <!-- ============================================================ -->
                <!-- TICKET FORM -->
                <!-- ============================================================ -->
                <div class="section-card">
                    <div class="section-header">
                        <h3>Ticket Form</h3>
                        <span class="badge">Live</span>
                    </div>
                    <div class="section-desc">The form which will be opened when a user attempts to open a ticket (helpful for asking specific questions about their issue)</div>

                    <div class="form-group">
                        <label for="formDescription">Form Introduction</label>
                        <textarea id="formDescription" rows="2"><%= editingPanel ? editingPanel.config?.ticketConfig?.formDescription || 'Please explain your issue in full detail' : 'Please explain your issue in full detail' %></textarea>
                        <div class="form-hint">This text will be shown at the top of the ticket form.</div>
                    </div>

                    <div class="section-desc" style="margin-top:12px;">
                        <strong>Questions: <span id="questionCount">1</span>/4</strong>
                    </div>

                    <div id="questions-list">
                        <% if (editingPanel && editingPanel.config?.ticketConfig?.questions && editingPanel.config.ticketConfig.questions.length > 0) { %>
                            <% editingPanel.config.ticketConfig.questions.forEach((q, index) => { %>
                                <div class="question-item" data-index="<%= index %>">
                                    <div class="q-header">
                                        <span class="q-number">●</span>
                                        <span class="q-title">Question <%= index + 1 %></span>
                                    </div>
                                    <div class="q-desc">
                                        <strong>Question title</strong><br>
                                        <%= q.title || 'Untitled Question' %>
                                    </div>
                                    <div class="q-desc">
                                        <strong>Description</strong><br>
                                        <%= q.description || 'No description' %>
                                    </div>
                                    <div class="q-desc">
                                        <strong>Placeholder</strong><br>
                                        <%= q.placeholder || 'No placeholder' %>
                                    </div>
                                    <div class="q-row">
                                        <div class="q-field">
                                            <label>Question type</label>
                                            <select>
                                                <option value="short" <%= q.type === 'short' ? 'selected' : '' %>>Short</option>
                                                <option value="paragraph" <%= q.type === 'paragraph' ? 'selected' : '' %>>Paragraph</option>
                                            </select>
                                        </div>
                                        <div class="q-field">
                                            <label>Required answer</label>
                                            <div class="toggle-wrapper" style="margin-top:4px;">
                                                <button class="toggle <%= q.required !== false ? 'active' : '' %>" type="button" role="switch" aria-checked="true" onclick="toggleSwitch(this)">
                                                    <span class="toggle-slider"></span>
                                                </button>
                                            </div>
                                        </div>
                                        <div class="q-field">
                                            <label>Min answer length</label>
                                            <input type="number" min="0" value="<%= q.minLength || 1 %>">
                                        </div>
                                        <div class="q-field">
                                            <label>Max answer length</label>
                                            <input type="number" min="1" value="<%= q.maxLength || 500 %>">
                                        </div>
                                    </div>
                                    <div class="q-actions">
                                        <button onclick="showToast('Edit question coming soon!', 'info')"><i class="fas fa-edit"></i> Edit</button>
                                        <button class="danger" onclick="deleteQuestion(this)"><i class="fas fa-trash"></i> Delete</button>
                                    </div>
                                </div>
                            <% }) %>
                        <% } else { %>
                            <!-- Default Question -->
                            <div class="question-item" data-index="0">
                                <div class="q-header">
                                    <span class="q-number">●</span>
                                    <span class="q-title">Question 1</span>
                                </div>
                                <div class="q-desc">
                                    <strong>Question title</strong><br>
                                    Do you like capybaras?
                                </div>
                                <div class="q-desc">
                                    <strong>Description</strong><br>
                                    Please explain your answer in full detail
                                </div>
                                <div class="q-desc">
                                    <strong>Placeholder</strong><br>
                                    Please describe your issue in full detail.
                                </div>
                                <div class="q-row">
                                    <div class="q-field">
                                        <label>Question type</label>
                                        <select>
                                            <option value="short" selected>Short</option>
                                            <option value="paragraph">Paragraph</option>
                                        </select>
                                    </div>
                                    <div class="q-field">
                                        <label>Required answer</label>
                                        <div class="toggle-wrapper" style="margin-top:4px;">
                                            <button class="toggle active" type="button" role="switch" aria-checked="true" onclick="toggleSwitch(this)">
                                                <span class="toggle-slider"></span>
                                            </button>
                                        </div>
                                    </div>
                                    <div class="q-field">
                                        <label>Min answer length</label>
                                        <input type="number" min="0" value="1">
                                    </div>
                                    <div class="q-field">
                                        <label>Max answer length</label>
                                        <input type="number" min="1" value="500">
                                    </div>
                                </div>
                                <div class="q-actions">
                                    <button onclick="showToast('Edit question coming soon!', 'info')"><i class="fas fa-edit"></i> Edit</button>
                                    <button class="danger" onclick="deleteQuestion(this)"><i class="fas fa-trash"></i> Delete</button>
                                </div>
                            </div>
                        <% } %>
                    </div>

                    <div style="display:flex; gap:10px; flex-wrap:wrap; margin-top:12px; align-items:center;">
                        <button class="btn-secondary" id="add-question-btn">
                            <i class="fas fa-plus"></i> New question
                        </button>
                        <span style="font-size:12px; color:var(--muted);"><span id="questions-used-count"><%= editingPanel && editingPanel.config?.ticketConfig?.questions ? editingPanel.config.ticketConfig.questions.length : 1 %></span>/4 questions used.</span>
                    </div>
                </div>

                <!-- ============================================================ -->
                <!-- ACTIONS -->
                <!-- ============================================================ -->
                <div class="action-buttons" style="margin-top:16px; border-top:1px solid var(--line); padding-top:20px;">
                    <button class="btn-save-draft" onclick="saveDraft()">
                        <i class="fas fa-save"></i> Save Draft
                    </button>
                    <button class="btn-save-panel" onclick="savePanel()">
                        <i class="fas fa-save"></i> Save Panel
                    </button>
                    <button class="btn-send-panel" onclick="sendPanel()">
                        <i class="fas fa-paper-plane"></i> Send Panel
                    </button>
                </div>
            </div>

        </div>
    </div>

    <footer class="footer">
        © 2026 SENTINAL — STATUS: OPERATIONAL
    </footer>

    <script>
        // ============ View Switching ============
        let currentView = 'list';
        let editingPanelId = '<%= editingPanel ? editingPanel._id : "" %>';

        function switchView(view) {
            currentView = view;
            document.getElementById('listView').classList.toggle('hidden', view !== 'list');
            document.getElementById('createView').classList.toggle('hidden', view !== 'create');
            document.getElementById('listActions').style.display = view === 'list' ? 'flex' : 'none';
            
            document.getElementById('viewListBtn').classList.toggle('active', view === 'list');
            document.getElementById('viewCreateBtn').classList.toggle('active', view === 'create');
            
            if (view === 'create') {
                document.querySelector('#createView h2').textContent = editingPanelId ? 'Edit Panel' : 'Create New Panel';
                if (editingPanelId) {
                    document.getElementById('panelStatusBadge').style.display = 'inline';
                } else {
                    document.getElementById('panelStatusBadge').style.display = 'none';
                }
            }
        }

        // ============ Toast Notifications ============
        function showToast(message, type = 'info') {
            const container = document.getElementById('toastContainer');
            const toast = document.createElement('div');
            toast.className = 'toast ' + type;
            toast.innerHTML = `
                <span class="toast-icon"><i class="fas fa-${type === 'success' ? 'check-circle' : 'exclamation-circle'}"></i></span>
                <span class="toast-content">${message}</span>
                <button class="toast-close" onclick="this.closest('.toast').classList.add('hiding'); setTimeout(() => this.closest('.toast').remove(), 300);">
                    <i class="fas fa-times"></i>
                </button>
            `;
            container.appendChild(toast);
            setTimeout(() => {
                if (toast.parentNode) {
                    toast.classList.add('hiding');
                    setTimeout(() => { if (toast.parentNode) toast.remove(); }, 300);
                }
            }, 4000);
        }

        // ============ Toggle Switch ============
        function toggleSwitch(el) {
            el.classList.toggle('active');
            const isOn = el.classList.contains('active');
            el.setAttribute('aria-checked', String(isOn));
        }

        // ============ Multi-Select Role Picker ============
        function toggleDropdown(type) {
            const dropdown = document.getElementById(type + 'Dropdown');
            const arrow = document.querySelector(`#${type}RolesWrapper .arrow`);
            
            document.querySelectorAll('.multi-select-dropdown').forEach(d => {
                if (d.id !== type + 'Dropdown' && d.classList.contains('open')) {
                    d.classList.remove('open');
                    const otherArrow = d.parentElement.querySelector('.arrow');
                    if (otherArrow) otherArrow.classList.remove('open');
                }
            });
            
            dropdown.classList.toggle('open');
            if (arrow) arrow.classList.toggle('open');
            
            if (dropdown.classList.contains('open')) {
                const search = dropdown.querySelector('.search-input');
                if (search) setTimeout(() => search.focus(), 50);
            }
        }

        function filterRoles(type, query) {
            const options = document.getElementById(type + 'Options');
            const items = options.querySelectorAll('.option-item');
            let hasResults = false;
            
            items.forEach(item => {
                const name = item.dataset.name.toLowerCase();
                const match = name.includes(query.toLowerCase());
                item.style.display = match ? 'flex' : 'none';
                if (match) hasResults = true;
            });
            
            let noResults = options.querySelector('.no-results');
            if (!hasResults) {
                if (!noResults) {
                    noResults = document.createElement('div');
                    noResults.className = 'no-results';
                    noResults.textContent = 'No roles found';
                    options.appendChild(noResults);
                }
                noResults.style.display = 'block';
            } else if (noResults) {
                noResults.style.display = 'none';
            }
        }

        function toggleRole(type, roleId, roleName, color) {
            const max = type === 'support' ? 2 : 10;
            const selectedContainer = document.getElementById(type + 'Selected');
            const countSpan = document.getElementById(type + 'Count');
            
            let selected = JSON.parse(selectedContainer.dataset.selected || '[]');
            const index = selected.indexOf(roleId);
            const isSelected = index !== -1;
            
            if (isSelected) {
                selected.splice(index, 1);
            } else {
                if (selected.length >= max) {
                    showToast(`You can select up to ${max} roles.`, 'error');
                    return;
                }
                selected.push(roleId);
            }
            
            const option = document.querySelector(`#${type}Options .option-item[data-id="${roleId}"]`);
            if (option) {
                const checkbox = option.querySelector('.checkbox');
                if (checkbox) {
                    checkbox.classList.toggle('checked', !isSelected);
                }
            }
            
            updateSelectedDisplay(type, selected);
        }

        function updateSelectedDisplay(type, selected) {
            const container = document.getElementById(type + 'Selected');
            const countSpan = document.getElementById(type + 'Count');
            const max = type === 'support' ? 2 : 10;
            const dropdown = document.getElementById(type + 'Dropdown');
            
            const roleItems = dropdown.querySelectorAll('.option-item');
            const roles = {};
            roleItems.forEach(item => {
                roles[item.dataset.id] = {
                    name: item.dataset.name,
                    color: item.dataset.color
                };
            });
            
            container.innerHTML = '';
            selected.forEach(id => {
                if (roles[id]) {
                    const tag = document.createElement('span');
                    tag.className = 'selected-role-tag';
                    const colorHex = roles[id].color || '#6C7A90';
                    tag.innerHTML = `
                        <span class="role-dot" style="background-color: ${colorHex};"></span>
                        ${roles[id].name}
                        <button class="remove-role" onclick="event.stopPropagation(); toggleRole('${type}', '${id}', '${roles[id].name}', '${colorHex}')">×</button>
                    `;
                    container.appendChild(tag);
                }
            });
            
            countSpan.textContent = `${selected.length}/${max}`;
            container.dataset.selected = JSON.stringify(selected);
        }

        function populateRoles(type, roles) {
            const optionsContainer = document.getElementById(type + 'Options');
            optionsContainer.innerHTML = '';
            
            const sortedRoles = [...roles].sort((a, b) => (b.position || 0) - (a.position || 0));
            
            sortedRoles.forEach(role => {
                const div = document.createElement('div');
                div.className = 'option-item';
                div.dataset.id = role.id;
                div.dataset.name = role.name;
                div.dataset.color = role.color;
                div.onclick = function(e) {
                    e.stopPropagation();
                    toggleRole(type, role.id, role.name, role.color);
                };
                
                const colorHex = role.color ? '#' + role.color.toString(16).padStart(6, '0') : '#6C7A90';
                div.innerHTML = `
                    <div class="checkbox"></div>
                    <span class="role-color-dot" style="background-color: ${colorHex};"></span>
                    <span class="role-name">${role.name}</span>
                `;
                optionsContainer.appendChild(div);
            });
        }

        // ============ Fetch Roles from Discord ============
        async function fetchRoles() {
            const guildId = '<%= locals.guild ? guild.id : "" %>';
            
            try {
                const response = await fetch(`/api/servers/${guildId}/roles`);
                const data = await response.json();

                if (data.success && data.roles && data.roles.length > 0) {
                    ['blocked', 'required', 'support'].forEach(type => {
                        populateRoles(type, data.roles);
                        document.getElementById(type + 'Selected').dataset.selected = '[]';
                        document.getElementById(type + 'Count').textContent = `0/${type === 'support' ? 2 : 10}`;
                    });
                }
            } catch (error) {
                console.error('Error fetching roles:', error);
                showToast('Failed to load roles', 'error');
            }
        }

        // ============ Question Management ============
        function addQuestion() {
            const list = document.getElementById('questions-list');
            const count = list.querySelectorAll('.question-item').length;
            
            if (count >= 4) {
                showToast('Maximum 4 questions allowed.', 'error');
                return;
            }

            const newIndex = count;
            const questionHtml = `
                <div class="question-item" data-index="${newIndex}">
                    <div class="q-header">
                        <span class="q-number">●</span>
                        <span class="q-title">Question ${newIndex + 1}</span>
                    </div>
                    <div class="q-desc">
                        <strong>Question title</strong><br>
                        New Question
                    </div>
                    <div class="q-desc">
                        <strong>Description</strong><br>
                        Please explain your answer in full detail
                    </div>
                    <div class="q-desc">
                        <strong>Placeholder</strong><br>
                        Please describe your issue in full detail.
                    </div>
                    <div class="q-row">
                        <div class="q-field">
                            <label>Question type</label>
                            <select>
                                <option value="short" selected>Short</option>
                                <option value="paragraph">Paragraph</option>
                            </select>
                        </div>
                        <div class="q-field">
                            <label>Required answer</label>
                            <div class="toggle-wrapper" style="margin-top:4px;">
                                <button class="toggle active" type="button" role="switch" aria-checked="true" onclick="toggleSwitch(this)">
                                    <span class="toggle-slider"></span>
                                </button>
                            </div>
                        </div>
                        <div class="q-field">
                            <label>Min answer length</label>
                            <input type="number" min="0" value="1">
                        </div>
                        <div class="q-field">
                            <label>Max answer length</label>
                            <input type="number" min="1" value="500">
                        </div>
                    </div>
                    <div class="q-actions">
                        <button onclick="showToast('Edit question coming soon!', 'info')"><i class="fas fa-edit"></i> Edit</button>
                        <button class="danger" onclick="deleteQuestion(this)"><i class="fas fa-trash"></i> Delete</button>
                    </div>
                </div>
            `;
            
            list.insertAdjacentHTML('beforeend', questionHtml);
            updateQuestionCounts();
            showToast('New question added!', 'success');
        }

        function deleteQuestion(btn) {
            const item = btn.closest('.question-item');
            const list = document.getElementById('questions-list');
            const count = list.querySelectorAll('.question-item').length;
            
            if (count <= 1) {
                showToast('Cannot delete the last question.', 'error');
                return;
            }
            
            item.remove();
            updateQuestionCounts();
            showToast('Question deleted.', 'info');
        }

        function updateQuestionCounts() {
            const items = document.querySelectorAll('.question-item');
            const count = items.length;
            
            document.getElementById('questionCount').textContent = count;
            document.getElementById('questions-used-count').textContent = count;
            
            items.forEach((item, i) => {
                const title = item.querySelector('.q-title');
                if (title) {
                    title.textContent = `Question ${i + 1}`;
                }
            });
        }

        // ============ Edit Panel ============
        function editPanel(panelId) {
            window.location.href = `/servers/<%= locals.guild ? guild.id : '' %>/panels/${panelId}/edit`;
        }

        // ============ Delete Modal ============
        let deletePanelId = null;
        let deletePanelName = null;

        function openDeleteModal(panelId, panelName) {
            deletePanelId = panelId;
            deletePanelName = panelName;
            document.getElementById('deletePanelName').textContent = panelName;
            document.getElementById('deleteModal').classList.add('active');
        }

        function closeDeleteModal() {
            document.getElementById('deleteModal').classList.remove('active');
            deletePanelId = null;
            deletePanelName = null;
        }

        function confirmDelete() {
            if (deletePanelId) {
                performDelete(deletePanelId, deletePanelName);
                closeDeleteModal();
            }
        }

        function performDelete(panelId, panelName) {
            const card = document.querySelector(`.panel-card[data-panel-id="${panelId}"]`);
            if (card) {
                const buttons = card.querySelectorAll('.card-actions button');
                buttons.forEach(btn => {
                    btn.disabled = true;
                    btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i>';
                });
            }

            fetch(`/api/panels/${panelId}`, {
                method: 'DELETE',
                headers: { 'Content-Type': 'application/json' }
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    if (card) {
                        card.style.transition = 'all 0.3s ease';
                        card.style.opacity = '0';
                        card.style.transform = 'scale(0.95)';
                        setTimeout(() => {
                            card.remove();
                            const remainingPanels = document.querySelectorAll('.panel-card');
                            if (remainingPanels.length === 0) {
                                location.reload();
                            }
                            showToast('✅ Panel deleted successfully!', 'success');
                        }, 300);
                    }
                } else {
                    showToast('❌ Error: ' + data.error, 'error');
                    if (card) {
                        const buttons = card.querySelectorAll('.card-actions button');
                        buttons.forEach(btn => {
                            btn.disabled = false;
                            if (btn.classList.contains('btn-secondary')) {
                                btn.innerHTML = '<i class="fas fa-edit"></i> Edit';
                            } else if (btn.classList.contains('btn-danger')) {
                                btn.innerHTML = '<i class="fas fa-trash"></i> Delete';
                            }
                        });
                    }
                }
            })
            .catch(error => {
                showToast('❌ Error: ' + error.message, 'error');
                if (card) {
                    const buttons = card.querySelectorAll('.card-actions button');
                    buttons.forEach(btn => {
                        btn.disabled = false;
                        if (btn.classList.contains('btn-secondary')) {
                            btn.innerHTML = '<i class="fas fa-edit"></i> Edit';
                        } else if (btn.classList.contains('btn-danger')) {
                            btn.innerHTML = '<i class="fas fa-trash"></i> Delete';
                        }
                    });
                }
            });
        }

        // ============ Search Panels ============
        function searchPanels() {
            const query = document.getElementById('panelSearch').value.toLowerCase().trim();
            const cards = document.querySelectorAll('.panel-card');

            cards.forEach(card => {
                const title = card.dataset.name?.toLowerCase() || '';
                const desc = card.querySelector('.card-desc')?.textContent?.toLowerCase() || '';
                const match = title.includes(query) || desc.includes(query);
                card.style.display = match ? '' : 'none';
            });
        }

        // ============ Close modal on escape/click outside ============
        document.addEventListener('keydown', function(event) {
            if (event.key === 'Escape') closeDeleteModal();
        });
        document.addEventListener('click', function(event) {
            const modal = document.getElementById('deleteModal');
            if (event.target === modal) closeDeleteModal();
        });

        // ============ Save Draft ============
        function saveDraft() {
            collectPanelData('draft');
        }

        // ============ Save Panel ============
        function savePanel() {
            collectPanelData('active');
        }

        // ============ Send Panel ============
        function sendPanel() {
            collectPanelData('active', true);
        }

        // ============ Collect Panel Data ============
        function collectPanelData(status, sendToChannel = false) {
            const panelName = document.getElementById('panelName').value || 'Panel';
            const ticketCategory = document.getElementById('ticketCategory').value;
            const ticketChannelName = document.getElementById('ticketChannelName').value;
            const canClose = document.getElementById('canClose').classList.contains('active');
            
            const blockedSelected = JSON.parse(document.getElementById('blockedSelected').dataset.selected || '[]');
            const requiredSelected = JSON.parse(document.getElementById('requiredSelected').dataset.selected || '[]');
            const supportSelected = JSON.parse(document.getElementById('supportSelected').dataset.selected || '[]');
            
            const maxTickets = document.getElementById('maxTickets').value;
            const pingSupport = document.getElementById('pingSupport').classList.contains('active');
            const ticketClaiming = document.getElementById('ticketClaiming').classList.contains('active');
            const formDescription = document.getElementById('formDescription').value;

            const questions = [];
            document.querySelectorAll('.question-item').forEach((item, index) => {
                const title = item.querySelector('.q-desc strong')?.textContent === 'Question title' 
                    ? item.querySelector('.q-desc:first-of-type')?.textContent?.replace('Question title', '').trim() 
                    : `Question ${index + 1}`;
                
                const description = item.querySelector('.q-desc:nth-of-type(2)')?.textContent?.replace('Description', '').trim() || 'Please explain your answer in full detail';
                const placeholder = item.querySelector('.q-desc:nth-of-type(3)')?.textContent?.replace('Placeholder', '').trim() || 'Please describe your issue in full detail.';
                const type = item.querySelector('.q-field select')?.value || 'short';
                const required = item.querySelector('.q-field .toggle')?.classList.contains('active') || false;
                const minLength = parseInt(item.querySelector('.q-field input[type="number"]:first-of-type')?.value) || 1;
                const maxLength = parseInt(item.querySelector('.q-field input[type="number"]:last-of-type')?.value) || 500;
                
                questions.push({
                    title: title || `Question ${index + 1}`,
                    description: description,
                    placeholder: placeholder,
                    type: type,
                    required: required,
                    minLength: minLength,
                    maxLength: maxLength
                });
            });

            const data = {
                guildId: '<%= locals.guild ? guild.id : "" %>',
                name: panelName,
                type: 'ticket',
                style: 'text',
                channel: '<%= sendChannel || "" %>',
                status: status,
                config: {
                    embeds: [{
                        title: 'Tickets',
                        description: 'Click below to create a new ticket',
                        color: '#5865F2'
                    }],
                    buttons: [
                        { label: 'Create Ticket', style: 'primary', emoji: '🎫' }
                    ],
                    rows: [
                        { buttons: ['Create Ticket'] }
                    ],
                    ticketConfig: {
                        category: ticketCategory,
                        channelName: ticketChannelName,
                        canClose: canClose,
                        blockedRoles: blockedSelected,
                        requiredRoles: requiredSelected,
                        maxTickets: parseInt(maxTickets) || 3,
                        supportRoles: supportSelected,
                        pingSupport: pingSupport,
                        ticketClaiming: ticketClaiming,
                        formDescription: formDescription,
                        questions: questions
                    }
                }
            };

            // Determine which button to show loading state on
            let btn;
            if (sendToChannel) {
                btn = document.querySelector('.btn-send-panel');
            } else if (status === 'draft') {
                btn = document.querySelector('.btn-save-draft');
            } else {
                btn = document.querySelector('.btn-save-panel');
            }
            
            if (btn) {
                btn.disabled = true;
                btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Saving...';
            }

            // Check if we have a panel ID from URL
            const urlParams = new URLSearchParams(window.location.search);
            const panelId = urlParams.get('panel') || editingPanelId;

            let url = '/api/panels/create';
            let method = 'POST';

            if (panelId) {
                url = `/api/panels/${panelId}/save`;
                method = 'POST';
                data.panelId = panelId;
            }

            fetch(url, {
                method: method,
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    const msg = sendToChannel ? '✅ Panel sent to channel!' : '✅ Panel saved successfully!';
                    showToast(msg, 'success');
                    
                    if (sendToChannel) {
                        setTimeout(() => {
                            window.location.href = `/servers/<%= locals.guild ? guild.id : '' %>/panels`;
                        }, 1500);
                    } else {
                        const newUrl = `/servers/<%= locals.guild ? guild.id : '' %>/panels/create?edit=${data.panelId || panelId}`;
                        window.history.replaceState({}, '', newUrl);
                        editingPanelId = data.panelId || panelId;
                        document.querySelector('#createView h2').textContent = 'Edit Panel';
                        document.getElementById('panelStatusBadge').style.display = 'inline';
                    }
                } else {
                    showToast('❌ Error: ' + data.error, 'error');
                }
                if (btn) {
                    btn.disabled = false;
                    if (sendToChannel) btn.innerHTML = '<i class="fas fa-paper-plane"></i> Send Panel';
                    else if (status === 'draft') btn.innerHTML = '<i class="fas fa-save"></i> Save Draft';
                    else btn.innerHTML = '<i class="fas fa-save"></i> Save Panel';
                }
            })
            .catch(error => {
                showToast('❌ Error: ' + error.message, 'error');
                if (btn) {
                    btn.disabled = false;
                    if (sendToChannel) btn.innerHTML = '<i class="fas fa-paper-plane"></i> Send Panel';
                    else if (status === 'draft') btn.innerHTML = '<i class="fas fa-save"></i> Save Draft';
                    else btn.innerHTML = '<i class="fas fa-save"></i> Save Panel';
                }
            });
        }

        // ============ Initialize ============
        document.addEventListener('DOMContentLoaded', function() {
            fetchRoles();
            document.getElementById('add-question-btn').addEventListener('click', addQuestion);
            updateQuestionCounts();
            
            // Check if we're in edit mode
            const urlParams = new URLSearchParams(window.location.search);
            if (urlParams.get('edit')) {
                switchView('create');
            }
        });

        // Make functions globally accessible
        window.toggleSwitch = toggleSwitch;
        window.showToast = showToast;
        window.addQuestion = addQuestion;
        window.deleteQuestion = deleteQuestion;
        window.toggleDropdown = toggleDropdown;
        window.filterRoles = filterRoles;
        window.toggleRole = toggleRole;
        window.saveDraft = saveDraft;
        window.savePanel = savePanel;
        window.sendPanel = sendPanel;
        window.populateRoles = populateRoles;
        window.updateSelectedDisplay = updateSelectedDisplay;
        window.switchView = switchView;
        window.editPanel = editPanel;
        window.openDeleteModal = openDeleteModal;
        window.closeDeleteModal = closeDeleteModal;
        window.confirmDelete = confirmDelete;
        window.searchPanels = searchPanels;
    </script>

</body>
</html>
