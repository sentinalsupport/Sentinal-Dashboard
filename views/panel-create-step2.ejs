<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title || 'Panel Designer — Sentinal' %></title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/dashboard.css">
    <style>
        .designer-container {
            max-width: 900px;
            margin: 0 auto;
        }

        .designer-progress {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 32px;
            padding: 0 20px;
            position: relative;
        }

        .designer-progress::before {
            content: '';
            position: absolute;
            top: 50%;
            left: 40px;
            right: 40px;
            height: 2px;
            background: var(--border-soft);
            transform: translateY(-50%);
        }

        .progress-step {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 8px;
            position: relative;
            z-index: 1;
        }

        .progress-step .step-number {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            background: var(--bg-input);
            border: 2px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            font-size: 13px;
            color: var(--text-muted);
            transition: all 0.3s ease;
        }

        .progress-step.active .step-number {
            background: var(--accent);
            border-color: var(--accent);
            color: white;
        }

        .progress-step.completed .step-number {
            background: #34d399;
            border-color: #34d399;
            color: white;
        }

        .progress-step .step-label {
            font-size: 11px;
            color: var(--text-muted);
            font-weight: 500;
        }

        .progress-step.active .step-label {
            color: var(--text-primary);
        }

        .style-option {
            display: flex;
            align-items: center;
            gap: 16px;
            background: var(--bg-card);
            border: 2px solid var(--border-soft);
            border-radius: var(--radius-lg);
            padding: 20px 24px;
            cursor: pointer;
            transition: all 0.18s ease;
            margin-bottom: 12px;
        }

        .style-option:hover {
            border-color: var(--border);
        }

        .style-option.selected {
            border-color: var(--accent);
            background: var(--accent-soft);
        }

        .style-option .style-icon {
            font-size: 28px;
            flex-shrink: 0;
        }

        .style-option .style-content h4 {
            margin: 0 0 4px;
            font-size: 15px;
        }

        .style-option .style-content p {
            margin: 0;
            color: var(--text-secondary);
            font-size: 13px;
        }

        .style-option .style-badge {
            margin-left: auto;
            font-size: 10px;
            font-weight: 700;
            color: var(--accent);
            background: var(--accent-soft);
            padding: 2px 10px;
            border-radius: 100px;
            white-space: nowrap;
        }

        .note-box {
            background: var(--bg-input-alt);
            border: 1px solid var(--border-soft);
            border-radius: var(--radius-md);
            padding: 12px 16px;
            margin: 16px 0 24px;
            font-size: 13px;
            color: var(--text-secondary);
        }

        .note-box i {
            color: var(--accent);
            margin-right: 8px;
        }

        .designer-actions {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-top: 32px;
            padding-top: 20px;
            border-top: 1px solid var(--border-soft);
        }

        .btn-back {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 10px 20px;
            border-radius: var(--radius-md);
            background: transparent;
            color: var(--text-secondary);
            border: 1px solid var(--border-soft);
            font-weight: 600;
            font-size: 13px;
            cursor: pointer;
            transition: all 0.18s ease;
            text-decoration: none;
        }

        .btn-back:hover {
            background: var(--bg-input-alt);
            color: var(--text-primary);
        }

        .btn-continue {
            padding: 10px 32px;
            border-radius: var(--radius-md);
            background: var(--accent);
            color: white;
            border: none;
            font-weight: 600;
            font-size: 13px;
            cursor: pointer;
            transition: all 0.18s ease;
        }

        .btn-continue:hover {
            background: var(--accent-hover);
            transform: translateY(-1px);
        }

        .form-hint {
            color: var(--text-muted);
            font-size: 13px;
            margin-bottom: 20px;
        }

        @media (max-width: 768px) {
            .style-option {
                flex-direction: column;
                text-align: center;
            }
            .style-option .style-badge {
                margin-left: 0;
            }
            .designer-progress {
                overflow-x: auto;
                gap: 8px;
            }
            .designer-progress::before {
                display: none;
            }
            .progress-step .step-label {
                display: none;
            }
        }
    </style>
</head>
<body>
    <div class="layout">
        <aside class="sidebar">
            <div class="brand">
                <span class="brand-icon">🛡️</span>
                Sentinal
            </div>
            <div class="server-switcher">
                <div class="server-avatar"></div>
                <div>
                    <div class="server-name"><%= locals.guild ? guild.name : 'Sentinal Support' %></div>
                    <div class="server-plan">Free</div>
                </div>
            </div>
            <nav class="nav">
                <a href="/dashboard" class="nav-link nav-top"><span><span class="nav-icon">🏠</span> Dashboard</span></a>
                <div class="nav-group">
                    <a href="/servers" class="nav-link"><span><span class="nav-icon">🖥️</span> Servers</span></a>
                    <div class="nav-sub">
                        <a href="/servers/<%= locals.guild ? guild.id : '' %>/applications" class="nav-link"><span><span class="nav-icon">📄</span> Applications</span></a>
                        <a href="/servers/<%= locals.guild ? guild.id : '' %>/tickets" class="nav-link"><span><span class="nav-icon">🎫</span> Tickets</span></a>
                        <a href="/servers/<%= locals.guild ? guild.id : '' %>/panels" class="nav-link active"><span><span class="nav-icon">📋</span> Panels</span></a>
                    </div>
                </div>
            </nav>
            <div class="sidebar-footer">
                <a href="#" class="support-link"><span>💬</span> Support</a>
                <div class="user-card">
                    <div class="user-avatar"><%= locals.user ? (user.global_name ? user.global_name.charAt(0).toUpperCase() : user.username.charAt(0).toUpperCase()) : 'U' %></div>
                    <div>
                        <div class="user-name"><%= locals.user ? (user.global_name || user.username) : 'thedude12355' %></div>
                        <div class="user-plan-badge">FREE</div>
                    </div>
                </div>
            </div>
        </aside>

        <main class="content">
            <div class="designer-container">
                <!-- Status Bar -->
                <div style="display:flex; align-items:center; gap:12px; padding:12px 16px; background:var(--bg-card); border-radius:var(--radius-md); border:1px solid var(--border-soft); margin-bottom:24px;">
                    <span style="color:#34d399; font-size:12px; font-weight:600;">●</span>
                    <span style="color:var(--text-secondary); font-size:13px;">All Systems Operational</span>
                    <span style="margin-left:auto; color:var(--text-muted); font-size:12px;"><%= new Date().toLocaleString() %></span>
                </div>

                <h1 style="font-size:28px; font-weight:700; margin:0 0 4px;">Panel Designer</h1>
                <p style="color:var(--text-secondary); margin:0 0 24px;">Create a new panel for your server.</p>

                <!-- Progress Steps -->
                <div class="designer-progress">
                    <div class="progress-step completed">
                        <div class="step-number">✓</div>
                        <span class="step-label">Panel Type</span>
                    </div>
                    <div class="progress-step active">
                        <div class="step-number">2</div>
                        <span class="step-label">Ticket Style</span>
                    </div>
                    <div class="progress-step">
                        <div class="step-number">3</div>
                        <span class="step-label">Send Channel</span>
                    </div>
                    <div class="progress-step">
                        <div class="step-number">4</div>
                        <span class="step-label">Panel Defaults</span>
                    </div>
                </div>

                <h2 style="font-size:18px; font-weight:600; margin:0 0 4px;">Select Default Ticket Style</h2>
                <p class="form-hint">Choose how tickets should be created when users interact with this panel.</p>

                <div class="note-box">
                    <i class="fas fa-info-circle"></i>
                    This setting applies to new buttons and options added to your panel. To change the style for existing buttons later, you'll need to update each one individually.
                </div>

                <div class="style-option selected" data-style="text" onclick="selectStyle('text')">
                    <div class="style-icon">💬</div>
                    <div class="style-content">
                        <h4>Text Channel</h4>
                        <p>Create a new text channel in your server for each ticket.</p>
                    </div>
                    <span class="style-badge">Recommended · Selected</span>
                </div>

                <div class="style-option" data-style="thread" onclick="selectStyle('thread')">
                    <div class="style-icon">🧵</div>
                    <div class="style-content">
                        <h4>Thread</h4>
                        <p>Create a new thread for each ticket within a designated channel.</p>
                    </div>
                    <span class="style-badge" style="display:none;">Recommended for most users</span>
                </div>

                <div class="designer-actions">
                    <a href="/servers/<%= locals.guild ? guild.id : '' %>/panels/create?type=<%= panelType %>" class="btn-back">
                        <i class="fas fa-arrow-left"></i> Back
                    </a>
                    <button class="btn-continue" onclick="continueStep()">
                        Continue <i class="fas fa-arrow-right"></i>
                    </button>
                </div>
            </div>
        </main>
    </div>

    <script>
        let selectedStyle = 'text';

        function selectStyle(style) {
            selectedStyle = style;
            document.querySelectorAll('.style-option').forEach(c => c.classList.remove('selected'));
            document.querySelector(`.style-option[data-style="${style}"]`).classList.add('selected');
        }

        function continueStep() {
            const type = '<%= panelType %>';
            window.location.href = `/servers/<%= locals.guild ? guild.id : '' %>/panels/create/step3?type=${type}&style=${selectedStyle}`;
        }
    </script>
</body>
</html>
