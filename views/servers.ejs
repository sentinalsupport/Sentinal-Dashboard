<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title || 'My Servers — Sentinal' %></title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Inter', -apple-system, sans-serif;
            background: #080E1A;
            color: #E8EDF5;
            min-height: 100vh;
        }
        .navbar {
            background: rgba(8, 14, 26, 0.92);
            backdrop-filter: blur(16px);
            border-bottom: 1px solid rgba(255, 255, 255, 0.04);
            padding: 0 32px;
            height: 64px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: sticky;
            top: 0;
            z-index: 100;
        }
        .navbar .brand {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 18px;
            font-weight: 700;
            color: #FFFFFF;
            text-decoration: none;
        }
        .navbar .brand .logo-icon {
            width: 32px;
            height: 32px;
            background: linear-gradient(135deg, #2563EB, #1D4ED8);
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 15px;
        }
        .navbar .brand span { color: #60A5FA; }
        .navbar .nav-links {
            display: flex;
            align-items: center;
            gap: 28px;
        }
        .navbar .nav-links a {
            color: #8B9BB5;
            text-decoration: none;
            font-size: 13px;
            font-weight: 500;
            transition: color 0.2s ease;
        }
        .navbar .nav-links a:hover { color: #E8EDF5; }
        .navbar .nav-links a.active {
            color: #FFFFFF;
            position: relative;
        }
        .navbar .nav-links a.active::after {
            content: '';
            position: absolute;
            bottom: -20px;
            left: 0;
            right: 0;
            height: 2px;
            background: #2563EB;
            border-radius: 2px;
        }
        .navbar .nav-right {
            display: flex;
            align-items: center;
            gap: 16px;
        }
        .navbar .user-avatar {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            background: linear-gradient(135deg, #2563EB, #1D4ED8);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 14px;
            font-weight: 600;
            color: #FFFFFF;
            overflow: hidden;
        }
        .navbar .user-avatar img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }
        .navbar .logout-btn {
            background: rgba(255, 255, 255, 0.06);
            color: #8B9BB5;
            padding: 6px 16px;
            border-radius: 100px;
            text-decoration: none;
            font-size: 12px;
            font-weight: 500;
            border: 1px solid rgba(255, 255, 255, 0.06);
            transition: all 0.2s ease;
            display: flex;
            align-items: center;
            gap: 6px;
        }
        .navbar .logout-btn:hover {
            background: rgba(239, 68, 68, 0.1);
            color: #EF4444;
            border-color: rgba(239, 68, 68, 0.2);
        }
        .container {
            max-width: 1100px;
            margin: 0 auto;
            padding: 32px;
        }
        .page-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 24px;
            flex-wrap: wrap;
            gap: 12px;
        }
        .page-header h1 {
            font-size: 28px;
            font-weight: 800;
        }
        .page-header h1 span { color: #60A5FA; }
        .page-header .subtitle {
            color: #8B9BB5;
            font-size: 14px;
        }
        .server-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 16px;
        }
        .server-card {
            background: rgba(255, 255, 255, 0.02);
            border: 1px solid rgba(255, 255, 255, 0.04);
            border-radius: 14px;
            padding: 20px;
            transition: all 0.3s ease;
            text-decoration: none;
            color: #E8EDF5;
            display: flex;
            align-items: center;
            gap: 16px;
        }
        .server-card:hover {
            border-color: rgba(37, 99, 235, 0.2);
            transform: translateY(-4px);
            box-shadow: 0 8px 24px rgba(0, 0, 0, 0.2);
        }
        .server-card .icon {
            width: 48px;
            height: 48px;
            border-radius: 12px;
            background: linear-gradient(135deg, #1E3A5F, #1A365D);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            font-weight: 700;
            color: #60A5FA;
            flex-shrink: 0;
            overflow: hidden;
        }
        .server-card .icon img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }
        .server-card .info h3 {
            font-size: 16px;
            font-weight: 600;
            margin-bottom: 2px;
        }
        .server-card .info p {
            font-size: 13px;
            color: #8B9BB5;
        }
        .server-card .arrow {
            margin-left: auto;
            color: #2563EB;
            font-size: 14px;
        }
        .empty-state {
            text-align: center;
            padding: 60px 20px;
            color: #8B9BB5;
        }
        .empty-state i {
            font-size: 48px;
            color: #2563EB;
            margin-bottom: 16px;
        }
        .empty-state h3 {
            font-size: 20px;
            color: #E8EDF5;
            margin-bottom: 8px;
        }
        .footer {
            border-top: 1px solid rgba(255, 255, 255, 0.04);
            padding: 24px 32px;
            text-align: center;
            color: #5A6B85;
            font-size: 13px;
            margin-top: 20px;
        }
        @media (max-width: 768px) {
            .navbar { padding: 0 16px; height: 58px; flex-wrap: wrap; gap: 8px; }
            .navbar .nav-links { gap: 16px; }
            .navbar .nav-links a { font-size: 12px; }
            .container { padding: 16px; }
            .page-header h1 { font-size: 22px; }
            .server-grid { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body>
    <nav class="navbar">
        <a href="/dashboard" class="brand">
            <div class="logo-icon">⚡</div>
            Sentinal <span>Dashboard</span>
        </a>
        <div class="nav-links">
            <a href="/dashboard">Home</a>
            <a href="/servers" class="active">Servers</a>
            <a href="#" onclick="window.open('https://discord.gg/UmqmewYWRd', '_blank')">Support</a>
        </div>
        <div class="nav-right">
            <div class="user-avatar">
                <% if (user && user.avatar) { %>
                    <img src="https://cdn.discordapp.com/avatars/<%= user.id %>/<%= user.avatar %>.png" alt="Avatar">
                <% } else { %>
                    <%= user ? user.username ? user.username.charAt(0).toUpperCase() : 'U' : 'U' %>
                <% } %>
            </div>
            <a href="/logout" class="logout-btn"><i class="fas fa-sign-out-alt"></i> Logout</a>
        </div>
    </nav>

    <div class="container">
        <div class="page-header">
            <div>
                <h1>My <span>Servers</span></h1>
                <div class="subtitle">Select a server to manage its settings</div>
            </div>
        </div>

        <% if (guilds && guilds.length > 0) { %>
            <div class="server-grid">
                <% guilds.forEach(function(guild) { %>
                    <a href="/server/<%= guild.id %>" class="server-card">
                        <div class="icon">
                            <% if (guild.icon) { %>
                                <img src="https://cdn.discordapp.com/icons/<%= guild.id %>/<%= guild.icon %>.png" alt="<%= guild.name %>">
                            <% } else { %>
                                <%= guild.name ? guild.name.charAt(0).toUpperCase() : '?' %>
                            <% } %>
                        </div>
                        <div class="info">
                            <h3><%= guild.name %></h3>
                            <p><i class="fas fa-users"></i> <%= guild.approximate_member_count || 'N/A' %> members</p>
                        </div>
                        <div class="arrow"><i class="fas fa-chevron-right"></i></div>
                    </a>
                <% }); %>
            </div>
        <% } else { %>
            <div class="empty-state">
                <i class="fas fa-server"></i>
                <h3>No Servers Found</h3>
                <p>You don't have administrator access to any servers.</p>
            </div>
        <% } %>
    </div>

    <footer class="footer">
        © 2026 Sentinal — Made with ❤️
    </footer>
</body>
</html>
