<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Your Servers — BotCommand</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --purple: #7C3AED;
      --purple-light: #9D5CF5;
      --purple-dark: #5B21B6;
      --green: #10B981;
      --green-light: #34D399;
      --bg: #0D0D14;
      --surface: rgba(255,255,255,0.04);
      --border: rgba(255,255,255,0.08);
      --text: #F1F0FF;
      --muted: #8B8FAE;
    }

    html, body { min-height: 100%; font-family: 'Inter', sans-serif; background: var(--bg); color: var(--text); }

    .bg-scene { position: fixed; inset: 0; z-index: 0; pointer-events: none; overflow: hidden; }
    .blob { position: absolute; border-radius: 50%; filter: blur(130px); opacity: 0.2; }
    .blob-1 { width: 700px; height: 700px; background: var(--purple); top: -300px; left: -200px; }
    .blob-2 { width: 500px; height: 500px; background: var(--green); bottom: -200px; right: -150px; }

    /* Navbar */
    nav {
      position: sticky; top: 0; z-index: 100;
      display: flex; align-items: center; justify-content: space-between;
      padding: 0 40px; height: 64px;
      background: rgba(13,13,20,0.85);
      backdrop-filter: blur(20px);
      border-bottom: 1px solid var(--border);
    }
    .nav-logo { display: flex; align-items: center; gap: 10px; font-weight: 800; font-size: 17px; letter-spacing: -0.02em; }
    .nav-logo-icon {
      width: 32px; height: 32px; border-radius: 8px;
      background: linear-gradient(135deg, var(--purple), var(--purple-dark));
      display: flex; align-items: center; justify-content: center;
    }
    .nav-logo-icon svg { width: 18px; height: 18px; fill: #fff; }
    .nav-right { display: flex; align-items: center; gap: 16px; }
    .user-chip {
      display: flex; align-items: center; gap: 8px;
      background: var(--surface); border: 1px solid var(--border);
      padding: 6px 14px 6px 6px; border-radius: 99px;
      font-size: 13px; font-weight: 500;
    }
    .user-avatar {
      width: 26px; height: 26px; border-radius: 50%; object-fit: cover;
      background: var(--purple); display: flex; align-items: center; justify-content: center;
      font-size: 12px; font-weight: 700; flex-shrink: 0; overflow: hidden;
    }
    .btn-logout {
      padding: 7px 16px; border-radius: 8px; border: 1px solid var(--border);
      background: transparent; color: var(--muted); font-size: 13px; font-weight: 500;
      cursor: pointer; font-family: 'Inter', sans-serif; text-decoration: none;
      transition: all 0.15s ease;
    }
    .btn-logout:hover { color: var(--text); border-color: rgba(255,255,255,0.2); }

    /* Page */
    main { position: relative; z-index: 1; max-width: 1100px; margin: 0 auto; padding: 52px 24px; }

    .page-header { margin-bottom: 40px; }
    .page-header h1 { font-size: 32px; font-weight: 800; letter-spacing: -0.03em; margin-bottom: 6px; }
    .page-header p { color: var(--muted); font-size: 15px; }

    .stats-row {
      display: flex; gap: 16px; margin-bottom: 40px; flex-wrap: wrap;
    }
    .stat-chip {
      background: var(--surface); border: 1px solid var(--border);
      border-radius: 12px; padding: 14px 20px;
      display: flex; align-items: center; gap: 10px;
      font-size: 13px; color: var(--muted);
    }
    .stat-chip strong { color: var(--text); font-size: 20px; font-weight: 700; display: block; line-height: 1; }
    .stat-dot { width: 8px; height: 8px; border-radius: 50%; }
    .stat-dot.green { background: var(--green); box-shadow: 0 0 6px var(--green); }
    .stat-dot.purple { background: var(--purple); box-shadow: 0 0 6px var(--purple); }

    /* Grid */
    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: 20px;
    }

    /* Server card */
    .server-card {
      background: rgba(255,255,255,0.035);
      backdrop-filter: blur(16px);
      border: 1px solid var(--border);
      border-radius: 18px;
      padding: 24px;
      transition: all 0.2s ease;
      position: relative;
      overflow: hidden;
    }
    .server-card::before {
      content: '';
      position: absolute; inset: 0;
      background: linear-gradient(135deg, rgba(124,58,237,0.04), transparent);
      opacity: 0; transition: opacity 0.2s;
    }
    .server-card:hover { border-color: rgba(124,58,237,0.4); transform: translateY(-3px); box-shadow: 0 12px 40px rgba(0,0,0,0.3); }
    .server-card:hover::before { opacity: 1; }

    .card-top { display: flex; align-items: flex-start; gap: 14px; margin-bottom: 18px; }
    .server-icon {
      width: 52px; height: 52px; border-radius: 14px; flex-shrink: 0;
      background: linear-gradient(135deg, var(--purple-dark), var(--purple));
      display: flex; align-items: center; justify-content: center;
      font-size: 20px; font-weight: 700; overflow: hidden;
    }
    .server-icon img { width: 100%; height: 100%; object-fit: cover; }
    .server-meta { flex: 1; min-width: 0; }
    .server-name { font-weight: 700; font-size: 15px; margin-bottom: 4px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .bot-badge {
      display: inline-flex; align-items: center; gap: 5px;
      font-size: 11px; font-weight: 600; padding: 3px 8px; border-radius: 99px;
    }
    .bot-badge.active { background: rgba(16,185,129,0.15); color: var(--green-light); border: 1px solid rgba(16,185,129,0.3); }
    .bot-badge.inactive { background: rgba(255,255,255,0.05); color: var(--muted); border: 1px solid var(--border); }
    .badge-dot { width: 5px; height: 5px; border-radius: 50%; }
    .bot-badge.active .badge-dot { background: var(--green); }
    .bot-badge.inactive .badge-dot { background: var(--muted); }

    .card-actions { display: flex; gap: 8px; }
    .btn-primary {
      flex: 1; padding: 10px; border-radius: 10px; border: none;
      background: linear-gradient(135deg, var(--purple), var(--purple-dark));
      color: #fff; font-family: 'Inter', sans-serif; font-size: 13px; font-weight: 600;
      cursor: pointer; text-decoration: none; text-align: center;
      transition: all 0.15s ease;
      box-shadow: 0 2px 12px rgba(124,58,237,0.35);
    }
    .btn-primary:hover { box-shadow: 0 4px 20px rgba(124,58,237,0.55); transform: translateY(-1px); }
    .btn-secondary {
      padding: 10px 14px; border-radius: 10px;
      border: 1px solid var(--border); background: transparent;
      color: var(--muted); font-family: 'Inter', sans-serif; font-size: 13px; font-weight: 500;
      cursor: pointer; text-decoration: none; text-align: center;
      transition: all 0.15s ease;
    }
    .btn-secondary:hover { color: var(--text); border-color: rgba(255,255,255,0.2); }

    /* Empty state */
    .empty {
      grid-column: 1/-1; text-align: center; padding: 80px 24px;
      color: var(--muted);
    }
    .empty-icon { font-size: 48px; margin-bottom: 16px; opacity: 0.5; }
    .empty h3 { font-size: 18px; font-weight: 700; color: var(--text); margin-bottom: 8px; }
    .empty p { font-size: 14px; line-height: 1.6; max-width: 320px; margin: 0 auto 24px; }

    @media (max-width: 600px) {
      nav { padding: 0 20px; }
      main { padding: 32px 16px; }
      .page-header h1 { font-size: 24px; }
    }
  </style>
</head>
<body>
  <div class="bg-scene">
    <div class="blob blob-1"></div>
    <div class="blob blob-2"></div>
  </div>

  <nav>
    <div class="nav-logo">
      <div class="nav-logo-icon">
        <svg viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 14H9V8h2v8zm4 0h-2V8h2v8z"/></svg>
      </div>
      BotCommand
    </div>
    <div class="nav-right">
      <div class="user-chip">
        <div class="user-avatar">
          <% if (user.avatar) { %>
            <img src="https://cdn.discordapp.com/avatars/<%= user.id %>/<%= user.avatar %>.png" alt="" style="width:100%;height:100%;object-fit:cover;" />
          <% } else { %>
            <%= user.username.charAt(0).toUpperCase() %>
          <% } %>
        </div>
        <%= user.username %>
      </div>
      <a href="/logout" class="btn-logout">Sign out</a>
    </div>
  </nav>

  <main>
    <div class="page-header">
      <h1>Your Servers</h1>
      <p>Select a server you manage to configure your bot.</p>
    </div>

    <%
      const botServers = guilds.filter(g => g.botPresent);
      const nonBotServers = guilds.filter(g => !g.botPresent);
    %>

    <div class="stats-row">
      <div class="stat-chip">
        <div class="stat-dot purple"></div>
        <div>
          <strong><%= guilds.length %></strong>
          Servers managed
        </div>
      </div>
      <div class="stat-chip">
        <div class="stat-dot green"></div>
        <div>
          <strong><%= botServers.length %></strong>
          Bot active
        </div>
      </div>
    </div>

    <div class="grid">
      <% if (guilds.length === 0) { %>
        <div class="empty">
          <div class="empty-icon">🤖</div>
          <h3>No servers found</h3>
          <p>You don't manage any Discord servers, or none were returned. Make sure you're logged in with the right account.</p>
          <a href="/invite" class="btn-primary" style="display:inline-block;padding:12px 24px;text-decoration:none;">Invite Bot</a>
        </div>
      <% } else { %>
        <% guilds.forEach(guild => { %>
          <div class="server-card">
            <div class="card-top">
              <div class="server-icon">
                <% if (guild.iconUrl) { %>
                  <img src="<%= guild.iconUrl %>" alt="<%= guild.name %>" />
                <% } else { %>
                  <%= guild.name.charAt(0).toUpperCase() %>
                <% } %>
              </div>
              <div class="server-meta">
                <div class="server-name" title="<%= guild.name %>"><%= guild.name %></div>
                <% if (guild.botPresent) { %>
                  <span class="bot-badge active"><span class="badge-dot"></span>Bot active</span>
                <% } else { %>
                  <span class="bot-badge inactive"><span class="badge-dot"></span>Not installed</span>
                <% } %>
              </div>
            </div>
            <div class="card-actions">
              <% if (guild.botPresent) { %>
                <a href="/servers/<%= guild.id %>" class="btn-primary">Configure</a>
              <% } else { %>
                <a href="/servers/<%= guild.id %>" class="btn-secondary">View</a>
                <a href="/invite/<%= guild.id %>" class="btn-primary">Add Bot</a>
              <% } %>
            </div>
          </div>
        <% }); %>
      <% } %>
    </div>
  </main>
</body>
</html>
