<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title || 'My Servers — Sentinal' %></title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@400;500;600;700;800&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --ink: #05070C;
            --panel: #0B1018;
            --panel-raised: #0F1622;
            --line: rgba(255, 255, 255, 0.07);
            --line-bright: rgba(255, 255, 255, 0.14);
            --text: #E9EDF6;
            --muted: #6C7588;
            --muted-dim: #444C5E;
            --signal: #3DFFB8;
            --signal-dim: #1F8C6B;
            --signal-glow: rgba(61, 255, 184, 0.18);
        }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Inter', -apple-system, sans-serif;
            background: var(--ink);
            color: var(--text);
            min-height: 100vh;
        }
        .navbar {
            background: rgba(5, 7, 12, 0.7);
            backdrop-filter: blur(20px) saturate(140%);
            border-bottom: 1px solid var(--line);
            padding: 0 32px;
            height: 68px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: sticky;
            top: 0;
            z-index: 100;
        }
        .navbar .brand {
            display: flex;
            align-items: center;
            gap: 11px;
            font-family: 'Space Grotesk', sans-serif;
            font-size: 17px;
            font-weight: 600;
            color: #FFFFFF;
            text-decoration: none;
        }
        .navbar .brand .logo-icon {
            width: 34px; height: 34px;
            border-radius: 9px;
            background: var(--panel-raised);
            border: 1px solid var(--line-bright);
            display: flex; align-items: center; justify-content: center;
        }
        .navbar .brand .logo-icon svg { width: 18px; height: 18px; }
        .navbar .brand .brand-sub {
            color: var(--muted);
            font-weight: 500;
            font-size: 13px;
            padding-left: 11px;
            border-left: 1px solid var(--line);
        }
        .navbar .nav-links { display: flex; align-items: center; gap: 30px; }
        .navbar .nav-links a {
            color: var(--muted);
            text-decoration: none;
            font-size: 13px;
            font-weight: 500;
            transition: color 0.2s ease;
        }
        .navbar .nav-links a:hover { color: var(--text); }
        .navbar .nav-links a.active { color: #FFFFFF; }
        .navbar .nav-links a.active::after {
            content: '';
            position: absolute;
            bottom: -23px; left: 0; right: 0;
            height: 2px;
            background: var(--signal);
        }
        .navbar .nav-right { display: flex; align-items: center; gap: 16px; }
        .navbar .user-avatar {
            width: 32px; height: 32px;
            border-radius: 50%;
            background: var(--panel-raised);
            border: 1px solid var(--line-bright);
            display: flex; align-items: center; justify-content: center;
            overflow: hidden;
        }
        .navbar .user-avatar img { width: 100%; height: 100%; object-fit: cover; }
        .navbar .logout-btn {
            background: transparent;
            color: var(--muted);
            padding: 7px 16px;
            border-radius: 100px;
            text-decoration: none;
            font-size: 12px;
            font-weight: 500;
            border: 1px solid var(--line);
            transition: all 0.2s ease;
            display: flex;
            align-items: center;
            gap: 6px;
        }
        .navbar .logout-btn:hover {
            background: rgba(239, 68, 68, 0.08);
            color: #F87171;
            border-color: rgba(239, 68, 68, 0.25);
        }
        .container { max-width: 1200px; margin: 0 auto; padding: 32px; }
        .page-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px; flex-wrap: wrap; gap: 12px; }
        .page-header h1 { font-size: 28px; font-weight: 800; }
        .page-header h1 span { color: var(--signal); }
        .page-header .subtitle { color: var(--muted); font-size: 14px; }
        .server-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 16px;
        }
        .server-card {
            background: var(--panel);
            border: 1px solid var(--line);
            border-radius: 12px;
            padding: 16px 20px;
            display: flex;
            align-items: center;
            gap: 14px;
            text-decoration: none;
            color: var(--text);
            transition: all 0.2s ease;
        }
        .server-card:hover {
            border-color: var(--line-bright);
            transform: translateY(-3px);
        }
        .server-card .icon {
            width: 40px; height: 40px;
            border-radius: 10px;
            background: var(--panel-raised);
            display: flex; align-items: center; justify-content: center;
            font-size: 18px; font-weight: 700;
            overflow: hidden;
        }
        .server-card .icon img { width: 100%; height: 100%; object-fit: cover; }
        .server-card .info { flex: 1; }
        .server-card .info .name { font-weight: 600; }
        .server-card .info .role { font-size: 12px; color: var(--muted); }
        .server-card .action { color: var(--signal); font-size: 13px; font-weight: 500; }
        .empty-state { text-align: center; padding: 60px 20px; color: var(--muted); }
        .empty-state i { font-size: 48px; color: var(--signal); margin-bottom: 16px; display: block; }
        .empty-state h3 { color: var(--text); margin-bottom: 8px; }
        .footer {
            border-top: 1px solid var(--line);
            padding: 24px 32px;
            text-align: center;
            color: var(--muted-dim);
            font-size: 12.5px;
            font-family: 'IBM Plex Mono', monospace;
            margin-top: 32px;
        }
        @media (max-width: 768px) {
            .navbar { padding: 0 16px; height: 60px; flex-wrap: wrap; gap: 8px; }
            .navbar .nav-links { gap: 16px; }
            .navbar .nav-links a { font-size: 12px; }
            .navbar .brand .brand-sub { display: none; }
            .container { padding: 16px; }
            .page-header h1 { font-size: 22px; }
            .server-grid { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body>
    <nav class="navbar">
        <a href="/dashboard" class="brand">
            <div class="logo-icon">
                <svg viewBox="0 0 245 240" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M104.4 103.9c-5.7 0-10.2 5-10.2 11.1s4.6 11.1 10.2 11.1c5.7 0 10.2-5 10.2-11.1.1-6.1-4.5-11.1-10.2-11.1zM140.9 103.9c-5.7 0-10.2 5-10.2 11.1s4.6 11.1 10.2 11.1c5.7 0 10.2-5 10.2-11.1s-4.5-11.1-10.2-11.1z" fill="#3DFFB8"/>
                    <path d="M189.5 20H55.5C44.7 20 36 28.7 36 39.5v140.9c0 10.8 8.7 19.5 19.5 19.5h113.5l-5.3-18.5 12.8 11.9 12.1 11.2L209 220V39.5C209 28.7 200.3 20 189.5 20zM155.7 152.1s-3.6-4.3-6.6-8.1c13.1-3.7 18.1-11.9 18.1-11.9-4.1 2.7-8 4.6-11.5 5.9-5 2.1-9.8 3.5-14.5 4.3-9.6 1.8-18.4 1.3-25.9-.1-5.7-1.1-10.6-2.6-14.7-4.3-2.3-.9-4.8-2-7.3-3.4-.3-.2-.6-.3-.9-.5-.2-.1-.3-.2-.4-.3-2-1.1-3.1-1.9-3.1-1.9 4.7 4.3 9.3 6.5 21.7 10.2-2.9 3.8-6.6 8.1-6.6 8.1-22 0-32.1-15.2-32.1-15.2 0-32.2 14.4-58.4 14.4-58.4 14.4-10.8 28.1-10.5 28.1-10.5l1 1.2C99.2 87.7 87.9 97.4 87.9 97.4s2.9-1.6 7.8-3.8c14.1-6.2 25.3-7.9 29.9-8.3.8-.1 1.5-.2 2.3-.2 8.2-1 17.5-1.3 27.2.2 12.9 2 26.7 7.5 40.8 17.3 0 0-10.8-10.2-28.5-13.7l1.4-1.6s13.7-.3 28.1 10.5c0 0 14.4 26.2 14.4 58.4 0 0-10.2 15.2-32.1 15.2z" fill="#3DFFB8"/>
                </svg>
            </div>
            Sentinal <span class="brand-sub">Dashboard</span>
        </a>
        <div class="nav-links">
            <a href="/dashboard">Home</a>
            <a href="/servers" class="active">Servers</a>
            <a href="#" onclick="window.open('https://discord.gg/UmqmewYWRd', '_blank')">Support</a>
        </div>
        <div class="nav-right">
            <div class="user-avatar">
                <% if (user && user.avatar) { %>
                    <img src="https://cdn.discordapp.com/avatars/<%= user.id %>/<%= user.avatar %>.png" alt="Avatar">
                <% } else { %>
                    <%= user ? user.username ? user.username.charAt(0).toUpperCase() : 'U' : 'U' %>
                <% } %>
            </div>
            <a href="/logout" class="logout-btn"><i class="fas fa-sign-out-alt"></i> Logout</a>
        </div>
    </nav>

    <div class="container">
        <div class="page-header">
            <div>
                <h1>My <span>Servers</span></h1>
                <div class="subtitle">Select a server to manage its settings</div>
            </div>
        </div>

        <% if (guilds && guilds.length > 0) { %>
            <div class="server-grid">
                <% guilds.forEach(function(guild) { %>
                    <a href="/server/<%= guild.id %>" class="server-card">
                        <div class="icon">
                            <% if (guild.icon) { %>
                                <img src="https://cdn.discordapp.com/icons/<%= guild.id %>/<%= guild.icon %>.png" alt="<%= guild.name %>">
                            <% } else { %>
                                <%= guild.name ? guild.name.charAt(0).toUpperCase() : '?' %>
                            <% } %>
                        </div>
                        <div class="info">
                            <div class="name"><%= guild.name %></div>
                            <div class="role"><i class="fas fa-crown" style="color:#FBBF24; font-size:11px;"></i> Owner</div>
                        </div>
                        <div class="action">Manage →</div>
                    </a>
                <% }); %>
            </div>
        <% } else { %>
            <div class="empty-state">
                <i class="fas fa-server"></i>
                <h3>No Servers Found</h3>
                <p>You don't have administrator access to any servers.</p>
            </div>
        <% } %>
    </div>

    <footer class="footer">
        © 2026 SENTINAL — STATUS: OPERATIONAL
    </footer>
</body>
</html>
