<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title || 'My Servers — Sentinal' %></title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@400;500;600;700;800&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --ink: #060A10;
            --panel: #0D1520;
            --panel-raised: #111D2C;
            --panel-hover: #162033;
            --line: rgba(255,255,255,0.07);
            --line-bright: rgba(255,255,255,0.13);
            --text: #E6EDF6;
            --muted: #6C7A90;
            --muted-dim: #3E4A5C;
            --signal: #3DFFB8;
            --signal-dim: #1A9E72;
            --signal-glow: rgba(61,255,184,0.15);
            --signal-tab: rgba(61,255,184,0.12);
            --violet: #7B8AFF;
            --gold: #F5C842;
            --red: #F87171;
            --red-bg: rgba(248,113,113,0.08);
            --red-border: rgba(248,113,113,0.22);
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Inter', -apple-system, sans-serif;
            background: var(--ink);
            color: var(--text);
            min-height: 100vh;
        }

        /* ─── NAVBAR ─── */
        .navbar {
            background: rgba(6, 10, 16, 0.85);
            backdrop-filter: blur(24px) saturate(150%);
            border-bottom: 1px solid var(--line);
            padding: 0 40px;
            height: 64px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: sticky;
            top: 0;
            z-index: 200;
        }

        .brand {
            display: flex;
            align-items: center;
            gap: 10px;
            text-decoration: none;
        }
        .brand-logo {
            width: 36px; height: 36px;
            border-radius: 10px;
            background: var(--panel-raised);
            border: 1px solid var(--line-bright);
            display: flex; align-items: center; justify-content: center;
        }
        .brand-logo svg { width: 20px; height: 20px; }
        .brand-name {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 17px;
            font-weight: 700;
            color: #fff;
            letter-spacing: -0.3px;
        }

        .nav-center {
            display: flex;
            align-items: center;
            gap: 6px;
        }
        .nav-center a {
            color: var(--muted);
            text-decoration: none;
            font-size: 13.5px;
            font-weight: 500;
            padding: 6px 14px;
            border-radius: 8px;
            transition: all 0.18s ease;
        }
        .nav-center a:hover { color: var(--text); background: rgba(255,255,255,0.05); }

        .nav-right {
            display: flex;
            align-items: center;
            gap: 12px;
        }
        .user-pill {
            display: flex;
            align-items: center;
            gap: 9px;
            background: var(--panel);
            border: 1px solid var(--line);
            border-radius: 100px;
            padding: 5px 14px 5px 6px;
            cursor: pointer;
        }
        .user-avatar {
            width: 28px; height: 28px;
            border-radius: 50%;
            background: var(--panel-raised);
            overflow: hidden;
            display: flex; align-items: center; justify-content: center;
            font-size: 12px; font-weight: 700;
        }
        .user-avatar img { width: 100%; height: 100%; object-fit: cover; }
        .user-name { font-size: 13px; font-weight: 500; color: var(--text); }
        .user-plan {
            font-size: 10px;
            font-weight: 600;
            color: var(--signal);
            background: var(--signal-tab);
            border: 1px solid rgba(61,255,184,0.22);
            border-radius: 100px;
            padding: 2px 8px;
            letter-spacing: 0.3px;
        }
        .logout-btn {
            background: transparent;
            border: 1px solid var(--line);
            border-radius: 8px;
            padding: 7px 12px;
            color: var(--muted);
            cursor: pointer;
            font-size: 13px;
            transition: all 0.18s ease;
            text-decoration: none;
            display: flex; align-items: center; gap: 6px;
        }
        .logout-btn:hover {
            background: var(--red-bg);
            border-color: var(--red-border);
            color: var(--red);
        }

        /* ─── LAYOUT ─── */
        .page-wrapper {
            max-width: 1120px;
            margin: 0 auto;
            padding: 40px 32px 60px;
        }

        /* ─── TAB NAV ─── */
        .tab-nav {
            display: flex;
            align-items: center;
            gap: 4px;
            margin-bottom: 32px;
        }
        .tab-btn {
            display: flex;
            align-items: center;
            gap: 7px;
            padding: 8px 18px;
            border-radius: 10px;
            font-size: 13.5px;
            font-weight: 600;
            cursor: pointer;
            text-decoration: none;
            transition: all 0.18s ease;
            color: var(--muted);
            border: 1.5px solid transparent;
            background: transparent;
        }
        .tab-btn:hover { color: var(--text); background: rgba(255,255,255,0.04); }
        .tab-btn.active {
            background: var(--signal-tab);
            border-color: rgba(61,255,184,0.3);
            color: var(--signal);
        }
        .tab-btn i { font-size: 12px; }
        .tab-btn .crown { color: var(--gold); }

        /* ─── SECTION HEADER ─── */
        .section-header {
            display: flex;
            align-items: flex-end;
            justify-content: space-between;
            gap: 16px;
            margin-bottom: 20px;
            flex-wrap: wrap;
        }
        .section-title h2 {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 22px;
            font-weight: 700;
            color: #fff;
            letter-spacing: -0.4px;
            margin-bottom: 3px;
        }
        .section-title p {
            font-size: 13px;
            color: var(--muted);
        }

        .header-actions {
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .search-wrap {
            display: flex;
            align-items: center;
            gap: 8px;
            background: var(--panel);
            border: 1px solid var(--line);
            border-radius: 10px;
            padding: 0 14px;
            height: 38px;
            transition: border-color 0.18s;
        }
        .search-wrap:focus-within { border-color: var(--line-bright); }
        .search-wrap i { color: var(--muted-dim); font-size: 12.5px; }
        .search-wrap input {
            background: none;
            border: none;
            outline: none;
            color: var(--text);
            font-size: 13px;
            font-family: 'Inter', sans-serif;
            width: 180px;
        }
        .search-wrap input::placeholder { color: var(--muted-dim); }

        .refresh-btn {
            display: flex;
            align-items: center;
            gap: 7px;
            padding: 0 16px;
            height: 38px;
            background: var(--signal);
            border: none;
            border-radius: 10px;
            color: #041A10;
            font-size: 13px;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.18s ease;
            white-space: nowrap;
        }
        .refresh-btn:hover {
            transform: translateY(-1px);
            box-shadow: 0 4px 18px var(--signal-glow);
        }
        .refresh-btn i { font-size: 12px; }

        /* ─── SERVER GRID ─── */
        .server-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 14px;
        }

        .server-card {
            background: var(--panel);
            border: 1px solid var(--line);
            border-radius: 14px;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            transition: all 0.2s ease;
            text-decoration: none;
            color: var(--text);
        }
        .server-card:hover {
            border-color: var(--line-bright);
            transform: translateY(-2px);
            background: var(--panel-hover);
        }

        .card-body {
            display: flex;
            align-items: center;
            gap: 14px;
            padding: 18px 20px 16px;
        }

        .server-icon {
            width: 46px; height: 46px;
            border-radius: 12px;
            background: var(--panel-raised);
            border: 1px solid var(--line);
            display: flex; align-items: center; justify-content: center;
            font-size: 19px;
            font-weight: 700;
            font-family: 'Space Grotesk', sans-serif;
            overflow: hidden;
            flex-shrink: 0;
            color: var(--signal);
        }
        .server-icon img { width: 100%; height: 100%; object-fit: cover; }

        .server-info { flex: 1; min-width: 0; }
        .server-name {
            font-size: 14.5px;
            font-weight: 600;
            color: #fff;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            margin-bottom: 4px;
        }
        .server-role {
            display: flex;
            align-items: center;
            gap: 5px;
            font-size: 12px;
            color: var(--muted);
        }
        .server-role i { color: var(--gold); font-size: 10px; }

        .card-status {
            width: 8px; height: 8px;
            border-radius: 50%;
            flex-shrink: 0;
        }
        .card-status.online { background: var(--signal); box-shadow: 0 0 6px var(--signal-glow); }
        .card-status.offline { background: var(--muted-dim); }

        .card-footer {
            border-top: 1px solid var(--line);
        }
        .card-action {
            display: block;
            width: 100%;
            padding: 12px 20px;
            text-align: center;
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            text-decoration: none;
            transition: all 0.18s ease;
            border: none;
            background: transparent;
        }
        .card-action.manage {
            color: var(--signal);
        }
        .card-action.manage:hover {
            background: var(--signal-tab);
        }
        .card-action.invite {
            color: var(--muted);
        }
        .card-action.invite:hover {
            background: rgba(255,255,255,0.04);
            color: var(--text);
        }

        /* ─── EMPTY STATE ─── */
        .empty-state {
            grid-column: 1 / -1;
            text-align: center;
            padding: 72px 20px;
        }
        .empty-icon {
            width: 64px; height: 64px;
            border-radius: 16px;
            background: var(--panel-raised);
            border: 1px solid var(--line);
            display: flex; align-items: center; justify-content: center;
            margin: 0 auto 20px;
            font-size: 24px;
            color: var(--signal);
        }
        .empty-state h3 {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 18px;
            color: #fff;
            margin-bottom: 8px;
        }
        .empty-state p { font-size: 13.5px; color: var(--muted); }

        /* ─── FOOTER ─── */
        .footer {
            border-top: 1px solid var(--line);
            margin-top: 60px;
            padding: 24px 40px;
            text-align: center;
            color: var(--muted-dim);
            font-size: 12px;
            font-family: 'IBM Plex Mono', monospace;
            letter-spacing: 0.5px;
        }

        /* ─── RESPONSIVE ─── */
        @media (max-width: 768px) {
            .navbar { padding: 0 16px; }
            .nav-center { display: none; }
            .page-wrapper { padding: 24px 16px 48px; }
            .server-grid { grid-template-columns: 1fr; }
            .section-header { flex-direction: column; align-items: stretch; }
            .header-actions { flex-direction: column; }
            .search-wrap { width: 100%; }
            .search-wrap input { width: 100%; }
            .refresh-btn { width: 100%; justify-content: center; }
        }

        /* ─── SPIN ANIMATION ─── */
        @keyframes spin { to { transform: rotate(360deg); } }
        .spinning { animation: spin 0.6s linear; }
    </style>
</head>
<body>

    <!-- NAVBAR -->
    <nav class="navbar">
        <a href="/dashboard" class="brand">
            <div class="brand-logo">
                <svg viewBox="0 0 245 240" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M104.4 103.9c-5.7 0-10.2 5-10.2 11.1s4.6 11.1 10.2 11.1c5.7 0 10.2-5 10.2-11.1.1-6.1-4.5-11.1-10.2-11.1zM140.9 103.9c-5.7 0-10.2 5-10.2 11.1s4.6 11.1 10.2 11.1c5.7 0 10.2-5 10.2-11.1s-4.5-11.1-10.2-11.1z" fill="#3DFFB8"/>
                    <path d="M189.5 20H55.5C44.7 20 36 28.7 36 39.5v140.9c0 10.8 8.7 19.5 19.5 19.5h113.5l-5.3-18.5 12.8 11.9 12.1 11.2L209 220V39.5C209 28.7 200.3 20 189.5 20zM155.7 152.1s-3.6-4.3-6.6-8.1c13.1-3.7 18.1-11.9 18.1-11.9-4.1 2.7-8 4.6-11.5 5.9-5 2.1-9.8 3.5-14.5 4.3-9.6 1.8-18.4 1.3-25.9-.1-5.7-1.1-10.6-2.6-14.7-4.3-2.3-.9-4.8-2-7.3-3.4-.3-.2-.6-.3-.9-.5-.2-.1-.3-.2-.4-.3-2-1.1-3.1-1.9-3.1-1.9 4.7 4.3 9.3 6.5 21.7 10.2-2.9 3.8-6.6 8.1-6.6 8.1-22 0-32.1-15.2-32.1-15.2 0-32.2 14.4-58.4 14.4-58.4 14.4-10.8 28.1-10.5 28.1-10.5l1 1.2C99.2 87.7 87.9 97.4 87.9 97.4s2.9-1.6 7.8-3.8c14.1-6.2 25.3-7.9 29.9-8.3.8-.1 1.5-.2 2.3-.2 8.2-1 17.5-1.3 27.2.2 12.9 2 26.7 7.5 40.8 17.3 0 0-10.8-10.2-28.5-13.7l1.4-1.6s13.7-.3 28.1 10.5c0 0 14.4 26.2 14.4 58.4 0 0-10.2 15.2-32.1 15.2z" fill="#3DFFB8"/>
                </svg>
            </div>
            <span class="brand-name">Sentinal</span>
        </a>

        <div class="nav-center">
            <a href="/dashboard">Home</a>
            <a href="#">Status</a>
            <a href="#">Documentation</a>
            <a href="#" onclick="window.open('https://discord.gg/UmqmewYWRd','_blank'); return false;">Support</a>
            <a href="#">Premium</a>
        </div>

        <div class="nav-right">
            <div class="user-pill">
                <div class="user-avatar">
                    <% if (user && user.avatar) { %>
                        <img src="https://cdn.discordapp.com/avatars/<%= user.id %>/<%= user.avatar %>.png" alt="Avatar">
                    <% } else { %>
                        <%= user ? (user.username ? user.username.charAt(0).toUpperCase() : 'U') : 'U' %>
                    <% } %>
                </div>
                <span class="user-name"><%= user ? user.global_name || user.username : 'User' %></span>
                <span class="user-plan">Free</span>
            </div>
            <a href="/logout" class="logout-btn">
                <i class="fas fa-sign-out-alt"></i>
            </a>
        </div>
    </nav>

    <!-- PAGE -->
    <div class="page-wrapper">

        <!-- TAB NAV -->
        <div class="tab-nav">
            <a href="/servers" class="tab-btn active">
                <i class="fas fa-sliders-h"></i> Server Selection
            </a>
            <a href="#" class="tab-btn">
                <i class="fas fa-crown crown"></i> Premium
            </a>
            <a href="#" class="tab-btn">
                <i class="fas fa-robot crown"></i> Custom Bot
            </a>
        </div>

        <!-- SECTION HEADER -->
        <div class="section-header">
            <div class="section-title">
                <h2>Select a Server</h2>
                <p>Only servers you have administrator permissions in are shown.</p>
            </div>
            <div class="header-actions">
                <div class="search-wrap">
                    <i class="fas fa-search"></i>
                    <input type="text" id="serverSearch" placeholder="Search for your server..." onkeyup="filterServers()">
                </div>
                <button class="refresh-btn" onclick="handleRefresh(this)">
                    <i class="fas fa-sync-alt" id="refreshIcon"></i> Refresh
                </button>
            </div>
        </div>

        <!-- SERVER GRID -->
        <div class="server-grid" id="serverGrid">
            <% if (guilds && guilds.length > 0) { %>
                <% guilds.forEach(function(guild) { %>
                    <% const botInServer = guild.botInServer || false; %>
                    <% const inviteLink = `https://discord.com/oauth2/authorize?client_id=${process.env.DISCORD_CLIENT_ID || '1493217033956102215'}&permissions=8&integration_type=0&scope=bot+applications.commands`; %>
                    <div class="server-card" data-name="<%= guild.name.toLowerCase() %>">
                        <div class="card-body">
                            <div class="server-icon">
                                <% if (guild.icon) { %>
                                    <img src="https://cdn.discordapp.com/icons/<%= guild.id %>/<%= guild.icon %>.png" alt="<%= guild.name %>">
                                <% } else { %>
                                    <%= guild.name ? guild.name.charAt(0).toUpperCase() : '?' %>
                                <% } %>
                            </div>
                            <div class="server-info">
                                <div class="server-name"><%= guild.name %></div>
                                <div class="server-role">
                                    <i class="fas fa-crown"></i> Owner
                                </div>
                            </div>
                            <div class="card-status <%= botInServer ? 'online' : 'offline' %>"></div>
                        </div>
                        <div class="card-footer">
                            <% if (botInServer) { %>
                                <a href="/server/<%= guild.id %>" class="card-action manage">Configure</a>
                            <% } else { %>
                                <a href="<%= inviteLink %>" target="_blank" class="card-action invite">Invite the bot</a>
                            <% } %>
                        </div>
                    </div>
                <% }); %>
            <% } else { %>
                <div class="empty-state">
                    <div class="empty-icon"><i class="fas fa-server"></i></div>
                    <h3>No Servers Found</h3>
                    <p>You don't have administrator access to any servers.</p>
                </div>
            <% } %>
        </div>

    </div>

    <!-- FOOTER -->
    <footer class="footer">
        © 2026 SENTINAL — STATUS: OPERATIONAL
    </footer>

    <script>
        function filterServers() {
            const filter = document.getElementById('serverSearch').value.toLowerCase();
            document.querySelectorAll('.server-card').forEach(card => {
                const name = card.getAttribute('data-name') || '';
                card.style.display = name.includes(filter) ? '' : 'none';
            });
        }

        function handleRefresh(btn) {
            const icon = document.getElementById('refreshIcon');
            icon.classList.add('spinning');
            setTimeout(() => {
                icon.classList.remove('spinning');
                location.reload();
            }, 600);
        }
    </script>

</body>
</html>
