                </div>
                <div class="selected-roles-display" id="requiredSelected"></div>
                <div class="form-hint">Members with all of these roles will be able to open a ticket.</div>
                <div class="match-mode">
                    <div class="match-mode-label">
                        Match Mode
                        <span class="info-icon" title="User is required only if they have ALL of the listed roles.">ⓘ</span>
                    </div>
                    <div class="segmented" id="requiredMatchMode">
                        <button class="segment active" data-value="all" onclick="setMatchMode('required', 'all')">Has all roles</button>
                        <button class="segment" data-value="any" onclick="setMatchMode('required', 'any')">Has any role</button>
