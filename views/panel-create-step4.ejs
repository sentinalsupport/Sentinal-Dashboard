<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title || 'Panel Designer — Sentinal' %></title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@400;500;600;700;800&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --ink: #060A10;
            --panel: #0D1520;
            --panel-raised: #111D2C;
            --panel-hover: #162033;
            --line: rgba(255,255,255,0.07);
            --line-bright: rgba(255,255,255,0.13);
            --text: #E6EDF6;
            --muted: #6C7A90;
            --muted-dim: #3E4A5C;
            --signal: #3DFFB8;
            --signal-tab: rgba(61,255,184,0.08);
            --signal-glow: rgba(61,255,184,0.15);
            --gold: #F5C842;
            --gold-tab: rgba(245,200,66,0.12);
            --violet: #8B7EFF;
            --violet-tab: rgba(139,126,255,0.12);
            --red: #F87171;
            --red-bg: rgba(248,113,113,0.08);
            --red-border: rgba(248,113,113,0.22);
            --discord: #5865F2;
            --discord-hover: #4752C4;
        }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Inter', -apple-system, sans-serif;
            background: var(--ink);
            color: var(--text);
            min-height: 100vh;
            overflow-x: hidden;
        }

        .navbar {
            background: rgba(6,10,16,0.9);
            backdrop-filter: blur(28px) saturate(160%);
            border-bottom: 1px solid var(--line);
            padding: 0 48px;
            height: 72px;
            display: flex; align-items: center; justify-content: space-between;
            position: sticky; top: 0; z-index: 200;
        }
        .brand { display: flex; align-items: center; gap: 12px; text-decoration: none; }
        .brand-logo {
            width: 40px; height: 40px; border-radius: 12px;
            background: var(--panel-raised); border: 1px solid var(--line-bright);
            display: flex; align-items: center; justify-content: center;
        }
        .brand-logo svg { width: 22px; height: 22px; }
        .brand-name {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 20px; font-weight: 700; color: #fff; letter-spacing: -0.3px;
        }
        .nav-center { display: flex; align-items: center; gap: 8px; }
        .nav-center a {
            color: var(--muted); text-decoration: none; font-size: 15px; font-weight: 500;
            padding: 8px 18px; border-radius: 10px; transition: all 0.18s ease;
        }
        .nav-center a:hover { color: var(--text); background: rgba(255,255,255,0.05); }
        .nav-center a.active { color: #fff; }
        .nav-right { display: flex; align-items: center; gap: 16px; }
        .user-pill {
            display: flex; align-items: center; gap: 12px;
            background: var(--panel); border: 1px solid var(--line);
            border-radius: 100px; padding: 6px 18px 6px 8px;
        }
        .user-avatar {
            width: 32px; height: 32px; border-radius: 50%;
            background: var(--panel-raised); overflow: hidden;
            display: flex; align-items: center; justify-content: center;
            font-size: 14px; font-weight: 700;
        }
        .user-avatar img { width: 100%; height: 100%; object-fit: cover; }
        .user-name { font-size: 14px; font-weight: 500; color: var(--text); }
        .user-plan {
            font-size: 11px; font-weight: 600; color: var(--signal);
            background: var(--signal-tab); border: 1px solid rgba(61,255,184,0.22);
            border-radius: 100px; padding: 3px 10px; letter-spacing: 0.3px;
        }
        .logout-btn {
            background: transparent; border: 1px solid var(--line); border-radius: 10px;
            padding: 8px 14px; color: var(--muted); cursor: pointer; font-size: 14px;
            transition: all 0.18s ease; text-decoration: none;
            display: flex; align-items: center; gap: 8px;
        }
        .logout-btn:hover { background: var(--red-bg); border-color: var(--red-border); color: var(--red); }

        .page-wrapper {
            max-width: 1200px;
            margin: 0 auto;
            padding: 32px 48px 60px;
        }

        .status-bar {
            display: flex; align-items: center; gap: 12px;
            padding: 12px 16px;
            background: var(--panel);
            border-radius: 12px;
            border: 1px solid var(--line);
            margin-bottom: 24px;
        }
        .status-bar .dot { color: #34d399; font-size: 12px; font-weight: 600; }
        .status-bar .text { color: var(--text-secondary); font-size: 13px; }
        .status-bar .time { margin-left: auto; color: var(--muted-dim); font-size: 12px; }

        .page-header {
            margin-bottom: 28px;
        }
        .page-header h1 {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 28px; font-weight: 700; color: #fff;
        }
        .page-header p {
            color: var(--muted);
            font-size: 16px;
        }

        .designer-progress {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 40px;
            padding: 0 20px;
            position: relative;
        }

        .designer-progress::before {
            content: '';
            position: absolute;
            top: 50%;
            left: 40px;
            right: 40px;
            height: 2px;
            background: var(--line);
            transform: translateY(-50%);
        }

        .progress-step {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 8px;
            position: relative;
            z-index: 1;
        }

        .progress-step .step-number {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            background: var(--panel);
            border: 2px solid var(--line);
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            font-size: 14px;
            color: var(--muted-dim);
            transition: all 0.3s ease;
        }

        .progress-step.active .step-number {
            background: var(--signal);
            border-color: var(--signal);
            color: var(--ink);
        }

        .progress-step.completed .step-number {
            background: #34d399;
            border-color: #34d399;
            color: var(--ink);
        }

        .progress-step .step-label {
            font-size: 12px;
            color: var(--muted-dim);
            font-weight: 500;
        }

        .progress-step.active .step-label {
            color: var(--text);
        }

        .section-card {
            background: var(--panel);
            border: 1px solid var(--line);
            border-radius: 14px;
            padding: 24px 28px;
            margin-bottom: 16px;
        }

        .section-card .section-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 6px;
            flex-wrap: wrap;
            gap: 8px;
        }

        .section-card .section-header h3 {
            font-size: 15px;
            font-weight: 600;
            margin: 0;
            color: var(--text-primary);
        }

        .section-card .section-header .badge {
            font-size: 10px;
            font-weight: 600;
            padding: 2px 10px;
            border-radius: 100px;
            background: var(--signal-tab);
            color: var(--signal);
            border: 1px solid rgba(61,255,184,0.2);
        }

        .section-card .section-desc {
            font-size: 13px;
            color: var(--muted);
            margin-bottom: 14px;
        }

        .form-group {
            margin-bottom: 14px;
        }

        .form-group label {
            display: block;
            font-size: 12px;
            font-weight: 600;
            margin-bottom: 4px;
            color: var(--text);
        }

        .form-group .form-hint {
            font-size: 11px;
            color: var(--muted-dim);
            margin-top: 2px;
        }

        .form-group input,
        .form-group select,
        .form-group textarea {
            width: 100%;
            padding: 10px 14px;
            border-radius: 8px;
            border: 1px solid var(--line);
            background: var(--ink);
            color: var(--text);
            font-size: 13px;
            font-family: 'Inter', sans-serif;
            outline: none;
            transition: all 0.2s ease;
        }

        .form-group input:focus,
        .form-group select:focus,
        .form-group textarea:focus {
            border-color: var(--signal);
            box-shadow: 0 0 0 3px var(--signal-glow);
        }

        .form-group select option {
            background: var(--ink);
        }

        .form-group select[multiple] {
            min-height: 80px;
        }

        .form-group select[multiple] option {
            padding: 6px 8px;
        }

        .form-group select[multiple] option:checked {
            background: var(--signal-tab);
            color: var(--signal);
        }

        .form-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 16px;
        }

        .toggle-wrapper {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .toggle-wrapper span {
            font-size: 13px;
            font-weight: 500;
            color: var(--text);
        }

        .toggle {
            width: 44px;
            height: 24px;
            background: var(--muted-dim);
            border-radius: 12px;
            cursor: pointer;
            transition: all 0.3s ease;
            position: relative;
            border: none;
            flex-shrink: 0;
        }

        .toggle.active {
            background: var(--signal);
        }

        .toggle .toggle-slider {
            width: 18px;
            height: 18px;
            background: #fff;
            border-radius: 50%;
            position: absolute;
            top: 3px;
            left: 3px;
            transition: all 0.3s ease;
        }

        .toggle.active .toggle-slider {
            left: 23px;
        }

        .premium-badge {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            font-size: 10px;
            font-weight: 700;
            color: var(--gold);
            background: var(--gold-tab);
            padding: 2px 10px;
            border-radius: 100px;
            border: 1px solid rgba(245,200,66,0.2);
            margin-left: 8px;
        }

        .premium-feature {
            opacity: 0.6;
            position: relative;
        }

        .premium-feature::after {
            content: '🔒 PREMIUM';
            position: absolute;
            top: 8px;
            right: 8px;
            font-size: 9px;
            font-weight: 700;
            color: var(--gold);
            background: var(--gold-tab);
            padding: 2px 10px;
            border-radius: 100px;
            border: 1px solid rgba(245,200,66,0.2);
        }

        .premium-feature .toggle {
            opacity: 0.5;
            cursor: not-allowed;
        }

        .premium-feature select,
        .premium-feature input {
            opacity: 0.5;
            cursor: not-allowed;
        }

        /* ============ CUSTOM MULTI-SELECT ============ */
        .multi-select-wrapper {
            position: relative;
            width: 100%;
        }

        .multi-select-wrapper .dropdown-toggle {
            width: 100%;
            padding: 10px 14px;
            border-radius: 8px;
            border: 1px solid var(--line);
            background: var(--ink);
            color: var(--text);
            font-size: 13px;
            font-family: 'Inter', sans-serif;
            cursor: pointer;
            display: flex;
            justify-content: space-between;
            align-items: center;
            transition: all 0.2s ease;
            text-align: left;
        }

        .multi-select-wrapper .dropdown-toggle:hover {
            border-color: var(--line-bright);
        }

        .multi-select-wrapper .dropdown-toggle:focus {
            border-color: var(--signal);
            box-shadow: 0 0 0 3px var(--signal-glow);
        }

        .multi-select-wrapper .dropdown-toggle .selected-text {
            color: var(--muted);
            font-weight: 400;
        }

        .multi-select-wrapper .dropdown-toggle .selected-text span {
            color: var(--text);
            font-weight: 500;
        }

        .multi-select-wrapper .dropdown-toggle .arrow {
            color: var(--muted);
            transition: transform 0.2s ease;
            font-size: 12px;
        }

        .multi-select-wrapper .dropdown-toggle .arrow.open {
            transform: rotate(180deg);
        }

        .multi-select-dropdown {
            display: none;
            position: absolute;
            top: calc(100% + 4px);
            left: 0;
            right: 0;
            background: var(--panel);
            border: 1px solid var(--line);
            border-radius: 8px;
            padding: 8px;
            z-index: 100;
            max-height: 220px;
            overflow-y: auto;
            box-shadow: 0 8px 32px rgba(0,0,0,0.4);
        }

        .multi-select-dropdown::-webkit-scrollbar {
            width: 4px;
        }
        .multi-select-dropdown::-webkit-scrollbar-track {
            background: transparent;
        }
        .multi-select-dropdown::-webkit-scrollbar-thumb {
            background: var(--muted-dim);
            border-radius: 10px;
        }

        .multi-select-dropdown.open {
            display: block;
            animation: fadeIn 0.15s ease;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(-4px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .multi-select-dropdown .search-input {
            width: 100%;
            padding: 8px 12px;
            border-radius: 6px;
            border: 1px solid var(--line);
            background: var(--ink);
            color: var(--text);
            font-size: 13px;
            font-family: 'Inter', sans-serif;
            outline: none;
            margin-bottom: 6px;
        }

        .multi-select-dropdown .search-input:focus {
            border-color: var(--signal);
            box-shadow: 0 0 0 3px var(--signal-glow);
        }

        .multi-select-dropdown .search-input::placeholder {
            color: var(--muted-dim);
        }

        .multi-select-dropdown .option-item {
            padding: 6px 10px;
            border-radius: 6px;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 10px;
            transition: all 0.15s ease;
            color: var(--text);
            font-size: 13px;
            user-select: none;
        }

        .multi-select-dropdown .option-item:hover {
            background: var(--panel-hover);
        }

        .multi-select-dropdown .option-item .checkbox {
            width: 18px;
            height: 18px;
            border-radius: 4px;
            border: 2px solid var(--muted-dim);
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            transition: all 0.15s ease;
        }

        .multi-select-dropdown .option-item .checkbox.checked {
            background: var(--signal);
            border-color: var(--signal);
        }

        .multi-select-dropdown .option-item .checkbox.checked::after {
            content: '✓';
            color: var(--ink);
            font-size: 12px;
            font-weight: 700;
        }

        .multi-select-dropdown .option-item .role-color-dot {
            width: 10px;
            height: 10px;
            border-radius: 50%;
            flex-shrink: 0;
        }

        .multi-select-dropdown .option-item .role-name {
            flex: 1;
        }

        .multi-select-dropdown .option-item .role-count {
            font-size: 11px;
            color: var(--muted-dim);
        }

        .multi-select-dropdown .no-results {
            padding: 12px;
            text-align: center;
            color: var(--muted-dim);
            font-size: 13px;
        }

        .selected-roles-display {
            display: flex;
            flex-wrap: wrap;
            gap: 6px;
            margin-top: 8px;
            min-height: 28px;
        }

        .selected-role-tag {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            padding: 2px 10px 2px 6px;
            border-radius: 100px;
            font-size: 11px;
            font-weight: 500;
            background: var(--signal-tab);
            color: var(--signal);
            border: 1px solid rgba(61,255,184,0.2);
            animation: tagIn 0.2s ease;
        }

        @keyframes tagIn {
            from { opacity: 0; transform: scale(0.9); }
            to { opacity: 1; transform: scale(1); }
        }

        .selected-role-tag .role-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            display: inline-block;
            flex-shrink: 0;
        }

        .selected-role-tag .remove-role {
            cursor: pointer;
            font-size: 12px;
            opacity: 0.6;
            transition: all 0.15s ease;
            background: none;
            border: none;
            color: var(--signal);
            padding: 0 2px;
            line-height: 1;
        }

        .selected-role-tag .remove-role:hover {
            opacity: 1;
        }

        .match-mode {
            margin-top: 12px;
            padding: 12px 16px;
            background: var(--panel-raised);
            border-radius: 8px;
            border: 1px solid var(--line);
        }

        .match-mode-label {
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 12px;
            font-weight: 600;
            color: var(--muted);
            margin-bottom: 6px;
        }

        .match-mode-label .info-icon {
            color: var(--muted-dim);
            font-size: 12px;
            cursor: help;
        }

        .segmented {
            display: inline-flex;
            background: var(--ink);
            border: 1px solid var(--line);
            border-radius: 6px;
            padding: 3px;
            gap: 2px;
        }

        .segment {
            background: none;
            border: none;
            color: var(--muted);
            font-size: 12px;
            font-weight: 600;
            padding: 4px 14px;
            border-radius: 4px;
            cursor: pointer;
            transition: all 0.15s ease;
            font-family: 'Inter', sans-serif;
        }

        .segment.active {
            background: var(--signal);
            color: var(--ink);
        }

        .match-mode-desc {
            font-size: 12px;
            color: var(--muted);
            margin-top: 6px;
            padding: 6px 12px;
            background: var(--ink);
            border-radius: 6px;
        }

        .match-mode-desc strong {
            color: var(--text);
        }

        /* ============ QUESTIONS ============ */
        .question-item {
            background: var(--panel-raised);
            border: 1px solid var(--line);
            border-radius: 10px;
            padding: 16px 18px;
            margin-bottom: 10px;
        }

        .question-item .q-header {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 6px;
        }

        .question-item .q-header .q-number {
            font-weight: 700;
            font-size: 13px;
            color: var(--signal);
        }

        .question-item .q-header .q-title {
            font-weight: 600;
            font-size: 14px;
            color: #fff;
        }

        .question-item .q-desc {
            font-size: 12px;
            color: var(--muted);
            margin-bottom: 6px;
        }

        .question-item .q-desc strong {
            color: var(--text);
        }

        .question-item .q-type {
            font-size: 11px;
            color: var(--muted);
            background: var(--panel);
            padding: 2px 10px;
            border-radius: 100px;
            border: 1px solid var(--line);
            display: inline-block;
        }

        .question-item .q-actions {
            display: flex;
            gap: 6px;
            margin-top: 8px;
        }

        .question-item .q-actions button {
            background: none;
            border: none;
            color: var(--muted);
            cursor: pointer;
            padding: 4px 10px;
            border-radius: 6px;
            font-size: 12px;
            font-weight: 500;
            transition: all 0.18s ease;
        }

        .question-item .q-actions button:hover {
            background: rgba(255,255,255,0.04);
            color: var(--text);
        }

        .question-item .q-actions button.danger:hover {
            background: var(--red-bg);
            color: var(--red);
        }

        .question-item .q-row {
            display: flex;
            gap: 16px;
            margin-top: 10px;
            flex-wrap: wrap;
        }

        .question-item .q-row .q-field {
            flex: 1;
            min-width: 100px;
        }

        .question-item .q-row .q-field label {
            font-size: 11px;
            font-weight: 600;
            color: var(--muted);
            display: block;
            margin-bottom: 2px;
        }

        .question-item .q-row .q-field input,
        .question-item .q-row .q-field select {
            width: 100%;
            padding: 6px 10px;
            border-radius: 6px;
            border: 1px solid var(--line);
            background: var(--ink);
            color: var(--text);
            font-size: 12px;
            font-family: 'Inter', sans-serif;
            outline: none;
        }

        .question-item .q-row .q-field input:focus,
        .question-item .q-row .q-field select:focus {
            border-color: var(--signal);
        }

        .question-item .q-row .q-field .toggle {
            width: 36px;
            height: 20px;
        }

        .question-item .q-row .q-field .toggle .toggle-slider {
            width: 14px;
            height: 14px;
            top: 3px;
            left: 3px;
        }

        .question-item .q-row .q-field .toggle.active .toggle-slider {
            left: 19px;
        }

        .btn-secondary {
            padding: 8px 20px;
            border-radius: 8px;
            background: transparent;
            color: var(--muted);
            border: 1px solid var(--line);
            font-weight: 600;
            font-size: 13px;
            cursor: pointer;
            transition: all 0.18s ease;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 7px;
            font-family: 'Inter', sans-serif;
        }

        .btn-secondary:hover {
            background: rgba(255,255,255,0.04);
            color: var(--text);
        }

        .btn-save {
            padding: 10px 28px;
            border-radius: 8px;
            border: none;
            font-weight: 700;
            font-size: 14px;
            cursor: pointer;
            background: var(--signal);
            color: var(--ink);
            transition: all 0.18s ease;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            font-family: 'Inter', sans-serif;
        }

        .btn-save:hover {
            transform: translateY(-1px);
            box-shadow: 0 4px 18px var(--signal-glow);
        }

        .designer-actions {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-top: 32px;
            padding-top: 20px;
            border-top: 1px solid var(--line);
        }

        .btn-back {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 10px 24px;
            border-radius: 10px;
            background: transparent;
            color: var(--muted);
            border: 1px solid var(--line);
            font-weight: 600;
            font-size: 14px;
            cursor: pointer;
            transition: all 0.2s ease;
            text-decoration: none;
        }

        .btn-back:hover {
            background: rgba(255,255,255,0.04);
            color: var(--text);
        }

        .btn-continue {
            padding: 10px 32px;
            border-radius: 10px;
            background: var(--signal);
            color: var(--ink);
            border: none;
            font-weight: 700;
            font-size: 14px;
            cursor: pointer;
            transition: all 0.2s ease;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

        .btn-continue:hover:not(:disabled) {
            transform: translateY(-1px);
            box-shadow: 0 4px 20px var(--signal-glow);
        }

        .btn-continue:disabled {
            opacity: 0.4;
            cursor: not-allowed;
            transform: none;
        }

        .toast-container {
            position: fixed;
            bottom: 24px;
            right: 24px;
            z-index: 9999;
            display: flex;
            flex-direction: column;
            gap: 10px;
            max-width: 380px;
            width: 100%;
        }
        .toast {
            background: var(--panel);
            border: 1px solid var(--line);
            border-radius: 12px;
            padding: 14px 20px;
            display: flex;
            align-items: center;
            gap: 12px;
            box-shadow: 0 8px 32px rgba(0,0,0,0.4);
            animation: slideIn 0.3s ease;
            backdrop-filter: blur(10px);
            border-left: 4px solid var(--signal);
        }
        .toast .toast-icon { color: var(--signal); font-size: 18px; flex-shrink: 0; }
        .toast .toast-content { flex: 1; font-size: 13px; color: var(--text); line-height: 1.4; }
        .toast .toast-close {
            background: none; border: none;
            color: var(--muted-dim); cursor: pointer;
            font-size: 14px; padding: 4px;
        }
        .toast .toast-close:hover { color: var(--text); }
        .toast.error { border-left-color: var(--red); }
        .toast.error .toast-icon { color: var(--red); }
        .toast.success { border-left-color: var(--signal); }
        .toast.success .toast-icon { color: var(--signal); }
        @keyframes slideIn {
            from { opacity: 0; transform: translateX(40px); }
            to { opacity: 1; transform: translateX(0); }
        }
        @keyframes slideOut {
            from { opacity: 1; transform: translateX(0); }
            to { opacity: 0; transform: translateX(40px); }
        }
        .toast.hiding { animation: slideOut 0.3s ease forwards; }

        .footer {
            border-top: 1px solid var(--line);
            margin-top: 60px;
            padding: 28px 48px;
            text-align: center;
            color: var(--muted-dim);
            font-size: 13px;
            font-family: 'IBM Plex Mono', monospace;
            letter-spacing: 0.5px;
        }

        @media (max-width: 768px) {
            .navbar { padding: 0 16px; height: 64px; }
            .nav-center { display: none; }
            .page-wrapper { padding: 16px; }
            .form-row { grid-template-columns: 1fr; }
            .section-card { padding: 16px; }
            .designer-progress { padding: 0; }
            .designer-progress::before { display: none; }
            .progress-step .step-label { display: none; }
            .designer-actions { flex-direction: column; gap: 12px; }
            .designer-actions .btn-back,
            .designer-actions .btn-continue { width: 100%; justify-content: center; }
            .question-item .q-row { flex-direction: column; }
        }
    </style>
</head>
