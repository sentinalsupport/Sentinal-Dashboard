<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title || 'Sentinal Dashboard' %></title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Inter', -apple-system, sans-serif;
            background: #080E1A;
            color: #E8EDF5;
            min-height: 100vh;
        }
        .navbar {
            background: rgba(8, 14, 26, 0.92);
            backdrop-filter: blur(16px);
            border-bottom: 1px solid rgba(255, 255, 255, 0.04);
            padding: 0 32px;
            height: 64px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: sticky;
            top: 0;
            z-index: 100;
        }
        .navbar .brand {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 18px;
            font-weight: 700;
            color: #FFFFFF;
            text-decoration: none;
        }
        .navbar .brand .logo-icon {
            width: 32px;
            height: 32px;
            background: linear-gradient(135deg, #2563EB, #1D4ED8);
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 15px;
        }
        .navbar .brand span { color: #60A5FA; }
        .navbar .nav-links {
            display: flex;
            align-items: center;
            gap: 28px;
        }
        .navbar .nav-links a {
            color: #8B9BB5;
            text-decoration: none;
            font-size: 13px;
            font-weight: 500;
            transition: color 0.2s ease;
        }
        .navbar .nav-links a:hover { color: #E8EDF5; }
        .navbar .nav-right {
            display: flex;
            align-items: center;
            gap: 16px;
        }
        .navbar .user-avatar {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            background: linear-gradient(135deg, #2563EB, #1D4ED8);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 14px;
            font-weight: 600;
            color: #FFFFFF;
            overflow: hidden;
        }
        .navbar .user-avatar img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }
        .navbar .login-btn {
            background: linear-gradient(135deg, #2563EB, #1D4ED8);
            color: #FFFFFF;
            padding: 6px 20px;
            border-radius: 100px;
            text-decoration: none;
            font-size: 12px;
            font-weight: 600;
            transition: all 0.2s ease;
            border: none;
            cursor: pointer;
        }
        .navbar .login-btn:hover {
            transform: translateY(-1px);
            box-shadow: 0 4px 16px rgba(37, 99, 235, 0.25);
        }
        .navbar .logout-btn {
            background: rgba(255, 255, 255, 0.06);
            color: #8B9BB5;
            padding: 6px 16px;
            border-radius: 100px;
            text-decoration: none;
            font-size: 12px;
            font-weight: 500;
            border: 1px solid rgba(255, 255, 255, 0.06);
            transition: all 0.2s ease;
            display: flex;
            align-items: center;
            gap: 6px;
        }
        .navbar .logout-btn:hover {
            background: rgba(239, 68, 68, 0.1);
            color: #EF4444;
            border-color: rgba(239, 68, 68, 0.2);
        }
        .hero {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            text-align: center;
            padding: 80px 20px 60px;
        }
        .hero h1 {
            font-size: 52px;
            font-weight: 900;
            background: linear-gradient(135deg, #FFFFFF, #60A5FA);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-bottom: 16px;
        }
        .hero p {
            font-size: 18px;
            color: #8B9BB5;
            max-width: 500px;
            line-height: 1.6;
        }
        .hero .cta-btn {
            margin-top: 24px;
            padding: 12px 36px;
            border-radius: 100px;
            background: linear-gradient(135deg, #2563EB, #1D4ED8);
            color: #FFFFFF;
            text-decoration: none;
            font-weight: 600;
            font-size: 15px;
            transition: all 0.2s ease;
        }
        .hero .cta-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 24px rgba(37, 99, 235, 0.3);
        }
        .features {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px;
            max-width: 1100px;
            margin: 0 auto;
            padding: 0 20px 60px;
        }
        .feature-card {
            background: rgba(255, 255, 255, 0.02);
            border: 1px solid rgba(255, 255, 255, 0.04);
            border-radius: 14px;
            padding: 24px;
            text-align: center;
            transition: all 0.3s ease;
        }
        .feature-card:hover {
            border-color: rgba(37, 99, 235, 0.2);
            transform: translateY(-4px);
        }
        .feature-card i {
            font-size: 32px;
            color: #2563EB;
            margin-bottom: 12px;
        }
        .feature-card h3 {
            font-size: 16px;
            font-weight: 600;
            margin-bottom: 6px;
        }
        .feature-card p {
            font-size: 13px;
            color: #8B9BB5;
        }
        .footer {
            border-top: 1px solid rgba(255, 255, 255, 0.04);
            padding: 24px 32px;
            text-align: center;
            color: #5A6B85;
            font-size: 13px;
        }
        @media (max-width: 768px) {
            .navbar { padding: 0 16px; height: 58px; flex-wrap: wrap; gap: 8px; }
            .navbar .nav-links { gap: 16px; }
            .navbar .nav-links a { font-size: 12px; }
            .hero h1 { font-size: 32px; }
            .hero p { font-size: 16px; padding: 0 16px; }
            .features { grid-template-columns: 1fr; padding: 0 16px 40px; }
        }
    </style>
</head>
<body>
    <nav class="navbar">
        <a href="/" class="brand">
            <div class="logo-icon">⚡</div>
            Sentinal <span>Dashboard</span>
        </a>
        <div class="nav-links">
            <a href="/">Home</a>
            <a href="/servers">Servers</a>
            <a href="#" onclick="window.open('https://discord.gg/UmqmewYWRd', '_blank')">Support</a>
        </div>
        <div class="nav-right">
            <% if (user) { %>
                <div class="user-avatar">
                    <% if (user.avatar) { %>
                        <img src="https://cdn.discordapp.com/avatars/<%= user.id %>/<%= user.avatar %>.png" alt="Avatar">
                    <% } else { %>
                        <%= user.username ? user.username.charAt(0).toUpperCase() : 'U' %>
                    <% } %>
                </div>
                <a href="/logout" class="logout-btn"><i class="fas fa-sign-out-alt"></i> Logout</a>
            <% } else { %>
                <a href="/auth/login" class="login-btn"><i class="fas fa-sign-in-alt"></i> Login</a>
            <% } %>
        </div>
    </nav>

    <section class="hero">
        <h1>🛡️ Sentinal</h1>
        <p>The most advanced Discord bot management dashboard. Secure, powerful, and built for your community.</p>
        <% if (user) { %>
            <a href="/dashboard" class="cta-btn">Go to Dashboard →</a>
        <% } else { %>
            <a href="/auth/login" class="cta-btn"><i class="fab fa-discord"></i> Login with Discord</a>
        <% } %>
    </section>

    <section class="features">
        <div class="feature-card">
            <i class="fas fa-ticket"></i>
            <h3>Ticket System</h3>
            <p>Manage support tickets efficiently</p>
        </div>
        <div class="feature-card">
            <i class="fas fa-shield-halved"></i>
            <h3>Security</h3>
            <p>Advanced moderation tools</p>
        </div>
        <div class="feature-card">
            <i class="fas fa-chart-line"></i>
            <h3>Analytics</h3>
            <p>Real-time bot statistics</p>
        </div>
        <div class="feature-card">
            <i class="fas fa-crown"></i>
            <h3>Premium</h3>
            <p>Unlock powerful features</p>
        </div>
    </section>

    <footer class="footer">
        © 2026 Sentinal — Made with ❤️
    </footer>
</body>
</html>
