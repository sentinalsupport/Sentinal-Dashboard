    <script>
        // scroll-aware navbar
        const navbar = document.getElementById('navbar');
        window.addEventListener('scroll', () => {
            navbar.classList.toggle('scrolled', window.scrollY > 12);
        }, { passive: true });

        // scroll-triggered reveal
        const revealEls = document.querySelectorAll('.reveal');
        const io = new IntersectionObserver((entries) => {
            entries.forEach((entry, i) => {
                if (entry.isIntersecting) {
                    setTimeout(() => entry.target.classList.add('in-view'), i * 70);
                    io.unobserve(entry.target);
                }
            });
        }, { threshold: 0.15, rootMargin: '0px 0px -40px 0px' });
        revealEls.forEach(el => io.observe(el));

        // live log feed
        const feed = [
            { tag: 'mod', tagLabel: 'MOD', msg: 'Muted <span class="who">@drift_king</span> in #general — spam (3 msgs/2s)' },
            { tag: 'info', tagLabel: 'TICKET', msg: 'New ticket opened by <span class="who">@kestrel</span> — "role not assigned"' },
            { tag: 'danger', tagLabel: 'BLOCK', msg: 'Blocked invite link posted in #welcome by <span class="who">@unknown_482</span>' },
            { tag: 'mod', tagLabel: 'MOD', msg: 'Warned <span class="who">@ember.</span> — banned word filter triggered' },
            { tag: 'warn', tagLabel: 'RAID', msg: '14 accounts joined in 6s — lockdown triggered on #general' },
            { tag: 'info', tagLabel: 'TICKET', msg: 'Ticket #214 closed by <span class="who">@mod_lyra</span>' },
            { tag: 'mod', tagLabel: 'MOD', msg: 'Kicked <span class="who">@altf4_99</span> — repeated mention spam' },
            { tag: 'danger', tagLabel: 'BAN', msg: 'Banned <span class="who">@nullroute</span> — known raid account' },
            { tag: 'info', tagLabel: 'ROLE', msg: 'Auto-assigned @Member to 3 new joins' },
            { tag: 'warn', tagLabel: 'FLAG', msg: 'Message flagged for review in #support — link to suspicious domain' }
        ];

        function pad(n) { return n.toString().padStart(2, '0'); }
        function timestamp() {
            const d = new Date();
            return `${pad(d.getHours())}:${pad(d.getMinutes())}:${pad(d.getSeconds())}`;
        }

        const logFeedEl = document.getElementById('logFeed');
        const MAX_LINES = 7;
        let i = 0;

        function pushLine() {
            const entry = feed[i % feed.length];
            i++;
            const line = document.createElement('div');
            line.className = 'log-line';
            line.innerHTML = `<span class="ts">${timestamp()}</span><span class="tag ${entry.tag}">${entry.tagLabel}</span><span class="msg">${entry.msg}</span>`;
            logFeedEl.appendChild(line);
            while (logFeedEl.children.length > MAX_LINES) {
                logFeedEl.removeChild(logFeedEl.firstChild);
            }
        }

        for (let n = 0; n < 6; n++) pushLine();
        setInterval(pushLine, 2400);

        // signature effect: rising sun motes drifting up the page
        (function spawnMotes() {
            const wrap = document.getElementById('motes');
            if (!wrap || window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
            const COUNT = 22;
            for (let n = 0; n < COUNT; n++) {
                const m = document.createElement('div');
                m.className = 'mote';
                const left = Math.random() * 100;
                const size = 3 + Math.random() * 4;
                const duration = 10 + Math.random() * 10;
                const delay = Math.random() * duration;
                const drift = (Math.random() * 80 - 40) + 'px';
                m.style.left = left + 'vw';
                m.style.width = size + 'px';
                m.style.height = size + 'px';
                m.style.setProperty('--drift', drift);
                m.style.animationDuration = duration + 's';
                m.style.animationDelay = '-' + delay + 's';
                if (n % 4 === 0) m.style.background = 'var(--signal)';
                else if (n % 4 === 1) m.style.background = 'var(--coral)';
                else if (n % 4 === 2) m.style.background = 'var(--lagoon)';
                wrap.appendChild(m);
            }
        })();
    </script>
