<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title || 'Auto Roles — Sentinal' %></title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@400;500;600;700;800&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --ink: #060A10;
            --panel: #0D1520;
            --panel-raised: #111D2C;
            --panel-hover: #162033;
            --line: rgba(255,255,255,0.07);
            --line-bright: rgba(255,255,255,0.13);
            --text: #E6EDF6;
            --muted: #6C7A90;
            --muted-dim: #3E4A5C;
            --signal: #3DFFB8;
            --signal-tab: rgba(61,255,184,0.08);
            --signal-glow: rgba(61,255,184,0.15);
            --gold: #F5C842;
            --gold-tab: rgba(245,200,66,0.12);
            --violet: #8B7EFF;
            --violet-tab: rgba(139,126,255,0.12);
            --red: #F87171;
            --red-bg: rgba(248,113,113,0.08);
            --red-border: rgba(248,113,113,0.22);
            --discord: #5865F2;
            --discord-hover: #4752C4;
        }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Inter', -apple-system, sans-serif;
            background: var(--ink);
            color: var(--text);
            min-height: 100vh;
            overflow-x: hidden;
        }

        .navbar {
            background: rgba(6,10,16,0.9);
            backdrop-filter: blur(28px) saturate(160%);
            border-bottom: 1px solid var(--line);
            padding: 0 48px;
            height: 72px;
            display: flex; align-items: center; justify-content: space-between;
            position: sticky; top: 0; z-index: 200;
        }
        .brand { display: flex; align-items: center; gap: 12px; text-decoration: none; }
        .brand-logo {
            width: 40px; height: 40px; border-radius: 12px;
            background: var(--panel-raised); border: 1px solid var(--line-bright);
            display: flex; align-items: center; justify-content: center;
        }
        .brand-logo svg { width: 22px; height: 22px; }
        .brand-name {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 20px; font-weight: 700; color: #fff; letter-spacing: -0.3px;
        }
        .nav-center { display: flex; align-items: center; gap: 8px; }
        .nav-center a {
            color: var(--muted); text-decoration: none; font-size: 15px; font-weight: 500;
            padding: 8px 18px; border-radius: 10px; transition: all 0.18s ease;
        }
        .nav-center a:hover { color: var(--text); background: rgba(255,255,255,0.05); }
        .nav-center a.active { color: #fff; }
        .nav-right { display: flex; align-items: center; gap: 16px; }
        .user-pill {
            display: flex; align-items: center; gap: 12px;
            background: var(--panel); border: 1px solid var(--line);
            border-radius: 100px; padding: 6px 18px 6px 8px;
        }
        .user-avatar {
            width: 32px; height: 32px; border-radius: 50%;
            background: var(--panel-raised); overflow: hidden;
            display: flex; align-items: center; justify-content: center;
            font-size: 14px; font-weight: 700;
        }
        .user-avatar img { width: 100%; height: 100%; object-fit: cover; }
        .user-name { font-size: 14px; font-weight: 500; color: var(--text); }
        .user-plan {
            font-size: 11px; font-weight: 600; color: var(--signal);
            background: var(--signal-tab); border: 1px solid rgba(61,255,184,0.22);
            border-radius: 100px; padding: 3px 10px; letter-spacing: 0.3px;
        }
        .logout-btn {
            background: transparent; border: 1px solid var(--line); border-radius: 10px;
            padding: 8px 14px; color: var(--muted); cursor: pointer; font-size: 14px;
            transition: all 0.18s ease; text-decoration: none;
            display: flex; align-items: center; gap: 8px;
        }
        .logout-btn:hover { background: var(--red-bg); border-color: var(--red-border); color: var(--red); }

        /* ============ PAGE WRAPPER ============ */
        .page-wrapper {
            max-width: 100%;
            margin: 0;
            padding: 32px 48px 60px 5px;
            display: flex;
            gap: 32px;
            align-items: flex-start;
            min-height: calc(100vh - 72px);
        }

        /* ============ SIDEBAR ============ */
        .sidebar {
            width: 280px;
            flex-shrink: 0;
            background: var(--panel);
            border: 1px solid var(--line);
            border-radius: 0 14px 14px 0;
            padding: 16px 18px;
            position: sticky;
            top: 88px;
            height: calc(100vh - 108px);
            overflow-y: auto;
            overflow-x: hidden;
            margin-left: -5px;
            border-left: none;
        }
        .sidebar::-webkit-scrollbar { width: 3px; }
        .sidebar::-webkit-scrollbar-track { background: transparent; }
        .sidebar::-webkit-scrollbar-thumb { background: var(--muted-dim); border-radius: 10px; }

        .sidebar .server-info {
            padding-bottom: 14px;
            border-bottom: 1px solid var(--line);
            margin-bottom: 12px;
        }
        .sidebar .server-info .icon {
            width: 40px; height: 40px; border-radius: 10px;
            background: var(--panel-raised); border: 1px solid var(--line);
            display: flex; align-items: center; justify-content: center;
            font-size: 16px; font-weight: 700;
            overflow: hidden;
            color: var(--signal);
            margin-bottom: 6px;
        }
        .sidebar .server-info .icon img { width: 100%; height: 100%; object-fit: cover; }
        .sidebar .server-info .name {
            font-weight: 600;
            font-size: 14px;
            color: #fff;
        }
        .sidebar .server-info .plan {
            font-size: 10px;
            color: var(--signal);
            font-weight: 500;
            background: var(--signal-tab);
            padding: 2px 12px;
            border-radius: 100px;
            display: inline-block;
            border: 1px solid rgba(61,255,184,0.2);
        }
        .sidebar .server-info .upgrade {
            display: block;
            margin-top: 8px;
            padding: 6px 12px;
            border-radius: 8px;
            background: var(--gold-tab);
            color: var(--gold);
            font-size: 11px;
            font-weight: 600;
            text-decoration: none;
            text-align: center;
            border: 1px solid rgba(245,200,66,0.2);
            transition: all 0.2s ease;
        }
        .sidebar .server-info .upgrade:hover { background: rgba(245,200,66,0.18); }

        .sidebar .nav-section { padding: 0; }
        .sidebar .section-title {
            font-size: 9px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.8px;
            color: var(--muted-dim);
            padding: 10px 8px 6px;
        }
        .sidebar .nav-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 8px 12px;
            border-radius: 8px;
            color: var(--muted);
            text-decoration: none;
            font-size: 13px;
            font-weight: 500;
            transition: all 0.18s ease;
            cursor: pointer;
            border: none;
            background: none;
            width: 100%;
            text-align: left;
        }
        .sidebar .nav-item:hover { background: rgba(255,255,255,0.04); color: var(--text); }
        .sidebar .nav-item.active { background: var(--signal-tab); color: var(--signal); }
        .sidebar .nav-item i { width: 18px; font-size: 14px; color: var(--muted-dim); }
        .sidebar .nav-item.active i { color: var(--signal); }
        .sidebar .nav-item .badge {
            margin-left: auto;
            font-size: 7px;
            font-weight: 700;
            padding: 2px 8px;
            border-radius: 100px;
            text-transform: uppercase;
        }
        .sidebar .nav-item .badge.live { background: var(--signal-tab); color: var(--signal); }
        .sidebar .nav-item .badge.new { background: var(--violet-tab); color: var(--violet); }

        .sidebar .divider { height: 1px; background: var(--line); margin: 8px 0; }

        .content {
            flex: 1;
            min-width: 0;
        }

        .status-bar {
            display: flex; align-items: center; gap: 12px;
            padding: 12px 16px;
            background: var(--panel);
            border-radius: 12px;
            border: 1px solid var(--line);
            margin-bottom: 24px;
        }
        .status-bar .dot { color: #34d399; font-size: 12px; font-weight: 600; }
        .status-bar .text { color: var(--muted); font-size: 13px; }
        .status-bar .time { margin-left: auto; color: var(--muted-dim); font-size: 12px; }

        .page-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 24px;
            flex-wrap: wrap;
            gap: 16px;
        }
        .page-header h1 {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 28px;
            font-weight: 700;
            color: #fff;
        }
        .page-header p {
            color: var(--muted);
            font-size: 16px;
            margin-top: 4px;
        }

        .section-card {
            background: var(--panel);
            border: 1px solid var(--line);
            border-radius: 14px;
            padding: 24px 28px;
            margin-bottom: 16px;
        }
        .section-card .section-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 4px;
            flex-wrap: wrap;
            gap: 8px;
        }
        .section-card .section-header h3 {
            font-size: 15px;
            font-weight: 600;
            color: var(--text);
        }
        .section-card .section-header .badge {
            font-size: 10px;
            font-weight: 600;
            padding: 2px 10px;
            border-radius: 100px;
            background: var(--signal-tab);
            color: var(--signal);
            border: 1px solid rgba(61,255,184,0.2);
        }
        .section-card .section-desc {
            font-size: 13px;
            color: var(--muted);
            margin-bottom: 16px;
        }

        .form-group {
            margin-bottom: 14px;
        }
        .form-group label {
            display: block;
            font-size: 12px;
            font-weight: 600;
            margin-bottom: 4px;
            color: var(--text);
        }
        .form-group .form-hint {
            font-size: 11px;
            color: var(--muted-dim);
            margin-top: 2px;
        }
        .form-group input,
        .form-group select {
            width: 100%;
            padding: 10px 14px;
            border-radius: 8px;
            border: 1px solid var(--line);
            background: var(--ink);
            color: var(--text);
            font-size: 13px;
            font-family: 'Inter', sans-serif;
            outline: none;
            transition: all 0.2s ease;
        }
        .form-group input:focus,
        .form-group select:focus {
            border-color: var(--signal);
            box-shadow: 0 0 0 3px var(--signal-glow);
        }
        .form-group select option {
            background: var(--ink);
        }

        .toggle-wrapper {
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .toggle-wrapper span {
            font-size: 13px;
            font-weight: 500;
            color: var(--text);
        }
        .toggle {
            width: 44px;
            height: 24px;
            background: var(--muted-dim);
            border-radius: 12px;
            cursor: pointer;
            transition: all 0.3s ease;
            position: relative;
            border: none;
            flex-shrink: 0;
        }
        .toggle.active {
            background: var(--signal);
        }
        .toggle .toggle-slider {
            width: 18px;
            height: 18px;
            background: #fff;
            border-radius: 50%;
            position: absolute;
            top: 3px;
            left: 3px;
            transition: all 0.3s ease;
        }
        .toggle.active .toggle-slider {
            left: 23px;
        }

        .role-select-wrapper {
            background: var(--ink);
            border: 1px solid var(--line);
            border-radius: 8px;
            padding: 8px;
            display: flex;
            flex-wrap: wrap;
            gap: 6px;
            min-height: 48px;
            align-items: center;
            position: relative;
        }
        .role-tag {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            padding: 4px 10px 4px 8px;
            border-radius: 100px;
            font-size: 12px;
            font-weight: 500;
            background: var(--signal-tab);
            color: var(--signal);
            border: 1px solid rgba(61,255,184,0.2);
        }
        .role-tag .role-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            display: inline-block;
        }
        .role-tag .remove-role {
            cursor: pointer;
            font-size: 12px;
            opacity: 0.6;
            background: none;
            border: none;
            color: var(--signal);
            padding: 0 2px;
        }
        .role-tag .remove-role:hover {
            opacity: 1;
        }
        .role-select-wrapper input {
            flex: 1;
            background: transparent;
            border: none;
            color: var(--text);
            font-size: 13px;
            font-family: 'Inter', sans-serif;
            outline: none;
            min-width: 120px;
            padding: 4px 0;
        }
        .role-select-wrapper input::placeholder {
            color: var(--muted-dim);
        }
        .role-dropdown {
            display: none;
            position: absolute;
            top: calc(100% + 4px);
            left: 0;
            right: 0;
            background: var(--panel);
            border: 1px solid var(--line);
            border-radius: 8px;
            padding: 8px;
            z-index: 100;
            max-height: 200px;
            overflow-y: auto;
            box-shadow: 0 8px 32px rgba(0,0,0,0.4);
        }
        .role-dropdown.open {
            display: block;
        }
        .role-dropdown .role-option {
            padding: 8px 10px;
            border-radius: 6px;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 10px;
            transition: all 0.15s ease;
            color: var(--text);
            font-size: 13px;
        }
        .role-dropdown .role-option:hover {
            background: var(--panel-hover);
        }
        .role-dropdown .role-option .role-color-dot {
            width: 10px;
            height: 10px;
            border-radius: 50%;
            flex-shrink: 0;
        }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
            gap: 16px;
            margin-bottom: 16px;
        }
        .stat-card {
            background: var(--panel-raised);
            border: 1px solid var(--line);
            border-radius: 10px;
            padding: 16px 20px;
            text-align: center;
        }
        .stat-card .stat-number {
            font-size: 28px;
            font-weight: 700;
            color: var(--signal);
        }
        .stat-card .stat-label {
            font-size: 12px;
            color: var(--muted);
            margin-top: 2px;
        }

        .empty-activity {
            text-align: center;
            padding: 40px 20px;
            color: var(--muted-dim);
        }
        .empty-activity i {
            font-size: 32px;
            margin-bottom: 8px;
            display: block;
        }
        .empty-activity p {
            font-size: 14px;
        }

        .action-buttons {
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
            margin-top: 16px;
            padding-top: 16px;
            border-top: 1px solid var(--line);
        }
        .btn-save {
            padding: 10px 32px;
            border-radius: 10px;
            border: none;
            background: var(--signal);
            color: var(--ink);
            font-weight: 700;
            font-size: 14px;
            cursor: pointer;
            transition: all 0.2s ease;
            font-family: 'Inter', sans-serif;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }
        .btn-save:hover {
            transform: translateY(-1px);
            box-shadow: 0 4px 18px var(--signal-glow);
        }
        .btn-save:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }
        .btn-cancel {
            padding: 10px 24px;
            border-radius: 10px;
            border: 1px solid var(--line);
            background: transparent;
            color: var(--muted);
            font-weight: 600;
            font-size: 14px;
            cursor: pointer;
            transition: all 0.2s ease;
            font-family: 'Inter', sans-serif;
        }
        .btn-cancel:hover {
            background: var(--panel-hover);
            color: var(--text);
        }

        .unsaved-changes {
            display: none;
            align-items: center;
            gap: 12px;
            padding: 12px 16px;
            background: var(--gold-tab);
            border: 1px solid rgba(245,200,66,0.2);
            border-radius: 10px;
            margin-top: 16px;
        }
        .unsaved-changes.show {
            display: flex;
        }
        .unsaved-changes .warning-icon {
            color: var(--gold);
            font-size: 18px;
        }
        .unsaved-changes .warning-text {
            color: var(--gold);
            font-size: 13px;
            font-weight: 500;
            flex: 1;
        }
        .unsaved-changes .btn-cancel {
            padding: 4px 16px;
            font-size: 12px;
        }
        .unsaved-changes .btn-save {
            padding: 4px 20px;
            font-size: 12px;
        }

        .toast-container {
            position: fixed;
            bottom: 24px;
            right: 24px;
            z-index: 9999;
            display: flex;
            flex-direction: column;
            gap: 10px;
            max-width: 380px;
            width: 100%;
        }
        .toast {
            background: var(--panel);
            border: 1px solid var(--line);
            border-radius: 12px;
            padding: 14px 20px;
            display: flex;
            align-items: center;
            gap: 12px;
            box-shadow: 0 8px 32px rgba(0,0,0,0.4);
            animation: slideIn 0.3s ease;
            backdrop-filter: blur(10px);
            border-left: 4px solid var(--signal);
        }
        .toast .toast-icon { color: var(--signal); font-size: 18px; flex-shrink: 0; }
        .toast .toast-content { flex: 1; font-size: 13px; color: var(--text); line-height: 1.4; }
        .toast .toast-close {
            background: none; border: none;
            color: var(--muted-dim); cursor: pointer;
            font-size: 14px; padding: 4px;
        }
        .toast .toast-close:hover { color: var(--text); }
        .toast.error { border-left-color: var(--red); }
        .toast.error .toast-icon { color: var(--red); }
        .toast.success { border-left-color: var(--signal); }
        .toast.success .toast-icon { color: var(--signal); }
        @keyframes slideIn {
            from { opacity: 0; transform: translateX(40px); }
            to { opacity: 1; transform: translateX(0); }
        }
        @keyframes slideOut {
            from { opacity: 1; transform: translateX(0); }
            to { opacity: 0; transform: translateX(40px); }
        }
        .toast.hiding { animation: slideOut 0.3s ease forwards; }

        .footer {
            border-top: 1px solid var(--line);
            margin-top: 60px;
            padding: 28px 48px;
            text-align: center;
            color: var(--muted-dim);
            font-size: 13px;
            font-family: 'IBM Plex Mono', monospace;
            letter-spacing: 0.5px;
        }

        @media (max-width: 1024px) {
            .page-wrapper { padding: 24px 32px 60px 5px; gap: 24px; }
            .sidebar { width: 240px; }
        }
        @media (max-width: 768px) {
            .navbar { padding: 0 16px; height: 64px; flex-wrap: wrap; }
            .nav-center { display: none; }
            .page-wrapper { padding: 16px; flex-direction: column; }
            .sidebar {
                width: 100%; position: relative; top: 0;
                display: flex; flex-wrap: wrap; gap: 4px; padding: 12px;
                border-radius: 12px; max-height: none; height: auto;
                margin-left: 0;
                border: 1px solid var(--line);
                border-radius: 12px;
            }
            .sidebar .server-info { display: none; }
            .sidebar .nav-section { display: flex; flex-wrap: wrap; gap: 4px; }
            .sidebar .section-title { display: none; }
            .sidebar .nav-item { padding: 6px 14px; font-size: 13px; width: auto; }
            .sidebar .divider { display: none; }
            .stats-grid { grid-template-columns: 1fr 1fr; }
            .footer { padding: 20px 16px; }
            .toast-container { bottom: 16px; right: 16px; max-width: calc(100% - 32px); }
        }
    </style>
</head>
<body>

    <nav class="navbar">
        <a href="/dashboard" class="brand">
            <div class="brand-logo">
                <svg viewBox="0 0 245 240" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M104.4 103.9c-5.7 0-10.2 5-10.2 11.1s4.6 11.1 10.2 11.1c5.7 0 10.2-5 10.2-11.1.1-6.1-4.5-11.1-10.2-11.1zM140.9 103.9c-5.7 0-10.2 5-10.2 11.1s4.6 11.1 10.2 11.1c5.7 0 10.2-5 10.2-11.1s-4.5-11.1-10.2-11.1z" fill="#3DFFB8"/>
                    <path d="M189.5 20H55.5C44.7 20 36 28.7 36 39.5v140.9c0 10.8 8.7 19.5 19.5 19.5h113.5l-5.3-18.5 12.8 11.9 12.1 11.2L209 220V39.5C209 28.7 200.3 20 189.5 20zM155.7 152.1s-3.6-4.3-6.6-8.1c13.1-3.7 18.1-11.9 18.1-11.9-4.1 2.7-8 4.6-11.5 5.9-5 2.1-9.8 3.5-14.5 4.3-9.6 1.8-18.4 1.3-25.9-.1-5.7-1.1-10.6-2.6-14.7-4.3-2.3-.9-4.8-2-7.3-3.4-.3-.2-.6-.3-.9-.5-.2-.1-.3-.2-.4-.3-2-1.1-3.1-1.9-3.1-1.9 4.7 4.3 9.3 6.5 21.7 10.2-2.9 3.8-6.6 8.1-6.6 8.1-22 0-32.1-15.2-32.1-15.2 0-32.2 14.4-58.4 14.4-58.4 14.4-10.8 28.1-10.5 28.1-10.5l1 1.2C99.2 87.7 87.9 97.4 87.9 97.4s2.9-1.6 7.8-3.8c14.1-6.2 25.3-7.9 29.9-8.3.8-.1 1.5-.2 2.3-.2 8.2-1 17.5-1.3 27.2.2 12.9 2 26.7 7.5 40.8 17.3 0 0-10.8-10.2-28.5-13.7l1.4-1.6s13.7-.3 28.1 10.5c0 0 14.4 26.2 14.4 58.4 0 0-10.2 15.2-32.1 15.2z" fill="#3DFFB8"/>
                </svg>
            </div>
            <span class="brand-name">Sentinal</span>
        </a>
        <div class="nav-center">
            <a href="/dashboard">Home</a>
            <a href="/servers" class="active">Servers</a>
            <a href="#" onclick="window.open('https://discord.gg/UmqmewYWRd','_blank'); return false;">Support</a>
            <a href="#">Premium</a>
        </div>
        <div class="nav-right">
            <div class="user-pill">
                <div class="user-avatar">
                    <% if (locals.user && user.avatar) { %>
                        <img src="https://cdn.discordapp.com/avatars/<%= user.id %>/<%= user.avatar %>.png" alt="Avatar">
                    <% } else { %>
                        <%= locals.user ? (user.username ? user.username.charAt(0).toUpperCase() : 'U') : 'U' %>
                    <% } %>
                </div>
                <span class="user-name"><%= locals.user ? (user.global_name || user.username) : 'User' %></span>
                <span class="user-plan">Free</span>
            </div>
            <a href="/logout" class="logout-btn"><i class="fas fa-sign-out-alt"></i></a>
        </div>
    </nav>

    <div class="toast-container" id="toastContainer"></div>

    <div class="page-wrapper">

        <!-- ─── LEFT SIDEBAR ─── -->
        <aside class="sidebar">
            <div class="server-info">
                <div class="icon">
                    <% if (locals.guild && guild.icon) { %>
                        <img src="https://cdn.discordapp.com/icons/<%= guild.id %>/<%= guild.icon %>.png" alt="<%= guild.name %>">
                    <% } else { %>
                        <%= locals.guild ? (guild.name ? guild.name.charAt(0).toUpperCase() : '?') : '?' %>
                    <% } %>
                </div>
                <div class="name"><%= locals.guild ? guild.name : 'Server' %></div>
                <div class="plan">Free</div>
                <a href="#" class="upgrade" onclick="showToast('Upgrade to Premium!', 'info')">Upgrade to Premium</a>
            </div>

            <div class="nav-section">
                <div class="section-title">Modules</div>
                <a href="/servers/<%= locals.guild ? guild.id : '' %>" class="nav-item">
                    <i class="fas fa-th-large"></i> Overview
                </a>
                <a href="/servers/<%= locals.guild ? guild.id : '' %>/automation" class="nav-item active">
                    <i class="fas fa-robot"></i> Automation
                    <span class="badge new">New</span>
                </a>
                <a href="/servers/<%= locals.guild ? guild.id : '' %>/security" class="nav-item">
                    <i class="fas fa-shield-halved"></i> Security
                    <span class="badge live">Live</span>
                </a>
                <a href="/servers/<%= locals.guild ? guild.id : '' %>/community" class="nav-item">
                    <i class="fas fa-users"></i> Community
                    <span class="badge new">New</span>
                </a>
                <a href="/servers/<%= locals.guild ? guild.id : '' %>/audit" class="nav-item">
                    <i class="fas fa-clipboard-list"></i> Audit & Logs
                </a>
            </div>

            <div class="divider"></div>

            <div class="nav-section">
                <div class="section-title">Support</div>
                <button class="nav-item" onclick="showToast('Support server coming soon!', 'info')">
                    <i class="fas fa-headset"></i> Support Server
                </button>
            </div>
        </aside>

        <!-- ─── RIGHT CONTENT ─── -->
        <div class="content">

            <!-- Status Bar -->
            <div class="status-bar">
                <span class="dot">●</span>
                <span class="text">All Systems Operational</span>
                <span class="time"><%= new Date().toLocaleString() %></span>
            </div>

            <div class="page-header">
                <div>
                    <h1>Auto Roles</h1>
                    <p>Automatically assign roles to users when they join your server</p>
                </div>
            </div>

            <!-- ============================================================ -->
            <!-- GLOBAL SETTINGS -->
            <!-- ============================================================ -->
            <div class="section-card">
                <div class="section-header">
                    <h3>Global Settings</h3>
                    <span class="badge">Live</span>
                </div>
                <div class="section-desc">Settings that will be applied to all configured auto roles</div>

                <div class="form-group">
                    <div class="toggle-wrapper">
                        <button class="toggle" type="button" role="switch" aria-checked="false" onclick="toggleSwitch(this)" id="enabled">
                            <span class="toggle-slider"></span>
                        </button>
                        <span>Enabled</span>
                    </div>
                    <div class="form-hint">Toggle automatic role assignment for all auto roles</div>
                </div>

                <div class="form-group">
                    <div class="toggle-wrapper">
                        <button class="toggle active" type="button" role="switch" aria-checked="true" onclick="toggleSwitch(this)" id="ignoreBots">
                            <span class="toggle-slider"></span>
                        </button>
                        <span>Ignore Bots</span>
                    </div>
                    <div class="form-hint">Ignore bots when assigning roles</div>
                </div>
            </div>

            <!-- ============================================================ -->
            <!-- AUTOROLES -->
            <!-- ============================================================ -->
            <div class="section-card">
                <div class="section-header">
                    <h3>Autoroles</h3>
                    <span class="badge">Live</span>
                </div>
                <div class="section-desc">Settings for the auto roles configuration</div>

                <!-- Stats -->
                <div class="stats-grid">
                    <div class="stat-card">
                        <div class="stat-number" id="roleCount">0</div>
                        <div class="stat-label">Autoroles</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-number" id="roleSlots">0 / 2</div>
                        <div class="stat-label">Role slots used</div>
                    </div>
                </div>

                <!-- Role Selector -->
                <div class="form-group">
                    <label>Add a role...</label>
                    <div style="position:relative;">
                        <div class="role-select-wrapper" onclick="toggleRoleDropdown()">
                            <div id="selectedRoles">
                                <!-- Selected roles will appear here as tags -->
                            </div>
                            <input type="text" id="roleSearch" placeholder="Only roles without administrative permissions will be displayed." oninput="filterRoles(this.value)">
                            <div class="role-dropdown" id="roleDropdown">
                                <!-- Roles will be populated here -->
                            </div>
                        </div>
                    </div>
                    <div class="form-hint">Only roles without administrative permissions will be displayed.</div>
                </div>
            </div>

            <!-- ============================================================ -->
            <!-- RECENT ACTIVITY -->
            <!-- ============================================================ -->
            <div class="section-card">
                <div class="section-header">
                    <h3>Recent Activity</h3>
                    <span class="badge">Live</span>
                </div>
                <div class="section-desc">Recent activity for the auto roles configuration</div>

                <div class="empty-activity">
                    <i class="fas fa-users"></i>
                    <p>No activity yet<br><span style="font-size:12px;color:var(--muted-dim);">When new members join and receive auto roles, they will appear here</span></p>
                </div>
            </div>

            <!-- ============================================================ -->
            <!-- UNSAVED CHANGES -->
            <!-- ============================================================ -->
            <div class="unsaved-changes" id="unsavedChanges">
                <span class="warning-icon">⚠️</span>
                <span class="warning-text">You have unsaved changes!</span>
                <button class="btn-cancel" onclick="cancelChanges()">Cancel</button>
                <button class="btn-save" onclick="saveChanges()">Save</button>
            </div>

            <!-- ============================================================ -->
            <!-- ACTIONS -->
            <!-- ============================================================ -->
            <div class="action-buttons">
                <button class="btn-save" onclick="saveChanges()">
                    <i class="fas fa-save"></i> Save
                </button>
                <button class="btn-cancel" onclick="cancelChanges()">
                    Cancel
                </button>
            </div>

        </div>
    </div>

    <footer class="footer">
        © 2026 SENTINAL — STATUS: OPERATIONAL
    </footer>

    <script>
        // ============ State ============
        let selectedRoles = [];
        let allRoles = [];
        let hasUnsavedChanges = false;

        // ============ Toggle Switch ============
        function toggleSwitch(el) {
            el.classList.toggle('active');
            const isOn = el.classList.contains('active');
            el.setAttribute('aria-checked', String(isOn));
            showUnsavedChanges();
        }

        // ============ Role Dropdown ============
        function toggleRoleDropdown() {
            const dropdown = document.getElementById('roleDropdown');
            dropdown.classList.toggle('open');
            if (dropdown.classList.contains('open')) {
                document.getElementById('roleSearch').focus();
            }
        }

        function filterRoles(query) {
            const options = document.querySelectorAll('.role-option');
            options.forEach(opt => {
                const name = opt.textContent.trim().toLowerCase();
                opt.style.display = name.includes(query.toLowerCase()) ? 'flex' : 'none';
            });
        }

        function addRole(roleId, roleName, color) {
            if (selectedRoles.length >= 2) {
                showToast('Maximum 2 roles allowed.', 'error');
                return;
            }
            if (selectedRoles.find(r => r.id === roleId)) {
                showToast('Role already added.', 'error');
                return;
            }
            selectedRoles.push({ id: roleId, name: roleName, color: color });
            updateSelectedRoles();
            document.getElementById('roleDropdown').classList.remove('open');
            document.getElementById('roleSearch').value = '';
            showUnsavedChanges();
            updateStats();
        }

        function removeRole(roleId) {
            selectedRoles = selectedRoles.filter(r => r.id !== roleId);
            updateSelectedRoles();
            showUnsavedChanges();
            updateStats();
        }

        function updateSelectedRoles() {
            const container = document.getElementById('selectedRoles');
            container.innerHTML = '';
            selectedRoles.forEach(role => {
                const tag = document.createElement('span');
                tag.className = 'role-tag';
                tag.dataset.roleId = role.id;
                tag.innerHTML = `
                    <span class="role-dot" style="background-color:${role.color};"></span>
                    ${role.name}
                    <button class="remove-role" onclick="removeRole('${role.id}')">×</button>
                `;
                container.appendChild(tag);
            });
            updateStats();
        }

        function updateStats() {
            document.getElementById('roleCount').textContent = selectedRoles.length;
            document.getElementById('roleSlots').textContent = `${selectedRoles.length} / 2`;
        }

        // ============ Unsaved Changes ============
        function showUnsavedChanges() {
            hasUnsavedChanges = true;
            document.getElementById('unsavedChanges').classList.add('show');
        }

        function hideUnsavedChanges() {
            hasUnsavedChanges = false;
            document.getElementById('unsavedChanges').classList.remove('show');
        }

        function cancelChanges() {
            // Reload from database
            loadAutoRoles();
            hideUnsavedChanges();
            showToast('Changes cancelled.', 'info');
        }

        // ============ Save Changes ============
        function saveChanges() {
            const enabled = document.getElementById('enabled').classList.contains('active');
            const ignoreBots = document.getElementById('ignoreBots').classList.contains('active');
            
            // Get selected role IDs from the DOM
            const roleTags = document.querySelectorAll('#selectedRoles .role-tag');
            const roles = [];
            roleTags.forEach(tag => {
                const roleId = tag.dataset.roleId;
                if (roleId) roles.push(roleId);
            });
            
            const data = {
                autoRoles: {
                    enabled: enabled,
                    ignoreBots: ignoreBots,
                    roles: roles,
                    maxRoles: 2
                }
            };

            // Log what we're saving
            console.log('Saving auto roles:', data);

            const saveBtn = document.querySelector('.action-buttons .btn-save');
            saveBtn.disabled = true;
            saveBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Saving...';

            fetch(`/api/config/<%= locals.guild ? guild.id : "" %>`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            })
            .then(response => response.json())
            .then(data => {
                console.log('Save response:', data);
                if (data.success) {
                    hideUnsavedChanges();
                    showToast('✅ Auto roles settings saved!', 'success');
                    // Reload the settings after save to ensure UI matches database
                    setTimeout(() => loadAutoRoles(), 500);
                } else {
                    showToast('❌ Error: ' + data.error, 'error');
                }
                saveBtn.disabled = false;
                saveBtn.innerHTML = '<i class="fas fa-save"></i> Save';
            })
            .catch(error => {
                console.error('Save error:', error);
                showToast('❌ Error: ' + error.message, 'error');
                saveBtn.disabled = false;
                saveBtn.innerHTML = '<i class="fas fa-save"></i> Save';
            });
        }

        // ============ Load Auto Roles from Database ============
        async function loadAutoRoles() {
            const guildId = '<%= locals.guild ? guild.id : "" %>';
            try {
                const response = await fetch(`/api/config/${guildId}`);
                const data = await response.json();
                
                console.log('Loaded config:', data);
                
                if (data.success && data.config) {
                    // Check if autoRoles exists
                    const autoRoles = data.config.autoRoles;
                    
                    if (autoRoles) {
                        // Set enabled toggle
                        if (autoRoles.enabled) {
                            document.getElementById('enabled').classList.add('active');
                            document.getElementById('enabled').setAttribute('aria-checked', 'true');
                        } else {
                            document.getElementById('enabled').classList.remove('active');
                            document.getElementById('enabled').setAttribute('aria-checked', 'false');
                        }
                        
                        // Set ignore bots toggle
                        if (autoRoles.ignoreBots) {
                            document.getElementById('ignoreBots').classList.add('active');
                            document.getElementById('ignoreBots').setAttribute('aria-checked', 'true');
                        } else {
                            document.getElementById('ignoreBots').classList.remove('active');
                            document.getElementById('ignoreBots').setAttribute('aria-checked', 'false');
                        }
                        
                        // Load roles
                        const roleIds = autoRoles.roles || [];
                        if (roleIds.length > 0) {
                            // Fetch role names from Discord API
                            const rolesResponse = await fetch(`/api/servers/${guildId}/roles`);
                            const rolesData = await rolesResponse.json();
                            
                            if (rolesData.success && rolesData.roles) {
                                selectedRoles = [];
                                roleIds.forEach(id => {
                                    const role = rolesData.roles.find(r => r.id === id);
                                    if (role) {
                                        const colorHex = role.color ? '#' + role.color.toString(16).padStart(6, '0') : '#6C7A90';
                                        selectedRoles.push({
                                            id: role.id,
                                            name: role.name,
                                            color: colorHex
                                        });
                                    }
                                });
                                updateSelectedRoles();
                                updateStats();
                            }
                        } else {
                            selectedRoles = [];
                            updateSelectedRoles();
                            updateStats();
                        }
                    } else {
                        // No autoRoles field, set defaults
                        console.log('No autoRoles field found, using defaults');
                        document.getElementById('enabled').classList.remove('active');
                        document.getElementById('ignoreBots').classList.add('active');
                        selectedRoles = [];
                        updateSelectedRoles();
                        updateStats();
                    }
                    
                    hideUnsavedChanges();
                } else {
                    console.log('No config data found, using defaults');
                    document.getElementById('enabled').classList.remove('active');
                    document.getElementById('ignoreBots').classList.add('active');
                    selectedRoles = [];
                    updateSelectedRoles();
                    updateStats();
                    hideUnsavedChanges();
                }
            } catch (error) {
                console.error('Error loading auto roles:', error);
                showToast('Error loading settings', 'error');
            }
        }

        // ============ Fetch Roles from Discord ============
        async function fetchRoles() {
            const guildId = '<%= locals.guild ? guild.id : "" %>';
            const dropdown = document.getElementById('roleDropdown');
            
            try {
                const response = await fetch(`/api/servers/${guildId}/roles`);
                const data = await response.json();

                if (data.success && data.roles && data.roles.length > 0) {
                    allRoles = data.roles;
                    dropdown.innerHTML = '';
                    
                    data.roles.forEach(role => {
                        const div = document.createElement('div');
                        div.className = 'role-option';
                        const colorHex = role.color ? '#' + role.color.toString(16).padStart(6, '0') : '#6C7A90';
                        div.innerHTML = `
                            <span class="role-color-dot" style="background-color:${colorHex};"></span>
                            @${role.name}
                        `;
                        div.onclick = function(e) {
                            e.stopPropagation();
                            addRole(role.id, role.name, colorHex);
                        };
                        dropdown.appendChild(div);
                    });
                } else {
                    dropdown.innerHTML = '<div style="padding:12px;text-align:center;color:var(--muted-dim);">No roles found</div>';
                }
            } catch (error) {
                console.error('Error fetching roles:', error);
                dropdown.innerHTML = '<div style="padding:12px;text-align:center;color:var(--muted-dim);">Error loading roles</div>';
            }
        }

        // ============ Toast Notifications ============
        function showToast(message, type = 'info') {
            const container = document.getElementById('toastContainer');
            const toast = document.createElement('div');
            toast.className = 'toast ' + type;
            toast.innerHTML = `
                <span class="toast-icon"><i class="fas fa-${type === 'success' ? 'check-circle' : 'exclamation-circle'}"></i></span>
                <span class="toast-content">${message}</span>
                <button class="toast-close" onclick="this.closest('.toast').classList.add('hiding'); setTimeout(() => this.closest('.toast').remove(), 300);">
                    <i class="fas fa-times"></i>
                </button>
            `;
            container.appendChild(toast);
            setTimeout(() => {
                if (toast.parentNode) {
                    toast.classList.add('hiding');
                    setTimeout(() => { if (toast.parentNode) toast.remove(); }, 300);
                }
            }, 4000);
        }

        // ============ Close dropdown on outside click ============
        document.addEventListener('click', function(event) {
            const wrapper = document.querySelector('.role-select-wrapper');
            if (wrapper && !wrapper.contains(event.target)) {
                document.getElementById('roleDropdown').classList.remove('open');
            }
        });

        // ============ Initialize ============
        document.addEventListener('DOMContentLoaded', async function() {
            // Load saved auto roles from database
            await loadAutoRoles();
            
            // Fetch roles from Discord
            await fetchRoles();
            
            // Update stats
            updateStats();
        });

        // Make functions globally accessible
        window.toggleSwitch = toggleSwitch;
        window.toggleRoleDropdown = toggleRoleDropdown;
        window.filterRoles = filterRoles;
        window.addRole = addRole;
        window.removeRole = removeRole;
        window.showUnsavedChanges = showUnsavedChanges;
        window.cancelChanges = cancelChanges;
        window.saveChanges = saveChanges;
        window.showToast = showToast;
        window.loadAutoRoles = loadAutoRoles;
    </script>

</body>
</html>
