// Add this to your DOMContentLoaded event
document.addEventListener('DOMContentLoaded', async function() {
    // ... existing code ...
    
    // Load saved auto roles from database
    const guildId = '<%= locals.guild ? guild.id : "" %>';
    try {
        const response = await fetch(`/api/config/${guildId}`);
        const data = await response.json();
        
        if (data.success && data.config && data.config.autoRoles) {
            // Set enabled toggle
            if (data.config.autoRoles.enabled) {
                document.getElementById('enabled').classList.add('active');
            } else {
                document.getElementById('enabled').classList.remove('active');
            }
            
            // Set ignore bots toggle
            if (data.config.autoRoles.ignoreBots) {
                document.getElementById('ignoreBots').classList.add('active');
            } else {
                document.getElementById('ignoreBots').classList.remove('active');
            }
            
            // Load roles
            selectedRoles = data.config.autoRoles.roles || [];
            // You'll need to fetch role names from Discord API
            // or store them with the role IDs
            updateSelectedRoles();
        }
    } catch (error) {
        console.error('Error loading auto roles:', error);
    }
});
