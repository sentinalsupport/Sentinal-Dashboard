<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title || 'Applications — Sentinal' %></title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@400;500;600;700;800&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --ink: #060A10;
            --panel: #0D1520;
            --panel-raised: #111D2C;
            --panel-hover: #162033;
            --line: rgba(255,255,255,0.07);
            --line-bright: rgba(255,255,255,0.13);
            --text: #E6EDF6;
            --muted: #6C7A90;
            --muted-dim: #3E4A5C;
            --signal: #3DFFB8;
            --signal-tab: rgba(61,255,184,0.10);
            --signal-glow: rgba(61,255,184,0.15);
            --gold: #F5C842;
            --gold-tab: rgba(245,200,66,0.12);
            --violet: #8B7EFF;
            --violet-tab: rgba(139,126,255,0.12);
            --red: #F87171;
            --red-bg: rgba(248,113,113,0.08);
            --red-border: rgba(248,113,113,0.22);
            --discord: #5865F2;
        }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Inter', -apple-system, sans-serif;
            background: var(--ink);
            color: var(--text);
            min-height: 100vh;
        }

        /* ─── NAVBAR ─── */
        .navbar {
            background: rgba(6,10,16,0.9);
            backdrop-filter: blur(28px) saturate(160%);
            border-bottom: 1px solid var(--line);
            padding: 0 40px;
            height: 64px;
            display: flex; align-items: center; justify-content: space-between;
            position: sticky; top: 0; z-index: 200;
        }
        .brand { display: flex; align-items: center; gap: 10px; text-decoration: none; }
        .brand-logo {
            width: 36px; height: 36px; border-radius: 10px;
            background: var(--panel-raised); border: 1px solid var(--line-bright);
            display: flex; align-items: center; justify-content: center;
        }
        .brand-logo svg { width: 20px; height: 20px; }
        .brand-name {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 17px; font-weight: 700; color: #fff; letter-spacing: -0.3px;
        }
        .nav-center { display: flex; align-items: center; gap: 4px; }
        .nav-center a {
            color: var(--muted); text-decoration: none; font-size: 13.5px; font-weight: 500;
            padding: 6px 14px; border-radius: 8px; transition: all 0.18s ease;
        }
        .nav-center a:hover { color: var(--text); background: rgba(255,255,255,0.05); }
        .nav-center a.active { color: #fff; }
        .nav-right { display: flex; align-items: center; gap: 12px; }
        .user-pill {
            display: flex; align-items: center; gap: 9px;
            background: var(--panel); border: 1px solid var(--line);
            border-radius: 100px; padding: 5px 14px 5px 6px;
        }
        .user-avatar {
            width: 28px; height: 28px; border-radius: 50%;
            background: var(--panel-raised); overflow: hidden;
            display: flex; align-items: center; justify-content: center;
            font-size: 12px; font-weight: 700;
        }
        .user-avatar img { width: 100%; height: 100%; object-fit: cover; }
        .user-name { font-size: 13px; font-weight: 500; color: var(--text); }
        .user-plan {
            font-size: 10px; font-weight: 600; color: var(--signal);
            background: var(--signal-tab); border: 1px solid rgba(61,255,184,0.22);
            border-radius: 100px; padding: 2px 8px; letter-spacing: 0.3px;
        }
        .logout-btn {
            background: transparent; border: 1px solid var(--line); border-radius: 8px;
            padding: 7px 12px; color: var(--muted); cursor: pointer; font-size: 13px;
            transition: all 0.18s ease; text-decoration: none;
            display: flex; align-items: center; gap: 6px;
        }
        .logout-btn:hover { background: var(--red-bg); border-color: var(--red-border); color: var(--red); }

        /* ─── PAGE ─── */
        .page-wrapper { max-width: 1200px; margin: 0 auto; padding: 0 32px 60px; }

        /* ─── PAGE HEADER ─── */
        .page-header {
            display: flex; justify-content: space-between; align-items: center;
            padding: 28px 0 20px;
            border-bottom: 1px solid var(--line);
            margin-bottom: 28px;
            flex-wrap: wrap;
            gap: 16px;
        }
        .page-header .left h1 {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 24px; font-weight: 700; color: #fff;
        }
        .page-header .left p {
            font-size: 13px; color: var(--muted);
        }
        .page-header .actions { display: flex; gap: 10px; flex-wrap: wrap; }
        .btn-primary {
            padding: 10px 24px; border-radius: 10px;
            background: var(--signal); color: #04140F;
            border: none; font-weight: 700; font-size: 13px;
            cursor: pointer; transition: all 0.18s ease;
            text-decoration: none; display: inline-flex; align-items: center; gap: 8px;
        }
        .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 4px 18px var(--signal-glow); }
        .btn-secondary {
            padding: 10px 24px; border-radius: 10px;
            background: transparent; color: var(--muted);
            border: 1px solid var(--line); font-weight: 600; font-size: 13px;
            cursor: pointer; transition: all 0.18s ease;
            text-decoration: none; display: inline-flex; align-items: center; gap: 8px;
        }
        .btn-secondary:hover { background: rgba(255,255,255,0.04); color: var(--text); }

        /* ─── LAYOUT ─── */
        .settings-layout {
            display: grid;
            grid-template-columns: 220px 1fr;
            gap: 32px;
            align-items: start;
        }

        /* ─── SIDEBAR ─── */
        .settings-sidebar {
            background: var(--panel);
            border: 1px solid var(--line);
            border-radius: 14px;
            padding: 12px 0;
            position: sticky;
            top: 80px;
        }
        .settings-sidebar .nav-item {
            display: flex; align-items: center; gap: 10px;
            padding: 10px 16px; border-radius: 8px;
            color: var(--muted); text-decoration: none;
            font-size: 13px; font-weight: 500;
            transition: all 0.18s ease; cursor: pointer; border: none;
            background: none; width: 100%; text-align: left;
        }
        .settings-sidebar .nav-item:hover {
            background: rgba(255,255,255,0.04); color: var(--text);
        }
        .settings-sidebar .nav-item.active {
            background: var(--signal-tab); color: var(--signal);
        }
        .settings-sidebar .nav-item i {
            width: 18px; font-size: 14px;
        }
        .settings-sidebar .nav-item .badge {
            margin-left: auto; font-size: 9px; font-weight: 700;
            padding: 2px 8px; border-radius: 100px;
            background: var(--signal-tab); color: var(--signal);
        }

        /* ─── PANEL CONTENT ─── */
        .panel-content {
            display: none;
            animation: fadeIn 0.25s ease;
        }
        .panel-content.active {
            display: block;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(6px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* ─── SECTION CARDS ─── */
        .section-card {
            background: var(--panel);
            border: 1px solid var(--line);
            border-radius: 12px;
            padding: 24px;
            margin-bottom: 16px;
        }
        .section-card .section-header {
            display: flex; justify-content: space-between; align-items: center;
            margin-bottom: 12px; flex-wrap: wrap; gap: 8px;
        }
        .section-card .section-header h3 {
            font-size: 15px; font-weight: 600; color: #fff;
        }
        .section-card .section-header .toggle-wrapper {
            display: flex; align-items: center; gap: 10px;
        }
        .toggle {
            width: 44px; height: 24px;
            background: var(--muted-dim); border-radius: 12px;
            cursor: pointer; transition: all 0.3s ease;
            position: relative;
        }
        .toggle.active { background: var(--signal); }
        .toggle .toggle-slider {
            width: 18px; height: 18px;
            background: #fff; border-radius: 50%;
            position: absolute; top: 3px; left: 3px;
            transition: all 0.3s ease;
        }
        .toggle.active .toggle-slider { left: 23px; }
        .toggle-label { font-size: 13px; color: var(--text); font-weight: 500; }

        .section-card .section-desc {
            font-size: 13px; color: var(--muted);
            margin-bottom: 16px;
        }

        .form-group { margin-bottom: 14px; }
        .form-group:last-child { margin-bottom: 0; }
        .form-group label {
            display: block; font-size: 12px; font-weight: 600;
            margin-bottom: 4px; color: var(--text);
        }
        .form-group .form-hint {
            font-size: 11px; color: var(--muted-dim); margin-top: 2px;
        }
        .form-group input, .form-group select, .form-group textarea {
            width: 100%; padding: 9px 14px;
            border-radius: 8px; border: 1px solid var(--line);
            background: rgba(0,0,0,0.3); color: var(--text);
            font-size: 13px; font-family: 'Inter', sans-serif;
            transition: all 0.18s ease; outline: none;
        }
        .form-group textarea {
            resize: vertical; min-height: 80px;
        }
        .form-group input:focus, .form-group select:focus, .form-group textarea:focus {
            border-color: var(--signal);
            box-shadow: 0 0 0 3px var(--signal-glow);
        }
        .form-group select option { background: var(--ink); }
        .form-group .channel-select {
            display: flex; gap: 8px; align-items: center;
        }
        .form-group .channel-select input { flex: 1; }

        .form-actions {
            display: flex; gap: 10px; flex-wrap: wrap; margin-top: 16px;
        }
        .btn-save {
            padding: 8px 28px; border-radius: 8px; border: none;
            font-weight: 600; font-size: 13px; cursor: pointer;
            background: var(--signal); color: #04140F;
            transition: all 0.18s ease;
        }
        .btn-save:hover { transform: translateY(-1px); box-shadow: 0 4px 18px var(--signal-glow); }

        .btn-danger {
            padding: 8px 28px; border-radius: 8px; border: none;
            font-weight: 600; font-size: 13px; cursor: pointer;
            background: var(--red); color: #fff;
            transition: all 0.18s ease;
        }
        .btn-danger:hover { transform: translateY(-1px); box-shadow: 0 4px 18px rgba(248,113,113,0.3); }

        /* ─── QUESTIONS SECTION ─── */
        .question-item {
            background: var(--panel-raised);
            border: 1px solid var(--line);
            border-radius: 10px;
            padding: 16px 20px;
            margin-bottom: 12px;
            display: flex;
            align-items: center;
            gap: 16px;
        }
        .question-item .q-number {
            font-size: 12px; font-weight: 700; color: var(--muted);
            min-width: 30px;
        }
        .question-item .q-text {
            flex: 1; font-weight: 500;
        }
        .question-item .q-type {
            font-size: 11px; color: var(--muted);
            background: var(--panel); padding: 2px 10px;
            border-radius: 100px; border: 1px solid var(--line);
        }
        .question-item .q-actions {
            display: flex; gap: 6px;
        }
        .question-item .q-actions button {
            background: none; border: none; color: var(--muted);
            cursor: pointer; padding: 4px 8px; border-radius: 6px;
            transition: all 0.18s ease;
        }
        .question-item .q-actions button:hover {
            background: rgba(255,255,255,0.04); color: var(--text);
        }
        .question-item .q-actions button.danger:hover {
            background: var(--red-bg); color: var(--red);
        }

        /* ─── PREMIUM BANNER ─── */
        .premium-banner {
            background: var(--gold-tab);
            border: 1px solid rgba(245,200,66,0.2);
            border-radius: 10px;
            padding: 16px 20px;
            display: flex; align-items: center; justify-content: space-between;
            flex-wrap: wrap; gap: 12px;
        }
        .premium-banner p {
            font-size: 13px; color: var(--gold);
        }
        .premium-banner p i { margin-right: 8px; }
        .premium-banner .btn-upgrade {
            padding: 6px 18px; border-radius: 8px;
            background: var(--gold); color: #04140F;
            border: none; font-weight: 700; font-size: 12px;
            cursor: pointer; transition: all 0.18s ease;
        }
        .premium-banner .btn-upgrade:hover { transform: scale(1.05); }

        .coming-soon {
            text-align: center; padding: 40px 20px;
            color: var(--muted);
        }
        .coming-soon i {
            font-size: 32px; color: var(--gold); margin-bottom: 12px; display: block;
        }
        .coming-soon h3 {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 17px; color: #fff; margin-bottom: 4px;
        }
        .coming-soon p { font-size: 13px; }

        .footer {
            border-top: 1px solid var(--line); margin-top: 60px;
            padding: 24px 40px; text-align: center;
            color: var(--muted-dim); font-size: 12px;
            font-family: 'IBM Plex Mono', monospace; letter-spacing: 0.5px;
        }

        @media (max-width: 768px) {
            .navbar { padding: 0 16px; }
            .nav-center { display: none; }
            .page-wrapper { padding: 0 16px 48px; }
            .settings-layout { grid-template-columns: 1fr; }
            .settings-sidebar {
                position: relative; top: 0;
                display: flex; flex-wrap: wrap; gap: 4px; padding: 12px;
                border-radius: 12px;
            }
            .settings-sidebar .nav-item { padding: 6px 12px; font-size: 12px; width: auto; }
            .section-card { padding: 16px; }
            .question-item { flex-wrap: wrap; }
            .page-header { flex-direction: column; align-items: stretch; }
            .page-header .actions { flex-direction: column; }
            .page-header .actions .btn-primary, .page-header .actions .btn-secondary {
                width: 100%; justify-content: center;
            }
        }
    </style>
</head>
<body>

    <!-- ─── NAVBAR ─── -->
    <nav class="navbar">
        <a href="/dashboard" class="brand">
            <div class="brand-logo">
                <svg viewBox="0 0 245 240" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M104.4 103.9c-5.7 0-10.2 5-10.2 11.1s4.6 11.1 10.2 11.1c5.7 0 10.2-5 10.2-11.1.1-6.1-4.5-11.1-10.2-11.1zM140.9 103.9c-5.7 0-10.2 5-10.2 11.1s4.6 11.1 10.2 11.1c5.7 0 10.2-5 10.2-11.1s-4.5-11.1-10.2-11.1z" fill="#3DFFB8"/>
                    <path d="M189.5 20H55.5C44.7 20 36 28.7 36 39.5v140.9c0 10.8 8.7 19.5 19.5 19.5h113.5l-5.3-18.5 12.8 11.9 12.1 11.2L209 220V39.5C209 28.7 200.3 20 189.5 20zM155.7 152.1s-3.6-4.3-6.6-8.1c13.1-3.7 18.1-11.9 18.1-11.9-4.1 2.7-8 4.6-11.5 5.9-5 2.1-9.8 3.5-14.5 4.3-9.6 1.8-18.4 1.3-25.9-.1-5.7-1.1-10.6-2.6-14.7-4.3-2.3-.9-4.8-2-7.3-3.4-.3-.2-.6-.3-.9-.5-.2-.1-.3-.2-.4-.3-2-1.1-3.1-1.9-3.1-1.9 4.7 4.3 9.3 6.5 21.7 10.2-2.9 3.8-6.6 8.1-6.6 8.1-22 0-32.1-15.2-32.1-15.2 0-32.2 14.4-58.4 14.4-58.4 14.4-10.8 28.1-10.5 28.1-10.5l1 1.2C99.2 87.7 87.9 97.4 87.9 97.4s2.9-1.6 7.8-3.8c14.1-6.2 25.3-7.9 29.9-8.3.8-.1 1.5-.2 2.3-.2 8.2-1 17.5-1.3 27.2.2 12.9 2 26.7 7.5 40.8 17.3 0 0-10.8-10.2-28.5-13.7l1.4-1.6s13.7-.3 28.1 10.5c0 0 14.4 26.2 14.4 58.4 0 0-10.2 15.2-32.1 15.2z" fill="#3DFFB8"/>
                </svg>
            </div>
            <span class="brand-name">Sentinal</span>
        </a>
        <div class="nav-center">
            <a href="/dashboard">Home</a>
            <a href="/servers">Servers</a>
            <a href="#" onclick="window.open('https://discord.gg/UmqmewYWRd','_blank'); return false;">Support</a>
            <a href="#">Premium</a>
        </div>
        <div class="nav-right">
            <div class="user-pill">
                <div class="user-avatar">
                    <% if (locals.user && user.avatar) { %>
                        <img src="https://cdn.discordapp.com/avatars/<%= user.id %>/<%= user.avatar %>.png" alt="Avatar">
                    <% } else { %>
                        <%= locals.user ? (user.username ? user.username.charAt(0).toUpperCase() : 'U') : 'U' %>
                    <% } %>
                </div>
                <span class="user-name"><%= locals.user ? (user.global_name || user.username) : 'User' %></span>
                <span class="user-plan">Free</span>
            </div>
            <a href="/logout" class="logout-btn"><i class="fas fa-sign-out-alt"></i></a>
        </div>
    </nav>

    <!-- ─── PAGE ─── -->
    <div class="page-wrapper">

        <!-- ─── PAGE HEADER ─── -->
        <div class="page-header">
            <div class="left">
                <h1><i class="fas fa-file-alt" style="color:var(--signal); margin-right:10px;"></i> <span id="appName">jkjk</span></h1>
                <p>Configure your application settings below.</p>
            </div>
            <div class="actions">
                <a href="#" class="btn-secondary"><i class="fas fa-sync-alt"></i> Refresh</a>
                <a href="#" class="btn-secondary"><i class="fas fa-download"></i> Download Submissions</a>
            </div>
        </div>

        <!-- ─── SETTINGS LAYOUT ─── -->
        <div class="settings-layout">

            <!-- ─── SIDEBAR ─── -->
            <aside class="settings-sidebar">
                <button class="nav-item active" onclick="showPanel('requirements')">
                    <i class="fas fa-list-check"></i> Requirements
                </button>
                <button class="nav-item" onclick="showPanel('embed')">
                    <i class="fas fa-palette"></i> Embed Customization
                </button>
                <button class="nav-item" onclick="showPanel('roles')">
                    <i class="fas fa-user-tag"></i> Role Config
                </button>
                <button class="nav-item" onclick="showPanel('other')">
                    <i class="fas fa-cog"></i> Other
                </button>
                <button class="nav-item" onclick="showPanel('questions')">
                    <i class="fas fa-question-circle"></i> Questions
                    <span class="badge">2</span>
                </button>
            </aside>

            <!-- ─── CONTENT ─── -->

            <!-- ─── REQUIREMENTS PANEL ─── -->
            <div class="panel-content active" id="panel-requirements">

                <!-- Enabled Toggle -->
                <div class="section-card">
                    <div class="section-header">
                        <h3>Enabled</h3>
                        <div class="toggle-wrapper">
                            <div class="toggle active" id="enabledToggle" onclick="toggleSwitch(this)">
                                <div class="toggle-slider"></div>
                            </div>
                            <span class="toggle-label">Toggle the application status to open or close it.</span>
                        </div>
                    </div>
                    <p class="section-desc">Closed applications will not be able to receive submissions.</p>
                </div>

                <!-- Application Name -->
                <div class="section-card">
                    <div class="section-header">
                        <h3>Application name</h3>
                    </div>
                    <p class="section-desc">The name of the application.</p>
                    <div class="form-group">
                        <input type="text" id="appNameInput" value="jkjk" placeholder="Application Name">
                    </div>
                </div>

                <!-- Pending Submission Channel -->
                <div class="section-card">
                    <div class="section-header">
                        <h3>Pending Submission Channel</h3>
                    </div>
                    <p class="section-desc">The channel that application submissions will be sent to when they are pending review. It is recommended to make sure the channel can only be viewed by staff.</p>
                    <div class="form-group">
                        <div class="channel-select">
                            <input type="text" id="pendingChannel" placeholder="Select a channel" value="#pending-applications">
                            <button class="btn-secondary" style="padding:8px 16px; white-space:nowrap;" onclick="alert('Channel selector coming soon!')">Select</button>
                        </div>
                    </div>
                </div>

                <!-- Accepted Submission Channel -->
                <div class="section-card">
                    <div class="section-header">
                        <h3>Accepted Submission Channel</h3>
                    </div>
                    <p class="section-desc">The channel that application submissions will be sent to when they are accepted. It is recommended to make sure the channel can only be viewed by staff.</p>
                    <div class="form-group">
                        <div class="channel-select">
                            <input type="text" id="acceptedChannel" placeholder="Select a channel" value="#accepted-applications">
                            <button class="btn-secondary" style="padding:8px 16px; white-space:nowrap;" onclick="alert('Channel selector coming soon!')">Select</button>
                        </div>
                    </div>
                </div>

                <!-- Denied Submission Channel -->
                <div class="section-card">
                    <div class="section-header">
                        <h3>Denied Submission Channel</h3>
                    </div>
                    <p class="section-desc">The channel that application submissions will be sent to when they are denied. It is recommended to make sure the channel can only be viewed by staff.</p>
                    <div class="form-group">
                        <div class="channel-select">
                            <input type="text" id="deniedChannel" placeholder="Select a channel" value="#denied-applications">
                            <button class="btn-secondary" style="padding:8px 16px; white-space:nowrap;" onclick="alert('Channel selector coming soon!')">Select</button>
                        </div>
                    </div>
                </div>

                <div class="form-actions">
                    <button class="btn-save" onclick="saveApplication()"><i class="fas fa-save"></i> Save Changes</button>
                </div>
            </div>

            <!-- ─── EMBED CUSTOMIZATION PANEL ─── -->
            <div class="panel-content" id="panel-embed">
                <div class="section-card">
                    <div class="section-header">
                        <h3>Accepted Message</h3>
                    </div>
                    <p class="section-desc">The message which will be sent to the user when their submission is accepted.</p>
                    <div class="form-group">
                        <textarea id="acceptedMessage" rows="3">Your application for `{applicationName}` has been accepted by {user}</textarea>
                        <div class="form-hint">Use {applicationName} for the app name, {user} for the reviewer</div>
                    </div>
                </div>

                <div class="section-card">
                    <div class="section-header">
                        <h3>Denied Message</h3>
                    </div>
                    <p class="section-desc">The message which will be sent to the user when their submission is denied.</p>
                    <div class="form-group">
                        <textarea id="deniedMessage" rows="3">Your application for `{applicationName}` has been denied by {user}</textarea>
                        <div class="form-hint">Use {applicationName} for the app name, {user} for the reviewer</div>
                    </div>
                </div>

                <div class="section-card">
                    <div class="section-header">
                        <h3>Confirmation Message</h3>
                    </div>
                    <p class="section-desc">The first message someone receives when starting their submission.</p>
                    <div class="form-group">
                        <textarea id="confirmationMessage" rows="4">Are you sure you want to apply?

Once you start the application I will send you a series of questions. You will have 3 hours to complete the application. If you do not complete the application in time, you will have to restart. If you wish to stop the application feel free to click the cancel button at any time.</textarea>
                    </div>
                </div>

                <div class="section-card">
                    <div class="section-header">
                        <h3>Completion Message</h3>
                    </div>
                    <p class="section-desc">The message the user will receive when they have completed their submission.</p>
                    <div class="form-group">
                        <textarea id="completionMessage" rows="2">Your application has been submitted.</textarea>
                    </div>
                </div>

                <div class="section-card">
                    <div class="section-header">
                        <h3>Show advanced options</h3>
                        <div class="toggle-wrapper">
                            <div class="toggle" id="advancedToggle" onclick="toggleSwitch(this)">
                                <div class="toggle-slider"></div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="form-actions">
                    <button class="btn-save" onclick="saveApplication()"><i class="fas fa-save"></i> Save Changes</button>
                </div>
            </div>

            <!-- ─── ROLE CONFIG PANEL ─── -->
            <div class="panel-content" id="panel-roles">
                <div class="section-card">
                    <div class="section-header">
                        <h3>Restricted Roles</h3>
                        <span class="badge" style="background:var(--signal-tab); color:var(--signal); padding:2px 10px; border-radius:100px; font-size:11px;">0/1</span>
                    </div>
                    <p class="section-desc">The roles that the user must not have in order to submit an application.</p>
                    <div class="form-group">
                        <label>Match Mode</label>
                        <select>
                            <option>Has all roles</option>
                            <option>Has any role</option>
                        </select>
                        <div class="form-hint">User is restricted only if they have ALL of the listed roles.</div>
                    </div>
                    <div class="form-group">
                        <input type="text" placeholder="Select some roles..." value="No roles selected">
                    </div>
                </div>

                <div class="section-card">
                    <div class="section-header">
                        <h3>Required Roles</h3>
                        <span class="badge" style="background:var(--signal-tab); color:var(--signal); padding:2px 10px; border-radius:100px; font-size:11px;">0/1</span>
                    </div>
                    <p class="section-desc">The roles that the user must have in order to submit an application.</p>
                    <div class="form-group">
                        <label>Match Mode</label>
                        <select>
                            <option>Has all roles</option>
                            <option>Has any role</option>
                        </select>
                        <div class="form-hint">User is required to have ALL of the listed roles.</div>
                    </div>
                    <div class="form-group">
                        <input type="text" placeholder="Select some roles..." value="No roles selected">
                    </div>
                </div>

                <div class="section-card">
                    <div class="section-header">
                        <h3>Accepted Roles</h3>
                        <span class="badge" style="background:var(--signal-tab); color:var(--signal); padding:2px 10px; border-radius:100px; font-size:11px;">0/1</span>
                    </div>
                    <p class="section-desc">The roles given to the applicant if their submission is accepted.</p>
                    <div class="form-group">
                        <input type="text" placeholder="Select some roles..." value="No roles selected">
                    </div>
                </div>

                <div class="section-card">
                    <div class="section-header">
                        <h3>Denied Roles</h3>
                        <span class="badge" style="background:var(--signal-tab); color:var(--signal); padding:2px 10px; border-radius:100px; font-size:11px;">0/1</span>
                    </div>
                    <p class="section-desc">The roles given to the applicant if their submission is denied.</p>
                    <div class="form-group">
                        <input type="text" placeholder="Select some roles..." value="No roles selected">
                    </div>
                </div>

                <div class="section-card">
                    <div class="section-header">
                        <h3>Ping Roles</h3>
                        <span class="badge" style="background:var(--signal-tab); color:var(--signal); padding:2px 10px; border-radius:100px; font-size:11px;">0/1</span>
                    </div>
                    <p class="section-desc">The roles pinged/mentioned when an application is submitted.</p>
                    <div class="form-group">
                        <input type="text" placeholder="Select some roles..." value="No roles selected">
                    </div>
                </div>

                <div class="premium-banner">
                    <p><i class="fas fa-crown"></i> You have reached the maximum allowed roles, upgrade to enable more.</p>
                    <button class="btn-upgrade" onclick="alert('Upgrade to Premium!')">Upgrade Plan</button>
                </div>

                <div class="form-actions">
                    <button class="btn-save" onclick="saveApplication()"><i class="fas fa-save"></i> Save Changes</button>
                </div>
            </div>

            <!-- ─── OTHER PANEL ─── -->
            <div class="panel-content" id="panel-other">
                <div class="section-card">
                    <div class="section-header">
                        <h3>Staff Threads</h3>
                        <div class="toggle-wrapper">
                            <div class="toggle" id="staffThreadsToggle" onclick="toggleSwitch(this)">
                                <div class="toggle-slider"></div>
                            </div>
                        </div>
                    </div>
                    <p class="section-desc">Automatically creates a thread for each submission, allowing you to communicate with your staff team about it.</p>
                </div>

                <div class="section-card">
                    <div class="section-header">
                        <h3>Application cooldown</h3>
                    </div>
                    <p class="section-desc">How long a user must wait before submitting a new application.</p>
                    <div style="display:flex; gap:12px; flex-wrap:wrap;">
                        <div class="form-group" style="flex:1; min-width:80px;">
                            <label>Days</label>
                            <input type="number" value="0" min="0">
                        </div>
                        <div class="form-group" style="flex:1; min-width:80px;">
                            <label>Hours</label>
                            <input type="number" value="0" min="0">
                        </div>
                        <div class="form-group" style="flex:1; min-width:80px;">
                            <label>Minutes</label>
                            <input type="number" value="0" min="0">
                        </div>
                    </div>
                </div>

                <div class="section-card">
                    <div class="section-header">
                        <h3>Time Limit</h3>
                    </div>
                    <p class="section-desc">Set how long users have to complete this application before it expires.</p>
                    <div style="display:flex; gap:12px; flex-wrap:wrap;">
                        <div class="form-group" style="flex:1; min-width:80px;">
                            <label>Days</label>
                            <input type="number" value="0" min="0">
                        </div>
                        <div class="form-group" style="flex:1; min-width:80px;">
                            <label>Hours</label>
                            <input type="number" value="3" min="0">
                        </div>
                        <div class="form-group" style="flex:1; min-width:80px;">
                            <label>Minutes</label>
                            <input type="number" value="0" min="0">
                        </div>
                    </div>
                </div>

                <div class="form-actions">
                    <button class="btn-save" onclick="saveApplication()"><i class="fas fa-save"></i> Save Changes</button>
                </div>
            </div>

            <!-- ─── QUESTIONS PANEL ─── -->
            <div class="panel-content" id="panel-questions">
                <div class="section-card">
                    <div class="section-header">
                        <h3>Questions: <span id="questionCount">2</span>/12</h3>
                    </div>

                    <!-- Question 1 -->
                    <div class="question-item">
                        <span class="q-number">1.</span>
                        <span class="q-text">Do you like dogs?</span>
                        <span class="q-type"><i class="fas fa-pen"></i> Text</span>
                        <div class="q-actions">
                            <button onclick="alert('Edit question')"><i class="fas fa-edit"></i></button>
                            <button class="danger" onclick="alert('Delete question')"><i class="fas fa-trash"></i></button>
                        </div>
                    </div>

                    <!-- Question 2 -->
                    <div class="question-item">
                        <span class="q-number">2.</span>
                        <span class="q-text">Are capybaras the best animal?</span>
                        <span class="q-type"><i class="fas fa-check-square"></i> Multiple choice</span>
                        <div class="q-actions">
                            <button onclick="alert('Edit question')"><i class="fas fa-edit"></i></button>
                            <button class="danger" onclick="alert('Delete question')"><i class="fas fa-trash"></i></button>
                        </div>
                    </div>

                    <!-- Add Question -->
                    <div style="display:flex; gap:10px; margin-top:12px; flex-wrap:wrap;">
                        <button class="btn-primary" onclick="alert('New question form coming soon!')"><i class="fas fa-plus"></i> New question</button>
                        <div style="display:flex; gap:6px; align-items:center; margin-left:auto;">
                            <span style="font-size:11px; color:var(--muted);">2/12 questions used.</span>
                        </div>
                    </div>

                    <div class="premium-banner" style="margin-top:12px;">
                        <p><i class="fas fa-crown"></i> Unlock Appy premium for up to 100 questions.</p>
                        <button class="btn-upgrade" onclick="alert('Upgrade to Premium!')">Upgrade Plan</button>
                    </div>
                </div>

                <div class="form-actions">
                    <button class="btn-save" onclick="saveApplication()"><i class="fas fa-save"></i> Save Changes</button>
                </div>
            </div>

        </div>
    </div>

    <footer class="footer">
        © 2026 SENTINAL — STATUS: OPERATIONAL
    </footer>

    <script>
        // ─── PANEL NAVIGATION ───
        function showPanel(panel) {
            document.querySelectorAll('.settings-sidebar .nav-item').forEach(el => el.classList.remove('active'));
            document.querySelectorAll('.settings-sidebar .nav-item').forEach(el => {
                if (el.textContent.trim().toLowerCase().includes(panel)) {
                    el.classList.add('active');
                }
            });

            document.querySelectorAll('.panel-content').forEach(el => el.classList.remove('active'));
            const target = document.getElementById('panel-' + panel);
            if (target) target.classList.add('active');
        }

        // ─── TOGGLE SWITCH ───
        function toggleSwitch(el) {
            el.classList.toggle('active');
        }

        // ─── SAVE APPLICATION ───
        function saveApplication() {
            const data = {
                name: document.getElementById('appNameInput')?.value || '',
                enabled: document.getElementById('enabledToggle')?.classList.contains('active') || false,
                pendingChannel: document.getElementById('pendingChannel')?.value || '',
                acceptedChannel: document.getElementById('acceptedChannel')?.value || '',
                deniedChannel: document.getElementById('deniedChannel')?.value || '',
                acceptedMessage: document.getElementById('acceptedMessage')?.value || '',
                deniedMessage: document.getElementById('deniedMessage')?.value || '',
                confirmationMessage: document.getElementById('confirmationMessage')?.value || '',
                completionMessage: document.getElementById('completionMessage')?.value || ''
            };

            fetch('/api/applications/<%= locals.guild ? guild.id : '' %>', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    alert('✅ Application saved successfully!');
                    location.reload();
                } else {
                    alert('❌ Error: ' + data.error);
                }
            })
            .catch(error => {
                alert('❌ Error saving application: ' + error.message);
            });
        }
    </script>

</body>
</html>
