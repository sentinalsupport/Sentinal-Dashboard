<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title || 'Panels — Sentinal' %></title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@400;500;600;700;800&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --ink: #060A10;
            --panel: #0D1520;
            --panel-raised: #111D2C;
            --panel-hover: #162033;
            --line: rgba(255,255,255,0.07);
            --line-bright: rgba(255,255,255,0.13);
            --text: #E6EDF6;
            --muted: #6C7A90;
            --muted-dim: #3E4A5C;
            --signal: #3DFFB8;
            --signal-tab: rgba(61,255,184,0.08);
            --signal-glow: rgba(61,255,184,0.15);
            --gold: #F5C842;
            --gold-tab: rgba(245,200,66,0.12);
            --violet: #8B7EFF;
            --violet-tab: rgba(139,126,255,0.12);
            --red: #F87171;
            --red-bg: rgba(248,113,113,0.08);
            --red-border: rgba(248,113,113,0.22);
            --discord: #5865F2;
            --discord-hover: #4752C4;
        }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Inter', -apple-system, sans-serif;
            background: var(--ink);
            color: var(--text);
            min-height: 100vh;
            overflow-x: hidden;
        }

        .navbar {
            background: rgba(6,10,16,0.9);
            backdrop-filter: blur(28px) saturate(160%);
            border-bottom: 1px solid var(--line);
            padding: 0 48px;
            height: 72px;
            display: flex; align-items: center; justify-content: space-between;
            position: sticky; top: 0; z-index: 200;
        }
        .brand { display: flex; align-items: center; gap: 12px; text-decoration: none; }
        .brand-logo {
            width: 40px; height: 40px; border-radius: 12px;
            background: var(--panel-raised); border: 1px solid var(--line-bright);
            display: flex; align-items: center; justify-content: center;
        }
        .brand-logo svg { width: 22px; height: 22px; }
        .brand-name {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 20px; font-weight: 700; color: #fff; letter-spacing: -0.3px;
        }
        .nav-center { display: flex; align-items: center; gap: 8px; }
        .nav-center a {
            color: var(--muted); text-decoration: none; font-size: 15px; font-weight: 500;
            padding: 8px 18px; border-radius: 10px; transition: all 0.18s ease;
        }
        .nav-center a:hover { color: var(--text); background: rgba(255,255,255,0.05); }
        .nav-center a.active { color: #fff; }
        .nav-right { display: flex; align-items: center; gap: 16px; }
        .user-pill {
            display: flex; align-items: center; gap: 12px;
            background: var(--panel); border: 1px solid var(--line);
            border-radius: 100px; padding: 6px 18px 6px 8px;
        }
        .user-avatar {
            width: 32px; height: 32px; border-radius: 50%;
            background: var(--panel-raised); overflow: hidden;
            display: flex; align-items: center; justify-content: center;
            font-size: 14px; font-weight: 700;
        }
        .user-avatar img { width: 100%; height: 100%; object-fit: cover; }
        .user-name { font-size: 14px; font-weight: 500; color: var(--text); }
        .user-plan {
            font-size: 11px; font-weight: 600; color: var(--signal);
            background: var(--signal-tab); border: 1px solid rgba(61,255,184,0.22);
            border-radius: 100px; padding: 3px 10px; letter-spacing: 0.3px;
        }
        .logout-btn {
            background: transparent; border: 1px solid var(--line); border-radius: 10px;
            padding: 8px 14px; color: var(--muted); cursor: pointer; font-size: 14px;
            transition: all 0.18s ease; text-decoration: none;
            display: flex; align-items: center; gap: 8px;
        }
        .logout-btn:hover { background: var(--red-bg); border-color: var(--red-border); color: var(--red); }

        .page-wrapper {
            max-width: 1920px;
            margin: 0 auto;
            padding: 32px 48px 60px;
            display: flex;
            gap: 32px;
            align-items: flex-start;
            min-height: calc(100vh - 72px);
        }

        .sidebar {
            width: 255px;
            flex-shrink: 0;
            background: var(--panel);
            border: 1px solid var(--line);
            border-radius: 14px;
            padding: 16px 18px;
            position: sticky;
            top: 88px;
            height: calc(100vh - 108px);
            overflow-y: auto;
            overflow-x: hidden;
        }
        .sidebar::-webkit-scrollbar { width: 3px; }
        .sidebar::-webkit-scrollbar-track { background: transparent; }
        .sidebar::-webkit-scrollbar-thumb { background: var(--muted-dim); border-radius: 10px; }

        .sidebar .server-info {
            padding-bottom: 14px;
            border-bottom: 1px solid var(--line);
            margin-bottom: 12px;
        }
        .sidebar .server-info .icon {
            width: 40px; height: 40px; border-radius: 10px;
            background: var(--panel-raised); border: 1px solid var(--line);
            display: flex; align-items: center; justify-content: center;
            font-size: 16px; font-weight: 700; overflow: hidden;
            color: var(--signal); margin-bottom: 6px;
        }
        .sidebar .server-info .icon img { width: 100%; height: 100%; object-fit: cover; }
        .sidebar .server-info .name {
            font-weight: 600; font-size: 13px; color: #fff;
        }
        .sidebar .server-info .plan {
            font-size: 10px; color: var(--signal);
            font-weight: 500;
        }
        .sidebar .server-info .upgrade {
            display: block; margin-top: 6px;
            padding: 4px 10px; border-radius: 6px;
            background: var(--gold-tab); color: var(--gold);
            font-size: 10px; font-weight: 600; text-decoration: none;
            text-align: center; border: 1px solid rgba(245,200,66,0.2);
        }
        .sidebar .server-info .upgrade:hover { background: rgba(245,200,66,0.18); }

        .sidebar .nav-section { padding: 0; }
        .sidebar .section-title {
            font-size: 9px; font-weight: 700; text-transform: uppercase;
            letter-spacing: 0.8px; color: var(--muted-dim);
            padding: 8px 8px 4px;
        }
        .sidebar .nav-item {
            display: flex; align-items: center; gap: 10px;
            padding: 7px 10px;
            border-radius: 8px;
            color: var(--muted); text-decoration: none;
            font-size: 12px; font-weight: 500;
            transition: all 0.18s ease; cursor: pointer; border: none;
            background: none; width: 100%; text-align: left;
        }
        .sidebar .nav-item:hover { background: rgba(255,255,255,0.04); color: var(--text); }
        .sidebar .nav-item.active { background: var(--signal-tab); color: var(--signal); }
        .sidebar .nav-item i { width: 16px; font-size: 13px; color: var(--muted-dim); }
        .sidebar .nav-item.active i { color: var(--signal); }
        .sidebar .nav-item .badge {
            margin-left: auto; font-size: 7px; font-weight: 700;
            padding: 1px 6px; border-radius: 100px; text-transform: uppercase;
        }
        .sidebar .nav-item .badge.live { background: var(--signal-tab); color: var(--signal); }
        .sidebar .nav-item .badge.coming { background: var(--gold-tab); color: var(--gold); }
        .sidebar .nav-item .badge.new { background: var(--violet-tab); color: var(--violet); }

        .sidebar .divider { height: 1px; background: var(--line); margin: 8px 0; }

        .content {
            flex: 1;
            min-width: 0;
        }

        .status-bar {
            display: flex; align-items: center; gap: 12px;
            padding: 12px 16px;
            background: var(--panel);
            border-radius: 12px;
            border: 1px solid var(--line);
            margin-bottom: 24px;
        }
        .status-bar .dot { color: #34d399; font-size: 12px; font-weight: 600; }
        .status-bar .text { color: var(--muted); font-size: 13px; }
        .status-bar .time { margin-left: auto; color: var(--muted-dim); font-size: 12px; }

        .panels-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 24px;
            flex-wrap: wrap;
            gap: 16px;
        }

        .panels-header h1 {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 28px;
            font-weight: 700;
            color: #fff;
            margin: 0;
        }

        .panels-header p {
            color: var(--muted);
            font-size: 16px;
            margin: 4px 0 0;
        }

        .panels-stats {
            display: flex;
            gap: 24px;
            align-items: center;
        }

        .stat-item {
            display: flex;
            align-items: center;
            gap: 8px;
            color: var(--muted);
            font-size: 14px;
        }

        .stat-item .stat-number {
            color: var(--text);
            font-weight: 700;
            font-size: 18px;
        }

        .search-bar {
            display: flex;
            align-items: center;
            gap: 12px;
            background: var(--panel);
            border: 1px solid var(--line);
            border-radius: 10px;
            padding: 8px 16px;
            flex: 1;
            max-width: 400px;
        }

        .search-bar input {
            background: transparent;
            border: none;
            color: var(--text);
            font-size: 14px;
            outline: none;
            width: 100%;
            font-family: 'Inter', sans-serif;
        }

        .search-bar input::placeholder {
            color: var(--muted-dim);
        }

        .search-bar i {
            color: var(--muted-dim);
        }

        .create-panel-btn {
            padding: 10px 24px;
            background: var(--signal);
            color: var(--ink);
            border: none;
            border-radius: 10px;
            font-weight: 700;
            font-size: 14px;
            cursor: pointer;
            transition: all 0.2s ease;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            white-space: nowrap;
            font-family: 'Inter', sans-serif;
        }

        .create-panel-btn:hover {
            transform: translateY(-1px);
            box-shadow: 0 4px 20px var(--signal-glow);
        }

        .panels-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
            gap: 20px;
            margin-top: 20px;
        }

        .panel-card {
            background: var(--panel);
            border: 1px solid var(--line);
            border-radius: 14px;
            padding: 22px 24px;
            transition: all 0.2s ease;
        }

        .panel-card:hover {
            border-color: var(--line-bright);
            transform: translateY(-2px);
        }

        .panel-card-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 10px;
        }

        .panel-card-title {
            font-size: 16px;
            font-weight: 600;
            color: #fff;
        }

        .panel-card-type {
            font-size: 10px;
            font-weight: 700;
            padding: 2px 12px;
            border-radius: 100px;
            background: var(--signal-tab);
            color: var(--signal);
            border: 1px solid rgba(61,255,184,0.2);
            text-transform: uppercase;
        }

        .panel-card-desc {
            color: var(--muted);
            font-size: 14px;
            margin-bottom: 16px;
            line-height: 1.5;
        }

        .panel-card-stats {
            display: flex;
            gap: 20px;
            padding-bottom: 12px;
            border-bottom: 1px solid var(--line);
            margin-bottom: 12px;
        }

        .panel-card-stat {
            font-size: 13px;
            color: var(--muted);
        }

        .panel-card-stat span {
            color: var(--text);
            font-weight: 600;
        }

        .panel-card-actions {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
        }

        .panel-card-actions .btn-edit,
        .panel-card-actions .btn-delete {
            padding: 6px 16px;
            border-radius: 8px;
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            border: none;
            transition: all 0.2s ease;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            font-family: 'Inter', sans-serif;
        }

        .panel-card-actions .btn-edit {
            background: var(--signal-tab);
            color: var(--signal);
            border: 1px solid rgba(61, 255, 184, 0.2);
        }

        .panel-card-actions .btn-edit:hover {
            background: rgba(61, 255, 184, 0.18);
            transform: translateY(-1px);
        }

        .panel-card-actions .btn-delete {
            background: var(--red-bg);
            color: var(--red);
            border: 1px solid var(--red-border);
        }

        .panel-card-actions .btn-delete:hover {
            background: rgba(248, 113, 113, 0.2);
            transform: translateY(-1px);
        }

        .panel-card-actions .btn-edit:disabled,
        .panel-card-actions .btn-delete:disabled {
            opacity: 0.5;
            cursor: not-allowed;
            transform: none;
        }

        .empty-state {
            text-align: center;
            padding: 60px 20px;
            background: var(--panel);
            border: 2px dashed var(--line);
            border-radius: 14px;
            margin-top: 20px;
        }

        .empty-state .empty-icon {
            font-size: 56px;
            color: var(--muted-dim);
            margin-bottom: 16px;
        }

        .empty-state h3 {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 24px;
            color: #fff;
            margin-bottom: 8px;
        }

        .empty-state p {
            color: var(--muted);
            font-size: 16px;
            margin-bottom: 24px;
        }

        .sort-controls {
            display: flex;
            align-items: center;
            gap: 12px;
            color: var(--muted);
            font-size: 14px;
        }

        .sort-controls select {
            background: var(--panel);
            border: 1px solid var(--line);
            color: var(--text);
            padding: 6px 12px;
            border-radius: 8px;
            font-size: 13px;
            outline: none;
            font-family: 'Inter', sans-serif;
            cursor: pointer;
        }

        .sort-controls select:focus {
            border-color: var(--signal);
            box-shadow: 0 0 0 4px var(--signal-glow);
        }

        .controls-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 12px;
            margin-bottom: 12px;
        }

        .controls-left {
            display: flex;
            align-items: center;
            gap: 24px;
            flex-wrap: wrap;
        }

        .controls-right {
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
        }

        .toast-container {
            position: fixed;
            bottom: 24px;
            right: 24px;
            z-index: 9999;
            display: flex;
            flex-direction: column;
            gap: 10px;
            max-width: 380px;
            width: 100%;
        }
        .toast {
            background: var(--panel);
            border: 1px solid var(--line);
            border-radius: 12px;
            padding: 14px 20px;
            display: flex;
            align-items: center;
            gap: 12px;
            box-shadow: 0 8px 32px rgba(0,0,0,0.4);
            animation: slideIn 0.3s ease;
            backdrop-filter: blur(10px);
            border-left: 4px solid var(--signal);
        }
        .toast .toast-icon { color: var(--signal); font-size: 18px; flex-shrink: 0; }
        .toast .toast-content { flex: 1; font-size: 13px; color: var(--text); line-height: 1.4; }
        .toast .toast-close {
            background: none; border: none;
            color: var(--muted-dim); cursor: pointer;
            font-size: 14px; padding: 4px;
        }
        .toast .toast-close:hover { color: var(--text); }
        .toast.error { border-left-color: var(--red); }
        .toast.error .toast-icon { color: var(--red); }
        .toast.success { border-left-color: var(--signal); }
        .toast.success .toast-icon { color: var(--signal); }
        @keyframes slideIn {
            from { opacity: 0; transform: translateX(40px); }
            to { opacity: 1; transform: translateX(0); }
        }
        @keyframes slideOut {
            from { opacity: 1; transform: translateX(0); }
            to { opacity: 0; transform: translateX(40px); }
        }
        .toast.hiding { animation: slideOut 0.3s ease forwards; }

        .footer {
            border-top: 1px solid var(--line);
            margin-top: 60px;
            padding: 28px 48px;
            text-align: center;
            color: var(--muted-dim);
            font-size: 13px;
            font-family: 'IBM Plex Mono', monospace;
            letter-spacing: 0.5px;
        }

        .modal-overlay {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0,0,0,0.7);
            backdrop-filter: blur(8px);
            z-index: 10000;
            align-items: center;
            justify-content: center;
        }

        .modal-overlay.active {
            display: flex;
        }

        .modal-box {
            background: var(--panel);
            border: 1px solid var(--line);
            border-radius: 16px;
            padding: 32px;
            max-width: 420px;
            width: 100%;
            text-align: center;
            animation: modalIn 0.3s ease;
        }

        @keyframes modalIn {
            from { opacity: 0; transform: scale(0.95) translateY(10px); }
            to { opacity: 1; transform: scale(1) translateY(0); }
        }

        .modal-box .modal-icon {
            font-size: 48px;
            margin-bottom: 12px;
        }
        .modal-box h3 {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 20px;
            color: #fff;
            margin-bottom: 8px;
        }
        .modal-box p {
            color: var(--muted);
            font-size: 14px;
            margin-bottom: 24px;
            line-height: 1.5;
        }
        .modal-box .modal-actions {
            display: flex;
            gap: 10px;
            justify-content: center;
        }
        .modal-box .modal-actions button {
            padding: 8px 24px;
            border-radius: 8px;
            font-weight: 600;
            font-size: 14px;
            cursor: pointer;
            border: none;
            transition: all 0.2s ease;
            font-family: 'Inter', sans-serif;
        }
        .modal-box .modal-actions .btn-cancel {
            background: transparent;
            color: var(--muted);
            border: 1px solid var(--line);
        }
        .modal-box .modal-actions .btn-cancel:hover {
            background: rgba(255,255,255,0.04);
            color: var(--text);
        }
        .modal-box .modal-actions .btn-confirm-delete {
            background: var(--red);
            color: #fff;
        }
        .modal-box .modal-actions .btn-confirm-delete:hover {
            background: #dc2626;
        }

        @media (max-width: 1200px) {
            .panels-grid { grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); }
        }
        @media (max-width: 1024px) {
            .page-wrapper { padding: 24px 32px 60px; gap: 24px; }
            .sidebar { width: 220px; }
        }
        @media (max-width: 768px) {
            .navbar { padding: 0 16px; height: 64px; flex-wrap: wrap; }
            .nav-center { display: none; }
            .page-wrapper { padding: 16px; flex-direction: column; }
            .sidebar {
                width: 100%; position: relative; top: 0;
                display: flex; flex-wrap: wrap; gap: 4px; padding: 12px;
                border-radius: 12px; max-height: none; height: auto;
            }
            .sidebar .server-info { display: none; }
            .sidebar .nav-section { display: flex; flex-wrap: wrap; gap: 4px; }
            .sidebar .section-title { display: none; }
            .sidebar .nav-item { padding: 6px 14px; font-size: 13px; width: auto; }
            .sidebar .divider { display: none; }
            .panels-header { flex-direction: column; align-items: stretch; }
            .search-bar { max-width: 100%; }
            .controls-row { flex-direction: column; align-items: stretch; }
            .controls-left { justify-content: space-between; }
            .panels-grid { grid-template-columns: 1fr; }
            .panel-card { padding: 18px 20px; }
            .footer { padding: 20px 16px; }
            .toast-container { bottom: 16px; right: 16px; max-width: calc(100% - 32px); }
            .modal-box { margin: 16px; padding: 24px; }
        }
    </style>
</head>
<body>

    <nav class="navbar">
        <a href="/dashboard" class="brand">
            <div class="brand-logo">
                <svg viewBox="0 0 245 240" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M104.4 103.9c-5.7 0-10.2 5-10.2 11.1s4.6 11.1 10.2 11.1c5.7 0 10.2-5 10.2-11.1.1-6.1-4.5-11.1-10.2-11.1zM140.9 103.9c-5.7 0-10.2 5-10.2 11.1s4.6 11.1 10.2 11.1c5.7 0 10.2-5 10.2-11.1s-4.5-11.1-10.2-11.1z" fill="#3DFFB8"/>
