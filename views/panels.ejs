=<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Panels — Sentinal</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/dashboard.css">
    <style>
        .panels-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 24px;
            flex-wrap: wrap;
            gap: 16px;
        }

        .panels-stats {
            display: flex;
            gap: 24px;
            align-items: center;
        }

        .stat-item {
            display: flex;
            align-items: center;
            gap: 8px;
            color: var(--text-secondary);
            font-size: 13px;
        }

        .stat-item .stat-number {
            color: var(--text-primary);
            font-weight: 700;
            font-size: 16px;
        }

        .search-bar {
            display: flex;
            align-items: center;
            gap: 12px;
            background: var(--bg-input);
            border: 1px solid var(--border);
            border-radius: var(--radius-md);
            padding: 8px 16px;
            flex: 1;
            max-width: 400px;
        }

        .search-bar input {
            background: transparent;
            border: none;
            color: var(--text-primary);
            font-size: 13px;
            outline: none;
            width: 100%;
        }

        .search-bar input::placeholder {
            color: var(--text-muted);
        }

        .search-bar i {
            color: var(--text-muted);
        }

        .create-panel-btn {
            padding: 10px 24px;
            background: var(--accent);
            color: white;
            border: none;
            border-radius: var(--radius-md);
            font-weight: 600;
            font-size: 13px;
            cursor: pointer;
            transition: all 0.18s ease;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            white-space: nowrap;
        }

        .create-panel-btn:hover {
            background: var(--accent-hover);
            transform: translateY(-1px);
            box-shadow: 0 4px 18px rgba(99, 102, 241, 0.25);
        }

        .panels-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 16px;
            margin-top: 20px;
        }

        .panel-card {
            background: var(--bg-card);
            border: 1px solid var(--border-soft);
            border-radius: var(--radius-lg);
            padding: 20px;
            transition: all 0.18s ease;
            cursor: pointer;
        }

        .panel-card:hover {
            border-color: var(--accent);
            transform: translateY(-2px);
            box-shadow: 0 4px 20px rgba(0,0,0,0.2);
        }

        .panel-card-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 12px;
        }

        .panel-card-title {
            font-size: 16px;
            font-weight: 600;
            color: var(--text-primary);
        }

        .panel-card-type {
            font-size: 11px;
            font-weight: 600;
            padding: 2px 10px;
            border-radius: 100px;
            background: var(--accent-soft);
            color: var(--accent);
        }

        .panel-card-desc {
            color: var(--text-secondary);
            font-size: 13px;
            margin-bottom: 16px;
            line-height: 1.5;
        }

        .panel-card-stats {
            display: flex;
            gap: 16px;
            padding-top: 12px;
            border-top: 1px solid var(--border-soft);
        }

        .panel-card-stat {
            font-size: 12px;
            color: var(--text-muted);
        }

        .panel-card-stat span {
            color: var(--text-primary);
            font-weight: 600;
        }

        .empty-state {
            text-align: center;
            padding: 60px 20px;
            background: var(--bg-card);
            border: 2px dashed var(--border-soft);
            border-radius: var(--radius-lg);
            margin-top: 20px;
        }

        .empty-state .empty-icon {
            font-size: 48px;
            color: var(--text-muted);
            margin-bottom: 16px;
        }

        .empty-state h3 {
            font-size: 20px;
            margin-bottom: 8px;
        }

        .empty-state p {
            color: var(--text-secondary);
            margin-bottom: 20px;
        }

        .sort-controls {
            display: flex;
            align-items: center;
            gap: 12px;
            color: var(--text-secondary);
            font-size: 13px;
        }

        .sort-controls select {
            background: var(--bg-input);
            border: 1px solid var(--border);
            color: var(--text-primary);
            padding: 6px 12px;
            border-radius: var(--radius-sm);
            font-size: 13px;
            outline: none;
        }

        @media (max-width: 768px) {
            .panels-header {
                flex-direction: column;
                align-items: stretch;
            }
            .search-bar {
                max-width: 100%;
            }
            .panels-stats {
                justify-content: space-between;
            }
        }
    </style>
</head>
<body>
    <div class="layout">
        <!-- Sidebar -->
        <aside class="sidebar">
            <div class="brand">
                <span class="brand-icon">🛡️</span>
                Sentinal
            </div>

            <div class="server-switcher">
                <div class="server-avatar"></div>
                <div>
                    <div class="server-name"><%= locals.guild ? guild.name : 'Sentinal Support' %></div>
                    <div class="server-plan">Free</div>
                </div>
            </div>

            <nav class="nav">
                <a href="/dashboard" class="nav-link nav-top">
                    <span><span class="nav-icon">🏠</span> Dashboard</span>
                </a>

                <div class="nav-group">
                    <a href="/servers" class="nav-link">
                        <span><span class="nav-icon">🖥️</span> Servers</span>
                    </a>
                    <div class="nav-sub">
                        <a href="/servers/<%= locals.guild ? guild.id : '' %>/applications" class="nav-link">
                            <span><span class="nav-icon">📄</span> Applications</span>
                        </a>
                        <a href="/servers/<%= locals.guild ? guild.id : '' %>/tickets" class="nav-link">
                            <span><span class="nav-icon">🎫</span> Tickets</span>
                        </a>
                        <a href="/servers/<%= locals.guild ? guild.id : '' %>/panels" class="nav-link active">
                            <span><span class="nav-icon">📋</span> Panels</span>
                            <span class="badge">LIVE</span>
                        </a>
                    </div>
                </div>
            </nav>

            <div class="sidebar-footer">
                <a href="#" class="support-link">
                    <span>💬</span> Support
                </a>
                <div class="user-card">
                    <div class="user-avatar">
                        <%= locals.user ? (user.global_name ? user.global_name.charAt(0).toUpperCase() : user.username.charAt(0).toUpperCase()) : 'U' %>
                    </div>
                    <div>
                        <div class="user-name"><%= locals.user ? (user.global_name || user.username) : 'thedude12355' %></div>
                        <div class="user-plan-badge">FREE</div>
                    </div>
                </div>
            </div>
        </aside>

        <!-- Main Content -->
        <main class="content">
            <div class="page-wrapper">
                <!-- Status Bar -->
                <div style="display:flex; align-items:center; gap:12px; padding:12px 16px; background:var(--bg-card); border-radius:var(--radius-md); border:1px solid var(--border-soft); margin-bottom:24px;">
                    <span style="color:#34d399; font-size:12px; font-weight:600;">●</span>
                    <span style="color:var(--text-secondary); font-size:13px;">All Systems Operational</span>
                    <span style="margin-left:auto; color:var(--text-muted); font-size:12px;"><%= new Date().toLocaleString() %></span>
                </div>

                <div class="panels-header">
                    <div>
                        <h1 style="font-size:24px; font-weight:700; margin:0;">Panels</h1>
                        <p style="color:var(--text-secondary); margin:4px 0 0;">Manage and view all your panels.</p>
                    </div>
                    <button class="create-panel-btn" onclick="window.location.href='/servers/<%= locals.guild ? guild.id : '' %>/panels/create'">
                        <i class="fas fa-plus"></i> Create Panel
                    </button>
                </div>

                <div style="display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:12px; margin-bottom:12px;">
                    <div class="panels-stats">
                        <div class="stat-item">
                            <span class="stat-number"><%= panels ? panels.length : 0 %></span>
                            <span>/ 10 Panels</span>
                        </div>
                    </div>
                    <div style="display:flex; gap:12px; flex-wrap:wrap;">
                        <div class="search-bar">
                            <i class="fas fa-search"></i>
                            <input type="text" placeholder="Search by panel content or title..">
                        </div>
                        <div class="sort-controls">
                            <span>Sort:</span>
                            <select>
                                <option>Last Seen (Newest First)</option>
                                <option>Last Seen (Oldest First)</option>
                                <option>Name (A-Z)</option>
                                <option>Name (Z-A)</option>
                            </select>
                        </div>
                    </div>
                </div>

                <% if (panels && panels.length > 0) { %>
                    <div class="panels-grid">
                        <% panels.forEach(panel => { %>
                            <div class="panel-card" onclick="window.location.href='/servers/<%= locals.guild ? guild.id : '' %>/panels/<%= panel._id %>/edit'">
                                <div class="panel-card-header">
                                    <span class="panel-card-title"><%= panel.name || 'Untitled Panel' %></span>
                                    <span class="panel-card-type"><%= panel.type || 'Ticket' %></span>
                                </div>
                                <div class="panel-card-desc">
                                    <%= panel.description || 'No description provided.' %>
                                </div>
                                <div class="panel-card-stats">
                                    <div class="panel-card-stat">
                                        📋 <span><%= panel.buttons ? panel.buttons.length : 0 %></span> buttons
                                    </div>
                                    <div class="panel-card-stat">
                                        🎫 <span><%= panel.tickets ? panel.tickets.length : 0 %></span> tickets
                                    </div>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                <% } else { %>
                    <div class="empty-state">
                        <div class="empty-icon">📋</div>
                        <h3>No panels yet</h3>
                        <p>Create your first panel to get started!</p>
                        <button class="create-panel-btn" onclick="window.location.href='/servers/<%= locals.guild ? guild.id : '' %>/panels/create'">
                            <i class="fas fa-plus"></i> Create First Panel
                        </button>
                    </div>
                <% } %>
            </div>
        </main>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Any additional JS for the panels page
        });
    </script>
</body>
</html>
