                </svg>
            </div>
            <span class="brand-name">Sentinal</span>
        </a>
        <div class="nav-center">
            <a href="/dashboard">Home</a>
            <a href="/servers" class="active">Servers</a>
            <a href="#" onclick="window.open('https://discord.gg/UmqmewYWRd','_blank'); return false;">Support</a>
            <a href="#">Premium</a>
        </div>
        <div class="nav-right">
            <div class="user-pill">
                <div class="user-avatar">
                    <% if (locals.user && user.avatar) { %>
                        <img src="https://cdn.discordapp.com/avatars/<%= user.id %>/<%= user.avatar %>.png" alt="Avatar">
                    <% } else { %>
                        <%= locals.user ? (user.username ? user.username.charAt(0).toUpperCase() : 'U') : 'U' %>
                    <% } %>
                </div>
                <span class="user-name"><%= locals.user ? (user.global_name || user.username) : 'User' %></span>
                <span class="user-plan">Free</span>
            </div>
            <a href="/logout" class="logout-btn"><i class="fas fa-sign-out-alt"></i></a>
        </div>
    </nav>

    <div class="toast-container" id="toastContainer"></div>

    <!-- Delete Confirmation Modal -->
    <div class="modal-overlay" id="deleteModal">
        <div class="modal-box">
            <div class="modal-icon">⚠️</div>
            <h3>Delete Panel?</h3>
            <p>Are you sure you want to delete the panel "<span id="deletePanelName"></span>"? This action cannot be undone.</p>
            <div class="modal-actions">
                <button class="btn-cancel" onclick="closeDeleteModal()">Cancel</button>
                <button class="btn-confirm-delete" onclick="confirmDelete()">Delete Panel</button>
            </div>
        </div>
    </div>

    <div class="page-wrapper">

        <!-- ─── LEFT SIDEBAR ─── -->
        <aside class="sidebar">
            <div class="server-info">
                <div class="icon">
                    <% if (locals.guild && guild.icon) { %>
                        <img src="https://cdn.discordapp.com/icons/<%= guild.id %>/<%= guild.icon %>.png" alt="<%= guild.name %>">
                    <% } else { %>
                        <%= locals.guild ? (guild.name ? guild.name.charAt(0).toUpperCase() : '?') : '?' %>
                    <% } %>
                </div>
                <div class="name"><%= locals.guild ? guild.name : 'Server' %></div>
                <div class="plan">Free</div>
                <a href="#" class="upgrade" onclick="showToast('Upgrade to Premium!', 'info')">Upgrade to Premium</a>
            </div>

            <div class="nav-section">
                <div class="section-title">Modules</div>
                <a href="/servers/<%= locals.guild ? guild.id : '' %>" class="nav-item">
                    <i class="fas fa-th-large"></i> Overview
                </a>
                <a href="/servers/<%= locals.guild ? guild.id : '' %>/applications" class="nav-item">
                    <i class="fas fa-file-alt"></i> Applications
                    <span class="badge live">Live</span>
                </a>
                <a href="/servers/<%= locals.guild ? guild.id : '' %>/tickets" class="nav-item">
                    <i class="fas fa-ticket"></i> Tickets
                    <span class="badge live">Live</span>
                </a>
                <a href="/servers/<%= locals.guild ? guild.id : '' %>/panels" class="nav-item active">
                    <i class="fas fa-clipboard"></i> Panels
                    <span class="badge live">Live</span>
                </a>
            </div>

            <div class="divider"></div>

            <div class="nav-section">
                <div class="section-title">Support</div>
                <button class="nav-item" onclick="showToast('Support server coming soon!', 'info')">
                    <i class="fas fa-headset"></i> Support Server
                </button>
            </div>
        </aside>

        <!-- ─── RIGHT CONTENT ─── -->
        <div class="content">

            <!-- Status Bar -->
            <div class="status-bar">
                <span class="dot">●</span>
                <span class="text">All Systems Operational</span>
                <span class="time"><%= new Date().toLocaleString() %></span>
            </div>

            <div class="panels-header">
                <div>
                    <h1>Panels</h1>
                    <p>Manage and view all your panels.</p>
                </div>
                <button class="create-panel-btn" onclick="window.location.href='/servers/<%= locals.guild ? guild.id : '' %>/panels/create'">
                    <i class="fas fa-plus"></i> Create Panel
                </button>
            </div>

            <div class="controls-row">
                <div class="controls-left">
                    <div class="panels-stats">
                        <div class="stat-item">
                            <span class="stat-number"><%= panels ? panels.length : 0 %></span>
                            <span>/ 10 Panels</span>
                        </div>
                    </div>
                </div>
                <div class="controls-right">
                    <div class="search-bar">
                        <i class="fas fa-search"></i>
                        <input type="text" placeholder="Search by panel content or title.." id="panelSearch" onkeyup="searchPanels()">
                    </div>
                    <div class="sort-controls">
                        <span>Sort:</span>
                        <select id="sortPanels" onchange="sortPanels()">
                            <option value="newest">Last Seen (Newest First)</option>
                            <option value="oldest">Last Seen (Oldest First)</option>
                            <option value="az">Name (A-Z)</option>
                            <option value="za">Name (Z-A)</option>
                        </select>
                    </div>
                </div>
            </div>

            <% if (panels && panels.length > 0) { %>
                <div class="panels-grid" id="panelsGrid">
                    <% panels.forEach(panel => { %>
                        <div class="panel-card" data-panel-id="<%= panel._id %>" data-name="<%= panel.name || 'Untitled Panel' %>">
                            <div class="panel-card-header">
                                <span class="panel-card-title"><%= panel.name || 'Untitled Panel' %></span>
                                <span class="panel-card-type"><%= panel.type || 'Ticket' %></span>
                            </div>
                            <div class="panel-card-desc">
                                <%= panel.description || 'No description provided.' %>
                            </div>
                            <div class="panel-card-stats">
                                <div class="panel-card-stat">
                                    📋 <span><%= panel.buttons ? panel.buttons.length : 0 %></span> buttons
                                </div>
                                <div class="panel-card-stat">
                                    🎫 <span><%= panel.tickets ? panel.tickets.length : 0 %></span> tickets
                                </div>
                            </div>
                            <div class="panel-card-actions">
                                <button class="btn-edit" onclick="editPanel('<%= panel._id %>')">
                                    <i class="fas fa-edit"></i> Edit
                                </button>
                                <button class="btn-delete" onclick="openDeleteModal('<%= panel._id %>', '<%= panel.name %>')">
                                    <i class="fas fa-trash"></i> Delete
                                </button>
                            </div>
                        </div>
                    <% }) %>
                </div>
            <% } else { %>
                <div class="empty-state">
                    <div class="empty-icon">📋</div>
                    <h3>No panels yet</h3>
                    <p>Create your first panel to get started!</p>
                    <button class="create-panel-btn" onclick="window.location.href='/servers/<%= locals.guild ? guild.id : '' %>/panels/create'">
                        <i class="fas fa-plus"></i> Create First Panel
                    </button>
                </div>
            <% } %>

        </div>
    </div>

    <footer class="footer">
        © 2026 SENTINAL — STATUS: OPERATIONAL
    </footer>

    <script>
        // ============ Toast Notifications ============
        function showToast(message, type = 'info') {
            const container = document.getElementById('toastContainer');
            const toast = document.createElement('div');
            toast.className = 'toast ' + type;
            toast.innerHTML = `
                <span class="toast-icon"><i class="fas fa-${type === 'success' ? 'check-circle' : 'exclamation-circle'}"></i></span>
                <span class="toast-content">${message}</span>
                <button class="toast-close" onclick="this.closest('.toast').classList.add('hiding'); setTimeout(() => this.closest('.toast').remove(), 300);">
                    <i class="fas fa-times"></i>
                </button>
            `;
            container.appendChild(toast);
            setTimeout(() => {
                if (toast.parentNode) {
                    toast.classList.add('hiding');
                    setTimeout(() => { if (toast.parentNode) toast.remove(); }, 300);
                }
            }, 4000);
        }

        // ============ Delete Modal ============
        let deletePanelId = null;
        let deletePanelName = null;

        function openDeleteModal(panelId, panelName) {
            deletePanelId = panelId;
            deletePanelName = panelName;
            document.getElementById('deletePanelName').textContent = panelName;
            document.getElementById('deleteModal').classList.add('active');
        }

        function closeDeleteModal() {
            document.getElementById('deleteModal').classList.remove('active');
            deletePanelId = null;
            deletePanelName = null;
        }

        function confirmDelete() {
            if (deletePanelId) {
                performDelete(deletePanelId, deletePanelName);
                closeDeleteModal();
            }
        }

        // ============ Edit Panel ============
        function editPanel(panelId) {
            const guildId = '<%= locals.guild ? guild.id : "" %>';
            window.location.href = `/servers/${guildId}/panels/${panelId}/edit`;
        }

        // ============ Delete Panel ============
        function performDelete(panelId, panelName) {
            const guildId = '<%= locals.guild ? guild.id : "" %>';
            
            // Show loading state on buttons
            const card = document.querySelector(`.panel-card[data-panel-id="${panelId}"]`);
            if (card) {
                const buttons = card.querySelectorAll('.panel-card-actions button');
                buttons.forEach(btn => {
                    btn.disabled = true;
                    btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i>';
                });
            }

            fetch(`/api/panels/${panelId}`, {
                method: 'DELETE',
                headers: {
                    'Content-Type': 'application/json'
                }
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    // Remove the panel card from the DOM with animation
                    if (card) {
                        card.style.transition = 'all 0.3s ease';
                        card.style.opacity = '0';
                        card.style.transform = 'scale(0.95)';
                        setTimeout(() => {
                            card.remove();
                            // Check if there are no more panels
                            const remainingPanels = document.querySelectorAll('.panel-card');
                            if (remainingPanels.length === 0) {
                                location.reload(); // Reload to show empty state
                            }
                            showToast('✅ Panel deleted successfully!', 'success');
                        }, 300);
                    }
                } else {
                    showToast('❌ Error: ' + data.error, 'error');
                    // Reset buttons
                    if (card) {
                        const buttons = card.querySelectorAll('.panel-card-actions button');
                        buttons.forEach(btn => {
                            btn.disabled = false;
                            if (btn.classList.contains('btn-edit')) {
                                btn.innerHTML = '<i class="fas fa-edit"></i> Edit';
                            } else if (btn.classList.contains('btn-delete')) {
                                btn.innerHTML = '<i class="fas fa-trash"></i> Delete';
                            }
                        });
                    }
                }
            })
            .catch(error => {
                showToast('❌ Error: ' + error.message, 'error');
                // Reset buttons
                if (card) {
                    const buttons = card.querySelectorAll('.panel-card-actions button');
                    buttons.forEach(btn => {
                        btn.disabled = false;
                        if (btn.classList.contains('btn-edit')) {
                            btn.innerHTML = '<i class="fas fa-edit"></i> Edit';
                        } else if (btn.classList.contains('btn-delete')) {
                            btn.innerHTML = '<i class="fas fa-trash"></i> Delete';
                        }
                    });
                }
            });
        }

        // ============ Search Panels ============
        function searchPanels() {
            const query = document.getElementById('panelSearch').value.toLowerCase().trim();
            const cards = document.querySelectorAll('.panel-card');

            cards.forEach(card => {
                const title = card.dataset.name?.toLowerCase() || '';
                const desc = card.querySelector('.panel-card-desc')?.textContent?.toLowerCase() || '';
                const match = title.includes(query) || desc.includes(query);
                card.style.display = match ? '' : 'none';
            });
        }

        // ============ Sort Panels ============
        function sortPanels() {
            const sort = document.getElementById('sortPanels').value;
            const grid = document.getElementById('panelsGrid');
            if (!grid) return;

            const cards = Array.from(grid.querySelectorAll('.panel-card'));

            cards.sort((a, b) => {
                const nameA = a.dataset.name || '';
                const nameB = b.dataset.name || '';

                switch(sort) {
                    case 'az':
                        return nameA.localeCompare(nameB);
                    case 'za':
                        return nameB.localeCompare(nameA);
                    case 'newest':
                        return 0;
                    case 'oldest':
                        return 0;
                    default:
                        return 0;
                }
            });

            if (sort === 'oldest') {
                cards.reverse();
            }

            cards.forEach(card => grid.appendChild(card));
        }

        // ============ Close modal on escape key ============
        document.addEventListener('keydown', function(event) {
            if (event.key === 'Escape') {
                closeDeleteModal();
            }
        });

        // ============ Close modal on overlay click ============
        document.addEventListener('click', function(event) {
            const modal = document.getElementById('deleteModal');
            if (event.target === modal) {
                closeDeleteModal();
            }
        });

        // ============ Initialize ============
        document.addEventListener('DOMContentLoaded', function() {
            // Any additional initialization
        });

        // Make functions globally accessible
        window.showToast = showToast;
        window.editPanel = editPanel;
        window.openDeleteModal = openDeleteModal;
        window.closeDeleteModal = closeDeleteModal;
        window.confirmDelete = confirmDelete;
        window.searchPanels = searchPanels;
        window.sortPanels = sortPanels;
    </script>

</body>
</html>
