<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title || 'Quick Responses — Sentinal' %></title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@400;500;600;700;800&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        /* Same styles as templates/index.ejs - simplified */
        :root {
            --ink: #060A10;
            --panel: #0D1520;
            --panel-raised: #111D2C;
            --panel-hover: #162033;
            --line: rgba(255,255,255,0.07);
            --line-bright: rgba(255,255,255,0.13);
            --text: #E6EDF6;
            --muted: #6C7A90;
            --muted-dim: #3E4A5C;
            --signal: #3DFFB8;
            --signal-tab: rgba(61,255,184,0.08);
            --signal-glow: rgba(61,255,184,0.15);
            --signal-hover: rgba(61,255,184,0.18);
            --gold: #F5C842;
            --gold-tab: rgba(245,200,66,0.12);
            --violet: #8B7EFF;
            --violet-tab: rgba(139,126,255,0.12);
            --red: #F87171;
            --red-bg: rgba(248,113,113,0.08);
            --red-border: rgba(248,113,113,0.22);
            --discord: #5865F2;
            --discord-hover: #4752C4;
        }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Inter', -apple-system, sans-serif; background: var(--ink); color: var(--text); min-height: 100vh; overflow-x: hidden; }
        /* Same navbar, sidebar, header, grid, card styles as templates/index.ejs */
        .navbar { /* ... copy from templates/index.ejs ... */ }
        .page-wrapper { /* ... */ }
        .sidebar { /* ... */ }
        .content { /* ... */ }
        .page-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px; flex-wrap: wrap; gap: 16px; }
        .page-header h1 { font-family: 'Space Grotesk', sans-serif; font-size: 28px; font-weight: 700; color: #fff; }
        .page-header p { color: var(--muted); font-size: 16px; margin-top: 4px; }
        .btn-primary { padding: 10px 24px; background: var(--signal); color: var(--ink); border: none; border-radius: 10px; font-weight: 700; font-size: 14px; cursor: pointer; transition: all 0.2s ease; display: inline-flex; align-items: center; gap: 8px; font-family: 'Inter', sans-serif; text-decoration: none; }
        .btn-primary:hover { transform: translateY(-1px); box-shadow: 0 4px 20px var(--signal-glow); }
        .btn-edit { padding: 6px 16px; border-radius: 8px; font-size: 13px; font-weight: 600; cursor: pointer; border: none; background: var(--signal-tab); color: var(--signal); border: 1px solid rgba(61,255,184,0.2); transition: all 0.18s ease; font-family: 'Inter', sans-serif; display: inline-flex; align-items: center; gap: 6px; }
        .btn-edit:hover { background: var(--signal-hover); }
        .btn-delete { padding: 6px 16px; border-radius: 8px; font-size: 13px; font-weight: 600; cursor: pointer; border: none; background: var(--red-bg); color: var(--red); border: 1px solid var(--red-border); transition: all 0.18s ease; font-family: 'Inter', sans-serif; display: inline-flex; align-items: center; gap: 6px; }
        .btn-delete:hover { background: rgba(248,113,113,0.2); }
        .responses-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(350px, 1fr)); gap: 20px; margin-top: 8px; }
        .response-card { background: var(--panel); border: 1px solid var(--line); border-radius: 14px; padding: 24px; transition: all 0.2s ease; }
        .response-card:hover { border-color: var(--line-bright); transform: translateY(-2px); }
        .response-card .card-top { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 10px; }
        .response-card .card-title { font-size: 18px; font-weight: 600; color: #fff; font-family: 'Space Grotesk', sans-serif; }
        .response-card .card-shortcut { font-size: 12px; color: var(--muted); background: var(--panel-raised); padding: 2px 12px; border-radius: 4px; font-family: 'IBM Plex Mono', monospace; }
        .response-card .card-desc { color: var(--muted); font-size: 14px; margin-bottom: 16px; line-height: 1.5; max-height: 80px; overflow: hidden; }
        .response-card .card-stats { display: flex; gap: 20px; padding: 12px 0; border-top: 1px solid var(--line); margin-bottom: 16px; }
        .response-card .card-stats .stat { font-size: 13px; color: var(--muted); display: flex; align-items: center; gap: 6px; }
        .response-card .card-stats .stat strong { color: var(--text); }
        .response-card .card-actions { display: flex; gap: 10px; flex-wrap: wrap; }
        .empty-state { text-align: center; padding: 60px 20px; background: var(--panel); border: 2px dashed var(--line); border-radius: 14px; margin-top: 20px; grid-column: 1 / -1; }
        .empty-state .empty-icon { font-size: 56px; color: var(--muted-dim); margin-bottom: 16px; }
        .empty-state h3 { font-family: 'Space Grotesk', sans-serif; font-size: 24px; color: #fff; margin-bottom: 8px; }
        .empty-state p { color: var(--muted); font-size: 16px; margin-bottom: 24px; }
        .toast-container { position: fixed; bottom: 24px; right: 24px; z-index: 9999; display: flex; flex-direction: column; gap: 10px; max-width: 380px; width: 100%; }
        .toast { background: var(--panel); border: 1px solid var(--line); border-radius: 12px; padding: 14px 20px; display: flex; align-items: center; gap: 12px; box-shadow: 0 8px 32px rgba(0,0,0,0.4); animation: slideIn 0.3s ease; backdrop-filter: blur(10px); border-left: 4px solid var(--signal); }
        .toast .toast-icon { color: var(--signal); font-size: 18px; flex-shrink: 0; }
        .toast .toast-content { flex: 1; font-size: 13px; color: var(--text); line-height: 1.4; }
        .toast .toast-close { background: none; border: none; color: var(--muted-dim); cursor: pointer; font-size: 14px; padding: 4px; }
        .toast .toast-close:hover { color: var(--text); }
        .toast.error { border-left-color: var(--red); }
        .toast.error .toast-icon { color: var(--red); }
        .toast.success { border-left-color: var(--signal); }
        .toast.success .toast-icon { color: var(--signal); }
        @keyframes slideIn { from { opacity: 0; transform: translateX(40px); } to { opacity: 1; transform: translateX(0); } }
        @keyframes slideOut { from { opacity: 1; transform: translateX(0); } to { opacity: 0; transform: translateX(40px); } }
        .toast.hiding { animation: slideOut 0.3s ease forwards; }
        .footer { border-top: 1px solid var(--line); margin-top: 60px; padding: 28px 48px; text-align: center; color: var(--muted-dim); font-size: 13px; font-family: 'IBM Plex Mono', monospace; letter-spacing: 0.5px; }
        @media (max-width: 768px) { /* ... responsive styles ... */ }
    </style>
</head>
<body>
    <!-- Same navbar, sidebar as other pages -->
    <nav class="navbar"><!-- ... same as templates/index.ejs ... --></nav>
    <div class="toast-container" id="toastContainer"></div>
    <div class="page-wrapper">
        <aside class="sidebar"><!-- ... same as templates/index.ejs ... --></aside>
        <div class="content">
            <div class="page-header">
                <div>
                    <h1>Quick Responses</h1>
                    <p>Create reusable responses for common questions</p>
                </div>
                <button class="btn-primary" onclick="showToast('Create response form opening...', 'info')">
                    <i class="fas fa-plus"></i> Create Response
                </button>
            </div>

            <% if (responses && responses.length > 0) { %>
                <div class="responses-grid">
                    <% responses.forEach(response => { %>
                        <div class="response-card" data-response-id="<%= response._id %>">
                            <div class="card-top">
                                <span class="card-title"><%= response.name %></span>
                                <span class="card-shortcut">!quick <%= response.shortcut || 'N/A' %></span>
                            </div>
                            <div class="card-desc"><%= response.content ? response.content.substring(0, 150) + (response.content.length > 150 ? '...' : '') : 'No content' %></div>
                            <div class="card-stats">
                                <span class="stat">📊 Used <strong><%= response.useCount || 0 %></strong> times</span>
                                <span class="stat">📂 <strong><%= response.category || 'General' %></strong></span>
                                <span class="stat">🔘 <strong><%= response.enabled ? 'Enabled' : 'Disabled' %></strong></span>
                            </div>
                            <div class="card-actions">
                                <button class="btn-edit" onclick="editResponse('<%= response._id %>')">
                                    <i class="fas fa-edit"></i> Edit
                                </button>
                                <button class="btn-delete" onclick="deleteResponse('<%= response._id %>', '<%= response.name %>')">
                                    <i class="fas fa-trash"></i> Delete
                                </button>
                            </div>
                        </div>
                    <% }) %>
                </div>
            <% } else { %>
                <div class="empty-state">
                    <div class="empty-icon">💬</div>
                    <h3>No Quick Responses</h3>
                    <p>Create quick responses to answer common questions efficiently.</p>
                    <button class="btn-primary" onclick="showToast('Create response form opening...', 'info')">
                        <i class="fas fa-plus"></i> Create Response
                    </button>
                </div>
            <% } %>

        </div>
    </div>
    <footer class="footer">© 2026 SENTINAL — STATUS: OPERATIONAL</footer>

    <script>
        function showToast(message, type = 'info') {
            const container = document.getElementById('toastContainer');
            const toast = document.createElement('div');
            toast.className = 'toast ' + type;
            toast.innerHTML = `
                <span class="toast-icon"><i class="fas fa-${type === 'success' ? 'check-circle' : type === 'error' ? 'exclamation-circle' : 'info-circle'}"></i></span>
                <span class="toast-content">${message}</span>
                <button class="toast-close" onclick="this.closest('.toast').classList.add('hiding'); setTimeout(() => this.closest('.toast').remove(), 300);">
                    <i class="fas fa-times"></i>
                </button>
            `;
            container.appendChild(toast);
            setTimeout(() => {
                if (toast.parentNode) {
                    toast.classList.add('hiding');
                    setTimeout(() => { if (toast.parentNode) toast.remove(); }, 300);
                }
            }, 4000);
        }

        function editResponse(responseId) {
            showToast('Edit response: ' + responseId, 'info');
        }

        function deleteResponse(responseId, responseName) {
            if (!confirm(`Are you sure you want to delete the response "${responseName}"?`)) return;
            showToast('✅ Response deleted!', 'success');
        }

        window.showToast = showToast;
        window.editResponse = editResponse;
        window.deleteResponse = deleteResponse;
    </script>
</body>
</html>
