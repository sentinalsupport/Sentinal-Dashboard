<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title || 'Error — Sentinal' %></title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Inter', -apple-system, sans-serif;
            background: #05070C;
            color: #E9EDF6;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
            padding: 20px;
            position: relative;
        }
        body::before {
            content: '';
            position: fixed;
            top: -25%; left: 50%;
            width: 800px; height: 800px;
            transform: translateX(-50%);
            background: radial-gradient(circle, rgba(61, 255, 184, 0.06) 0%, rgba(61, 255, 184, 0) 60%);
            pointer-events: none;
        }
        .error-container { max-width: 500px; position: relative; z-index: 2; }
        .error-container .icon { font-size: 64px; margin-bottom: 16px; }
        .error-container h1 {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 36px; font-weight: 700;
            margin-bottom: 8px; color: #FFFFFF;
        }
        .error-container p {
            color: #6C7588;
            font-size: 16px;
            margin-bottom: 24px;
            line-height: 1.6;
        }
        .error-container .btn {
            display: inline-block;
            padding: 12px 28px;
            border-radius: 8px;
            background: #3DFFB8;
            color: #04140F;
            text-decoration: none;
            font-weight: 600;
            font-size: 14px;
            transition: all 0.2s ease;
            margin: 4px;
            border: none;
            cursor: pointer;
        }
        .error-container .btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 24px rgba(61, 255, 184, 0.3);
        }
        .error-container .btn-secondary {
            background: transparent;
            color: #6C7588;
            border: 1px solid rgba(255,255,255,0.07);
        }
        .error-container .btn-secondary:hover {
            background: rgba(255,255,255,0.04);
            color: #E9EDF6;
            box-shadow: none;
        }
    </style>
</head>
<body>
    <div class="error-container">
        <div class="icon">⚠️</div>
        <h1><%= title || 'Something Went Wrong' %></h1>
        <p><%= message || 'An unexpected error occurred. Please try again later.' %></p>
        <a href="/dashboard" class="btn">Go to Dashboard</a>
        <a href="javascript:history.back()" class="btn btn-secondary">Go Back</a>
    </div>
</body>
</html>
