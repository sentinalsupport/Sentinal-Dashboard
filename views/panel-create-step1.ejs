<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Panel Designer — Sentinal</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/dashboard.css">
    <style>
        .designer-container {
            max-width: 900px;
            margin: 0 auto;
        }

        .designer-progress {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 32px;
            padding: 0 20px;
            position: relative;
        }

        .designer-progress::before {
            content: '';
            position: absolute;
            top: 50%;
            left: 40px;
            right: 40px;
            height: 2px;
            background: var(--border-soft);
            transform: translateY(-50%);
        }

        .progress-step {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 8px;
            position: relative;
            z-index: 1;
        }

        .progress-step .step-number {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            background: var(--bg-input);
            border: 2px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            font-size: 13px;
            color: var(--text-muted);
            transition: all 0.3s ease;
        }

        .progress-step.active .step-number {
            background: var(--accent);
            border-color: var(--accent);
            color: white;
        }

        .progress-step.completed .step-number {
            background: #34d399;
            border-color: #34d399;
            color: white;
        }

        .progress-step .step-label {
            font-size: 11px;
            color: var(--text-muted);
            font-weight: 500;
        }

        .progress-step.active .step-label {
            color: var(--text-primary);
        }

        .panel-type-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 16px;
            margin: 20px 0;
        }

        .panel-type-card {
            background: var(--bg-card);
            border: 2px solid var(--border-soft);
            border-radius: var(--radius-lg);
            padding: 24px;
            cursor: pointer;
            transition: all 0.18s ease;
            position: relative;
        }

        .panel-type-card:hover {
            border-color: var(--border);
        }

        .panel-type-card.selected {
            border-color: var(--accent);
            background: var(--accent-soft);
        }

        .panel-type-card.disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }

        .panel-type-card.disabled:hover {
            border-color: var(--border-soft);
        }

        .panel-type-card .coming-soon {
            position: absolute;
            top: 12px;
            right: 12px;
            font-size: 10px;
            font-weight: 700;
            color: var(--text-muted);
            background: var(--bg-input);
            padding: 2px 10px;
            border-radius: 100px;
            border: 1px solid var(--border-soft);
        }

        .panel-type-card .type-icon {
            font-size: 32px;
            margin-bottom: 12px;
            display: block;
        }

        .panel-type-card h3 {
            font-size: 16px;
            margin: 0 0 4px;
        }

        .panel-type-card p {
            color: var(--text-secondary);
            font-size: 13px;
            margin: 0;
            line-height: 1.5;
        }

        .panel-type-card .recommended {
            display: inline-block;
            font-size: 10px;
            font-weight: 700;
            color: var(--accent);
            background: var(--accent-soft);
            padding: 2px 10px;
            border-radius: 100px;
            margin-top: 8px;
        }

        .designer-actions {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-top: 32px;
            padding-top: 20px;
            border-top: 1px solid var(--border-soft);
        }

        .btn-back {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 10px 20px;
            border-radius: var(--radius-md);
            background: transparent;
            color: var(--text-secondary);
            border: 1px solid var(--border-soft);
            font-weight: 600;
            font-size: 13px;
            cursor: pointer;
            transition: all 0.18s ease;
            text-decoration: none;
        }

        .btn-back:hover {
            background: var(--bg-input-alt);
            color: var(--text-primary);
        }

        .btn-continue {
            padding: 10px 32px;
            border-radius: var(--radius-md);
            background: var(--accent);
            color: white;
            border: none;
            font-weight: 600;
            font-size: 13px;
            cursor: pointer;
            transition: all 0.18s ease;
        }

        .btn-continue:hover {
            background: var(--accent-hover);
            transform: translateY(-1px);
        }

        .btn-continue:disabled {
            opacity: 0.5;
            cursor: not-allowed;
            transform: none;
        }

        .form-hint {
            color: var(--text-muted);
            font-size: 13px;
            margin-bottom: 20px;
        }

        @media (max-width: 768px) {
            .panel-type-grid {
                grid-template-columns: 1fr;
            }
            .designer-progress {
                overflow-x: auto;
                gap: 8px;
            }
            .designer-progress::before {
                display: none;
            }
            .progress-step .step-label {
                display: none;
            }
        }
    </style>
</head>
<body>
    <div class="layout">
        <aside class="sidebar">
            <div class="brand">
                <span class="brand-icon">🛡️</span>
                Sentinal
            </div>
            <div class="server-switcher">
                <div class="server-avatar"></div>
                <div>
                    <div class="server-name"><%= locals.guild ? guild.name : 'Sentinal Support' %></div>
                    <div class="server-plan">Free</div>
                </div>
            </div>
            <nav class="nav">
                <a href="/dashboard" class="nav-link nav-top"><span><span class="nav-icon">🏠</span> Dashboard</span></a>
                <div class="nav-group">
                    <a href="/servers" class="nav-link"><span><span class="nav-icon">🖥️</span> Servers</span></a>
                    <div class="nav-sub">
                        <a href="/servers/<%= locals.guild ? guild.id : '' %>/applications" class="nav-link"><span><span class="nav-icon">📄</span> Applications</span></a>
                        <a href="/servers/<%= locals.guild ? guild.id : '' %>/tickets" class="nav-link"><span><span class="nav-icon">🎫</span> Tickets</span></a>
                        <a href="/servers/<%= locals.guild ? guild.id : '' %>/panels" class="nav-link active"><span><span class="nav-icon">📋</span> Panels</span></a>
                    </div>
                </div>
            </nav>
            <div class="sidebar-footer">
                <a href="#" class="support-link"><span>💬</span> Support</a>
                <div class="user-card">
                    <div class="user-avatar"><%= locals.user ? (user.global_name ? user.global_name.charAt(0).toUpperCase() : user.username.charAt(0).toUpperCase()) : 'U' %></div>
                    <div>
                        <div class="user-name"><%= locals.user ? (user.global_name || user.username) : 'thedude12355' %></div>
                        <div class="user-plan-badge">FREE</div>
                    </div>
                </div>
            </div>
        </aside>

        <main class="content">
            <div class="designer-container">
                <!-- Status Bar -->
                <div style="display:flex; align-items:center; gap:12px; padding:12px 16px; background:var(--bg-card); border-radius:var(--radius-md); border:1px solid var(--border-soft); margin-bottom:24px;">
                    <span style="color:#34d399; font-size:12px; font-weight:600;">●</span>
                    <span style="color:var(--text-secondary); font-size:13px;">All Systems Operational</span>
                    <span style="margin-left:auto; color:var(--text-muted); font-size:12px;"><%= new Date().toLocaleString() %></span>
                </div>

                <h1 style="font-size:28px; font-weight:700; margin:0 0 4px;">Panel Designer</h1>
                <p style="color:var(--text-secondary); margin:0 0 24px;">Create a new panel for your server.</p>

                <!-- Progress Steps -->
                <div class="designer-progress">
                    <div class="progress-step active">
                        <div class="step-number">1</div>
                        <span class="step-label">Panel Type</span>
                    </div>
                    <div class="progress-step">
                        <div class="step-number">2</div>
                        <span class="step-label">Ticket Style</span>
                    </div>
                    <div class="progress-step">
                        <div class="step-number">3</div>
                        <span class="step-label">Send Channel</span>
                    </div>
                    <div class="progress-step">
                        <div class="step-number">4</div>
                        <span class="step-label">Panel Defaults</span>
                    </div>
                </div>

                <h2 style="font-size:18px; font-weight:600; margin:0 0 4px;">Select Panel Type</h2>
                <p class="form-hint">Choose what type of panel you want to create. This cannot be changed later.</p>

                <div class="panel-type-grid">
                    <div class="panel-type-card selected" data-type="ticket" onclick="selectType('ticket')">
                        <span class="type-icon">🎫</span>
                        <h3>Ticket Panel</h3>
                        <p>Create support tickets for users to communicate with your team in private channels.</p>
                        <span class="recommended">Recommended</span>
                    </div>

                    <div class="panel-type-card disabled" data-type="application" onclick="selectType('application')">
                        <span class="type-icon">📝</span>
                        <h3>Coming Soon</h3>
                        <p>Collect applications via modal forms. Staff can review, approve, or deny submissions.</p>
                        <span class="coming-soon">COMING SOON</span>
                    </div>
                </div>

                <div class="designer-actions">
                    <a href="/servers/<%= locals.guild ? guild.id : '' %>/panels" class="btn-back">
                        <i class="fas fa-arrow-left"></i> Back to Panels
                    </a>
                    <button class="btn-continue" onclick="continueStep()">
                        Continue <i class="fas fa-arrow-right"></i>
                    </button>
                </div>
            </div>
        </main>
    </div>

    <script>
        let selectedType = 'ticket';

        function selectType(type) {
            if (type === 'application') return;
            selectedType = type;
            document.querySelectorAll('.panel-type-card').forEach(c => c.classList.remove('selected'));
            document.querySelector(`.panel-type-card[data-type="${type}"]`).classList.add('selected');
        }

        function continueStep() {
            if (selectedType) {
                window.location.href = `/servers/<%= locals.guild ? guild.id : '' %>/panels/create/step2?type=${selectedType}`;
            }
        }
    </script>
</body>
</html>
