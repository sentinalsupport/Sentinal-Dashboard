<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title || 'Dashboard — Sentinal' %></title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Inter', -apple-system, sans-serif;
            background: #0A0E17;
            color: #E8EDF5;
            min-height: 100vh;
            display: flex;
        }

        /* ========== SIDEBAR ========== */
        .sidebar {
            width: 280px;
            background: rgba(14, 20, 34, 0.95);
            border-right: 1px solid rgba(255, 255, 255, 0.04);
            padding: 24px 16px;
            height: 100vh;
            position: sticky;
            top: 0;
            overflow-y: auto;
            flex-shrink: 0;
        }
        .sidebar .logo {
            font-size: 20px;
            font-weight: 700;
            color: #FFFFFF;
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 0 12px 24px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.04);
            margin-bottom: 20px;
        }
        .sidebar .logo .logo-icon {
            width: 36px;
            height: 36px;
            background: linear-gradient(135deg, #2563EB, #1D4ED8);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
        }
        .sidebar .logo span { color: #60A5FA; }
        
        .sidebar .nav-section {
            margin-bottom: 24px;
        }
        .sidebar .nav-section .section-title {
            font-size: 11px;
            font-weight: 600;
            color: #5A6B85;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            padding: 0 12px;
            margin-bottom: 8px;
        }
        .sidebar .nav-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 10px 12px;
            border-radius: 8px;
            color: #8B9BB5;
            text-decoration: none;
            font-size: 14px;
            font-weight: 500;
            transition: all 0.2s ease;
            cursor: pointer;
            border: none;
            background: none;
            width: 100%;
            text-align: left;
        }
        .sidebar .nav-item:hover {
            background: rgba(255, 255, 255, 0.04);
            color: #E8EDF5;
        }
        .sidebar .nav-item.active {
            background: rgba(37, 99, 235, 0.12);
            color: #60A5FA;
        }
        .sidebar .nav-item i {
            width: 20px;
            font-size: 16px;
        }
        .sidebar .nav-item .badge {
            margin-left: auto;
            background: rgba(239, 68, 68, 0.15);
            color: #EF4444;
            font-size: 11px;
            padding: 2px 8px;
            border-radius: 12px;
        }
        .sidebar .nav-item .badge.coming {
            background: rgba(245, 158, 11, 0.15);
            color: #FBBF24;
        }
        .sidebar .nav-item .badge.live {
            background: rgba(34, 197, 94, 0.15);
            color: #4ADE80;
        }

        .sidebar .user-section {
            border-top: 1px solid rgba(255, 255, 255, 0.04);
            padding-top: 16px;
            margin-top: 16px;
        }
        .sidebar .user-section .user-info {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 8px 12px;
            border-radius: 8px;
        }
        .sidebar .user-section .user-info .avatar {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            background: linear-gradient(135deg, #2563EB, #1D4ED8);
            overflow: hidden;
            flex-shrink: 0;
        }
        .sidebar .user-section .user-info .avatar img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }
        .sidebar .user-section .user-info .name {
            font-size: 13px;
            font-weight: 600;
            color: #E8EDF5;
        }
        .sidebar .user-section .user-info .plan {
            font-size: 11px;
            color: #5A6B85;
        }
        .sidebar .user-section .user-info .plan .premium-badge {
            color: #FBBF24;
        }

        /* ========== MAIN CONTENT ========== */
        .main-content {
            flex: 1;
            padding: 32px 40px;
            overflow-y: auto;
        }
        .main-content .page-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 32px;
            flex-wrap: wrap;
            gap: 16px;
        }
        .main-content .page-header h1 {
            font-size: 28px;
            font-weight: 800;
        }
        .main-content .page-header h1 span { color: #60A5FA; }
        .main-content .page-header .subtitle {
            color: #8B9BB5;
            font-size: 14px;
        }

        /* ========== SERVER SELECTOR ========== */
        .server-selector {
            background: rgba(255, 255, 255, 0.02);
            border: 1px solid rgba(255, 255, 255, 0.04);
            border-radius: 14px;
            padding: 20px 24px;
            margin-bottom: 32px;
        }
        .server-selector .selector-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 16px;
            flex-wrap: wrap;
            gap: 12px;
        }
        .server-selector .selector-header h3 {
            font-size: 16px;
            font-weight: 600;
        }
        .server-selector .selector-header .server-count {
            color: #8B9BB5;
            font-size: 13px;
        }
        .server-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
            gap: 12px;
        }
        .server-grid .server-card {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 16px;
            background: rgba(255, 255, 255, 0.02);
            border: 1px solid rgba(255, 255, 255, 0.04);
            border-radius: 10px;
            text-decoration: none;
            color: #E8EDF5;
            transition: all 0.2s ease;
            cursor: pointer;
        }
        .server-grid .server-card:hover {
            border-color: rgba(37, 99, 235, 0.2);
            background: rgba(255, 255, 255, 0.04);
            transform: translateY(-2px);
        }
        .server-grid .server-card .icon {
            width: 36px;
            height: 36px;
            border-radius: 8px;
            background: linear-gradient(135deg, #1E3A5F, #1A365D);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 16px;
            font-weight: 700;
            color: #60A5FA;
            overflow: hidden;
            flex-shrink: 0;
        }
        .server-grid .server-card .icon img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }
        .server-grid .server-card .info {
            flex: 1;
            min-width: 0;
        }
        .server-grid .server-card .info .name {
            font-size: 14px;
            font-weight: 600;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }
        .server-grid .server-card .info .role {
            font-size: 12px;
            color: #5A6B85;
        }
        .server-grid .server-card .action {
            font-size: 12px;
            color: #2563EB;
            font-weight: 500;
        }

        /* ========== SERVER CONTEXT BAR ========== */
        .server-context {
            background: rgba(37, 99, 235, 0.08);
            border: 1px solid rgba(37, 99, 235, 0.15);
            border-radius: 12px;
            padding: 16px 24px;
            margin-bottom: 24px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 12px;
        }
        .server-context .server-info {
            display: flex;
            align-items: center;
            gap: 12px;
        }
        .server-context .server-info .icon {
            width: 40px;
            height: 40px;
            border-radius: 10px;
            background: linear-gradient(135deg, #1E3A5F, #1A365D);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
            font-weight: 700;
            color: #60A5FA;
            overflow: hidden;
        }
        .server-context .server-info .icon img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }
        .server-context .server-info .details .name {
            font-size: 16px;
            font-weight: 600;
        }
        .server-context .server-info .details .members {
            font-size: 13px;
            color: #8B9BB5;
        }
        .server-context .server-actions {
            display: flex;
            gap: 8px;
        }
        .server-context .server-actions .btn-sm {
            padding: 6px 16px;
            border-radius: 6px;
            background: rgba(255, 255, 255, 0.04);
            color: #8B9BB5;
            text-decoration: none;
            font-size: 12px;
            font-weight: 500;
            border: 1px solid rgba(255, 255, 255, 0.04);
            transition: all 0.2s ease;
            cursor: pointer;
        }
        .server-context .server-actions .btn-sm:hover {
            background: rgba(37, 99, 235, 0.1);
            color: #60A5FA;
            border-color: rgba(37, 99, 235, 0.2);
        }

        /* ========== MODULES ========== */
        .modules-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 20px;
            margin-top: 8px;
        }
        .module-card {
            background: rgba(255, 255, 255, 0.02);
            border: 1px solid rgba(255, 255, 255, 0.04);
            border-radius: 14px;
            padding: 20px 24px;
            transition: all 0.3s ease;
        }
        .module-card:hover {
            border-color: rgba(37, 99, 235, 0.15);
            transform: translateY(-2px);
        }
        .module-card .module-header {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 8px;
        }
        .module-card .module-header i {
            font-size: 20px;
            color: #2563EB;
        }
        .module-card .module-header h4 {
            font-size: 15px;
            font-weight: 600;
        }
        .module-card .module-header .status-live {
            font-size: 10px;
            padding: 2px 8px;
            border-radius: 12px;
            background: rgba(34, 197, 94, 0.15);
            color: #4ADE80;
            font-weight: 500;
        }
        .module-card .module-header .status-coming {
            font-size: 10px;
            padding: 2px 8px;
            border-radius: 12px;
            background: rgba(245, 158, 11, 0.15);
            color: #FBBF24;
            font-weight: 500;
        }
        .module-card p {
            color: #8B9BB5;
            font-size: 13px;
            line-height: 1.5;
        }
        .module-card .module-actions {
            display: flex;
            gap: 8px;
            margin-top: 12px;
            flex-wrap: wrap;
        }
        .module-card .module-actions .btn-module {
            padding: 6px 16px;
            border-radius: 6px;
            background: rgba(255, 255, 255, 0.04);
            color: #8B9BB5;
            text-decoration: none;
            font-size: 12px;
            font-weight: 500;
            border: 1px solid rgba(255, 255, 255, 0.04);
            transition: all 0.2s ease;
            cursor: pointer;
        }
        .module-card .module-actions .btn-module:hover {
            background: rgba(37, 99, 235, 0.1);
            color: #60A5FA;
            border-color: rgba(37, 99, 235, 0.2);
        }
        .module-card .module-actions .btn-module.primary {
            background: rgba(37, 99, 235, 0.15);
            color: #60A5FA;
            border-color: rgba(37, 99, 235, 0.2);
        }
        .module-card .module-actions .btn-module.primary:hover {
            background: rgba(37, 99, 235, 0.25);
        }

        /* ========== PREMIUM ========== */
        .premium-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 20px;
            margin-top: 8px;
        }
        .premium-card {
            background: rgba(255, 255, 255, 0.02);
            border: 1px solid rgba(255, 255, 255, 0.04);
            border-radius: 14px;
            padding: 24px;
            text-align: center;
            transition: all 0.3s ease;
        }
        .premium-card:hover {
            transform: translateY(-4px);
            border-color: rgba(245, 158, 11, 0.2);
        }
        .premium-card.popular {
            border-color: rgba(245, 158, 11, 0.3);
            background: rgba(245, 158, 11, 0.04);
        }
        .premium-card .price {
            font-size: 36px;
            font-weight: 800;
            color: #FBBF24;
        }
        .premium-card .price span {
            font-size: 16px;
            color: #8B9BB5;
            font-weight: 400;
        }
        .premium-card .plan-name {
            font-size: 18px;
            font-weight: 700;
            margin: 8px 0 4px;
        }
        .premium-card .plan-desc {
            color: #8B9BB5;
            font-size: 13px;
            margin-bottom: 16px;
        }
        .premium-card .features {
            list-style: none;
            text-align: left;
            margin: 16px 0;
        }
        .premium-card .features li {
            padding: 6px 0;
            color: #8B9BB5;
            font-size: 13px;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .premium-card .features li i {
            color: #4ADE80;
            font-size: 14px;
            width: 20px;
        }
        .premium-card .btn-upgrade {
            padding: 10px 32px;
            border-radius: 8px;
            border: none;
            font-weight: 600;
            font-size: 14px;
            cursor: pointer;
            transition: all 0.2s ease;
            background: linear-gradient(135deg, #F59E0B, #D97706);
            color: #FFFFFF;
            width: 100%;
        }
        .premium-card .btn-upgrade:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 16px rgba(245, 158, 11, 0.25);
        }

        /* ========== RESPONSIVE ========== */
        @media (max-width: 1024px) {
            .sidebar { width: 240px; padding: 16px 12px; }
            .main-content { padding: 24px 24px; }
        }
        @media (max-width: 768px) {
            body { flex-direction: column; }
            .sidebar {
                width: 100%;
                height: auto;
                position: relative;
                padding: 16px;
                border-right: none;
                border-bottom: 1px solid rgba(255, 255, 255, 0.04);
            }
            .sidebar .nav-section { display: flex; flex-wrap: wrap; gap: 4px; }
            .sidebar .nav-section .section-title { display: none; }
            .sidebar .nav-item { padding: 8px 12px; font-size: 13px; }
            .sidebar .user-section { display: none; }
            .main-content { padding: 16px; }
            .server-grid { grid-template-columns: 1fr; }
            .modules-grid { grid-template-columns: 1fr; }
            .premium-grid { grid-template-columns: 1fr; }
            .server-context { flex-direction: column; align-items: stretch; }
            .main-content .page-header h1 { font-size: 22px; }
        }
        @media (max-width: 480px) {
            .server-selector { padding: 16px; }
            .module-card { padding: 16px; }
            .premium-card { padding: 16px; }
            .server-context { padding: 12px 16px; }
        }

        ::-webkit-scrollbar { width: 4px; height: 4px; }
        ::-webkit-scrollbar-track { background: #0A0E17; }
        ::-webkit-scrollbar-thumb { background: #1E4B8A; border-radius: 4px; }
        ::-webkit-scrollbar-thumb:hover { background: #2563EB; }
    </style>
</head>
<body>

    <!-- ========== SIDEBAR ========== -->
    <nav class="sidebar">
        <div class="logo">
            <div class="logo-icon">⚡</div>
            Sentinal <span>Dashboard</span>
        </div>

        <div class="nav-section">
            <div class="section-title">Navigation</div>
            <a href="/dashboard" class="nav-item active">
                <i class="fas fa-home"></i> Home
            </a>
            <a href="/servers" class="nav-item">
                <i class="fas fa-server"></i> Servers
            </a>
            <a href="#" class="nav-item" onclick="alert('Coming soon! 🚀')">
                <i class="fas fa-chart-bar"></i> Analytics
                <span class="badge coming">Soon</span>
            </a>
        </div>

        <div class="nav-section">
            <div class="section-title">Modules</div>
            <a href="#" class="nav-item active" onclick="showModule('applications')">
                <i class="fas fa-file-alt"></i> Applications
                <span class="badge live">Live</span>
            </a>
            <a href="#" class="nav-item active" onclick="showModule('tickets')">
                <i class="fas fa-ticket"></i> Tickets
                <span class="badge live">Live</span>
            </a>
            <a href="#" class="nav-item active" onclick="showModule('verification')">
                <i class="fas fa-shield-halved"></i> Verification
                <span class="badge live">Live</span>
            </a>
            <a href="#" class="nav-item" onclick="alert('Coming soon! 🚀')">
                <i class="fas fa-robot"></i> Automation
                <span class="badge coming">Soon</span>
            </a>
            <a href="#" class="nav-item" onclick="alert('Coming soon! 🚀')">
                <i class="fas fa-users"></i> Community
                <span class="badge coming">Soon</span>
            </a>
            <a href="#" class="nav-item" onclick="alert('Coming soon! 🚀')">
                <i class="fas fa-clipboard-list"></i> Audit & Logs
                <span class="badge coming">Soon</span>
            </a>
            <a href="#" class="nav-item" onclick="alert('Coming soon! 🚀')">
                <i class="fas fa-gift"></i> Giveaways
                <span class="badge coming">Soon</span>
            </a>
        </div>

        <div class="nav-section">
            <div class="section-title">Premium</div>
            <a href="#" class="nav-item" onclick="showModule('premium')">
                <i class="fas fa-crown" style="color: #FBBF24;"></i> Upgrade
                <span class="badge" style="background: rgba(245, 158, 11, 0.15); color: #FBBF24;">⭐</span>
            </a>
        </div>

        <div class="user-section">
            <div class="user-info">
                <div class="avatar">
                    <% if (user && user.avatar) { %>
                        <img src="https://cdn.discordapp.com/avatars/<%= user.id %>/<%= user.avatar %>.png" alt="Avatar">
                    <% } else { %>
                        <%= user ? user.username ? user.username.charAt(0).toUpperCase() : 'U' : 'U' %>
                    <% } %>
                </div>
                <div>
                    <div class="name"><%= user ? user.global_name || user.username : 'User' %></div>
                    <div class="plan"><i class="fas fa-circle" style="color: #4ADE80; font-size: 8px; margin-right: 4px;"></i> <span class="premium-badge">Free</span></div>
                </div>
                <a href="/logout" style="margin-left: auto; color: #5A6B85; text-decoration: none; font-size: 14px;">
                    <i class="fas fa-sign-out-alt"></i>
                </a>
            </div>
        </div>
    </nav>

    <!-- ========== MAIN CONTENT ========== -->
    <main class="main-content" id="mainContent">

        <!-- ===== HEADER ===== -->
        <div class="page-header">
            <div>
                <h1>Welcome back, <span><%= user ? user.global_name || user.username : 'User' %></span>!</h1>
                <div class="subtitle">Select a server to start managing it.</div>
            </div>
        </div>

        <!-- ===== SERVER SELECTOR ===== -->
        <div class="server-selector">
            <div class="selector-header">
                <h3><i class="fas fa-server" style="color: #2563EB; margin-right: 8px;"></i> Select a Server</h3>
                <span class="server-count"><%= servers ? servers.length : 0 %> servers with admin access</span>
            </div>

            <% if (servers && servers.length > 0) { %>
                <div class="server-grid">
                    <% servers.forEach(function(guild) { %>
                        <a href="/server/<%= guild.id %>" class="server-card">
                            <div class="icon">
                                <% if (guild.icon) { %>
                                    <img src="https://cdn.discordapp.com/icons/<%= guild.id %>/<%= guild.icon %>.png" alt="<%= guild.name %>">
                                <% } else { %>
                                    <%= guild.name ? guild.name.charAt(0).toUpperCase() : '?' %>
                                <% } %>
                            </div>
                            <div class="info">
                                <div class="name"><%= guild.name %></div>
                                <div class="role"><i class="fas fa-crown" style="color: #FBBF24; font-size: 11px;"></i> Owner</div>
                            </div>
                            <div class="action">Manage →</div>
                        </a>
                    <% }); %>
                </div>
            <% } else { %>
                <div style="text-align: center; padding: 40px 20px; color: #5A6B85;">
                    <i class="fas fa-server" style="font-size: 48px; color: #2563EB; margin-bottom: 16px; display: block;"></i>
                    <h3 style="color: #E8EDF5; margin-bottom: 8px;">No Servers Found</h3>
                    <p>You don't have administrator access to any servers.</p>
                    <a href="#" class="btn-module primary" style="display: inline-block; margin-top: 12px; padding: 10px 24px; border-radius: 8px; background: #2563EB; color: #FFFFFF; text-decoration: none; font-weight: 600;">Invite Bot to a Server</a>
                </div>
            <% } %>
        </div>

        <!-- ===== MODULES ===== -->
        <h3 style="font-size: 18px; font-weight: 700; margin-bottom: 16px;"><i class="fas fa-puzzle-piece" style="color: #2563EB; margin-right: 8px;"></i> Available Modules</h3>
        <div class="modules-grid">

            <!-- Applications -->
            <div class="module-card" id="module-applications">
                <div class="module-header">
                    <i class="fas fa-file-alt"></i>
                    <h4>Applications</h4>
                    <span class="status-live">Live</span>
                </div>
                <p>Create custom application forms for staff, partners, or events. Review submissions and manage applicants.</p>
                <div class="module-actions">
                    <a href="#" class="btn-module primary" onclick="alert('📋 Applications module coming soon! Select a server first to configure.')">Configure</a>
                    <a href="#" class="btn-module" onclick="alert('📋 View submissions coming soon!')">Manage</a>
                </div>
            </div>

            <!-- Tickets -->
            <div class="module-card" id="module-tickets">
                <div class="module-header">
                    <i class="fas fa-ticket"></i>
                    <h4>Tickets</h4>
                    <span class="status-live">Live</span>
                </div>
                <p>Create support tickets for users to open in your server. Manage transcripts and quick responses.</p>
                <div class="module-actions">
                    <a href="#" class="btn-module primary" onclick="alert('🎫 Tickets module coming soon! Select a server first to configure.')">Configure</a>
                    <a href="#" class="btn-module" onclick="alert('📝 Ticket templates coming soon!')">Templates</a>
                </div>
            </div>

            <!-- Verification -->
            <div class="module-card" id="module-verification">
                <div class="module-header">
                    <i class="fas fa-shield-halved"></i>
                    <h4>Verification</h4>
                    <span class="status-live">Live</span>
                </div>
                <p>Set up verification with auto-roles, welcome messages, and advanced security settings.</p>
                <div class="module-actions">
                    <a href="#" class="btn-module primary" onclick="alert('🔒 Verification module coming soon! Select a server first to configure.')">Configure</a>
