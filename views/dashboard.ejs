<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title || 'Dashboard — Sentinal' %></title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@400;500;600;700;800&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --ink: #05070C;
            --panel: #0B1018;
            --panel-raised: #0F1622;
            --line: rgba(255, 255, 255, 0.07);
            --line-bright: rgba(255, 255, 255, 0.14);
            --text: #E9EDF6;
            --muted: #6C7588;
            --muted-dim: #444C5E;
            --signal: #3DFFB8;
            --signal-dim: #1F8C6B;
            --signal-glow: rgba(61, 255, 184, 0.18);
            --violet: #8B93FF;
            --danger: #FF6B6B;
            --gold: #FBBF24;
        }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Inter', -apple-system, sans-serif;
            background: var(--ink);
            color: var(--text);
            min-height: 100vh;
            position: relative;
        }
        .navbar {
            background: rgba(5, 7, 12, 0.7);
            backdrop-filter: blur(20px) saturate(140%);
            border-bottom: 1px solid var(--line);
            padding: 0 32px;
            height: 68px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: sticky;
            top: 0;
            z-index: 100;
        }
        .navbar .brand {
            display: flex;
            align-items: center;
            gap: 11px;
            font-family: 'Space Grotesk', sans-serif;
            font-size: 17px;
            font-weight: 600;
            color: #FFFFFF;
            text-decoration: none;
        }
        .navbar .brand .logo-icon {
            width: 34px; height: 34px;
            border-radius: 9px;
            background: var(--panel-raised);
            border: 1px solid var(--line-bright);
            display: flex; align-items: center; justify-content: center;
        }
        .navbar .brand .logo-icon svg { width: 18px; height: 18px; }
        .navbar .brand .brand-sub {
            color: var(--muted);
            font-weight: 500;
            font-size: 13px;
            padding-left: 11px;
            border-left: 1px solid var(--line);
        }
        .navbar .nav-links { display: flex; align-items: center; gap: 30px; }
        .navbar .nav-links a {
            color: var(--muted);
            text-decoration: none;
            font-size: 13px;
            font-weight: 500;
            transition: color 0.2s ease;
        }
        .navbar .nav-links a:hover { color: var(--text); }
        .navbar .nav-links a.active { color: #FFFFFF; }
        .navbar .nav-links a.active::after {
            content: '';
            position: absolute;
            bottom: -23px; left: 0; right: 0;
            height: 2px;
            background: var(--signal);
        }
        .navbar .nav-right { display: flex; align-items: center; gap: 16px; }
        .navbar .user-avatar {
            width: 32px; height: 32px;
            border-radius: 50%;
            background: var(--panel-raised);
            border: 1px solid var(--line-bright);
            display: flex; align-items: center; justify-content: center;
            overflow: hidden;
        }
        .navbar .user-avatar img { width: 100%; height: 100%; object-fit: cover; }
        .navbar .logout-btn {
            background: transparent;
            color: var(--muted);
            padding: 7px 16px;
            border-radius: 100px;
            text-decoration: none;
            font-size: 12px;
            font-weight: 500;
            border: 1px solid var(--line);
            transition: all 0.2s ease;
            display: flex;
            align-items: center;
            gap: 6px;
        }
        .navbar .logout-btn:hover {
            background: rgba(239, 68, 68, 0.08);
            color: #F87171;
            border-color: rgba(239, 68, 68, 0.25);
        }
        .container { max-width: 1200px; margin: 0 auto; padding: 32px; }
        .welcome { font-size: 28px; font-weight: 800; margin-bottom: 4px; }
        .welcome span { color: var(--signal); }
        .welcome-sub { color: var(--muted); font-size: 15px; margin-bottom: 28px; }
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 16px;
            margin-bottom: 32px;
        }
        .stat-card {
            background: var(--panel);
            border: 1px solid var(--line);
            border-radius: 12px;
            padding: 20px;
            text-align: center;
        }
        .stat-card .number { font-size: 32px; font-weight: 800; color: var(--signal); }
        .stat-card .label { font-size: 13px; color: var(--muted); margin-top: 4px; }
        .server-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 16px;
            margin-bottom: 32px;
        }
        .server-card {
            background: var(--panel);
            border: 1px solid var(--line);
            border-radius: 12px;
            padding: 16px 20px;
            display: flex;
            align-items: center;
            gap: 14px;
            text-decoration: none;
            color: var(--text);
            transition: all 0.2s ease;
        }
        .server-card:hover {
            border-color: var(--line-bright);
            transform: translateY(-2px);
        }
        .server-card .icon {
            width: 40px; height: 40px;
            border-radius: 10px;
            background: var(--panel-raised);
            display: flex; align-items: center; justify-content: center;
            font-size: 18px; font-weight: 700;
            overflow: hidden;
        }
        .server-card .icon img { width: 100%; height: 100%; object-fit: cover; }
        .server-card .info { flex: 1; }
        .server-card .info .name { font-weight: 600; }
        .server-card .info .role { font-size: 12px; color: var(--muted); }
        .server-card .action { color: var(--signal); font-size: 13px; font-weight: 500; }
        .modules-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 16px;
            margin-top: 16px;
        }
        .module-card {
            background: var(--panel);
            border: 1px solid var(--line);
            border-radius: 12px;
            padding: 20px 24px;
            transition: all 0.2s ease;
        }
        .module-card:hover { border-color: var(--line-bright); transform: translateY(-2px); }
        .module-card .header { display: flex; align-items: center; gap: 12px; margin-bottom: 8px; }
        .module-card .header i { font-size: 18px; color: var(--signal); }
        .module-card .header h4 { font-size: 15px; font-weight: 600; }
        .module-card p { color: var(--muted); font-size: 13px; line-height: 1.5; margin-bottom: 12px; }
        .module-card .actions { display: flex; gap: 8px; flex-wrap: wrap; }
        .module-card .actions .btn {
            padding: 6px 16px;
            border-radius: 6px;
            background: rgba(255, 255, 255, 0.04);
            color: var(--muted);
            text-decoration: none;
            font-size: 12px;
            font-weight: 500;
            border: 1px solid var(--line);
            transition: all 0.2s ease;
        }
        .module-card .actions .btn:hover { background: rgba(61, 255, 184, 0.1); color: var(--signal); }
        .module-card .actions .btn.primary { background: rgba(61, 255, 184, 0.12); color: var(--signal); border-color: rgba(61, 255, 184, 0.2); }
        .module-card .actions .btn.primary:hover { background: rgba(61, 255, 184, 0.2); }
        .module-card .status {
            font-size: 10px;
            padding: 2px 10px;
            border-radius: 100px;
            font-weight: 500;
        }
        .module-card .status.live { background: rgba(61, 255, 184, 0.12); color: var(--signal); }
        .module-card .status.coming { background: rgba(251, 191, 36, 0.12); color: var(--gold); }
        .footer {
            border-top: 1px solid var(--line);
            padding: 24px 32px;
            text-align: center;
            color: var(--muted-dim);
            font-size: 12.5px;
            font-family: 'IBM Plex Mono', monospace;
        }
        @media (max-width: 768px) {
            .navbar { padding: 0 16px; height: 60px; flex-wrap: wrap; gap: 8px; }
            .navbar .nav-links { gap: 16px; }
            .navbar .nav-links a { font-size: 12px; }
            .navbar .brand .brand-sub { display: none; }
            .container { padding: 16px; }
            .welcome { font-size: 22px; }
            .server-grid { grid-template-columns: 1fr; }
            .modules-grid { grid-template-columns: 1fr; }
            .stats-grid { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body>
