<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title || 'Dashboard — Sentinal' %></title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@400;500;600;700;800&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --ink: #060A10;
            --panel: #0D1520;
            --panel-raised: #111D2C;
            --panel-hover: #162033;
            --line: rgba(255,255,255,0.07);
            --line-bright: rgba(255,255,255,0.13);
            --text: #E6EDF6;
            --muted: #6C7A90;
            --muted-dim: #3E4A5C;
            --signal: #3DFFB8;
            --signal-tab: rgba(61,255,184,0.10);
            --signal-glow: rgba(61,255,184,0.18);
            --signal-mid: rgba(61,255,184,0.06);
            --gold: #F5C842;
            --gold-tab: rgba(245,200,66,0.12);
            --red: #F87171;
            --red-bg: rgba(248,113,113,0.08);
            --red-border: rgba(248,113,113,0.22);
            --violet: #8B7EFF;
            --violet-tab: rgba(139,126,255,0.12);
        }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Inter', -apple-system, sans-serif;
            background: var(--ink);
            color: var(--text);
            min-height: 100vh;
        }

        /* ─── SCANLINE OVERLAY ─── */
        body::before {
            content: '';
            position: fixed; inset: 0; z-index: 0; pointer-events: none;
            background: repeating-linear-gradient(
                0deg,
                transparent,
                transparent 2px,
                rgba(0,0,0,0.03) 2px,
                rgba(0,0,0,0.03) 4px
            );
        }

        /* ─── NAVBAR ─── */
        .navbar {
            background: rgba(6,10,16,0.9);
            backdrop-filter: blur(28px) saturate(160%);
            border-bottom: 1px solid var(--line);
            padding: 0 40px;
            height: 64px;
            display: flex; align-items: center; justify-content: space-between;
            position: sticky; top: 0; z-index: 200;
        }
        .brand { display: flex; align-items: center; gap: 10px; text-decoration: none; }
        .brand-logo {
            width: 36px; height: 36px; border-radius: 10px;
            background: var(--panel-raised); border: 1px solid var(--line-bright);
            display: flex; align-items: center; justify-content: center;
        }
        .brand-logo svg { width: 20px; height: 20px; }
        .brand-name {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 17px; font-weight: 700; color: #fff; letter-spacing: -0.3px;
        }
        .nav-center { display: flex; align-items: center; gap: 4px; }
        .nav-center a {
            color: var(--muted); text-decoration: none; font-size: 13.5px; font-weight: 500;
            padding: 6px 14px; border-radius: 8px; transition: all 0.18s ease;
        }
        .nav-center a:hover { color: var(--text); background: rgba(255,255,255,0.05); }
        .nav-center a.active { color: #fff; }
        .nav-right { display: flex; align-items: center; gap: 12px; }
        .user-pill {
            display: flex; align-items: center; gap: 9px;
            background: var(--panel); border: 1px solid var(--line);
            border-radius: 100px; padding: 5px 14px 5px 6px;
        }
        .user-avatar {
            width: 28px; height: 28px; border-radius: 50%;
            background: var(--panel-raised); overflow: hidden;
            display: flex; align-items: center; justify-content: center;
            font-size: 12px; font-weight: 700;
        }
        .user-avatar img { width: 100%; height: 100%; object-fit: cover; }
        .user-name { font-size: 13px; font-weight: 500; color: var(--text); }
        .user-plan {
            font-size: 10px; font-weight: 600; color: var(--signal);
            background: var(--signal-tab); border: 1px solid rgba(61,255,184,0.22);
            border-radius: 100px; padding: 2px 8px; letter-spacing: 0.3px;
        }
        .logout-btn {
            background: transparent; border: 1px solid var(--line); border-radius: 8px;
            padding: 7px 12px; color: var(--muted); cursor: pointer; font-size: 13px;
            transition: all 0.18s ease; text-decoration: none;
            display: flex; align-items: center; gap: 6px;
        }
        .logout-btn:hover { background: var(--red-bg); border-color: var(--red-border); color: var(--red); }

        /* ─── PAGE ─── */
        .page-wrapper { max-width: 1120px; margin: 0 auto; padding: 0 32px 60px; position: relative; z-index: 1; }

        /* ─── HERO BANNER ─── */
        .hero {
            position: relative; overflow: hidden;
            border-bottom: 1px solid var(--line);
            padding: 44px 0 40px;
            margin-bottom: 36px;
        }
        .hero::before {
            content: '';
            position: absolute; top: -60px; left: -80px;
            width: 480px; height: 480px; border-radius: 50%;
            background: radial-gradient(circle, rgba(61,255,184,0.07) 0%, transparent 70%);
            pointer-events: none;
        }
        .hero::after {
            content: '';
            position: absolute; bottom: -40px; right: 0;
            width: 300px; height: 300px; border-radius: 50%;
            background: radial-gradient(circle, rgba(139,126,255,0.05) 0%, transparent 70%);
            pointer-events: none;
        }
        .hero-inner { position: relative; z-index: 1; display: flex; align-items: center; justify-content: space-between; gap: 24px; flex-wrap: wrap; }
        .hero-text {}
        .hero-eyebrow {
            font-family: 'IBM Plex Mono', monospace;
            font-size: 11px; font-weight: 500;
            color: var(--signal); letter-spacing: 2px;
            text-transform: uppercase; margin-bottom: 10px;
            display: flex; align-items: center; gap: 8px;
        }
        .hero-eyebrow::before {
            content: '';
            width: 20px; height: 1px; background: var(--signal);
        }
        .hero-title {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 34px; font-weight: 700; color: #fff;
            letter-spacing: -0.8px; line-height: 1.15; margin-bottom: 10px;
        }
        .hero-title .name { color: var(--signal); }
        .hero-sub { font-size: 14px; color: var(--muted); max-width: 420px; line-height: 1.6; }
        .hero-stats {
            display: flex; gap: 2px;
            background: var(--panel); border: 1px solid var(--line);
            border-radius: 14px; overflow: hidden;
        }
        .hstat {
            padding: 16px 24px; text-align: center; position: relative;
        }
        .hstat + .hstat { border-left: 1px solid var(--line); }
        .hstat-num {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 26px; font-weight: 700; color: #fff; line-height: 1; margin-bottom: 4px;
        }
        .hstat-num.green { color: var(--signal); }
        .hstat-label { font-size: 11px; color: var(--muted); text-transform: uppercase; letter-spacing: 0.8px; font-weight: 500; }

        /* ─── TAB NAV ─── */
        .tab-nav { display: flex; align-items: center; gap: 4px; margin-bottom: 32px; }
        .tab-btn {
            display: flex; align-items: center; gap: 7px;
            padding: 8px 18px; border-radius: 10px; font-size: 13.5px; font-weight: 600;
            cursor: pointer; text-decoration: none; transition: all 0.18s ease;
            color: var(--muted); border: 1.5px solid transparent;
        }
        .tab-btn:hover { color: var(--text); background: rgba(255,255,255,0.04); }
        .tab-btn.active { background: var(--signal-tab); border-color: rgba(61,255,184,0.3); color: var(--signal); }
        .tab-btn i { font-size: 12px; }
        .crown { color: var(--gold); }

        /* ─── SECTION TITLES ─── */
        .section-head {
            display: flex; align-items: center; gap: 10px; margin-bottom: 16px;
        }
        .section-head h2 {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 16px; font-weight: 700; color: #fff;
        }
        .section-head .sh-icon { color: var(--signal); font-size: 14px; }
        .section-head .count-pill {
            font-size: 10.5px; font-weight: 600; color: var(--muted);
            background: var(--panel-raised); border: 1px solid var(--line);
            border-radius: 100px; padding: 2px 9px;
        }
        .section-head .sh-line {
            flex: 1; height: 1px; background: var(--line);
        }

        /* ─── SERVER GRID ─── */
        .server-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 14px;
            margin-bottom: 40px;
        }
        .server-card {
            background: var(--panel); border: 1px solid var(--line);
            border-radius: 14px; overflow: hidden; display: flex; flex-direction: column;
            transition: all 0.2s ease; text-decoration: none; color: var(--text);
        }
        .server-card:hover { border-color: var(--line-bright); transform: translateY(-2px); background: var(--panel-hover); }
        .card-body { display: flex; align-items: center; gap: 14px; padding: 18px 20px 16px; }
        .server-icon {
            width: 48px; height: 48px; border-radius: 14px; overflow: hidden; flex-shrink: 0;
            background: var(--panel-raised); border: 1px solid var(--line);
            display: flex; align-items: center; justify-content: center;
            font-family: 'Space Grotesk', sans-serif; font-size: 20px; font-weight: 700;
        }
        .server-icon img { width: 100%; height: 100%; object-fit: cover; display: block; }
        .ic-a{background:#1e2d40;color:#4FC3F7;}.ic-b{background:#1e2e1e;color:#66BB6A;}.ic-c{background:#2d1e2d;color:#CE93D8;}.ic-d{background:#2d2410;color:#FFA726;}.ic-e{background:#1e2d40;color:#4DD0E1;}.ic-f{background:#2d1e1e;color:#EF9A9A;}.ic-g{background:#1a2d1a;color:#80CBC4;}.ic-h{background:#1e1e2d;color:#9FA8DA;}.ic-i{background:#2d2d1e;color:#FFF176;}.ic-j{background:#1e2d28;color:#4DB6AC;}.ic-k{background:#2d1e28;color:#F48FB1;}.ic-l{background:#1e281e;color:#A5D6A7;}.ic-m{background:#1e1e1e;color:#3DFFB8;}.ic-n{background:#241e2d;color:#B39DDB;}.ic-o{background:#2d2010;color:#FFCC80;}.ic-p{background:#10202d;color:#81D4FA;}.ic-q{background:#2d101e;color:#F48FB1;}.ic-r{background:#1e2a10;color:#DCEDC8;}.ic-s{background:#102d20;color:#3DFFB8;}.ic-t{background:#2d1010;color:#FFAB91;}.ic-u{background:#102020;color:#80DEEA;}.ic-v{background:#1e102d;color:#CE93D8;}.ic-w{background:#102d10;color:#C5E1A5;}.ic-x{background:#2d1010;color:#EF9A9A;}.ic-y{background:#2d2810;color:#FFF59D;}.ic-z{background:#102d2d;color:#80CBC4;}.ic-default{background:var(--panel-raised);color:var(--muted);}
        .server-info { flex: 1; min-width: 0; }
        .server-name { font-size: 14.5px; font-weight: 600; color: #fff; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; margin-bottom: 4px; }
        .server-role { display: flex; align-items: center; gap: 5px; font-size: 12px; color: var(--muted); }
        .server-role i { color: var(--gold); font-size: 10px; }
        .bot-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
        .bot-dot.in { background: var(--signal); box-shadow: 0 0 6px var(--signal-glow); }
        .bot-dot.out { background: var(--muted-dim); }
        .card-footer { border-top: 1px solid var(--line); }
        .card-action {
            display: flex; align-items: center; justify-content: center;
            width: 100%; padding: 12px 20px; text-align: center;
            font-size: 13px; font-weight: 600; cursor: pointer; text-decoration: none;
            transition: all 0.18s ease; border: none; background: transparent; gap: 7px;
        }
        .card-action.manage { color: var(--signal); }
        .card-action.manage:hover { background: var(--signal-tab); }

        /* ─── EMPTY STATE ─── */
        .empty-state { grid-column: 1/-1; text-align: center; padding: 60px 20px; }
        .empty-icon {
            width: 60px; height: 60px; border-radius: 14px;
            background: var(--panel-raised); border: 1px solid var(--line);
            display: flex; align-items: center; justify-content: center;
            margin: 0 auto 18px; font-size: 22px; color: var(--signal);
        }
        .empty-state h3 { font-family: 'Space Grotesk', sans-serif; font-size: 17px; color: #fff; margin-bottom: 6px; }
        .empty-state p { font-size: 13px; color: var(--muted); }

        /* ─── MODULE GRID ─── */
        .modules-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
            gap: 14px;
        }

        .module-card {
            background: var(--panel); border: 1px solid var(--line); border-radius: 16px;
            padding: 0; display: flex; flex-direction: column;
            transition: all 0.22s ease; overflow: hidden;
            position: relative;
        }
        .module-card:hover { border-color: var(--line-bright); transform: translateY(-2px); }
        .module-card.live:hover { border-color: rgba(61,255,184,0.22); }
        .module-card.disabled { opacity: 0.55; }
        .module-card.disabled:hover { transform: none; border-color: var(--line); }

        .module-stripe {
            height: 3px; width: 100%;
            background: var(--signal);
        }
        .module-stripe.gold { background: var(--gold); }
        .module-stripe.violet { background: var(--violet); }
        .module-stripe.none { background: var(--muted-dim); }

        .module-inner { padding: 20px 22px 0; flex: 1; display: flex; flex-direction: column; gap: 10px; }
        .module-header { display: flex; align-items: center; gap: 10px; }
        .module-icon {
            width: 38px; height: 38px; border-radius: 10px; flex-shrink: 0;
            display: flex; align-items: center; justify-content: center; font-size: 16px;
        }
        .module-icon.live { background: var(--signal-tab); border: 1px solid rgba(61,255,184,0.2); color: var(--signal); }
        .module-icon.coming { background: var(--gold-tab); border: 1px solid rgba(245,200,66,0.2); color: var(--gold); }
        .module-icon.violet { background: var(--violet-tab); border: 1px solid rgba(139,126,255,0.2); color: var(--violet); }
        .module-title { font-size: 15px; font-weight: 700; color: #fff; flex: 1; font-family: 'Space Grotesk', sans-serif; }
        .mod-badge {
            font-size: 9.5px; font-weight: 700; border-radius: 100px; padding: 3px 9px; white-space: nowrap;
            letter-spacing: 0.5px; text-transform: uppercase;
        }
        .mod-badge.live { background: var(--signal-tab); color: var(--signal); border: 1px solid rgba(61,255,184,0.25); }
        .mod-badge.coming { background: var(--gold-tab); color: var(--gold); border: 1px solid rgba(245,200,66,0.25); }
        .module-desc { font-size: 13px; color: var(--muted); line-height: 1.6; }
        .module-footer {
            border-top: 1px solid var(--line); padding: 12px 22px;
            display: flex; gap: 8px; margin-top: 14px;
        }
        .mod-btn {
            padding: 7px 16px; border-radius: 8px; font-size: 12px; font-weight: 600;
            text-decoration: none; border: 1px solid var(--line); color: var(--muted);
            background: transparent; cursor: pointer; transition: all 0.18s ease;
        }
        .mod-btn:hover { border-color: var(--line-bright); color: var(--text); }
        .mod-btn.primary {
            background: var(--signal-tab); border-color: rgba(61,255,184,0.28); color: var(--signal);
        }
        .mod-btn.primary:hover { background: rgba(61,255,184,0.18); }
        .mod-btn.locked { opacity: 0.4; cursor: not-allowed; pointer-events: none; }

        .module-lock {
            position: absolute; top: 14px; right: 14px;
            width: 24px; height: 24px; border-radius: 6px;
            background: var(--gold-tab); border: 1px solid rgba(245,200,66,0.2);
            display: flex; align-items: center; justify-content: center;
            font-size: 10px; color: var(--gold);
        }

        /* ─── ERROR BANNER ─── */
        .error-banner {
            background: var(--red-bg); border: 1px solid var(--red-border);
            border-radius: 10px; padding: 12px 16px; color: var(--red);
            font-size: 13.5px; margin-bottom: 24px;
            display: flex; align-items: center; gap: 8px;
        }

        /* ─── FOOTER ─── */
        .footer {
            border-top: 1px solid var(--line); margin-top: 60px;
            padding: 24px 40px; text-align: center;
            color: var(--muted-dim); font-size: 12px;
            font-family: 'IBM Plex Mono', monospace; letter-spacing: 0.5px;
        }

        @keyframes pulse {
            0%, 100% { box-shadow: 0 0 0 0 rgba(61,255,184,0.4); }
            50% { box-shadow: 0 0 0 4px rgba(61,255,184,0); }
        }
        .pulse { animation: pulse 2.4s ease-in-out infinite; }

        @media (max-width: 768px) {
            .navbar { padding: 0 16px; }
            .nav-center { display: none; }
            .page-wrapper { padding: 0 16px 48px; }
            .hero-stats { display: none; }
            .server-grid, .modules-grid { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body>

    <!-- NAVBAR -->
    <nav class="navbar">
        <a href="/dashboard" class="brand">
            <div class="brand-logo">
                <svg viewBox="0 0 245 240" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M104.4 103.9c-5.7 0-10.2 5-10.2 11.1s4.6 11.1 10.2 11.1c5.7 0 10.2-5 10.2-11.1.1-6.1-4.5-11.1-10.2-11.1zM140.9 103.9c-5.7 0-10.2 5-10.2 11.1s4.6 11.1 10.2 11.1c5.7 0 10.2-5 10.2-11.1s-4.5-11.1-10.2-11.1z" fill="#3DFFB8"/>
                    <path d="M189.5 20H55.5C44.7 20 36 28.7 36 39.5v140.9c0 10.8 8.7 19.5 19.5 19.5h113.5l-5.3-18.5 12.8 11.9 12.1 11.2L209 220V39.5C209 28.7 200.3 20 189.5 20zM155.7 152.1s-3.6-4.3-6.6-8.1c13.1-3.7 18.1-11.9 18.1-11.9-4.1 2.7-8 4.6-11.5 5.9-5 2.1-9.8 3.5-14.5 4.3-9.6 1.8-18.4 1.3-25.9-.1-5.7-1.1-10.6-2.6-14.7-4.3-2.3-.9-4.8-2-7.3-3.4-.3-.2-.6-.3-.9-.5-.2-.1-.3-.2-.4-.3-2-1.1-3.1-1.9-3.1-1.9 4.7 4.3 9.3 6.5 21.7 10.2-2.9 3.8-6.6 8.1-6.6 8.1-22 0-32.1-15.2-32.1-15.2 0-32.2 14.4-58.4 14.4-58.4 14.4-10.8 28.1-10.5 28.1-10.5l1 1.2C99.2 87.7 87.9 97.4 87.9 97.4s2.9-1.6 7.8-3.8c14.1-6.2 25.3-7.9 29.9-8.3.8-.1 1.5-.2 2.3-.2 8.2-1 17.5-1.3 27.2.2 12.9 2 26.7 7.5 40.8 17.3 0 0-10.8-10.2-28.5-13.7l1.4-1.6s13.7-.3 28.1 10.5c0 0 14.4 26.2 14.4 58.4 0 0-10.2 15.2-32.1 15.2z" fill="#3DFFB8"/>
                </svg>
            </div>
            <span class="brand-name">Sentinal</span>
        </a>
        <div class="nav-center">
            <a href="/dashboard" class="active">Home</a>
            <a href="/servers">Servers</a>
            <a href="#" onclick="window.open('https://discord.gg/UmqmewYWRd','_blank'); return false;">Support</a>
            <a href="#">Premium</a>
        </div>
        <div class="nav-right">
            <div class="user-pill">
                <div class="user-avatar">
                    <% if (locals.user && user.avatar) { %>
                        <img src="https://cdn.discordapp.com/avatars/<%= user.id %>/<%= user.avatar %>.png" alt="Avatar">
                    <% } else { %>
                        <%= locals.user ? (user.username ? user.username.charAt(0).toUpperCase() : 'U') : 'U' %>
                    <% } %>
                </div>
                <span class="user-name"><%= locals.user ? (user.global_name || user.username) : 'User' %></span>
                <span class="user-plan">Free</span>
            </div>
            <a href="/logout" class="logout-btn"><i class="fas fa-sign-out-alt"></i></a>
        </div>
    </nav>

    <!-- PAGE -->
    <div class="page-wrapper">

        <!-- ─── HERO ─── -->
        <div class="hero">
            <div class="hero-inner">
                <div class="hero-text">
                    <div class="hero-eyebrow">Sentinal Control Center</div>
                    <h1 class="hero-title">
                        Hey, <span class="name"><%= locals.user ? (user.global_name || user.username) : 'there' %></span> 👋
                    </h1>
                    <p class="hero-sub">Your bot is online and watching. Manage servers, configure modules, and keep your community running.</p>
                </div>
                <div class="hero-stats">
                    <div class="hstat">
                        <div class="hstat-num"><%= locals.servers ? servers.length : 0 %></div>
                        <div class="hstat-label">Servers</div>
                    </div>
                    <div class="hstat">
                        <div class="hstat-num">0</div>
                        <div class="hstat-label">Tickets</div>
                    </div>
                    <div class="hstat">
                        <div class="hstat-num green">●</div>
                        <div class="hstat-label">Online</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- ─── ERROR BANNER ─── -->
        <% if (locals.error) { %>
        <div class="error-banner"><i class="fas fa-exclamation-circle"></i> <%= error %></div>
        <% } %>

        <!-- ─── TAB NAV ─── -->
        <div class="tab-nav">
            <a href="/dashboard" class="tab-btn active"><i class="fas fa-home"></i> Home</a>
            <a href="/servers" class="tab-btn"><i class="fas fa-server"></i> Servers</a>
            <a href="#" class="tab-btn"><i class="fas fa-crown crown"></i> Premium</a>
        </div>

        <!-- ─── YOUR SERVERS ─── -->
        <div class="section-head">
            <i class="fas fa-server sh-icon"></i>
            <h2>Your Servers</h2>
            <span class="count-pill"><%= locals.servers ? servers.length : 0 %></span>
            <div class="sh-line"></div>
        </div>

        <% if (locals.servers && servers.length > 0) { %>
        <div class="server-grid">
            <% servers.forEach(function(guild) { %>
            <%
                const initial = guild.name ? guild.name.charAt(0).toLowerCase() : 'default';
                const icClass = 'ic-' + (/[a-z]/.test(initial) ? initial : 'default');
            %>
            <a href="/server/<%= guild.id %>" class="server-card">
                <div class="card-body">
                    <div class="server-icon <%= guild.icon ? '' : icClass %>">
                        <% if (guild.icon) { %>
                            <img
                                src="https://cdn.discordapp.com/icons/<%= guild.id %>/<%= guild.icon %>.png?size=128"
                                alt="<%= guild.name %>"
                                onerror="this.style.display='none';this.parentElement.classList.add('<%= icClass %>');this.parentElement.textContent='<%= guild.name ? guild.name.charAt(0).toUpperCase() : '?' %>';"
                            >
                        <% } else { %>
                            <%= guild.name ? guild.name.charAt(0).toUpperCase() : '?' %>
                        <% } %>
                    </div>
                    <div class="server-info">
                        <div class="server-name"><%= guild.name %></div>
                        <div class="server-role"><i class="fas fa-crown"></i> Owner</div>
                    </div>
                    <div class="bot-dot in pulse"></div>
                </div>
                <div class="card-footer">
                    <span class="card-action manage">Manage →</span>
                </div>
            </a>
            <% }); %>
        </div>
        <% } else { %>
        <div class="server-grid" style="margin-bottom:40px;">
            <div class="empty-state">
                <div class="empty-icon"><i class="fas fa-server"></i></div>
                <h3>No Servers Found</h3>
                <p>Add Sentinal to a server to get started.</p>
            </div>
        </div>
        <% } %>

        <!-- ─── MODULES ─── -->
        <div class="section-head" style="margin-top: 8px;">
            <i class="fas fa-puzzle-piece sh-icon"></i>
            <h2>Modules</h2>
            <div class="sh-line"></div>
        </div>

        <div class="modules-grid">

            <!-- APPLICATIONS -->
            <div class="module-card live">
                <div class="module-stripe"></div>
                <div class="module-inner">
                    <div class="module-header">
                        <div class="module-icon live"><i class="fas fa-file-alt"></i></div>
                        <span class="module-title">Applications</span>
                        <span class="mod-badge live">Live</span>
                    </div>
                    <p class="module-desc">Build custom application forms for staff, partners, or events. Review, approve, and manage every submission.</p>
                </div>
                <div class="module-footer">
                    <a href="#" class="mod-btn primary">Configure</a>
                    <a href="#" class="mod-btn">Manage</a>
                </div>
            </div>

            <!-- TICKETS -->
            <div class="module-card live">
                <div class="module-stripe"></div>
                <div class="module-inner">
                    <div class="module-header">
                        <div class="module-icon live"><i class="fas fa-ticket"></i></div>
                        <span class="module-title">Tickets</span>
                        <span class="mod-badge live">Live</span>
                    </div>
                    <p class="module-desc">Open support channels for your community. Manage transcripts, templates, and quick responses at scale.</p>
                </div>
                <div class="module-footer">
                    <a href="#" class="mod-btn primary">Configure</a>
                    <a href="#" class="mod-btn">Templates</a>
                </div>
            </div>

            <!-- VERIFICATION -->
            <div class="module-card live">
                <div class="module-stripe"></div>
                <div class="module-inner">
                    <div class="module-header">
                        <div class="module-icon live"><i class="fas fa-shield-halved"></i></div>
                        <span class="module-title">Verification</span>
                        <span class="mod-badge live">Live</span>
                    </div>
                    <p class="module-desc">Gate your server with verification flows. Assign auto-roles, send welcome messages, and lock down entry.</p>
                </div>
                <div class="module-footer">
                    <a href="#" class="mod-btn primary">Configure</a>
                    <a href="#" class="mod-btn">Welcome</a>
                </div>
            </div>

            <!-- AUTOMATION -->
            <div class="module-card disabled">
                <div class="module-stripe none"></div>
                <div class="module-lock"><i class="fas fa-lock"></i></div>
                <div class="module-inner">
                    <div class="module-header">
                        <div class="module-icon coming"><i class="fas fa-robot"></i></div>
                        <span class="module-title">Automation</span>
                        <span class="mod-badge coming">Soon</span>
                    </div>
                    <p class="module-desc">Auto-moderation, reaction roles, and scheduled tasks — set rules once and let the bot handle the rest.</p>
                </div>
                <div class="module-footer">
                    <a href="#" class="mod-btn locked">Configure</a>
                    <a href="#" class="mod-btn locked">Auto-Mod</a>
                </div>
            </div>

            <!-- COMMUNITY -->
            <div class="module-card disabled">
                <div class="module-stripe none"></div>
                <div class="module-lock"><i class="fas fa-lock"></i></div>
                <div class="module-inner">
                    <div class="module-header">
                        <div class="module-icon coming"><i class="fas fa-users"></i></div>
                        <span class="module-title">Community</span>
                        <span class="mod-badge coming">Soon</span>
                    </div>
                    <p class="module-desc">Leveling, giveaways, and engagement tools that reward your most active members and grow your server.</p>
                </div>
                <div class="module-footer">
                    <a href="#" class="mod-btn locked">Configure</a>
                    <a href="#" class="mod-btn locked">Giveaways</a>
                </div>
            </div>

            <!-- AUDIT LOGS -->
            <div class="module-card disabled">
                <div class="module-stripe none"></div>
                <div class="module-lock"><i class="fas fa-lock"></i></div>
                <div class="module-inner">
                    <div class="module-header">
                        <div class="module-icon coming"><i class="fas fa-clipboard-list"></i></div>
                        <span class="module-title">Audit & Logs</span>
                        <span class="mod-badge coming">Soon</span>
                    </div>
                    <p class="module-desc">A full audit trail — moderation actions, member events, and system changes, searchable in one place.</p>
                </div>
                <div class="module-footer">
                    <a href="#" class="mod-btn locked">View Logs</a>
                    <a href="#" class="mod-btn locked">Settings</a>
                </div>
            </div>

        </div>
    </div>

    <footer class="footer">
        © 2026 SENTINAL — STATUS: OPERATIONAL
    </footer>

</body>
</html>
