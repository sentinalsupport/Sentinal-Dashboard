    <script>
        // Simple module navigation
        function showModule(module) {
            document.querySelectorAll('.nav-item.active').forEach(el => el.classList.remove('active'));
            document.querySelectorAll('.nav-item').forEach(el => {
                if (el.textContent.trim().toLowerCase().includes(module)) {
                    el.classList.add('active');
                }
            });
            
            if (module === 'premium') {
                document.getElementById('premium-section').style.display = 'block';
                document.getElementById('premium-section').scrollIntoView({ behavior: 'smooth' });
            } else {
                document.getElementById('premium-section').style.display = 'none';
                const moduleMap = {
                    'applications': 'module-applications',
                    'tickets': 'module-tickets',
                    'verification': 'module-verification',
                    'automation': 'module-automation',
                    'community': 'module-community',
                    'audit': 'module-audit'
                };
                const target = document.getElementById(moduleMap[module]);
                if (target) {
                    target.scrollIntoView({ behavior: 'smooth' });
                }
            }
        }
    </script>

