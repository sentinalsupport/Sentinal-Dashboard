<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title || 'Dashboard — Sentinal' %></title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@400;500;600;700;800&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --ink: #060A10;
            --panel: #0D1520;
            --panel-raised: #111D2C;
            --panel-hover: #162033;
            --line: rgba(255,255,255,0.07);
            --line-bright: rgba(255,255,255,0.13);
            --text: #E6EDF6;
            --muted: #6C7A90;
            --muted-dim: #3E4A5C;
            --signal: #3DFFB8;
            --signal-tab: rgba(61,255,184,0.10);
            --signal-glow: rgba(61,255,184,0.15);
            --gold: #F5C842;
        }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Inter', -apple-system, sans-serif;
            background: var(--ink);
            color: var(--text);
            min-height: 100vh;
        }
        .navbar {
            background: rgba(6,10,16,0.85);
            backdrop-filter: blur(24px) saturate(150%);
            border-bottom: 1px solid var(--line);
            padding: 0 40px;
            height: 64px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: sticky;
            top: 0;
            z-index: 200;
        }
        .brand {
            display: flex; align-items: center; gap: 10px;
            text-decoration: none;
        }
        .brand-logo {
            width: 36px; height: 36px;
            border-radius: 10px;
            background: var(--panel-raised);
            border: 1px solid var(--line-bright);
            display: flex; align-items: center; justify-content: center;
        }
        .brand-logo svg { width: 20px; height: 20px; }
        .brand-name {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 17px; font-weight: 700;
            color: #fff; letter-spacing: -0.3px;
        }
        .nav-center {
            display: flex; align-items: center; gap: 4px;
        }
        .nav-center a {
            color: var(--muted); text-decoration: none;
            font-size: 13.5px; font-weight: 500;
            padding: 6px 14px; border-radius: 8px;
            transition: all 0.18s ease;
        }
        .nav-center a:hover { color: var(--text); background: rgba(255,255,255,0.05); }
        .nav-center a.active { color: #fff; }
        .nav-right { display: flex; align-items: center; gap: 12px; }
        .user-pill {
            display: flex; align-items: center; gap: 9px;
            background: var(--panel); border: 1px solid var(--line);
            border-radius: 100px; padding: 5px 14px 5px 6px;
        }
        .user-avatar {
            width: 28px; height: 28px; border-radius: 50%;
            background: var(--panel-raised); overflow: hidden;
            display: flex; align-items: center; justify-content: center;
            font-size: 12px; font-weight: 700;
        }
        .user-avatar img { width: 100%; height: 100%; object-fit: cover; }
        .user-name { font-size: 13px; font-weight: 500; color: var(--text); }
        .user-plan {
            font-size: 10px; font-weight: 600;
            color: var(--signal); background: var(--signal-tab);
            border: 1px solid rgba(61,255,184,0.22);
            border-radius: 100px; padding: 2px 8px; letter-spacing: 0.3px;
        }
        .logout-btn {
            background: transparent; border: 1px solid var(--line);
            border-radius: 8px; padding: 7px 12px;
            color: var(--muted); cursor: pointer; font-size: 13px;
            transition: all 0.18s ease; text-decoration: none;
            display: flex; align-items: center; gap: 6px;
        }
        .logout-btn:hover { background: rgba(248,113,113,0.08); border-color: rgba(248,113,113,0.22); color: #F87171; }

        .page-wrapper { max-width: 1100px; margin: 0 auto; padding: 40px 32px 60px; }

        .welcome { margin-bottom: 32px; }
        .welcome h1 {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 28px; font-weight: 700; color: #fff; letter-spacing: -0.4px;
        }
        .welcome h1 span { color: var(--signal); }
        .welcome p { font-size: 14px; color: var(--muted); margin-top: 4px; }

        .stats-grid {
            display: grid; grid-template-columns: repeat(3, 1fr);
            gap: 14px; margin-bottom: 32px;
        }
        .stat-card {
            background: var(--panel); border: 1px solid var(--line);
            border-radius: 12px; padding: 18px 20px; text-align: center;
        }
        .stat-number {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 28px; font-weight: 700; color: var(--signal);
        }
        .stat-label { font-size: 13px; color: var(--muted); margin-top: 2px; }
        .stat-card .status-dot {
            display: inline-block; width: 10px; height: 10px;
            border-radius: 50%; background: var(--signal);
            box-shadow: 0 0 12px var(--signal-glow); margin-right: 6px;
        }

        .section-header {
            display: flex; align-items: center; justify-content: space-between;
            margin-bottom: 16px;
        }
        .section-header h3 {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 18px; font-weight: 600; color: #fff;
        }
        .section-header a {
            font-size: 13px; color: var(--muted); text-decoration: none;
        }
        .section-header a:hover { color: var(--signal); }

        .server-grid {
            display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 12px; margin-bottom: 40px;
        }
        .server-card {
            background: var(--panel); border: 1px solid var(--line);
            border-radius: 12px; padding: 16px 20px;
            display: flex; align-items: center; justify-content: space-between;
            transition: all 0.2s ease; text-decoration: none; color: var(--text);
        }
        .server-card:hover {
            border-color: var(--line-bright); transform: translateY(-2px);
        }
        .server-card .left { display: flex; align-items: center; gap: 12px; }
        .server-card .icon {
            width: 40px; height: 40px; border-radius: 10px;
            background: var(--panel-raised); display: flex;
            align-items: center; justify-content: center;
            font-size: 16px; font-weight: 700; overflow: hidden;
            flex-shrink: 0; color: var(--signal);
        }
        .server-card .icon img { width: 100%; height: 100%; object-fit: cover; }
        .server-card .info .name { font-weight: 600; font-size: 14px; }
        .server-card .info .role { font-size: 12px; color: var(--muted); }
        .server-card .info .role i { color: var(--gold); font-size: 10px; }
        .server-card .action { font-size: 13px; font-weight: 600; color: var(--signal); }

        .modules-grid {
            display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 14px;
        }
        .module-card {
            background: var(--panel); border: 1px solid var(--line);
            border-radius: 12px; padding: 20px 22px;
            transition: all 0.2s ease;
        }
        .module-card:hover { border-color: var(--line-bright); }
        .module-card .header {
            display: flex; align-items: center; gap: 10px; margin-bottom: 6px;
        }
        .module-card .header i { font-size: 18px; color: var(--signal); }
        .module-card .header h4 { font-size: 15px; font-weight: 600; color: #fff; }
        .module-card .header .status {
            font-size: 10px; font-weight: 600; padding: 2px 10px;
            border-radius: 100px; margin-left: auto;
        }
        .module-card .header .status.live {
            background: var(--signal-tab); color: var(--signal);
            border: 1px solid rgba(61,255,184,0.2);
        }
        .module-card .header .status.coming {
            background: rgba(255,255,255,0.05); color: var(--muted);
            border: 1px solid var(--line);
        }
        .module-card p {
            font-size: 13px; color: var(--muted); line-height: 1.5; margin-bottom: 12px;
        }
        .module-card .actions { display: flex; gap: 8px; flex-wrap: wrap; }
        .module-card .actions .btn {
            padding: 6px 16px; border-radius: 8px;
            font-size: 12px; font-weight: 600; cursor: pointer;
            text-decoration: none; transition: all 0.18s ease;
            border: 1px solid var(--line); background: transparent; color: var(--muted);
        }
        .module-card .actions .btn:hover {
            background: rgba(255,255,255,0.04); color: var(--text);
        }
        .module-card .actions .btn.primary {
            border-color: rgba(61,255,184,0.3); color: var(--signal);
        }
        .module-card .actions .btn.primary:hover { background: var(--signal-tab); }
        .module-card .actions .btn.disabled {
            opacity: 0.4; cursor: not-allowed;
        }

        .empty-state {
            text-align: center; padding: 40px 20px; color: var(--muted);
        }
        .empty-state i { font-size: 36px; color: var(--signal); margin-bottom: 12px; display: block; }
        .empty-state h3 { color: #fff; margin-bottom: 4px; }

        .footer {
            border-top: 1px solid var(--line); margin-top: 60px;
            padding: 24px 40px; text-align: center;
            color: var(--muted-dim); font-size: 12px;
            font-family: 'IBM Plex Mono', monospace; letter-spacing: 0.5px;
        }

        @media (max-width: 768px) {
            .navbar { padding: 0 16px; }
            .nav-center { display: none; }
            .page-wrapper { padding: 24px 16px 48px; }
            .stats-grid { grid-template-columns: 1fr; }
            .server-grid { grid-template-columns: 1fr; }
            .modules-grid { grid-template-columns: 1fr; }
            .welcome h1 { font-size: 22px; }
        }
    </style>
</head>
<body>

    <!-- NAVBAR -->
    <nav class="navbar">
        <a href="/dashboard" class="brand">
            <div class="brand-logo">
                <svg viewBox="0 0 245 240" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M104.4 103.9c-5.7 0-10.2 5-10.2 11.1s4.6 11.1 10.2 11.1c5.7 0 10.2-5 10.2-11.1.1-6.1-4.5-11.1-10.2-11.1zM140.9 103.9c-5.7 0-10.2 5-10.2 11.1s4.6 11.1 10.2 11.1c5.7 0 10.2-5 10.2-11.1s-4.5-11.1-10.2-11.1z" fill="#3DFFB8"/>
                    <path d="M189.5 20H55.5C44.7 20 36 28.7 36 39.5v140.9c0 10.8 8.7 19.5 19.5 19.5h113.5l-5.3-18.5 12.8 11.9 12.1 11.2L209 220V39.5C209 28.7 200.3 20 189.5 20zM155.7 152.1s-3.6-4.3-6.6-8.1c13.1-3.7 18.1-11.9 18.1-11.9-4.1 2.7-8 4.6-11.5 5.9-5 2.1-9.8 3.5-14.5 4.3-9.6 1.8-18.4 1.3-25.9-.1-5.7-1.1-10.6-2.6-14.7-4.3-2.3-.9-4.8-2-7.3-3.4-.3-.2-.6-.3-.9-.5-.2-.1-.3-.2-.4-.3-2-1.1-3.1-1.9-3.1-1.9 4.7 4.3 9.3 6.5 21.7 10.2-2.9 3.8-6.6 8.1-6.6 8.1-22 0-32.1-15.2-32.1-15.2 0-32.2 14.4-58.4 14.4-58.4 14.4-10.8 28.1-10.5 28.1-10.5l1 1.2C99.2 87.7 87.9 97.4 87.9 97.4s2.9-1.6 7.8-3.8c14.1-6.2 25.3-7.9 29.9-8.3.8-.1 1.5-.2 2.3-.2 8.2-1 17.5-1.3 27.2.2 12.9 2 26.7 7.5 40.8 17.3 0 0-10.8-10.2-28.5-13.7l1.4-1.6s13.7-.3 28.1 10.5c0 0 14.4 26.2 14.4 58.4 0 0-10.2 15.2-32.1 15.2z" fill="#3DFFB8"/>
                </svg>
            </div>
            <span class="brand-name">Sentinal</span>
        </a>
        <div class="nav-center">
            <a href="/dashboard" class="active">Home</a>
            <a href="/servers">Servers</a>
            <a href="#" onclick="window.open('https://discord.gg/UmqmewYWRd','_blank'); return false;">Support</a>
        </div>
        <div class="nav-right">
            <div class="user-pill">
                <div class="user-avatar">
                    <% if (locals.user && user.avatar) { %>
                        <img src="https://cdn.discordapp.com/avatars/<%= user.id %>/<%= user.avatar %>.png" alt="Avatar">
                    <% } else { %>
                        <%= locals.user ? (user.username ? user.username.charAt(0).toUpperCase() : 'U') : 'U' %>
                    <% } %>
                </div>
                <span class="user-name"><%= locals.user ? (user.global_name || user.username) : 'User' %></span>
                <span class="user-plan">Free</span>
            </div>
            <a href="/logout" class="logout-btn"><i class="fas fa-sign-out-alt"></i></a>
        </div>
    </nav>

    <!-- PAGE -->
    <div class="page-wrapper">

        <!-- WELCOME -->
        <div class="welcome">
            <h1>Welcome back, <span><%= locals.user ? (user.global_name || user.username) : 'User' %></span>!</h1>
            <p>Manage your servers and bot settings from one place.</p>
        </div>

        <!-- STATS -->
        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-number"><%= locals.servers ? servers.length : 0 %></div>
                <div class="stat-label">Servers</div>
            </div>
            <div class="stat-card">
                <div class="stat-number">0</div>
                <div class="stat-label">Active Tickets</div>
            </div>
            <div class="stat-card">
                <div class="stat-number"><span class="status-dot"></span> Online</div>
                <div class="stat-label">Bot Status</div>
            </div>
        </div>

        <!-- YOUR SERVERS -->
        <div class="section-header">
            <h3>Your Servers</h3>
            <a href="/servers">View All →</a>
        </div>

        <% if (locals.servers && servers.length > 0) { %>
            <div class="server-grid">
                <% servers.slice(0, 3).forEach(function(guild) { %>
                    <a href="/server/<%= guild.id %>" class="server-card">
                        <div class="left">
                            <div class="icon">
                                <% if (guild.icon) { %>
                                    <img src="https://cdn.discordapp.com/icons/<%= guild.id %>/<%= guild.icon %>.png" alt="<%= guild.name %>">
                                <% } else { %>
                                    <%= guild.name ? guild.name.charAt(0).toUpperCase() : '?' %>
                                <% } %>
                            </div>
                            <div class="info">
                                <div class="name"><%= guild.name %></div>
                                <div class="role"><i class="fas fa-crown"></i> Owner</div>
                            </div>
                        </div>
                        <div class="action">Manage →</div>
                    </a>
                <% }); %>
            </div>
        <% } else { %>
            <div class="empty-state">
                <i class="fas fa-server"></i>
                <h3>No Servers Found</h3>
                <p>You don't have administrator access to any servers.</p>
            </div>
        <% } %>

        <!-- MODULES -->
        <div class="section-header" style="margin-top: 8px;">
            <h3>Modules</h3>
        </div>

        <div class="modules-grid">
            <!-- Applications -->
            <div class="module-card">
                <div class="header">
                    <i class="fas fa-file-alt"></i>
                    <h4>Applications</h4>
                    <span class="status live">Live</span>
                </div>
                <p>Create custom application forms for staff, partners, or events. Review and manage submissions.</p>
                <div class="actions">
                    <a href="#" class="btn primary">Configure</a>
                    <a href="#" class="btn">Manage</a>
                </div>
            </div>

            <!-- Tickets -->
            <div class="module-card">
                <div class="header">
                    <i class="fas fa-ticket"></i>
                    <h4>Tickets</h4>
                    <span class="status live">Live</span>
                </div>
                <p>Create support tickets for users to open in your server. Manage transcripts and quick responses.</p>
                <div class="actions">
                    <a href="#" class="btn primary">Configure</a>
                    <a href="#" class="btn">Templates</a>
                </div>
            </div>

            <!-- Verification -->
            <div class="module-card">
                <div class="header">
                    <i class="fas fa-shield-halved"></i>
                    <h4>Verification</h4>
                    <span class="status live">Live</span>
                </div>
                <p>Set up verification with auto-roles, welcome messages, and advanced security settings.</p>
                <div class="actions">
                    <a href="#" class="btn primary">Configure</a>
                    <a href="#" class="btn">Welcome</a>
                </div>
            </div>

            <!-- Automation -->
            <div class="module-card">
                <div class="header">
                    <i class="fas fa-robot"></i>
                    <h4>Automation</h4>
                    <span class="status coming">Coming Soon</span>
                </div>
                <p>Auto-moderation, reaction roles, and scheduled tasks to automate your server management.</p>
                <div class="actions">
                    <a href="#" class="btn disabled">Configure</a>
                    <a href="#" class="btn disabled">Auto-Mod</a>
                </div>
            </div>

            <!-- Community -->
            <div class="module-card">
                <div class="header">
                    <i class="fas fa-users"></i>
                    <h4>Community</h4>
                    <span class="status coming">Coming Soon</span>
                </div>
                <p>Leveling system, giveaways, and community engagement features to grow your server.</p>
                <div class="actions">
                    <a href="#" class="btn disabled">Configure</a>
                    <a href="#" class="btn disabled">Giveaways</a>
                </div>
            </div>

            <!-- Audit & Logs -->
            <div class="module-card">
                <div class="header">
                    <i class="fas fa-clipboard-list"></i>
                    <h4>Audit & Logs</h4>
                    <span class="status coming">Coming Soon</span>
                </div>
                <p>View all moderation actions, member events, and system logs in one place.</p>
                <div class="actions">
                    <a href="#" class="btn disabled">View Logs</a>
                    <a href="#" class="btn disabled">Settings</a>
                </div>
            </div>
        </div>

    </div>

    <!-- FOOTER -->
    <footer class="footer">
        © 2026 SENTINAL — STATUS: OPERATIONAL
    </footer>

</body>
</html>
